---
// src/pages/privacy-policy.astro
import BaseLayout from '../components/layout/BaseLayout.astro';
const lastUpdated = "১৮ জুলাই, ২০২৬";
---

<Layout title="প্রাইভেসি পলিসি | স্মার্ট ফেনী">
  <main style="max-width: 800px; margin: 0 auto; padding: 40px 20px; color: #1B2A4A; line-height: 1.8;">
    <h1 style="font-size: 28px; margin-bottom: 8px;">প্রাইভেসি পলিসি</h1>
    <p style="color: #64748B; margin-bottom: 32px;">সর্বশেষ আপডেট: {lastUpdated}</p>

    <section style="margin-bottom: 28px;">
      <h2 style="font-size: 20px; margin-bottom: 10px;">১. আমরা কী তথ্য সংগ্রহ করি</h2>
      <p>স্মার্ট ফেনী ব্যবহার করার সময় আমরা নিচের তথ্যগুলো সংগ্রহ করি:</p>
      <ul style="margin-top: 10px; padding-left: 20px;">
        <li>পূর্ণ নাম ও ফোন নম্বর (অ্যাকাউন্ট তৈরির জন্য)</li>
        <li>ঐচ্ছিক রিকভারি ইমেইল</li>
        <li>উপজেলা তথ্য (আপনার এলাকার সেবা দেখানোর জন্য)</li>
        <li>প্রোফাইল ছবি (ঐচ্ছিক)</li>
        <li>ব্লাড গ্রুপ (ঐচ্ছিক, শুধু আপনি যদি ব্লাড ডোনার সেকশনে অংশ নিতে চান)</li>
        <li>আপনার পোস্ট করা লিস্টিং/বিজ্ঞাপনের তথ্য</li>
      </ul>
    </section>

    <section style="margin-bottom: 28px;">
      <h2 style="font-size: 20px; margin-bottom: 10px;">২. স্পর্শকাতর তথ্য (ব্লাড গ্রুপ)</h2>
      <p>ব্লাড গ্রুপ একটি স্বাস্থ্য-সংক্রান্ত তথ্য। এটি সম্পূর্ণ ঐচ্ছিক এবং শুধুমাত্র তখনই সংগ্রহ করা হয় যখন আপনি নিজে থেকে ব্লাড ডোনার হিসেবে নিবন্ধন করেন। এই তথ্য শুধুমাত্র প্ল্যাটফর্মের ব্লাড ডোনার খোঁজার ফিচারে ব্যবহৃত হয়, অন্য কোনো উদ্দেশ্যে না।</p>
    </section>

    <section style="margin-bottom: 28px;">
      <h2 style="font-size: 20px; margin-bottom: 10px;">৩. তথ্য ব্যবহারের উদ্দেশ্য</h2>
      <ul style="padding-left: 20px;">
        <li>আপনার অ্যাকাউন্ট তৈরি ও পরিচালনা করতে</li>
        <li>আপনার এলাকার (উপজেলা) প্রাসঙ্গিক সেবা দেখাতে</li>
        <li>লিস্টিং/বিজ্ঞাপন যাচাই ও প্রকাশ করতে</li>
        <li>প্ল্যাটফর্মের নিরাপত্তা ও অপব্যবহার প্রতিরোধে</li>
      </ul>
    </section>

    <section style="margin-bottom: 28px;">
      <h2 style="font-size: 20px; margin-bottom: 10px;">৪. তথ্য সংরক্ষণ ও নিরাপত্তা</h2>
      <p>আপনার তথ্য নিরাপদ ক্লাউড ডেটাবেজে এনক্রিপ্টেড অবস্থায় সংরক্ষণ করা হয়। শুধুমাত্র অনুমোদিত অ্যাডমিন/মডারেটররা প্রয়োজনীয় তথ্য দেখতে পারেন, নির্দিষ্ট নিয়ন্ত্রিত পদ্ধতিতে।</p>
    </section>

    <section style="margin-bottom: 28px;">
      <h2 style="font-size: 20px; margin-bottom: 10px;">৫. তৃতীয় পক্ষের সাথে শেয়ারিং</h2>
      <p>আমরা আপনার ব্যক্তিগত তথ্য কোনো তৃতীয় পক্ষের কাছে বিক্রি বা শেয়ার করি না। শুধুমাত্র আইনি বাধ্যবাধকতা থাকলে প্রয়োজনীয় কর্তৃপক্ষের সাথে শেয়ার করা হতে পারে।</p>
    </section>

    <section style="margin-bottom: 28px;">
      <h2 style="font-size: 20px; margin-bottom: 10px;">৬. আপনার অধিকার</h2>
      <ul style="padding-left: 20px;">
        <li>আপনার প্রোফাইল তথ্য যেকোনো সময় এডিট করতে পারবেন</li>
        <li>অ্যাকাউন্ট ডিলিট বা তথ্য মুছে ফেলার অনুরোধ করতে পারবেন (নিচের যোগাযোগ মাধ্যমে)</li>
        <li>ব্লাড ডোনার তালিকা থেকে যেকোনো সময় নিজেকে সরিয়ে নিতে পারবেন</li>
      </ul>
    </section>

    <section>
      <h2 style="font-size: 20px; margin-bottom: 10px;">৭. যোগাযোগ</h2>
      <p>প্রাইভেসি সংক্রান্ত কোনো প্রশ্ন বা অনুরোধের জন্য যোগাযোগ করুন: <a href="mailto:info@smartfeni.com" style="color: #FF6B35;">info@smartfeni.com</a></p>
    </section>
  </main>
</Layout>