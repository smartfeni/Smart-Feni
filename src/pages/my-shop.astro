---
// ============================================================
// পেজ: আমার শপ (/my-shop)
// শুধু is_shop_owner=true ইউজার অ্যাক্সেস করতে পারবে। নিজের প্রোডাক্ট
// (category='online-shop') Add/Edit/Delete করতে পারবে।
// ছবি ফ্রেমিং: aspect-ratio 4/3, object-fit contain (শেয়ারড ডিটেইল
// মোডাল সিস্টেমের সাথে সামঞ্জস্যপূর্ণ)
// ============================================================

export const prerender = false;

import BaseLayout from '../components/layout/BaseLayout.astro';
import AddListingModal from '../components/ui/AddListingModal.astro';
---

<BaseLayout title="আমার শপ | স্মার্ট ফেনী">
  <div class="shop-page">
    <div class="container">

      <div id="loadingState" class="loading-state">
        <div class="spinner"></div>
        <p>লোড হচ্ছে...</p>
      </div>

      <div id="guardedContent" class="shop-content" style="display:none;">

        <div class="shop-header">
          <div class="shop-icon"><i class="fas fa-store"></i></div>
          <div>
            <h1 id="shopName">—</h1>
            <p>আপনার প্রোডাক্ট যোগ, এডিট বা ডিলিট করুন</p>
          </div>
        </div>

        <button class="add-product-btn" id="openAddListing" type="button">
          <i class="fas fa-plus"></i> নতুন প্রোডাক্ট যোগ করুন
        </button>

        <div id="productsContainer" class="products-grid"></div>

        <div id="emptyState" class="empty-state" style="display:none;">
          <i class="fas fa-box-open"></i>
          <p>এখনো কোনো প্রোডাক্ট যোগ করা হয়নি</p>
          <span>উপরের বাটনে ক্লিক করে প্রথম প্রোডাক্ট যোগ করুন</span>
        </div>

      </div>
    </div>
  </div>

  <!-- ===== এডিট মোডাল ===== -->
  <div class="edit-overlay" id="editOverlay">
    <div class="edit-modal">
      <button class="edit-close" id="editClose" aria-label="বন্ধ করুন">
        <i class="fas fa-xmark"></i>
      </button>

      <h2 class="edit-title"><i class="fas fa-pen"></i> প্রোডাক্ট এডিট করুন</h2>

      <p class="edit-message" id="editMessage"></p>

      <label class="edit-label">প্রোডাক্টের নাম</label>
      <input type="text" class="edit-input" id="editTitle" />

      <label class="edit-label">বিবরণ</label>
      <textarea class="edit-input" id="editDescription" rows="3"></textarea>

      <label class="edit-label">দাম</label>
      <input type="text" class="edit-input" id="editPrice" />

      <button class="edit-save-btn" id="editSaveBtn" type="button">
        <i class="fas fa-check"></i> <span>সেভ করুন</span>
      </button>
    </div>
  </div>

  <AddListingModal
    category="online-shop"
    typeOptions={[{ id: 'product', label: 'প্রোডাক্ট' }]}
    titleLabel="প্রোডাক্টের নাম"
    priceLabel="দাম"
    autoActive={true}
  />

  <style>
    .shop-page {
      min-height: 70vh;
      padding: 40px 0 80px;
      background: #F8FAFC;
    }

    .loading-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .shop-content {
      max-width: 900px;
      margin: 0 auto;
    }

    .shop-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 22px;
    }

    .shop-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: #FFF0EA;
      color: #FF6B35;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      flex-shrink: 0;
    }

    .shop-header h1 {
      font-size: 1.3rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .shop-header p {
      font-size: 0.85rem;
      color: #8FA0BC;
    }

    .add-product-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #FF6B35;
      color: #fff;
      border: none;
      padding: 13px 26px;
      border-radius: 40px;
      font-weight: 700;
      font-size: 0.92rem;
      cursor: pointer;
      margin-bottom: 28px;
      box-shadow: 0 10px 24px rgba(255, 107, 53, 0.24);
    }

    .empty-state {
      text-align: center;
      background: #fff;
      border-radius: 20px;
      padding: 50px 24px;
      border: 1px dashed #E5EAF0;
    }

    .empty-state i {
      font-size: 2rem;
      color: #D7E0EC;
      margin-bottom: 12px;
    }

    .empty-state p {
      font-weight: 700;
      color: #1B2A4A;
      margin-bottom: 4px;
    }

    .empty-state span {
      color: #8FA0BC;
      font-size: 0.85rem;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 18px;
    }

    .product-card {
      background: #fff;
      border-radius: 18px;
      border: 1px solid #EEF3F9;
      overflow: hidden;
    }

    .product-photo {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: contain;
      object-position: center;
      display: block;
      background: #F4F7FC;
    }

    .product-icon {
      width: 100%;
      aspect-ratio: 4 / 3;
      background: #FFF0EA;
      color: #FF6B35;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
    }

    .product-body {
      padding: 14px;
    }

    .product-title {
      font-size: 0.92rem;
      font-weight: 700;
      color: #1B2A4A;
      margin-bottom: 4px;
    }

    .product-price {
      font-size: 0.95rem;
      font-weight: 700;
      color: #FF6B35;
      margin-bottom: 12px;
    }

    .product-actions {
      display: flex;
      gap: 8px;
    }

    .product-actions button {
      flex: 1;
      border: none;
      padding: 9px;
      border-radius: 10px;
      font-size: 0.78rem;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-edit {
      background: #F4F7FC;
      color: #1B2A4A;
    }

    .btn-delete {
      background: #FFF0EA;
      color: #D14343;
    }

    /* ===== এডিট মোডাল ===== */
    .edit-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.55);
      z-index: 2000;
      align-items: center;
      justify-content: center;
      padding: 20px;
      overflow-y: auto;
    }

    .edit-overlay.open {
      display: flex;
    }

    .edit-modal {
      position: relative;
      background: #fff;
      width: 100%;
      max-width: 420px;
      border-radius: 28px;
      padding: 32px 28px 28px;
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.25);
      margin: auto;
    }

    .edit-close {
      position: absolute;
      top: 16px;
      right: 16px;
      background: #F4F7FC;
      border: none;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      color: #5A6E85;
      cursor: pointer;
    }

    .edit-title {
      font-size: 1.15rem;
      color: #1B2A4A;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .edit-title i {
      color: #FF6B35;
    }

    .edit-message {
      display: none;
      font-size: 0.82rem;
      font-weight: 600;
      padding: 10px 14px;
      border-radius: 12px;
      margin-bottom: 12px;
      text-align: center;
    }

    .edit-message.show-error {
      display: block;
      background: #FFF0EA;
      color: #D14343;
    }

    .edit-message.show-success {
      display: block;
      background: #EAFBF0;
      color: #1B7A3C;
    }

    .edit-label {
      display: block;
      font-size: 0.82rem;
      font-weight: 600;
      color: #1B2A4A;
      margin-bottom: 6px;
      margin-top: 14px;
    }

    .edit-input {
      width: 100%;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1.5px solid #E5EAF0;
      font-size: 0.9rem;
      font-family: inherit;
      color: #1B2A4A;
      background: #FBFCFE;
    }

    .edit-input:focus {
      outline: none;
      border-color: #FF6B35;
      background: #fff;
    }

    textarea.edit-input {
      resize: vertical;
    }

    .edit-save-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #FF6B35;
      color: #fff;
      border: none;
      padding: 14px;
      border-radius: 14px;
      font-weight: 700;
      font-size: 0.92rem;
      cursor: pointer;
      margin-top: 22px;
    }
  </style>

  <script>
    import { supabase } from '../lib/supabase.js';

    const loadingState = document.getElementById('loadingState');
    const guardedContent = document.getElementById('guardedContent');
    const shopNameEl = document.getElementById('shopName');
    const productsContainer = document.getElementById('productsContainer');
    const emptyState = document.getElementById('emptyState');

    let currentUserId = null;
    let products = [];

    async function init() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/';
        return;
      }

      const { data: profile } = await supabase
        .from('profiles')
        .select('is_shop_owner, shop_name')
        .eq('id', session.user.id)
        .single();

      if (!profile?.is_shop_owner) {
        window.location.href = '/';
        return;
      }

      currentUserId = session.user.id;
      shopNameEl.textContent = profile.shop_name || 'আমার শপ';

      loadingState.style.display = 'none';
      guardedContent.style.display = 'block';

      loadProducts();
    }

    async function loadProducts() {
      const { data, error } = await supabase
        .from('listings')
        .select('*')
        .eq('category', 'online-shop')
        .eq('user_id', currentUserId)
        .order('created_at', { ascending: false });

      if (error) {
        console.error('প্রোডাক্ট লোড এরর:', error.message);
      }

      products = data || [];
      renderProducts();
    }

    function renderProducts() {
      productsContainer.innerHTML = '';

      if (products.length === 0) {
        emptyState.style.display = 'block';
        return;
      }
      emptyState.style.display = 'none';

      products.forEach((p) => {
        const card = document.createElement('div');
        card.className = 'product-card';

        const imageHtml = p.images && p.images.length > 0
          ? `<img src="${p.images[0]}" alt="${p.title || ''}" class="product-photo" />`
          : `<div class="product-icon"><i class="fas fa-box"></i></div>`;

        card.innerHTML = `
          ${imageHtml}
          <div class="product-body">
            <p class="product-title">${p.title || ''}</p>
            ${p.price ? `<p class="product-price">৳${p.price}</p>` : ''}
            <p style="font-size:0.72rem;color:#B0BCCB;margin-bottom:10px;">স্ট্যাটাস: ${p.status || 'অজানা'}</p>
            <div class="product-actions">
              <button class="btn-edit"><i class="fas fa-pen"></i> এডিট</button>
              <button class="btn-delete"><i class="fas fa-trash"></i> ডিলিট</button>
            </div>
          </div>
        `;

        card.querySelector('.btn-edit').addEventListener('click', () => openEdit(p));
        card.querySelector('.btn-delete').addEventListener('click', () => deleteProduct(p.id));

        productsContainer.appendChild(card);
      });
    }

    async function deleteProduct(id) {
      if (!confirm('এই প্রোডাক্টটি ডিলিট করতে চান?')) return;

      const { error } = await supabase.from('listings').delete().eq('id', id);
      if (error) {
        alert('ডিলিট ব্যর্থ: ' + error.message);
        return;
      }
      loadProducts();
    }

    // ===== এডিট মোডাল =====
    const editOverlay = document.getElementById('editOverlay');
    const editClose = document.getElementById('editClose');
    const editMessage = document.getElementById('editMessage');
    const editTitleInput = document.getElementById('editTitle');
    const editDescInput = document.getElementById('editDescription');
    const editPriceInput = document.getElementById('editPrice');
    const editSaveBtn = document.getElementById('editSaveBtn');
    let editingId = null;

    function openEdit(product) {
      editingId = product.id;
      editTitleInput.value = product.title || '';
      editDescInput.value = product.description || '';
      editPriceInput.value = product.price || '';
      editMessage.className = 'edit-message';
      editMessage.textContent = '';
      editOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeEdit() {
      editOverlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    editClose?.addEventListener('click', closeEdit);
    editOverlay?.addEventListener('click', (e) => {
      if (e.target === editOverlay) closeEdit();
    });

    editSaveBtn?.addEventListener('click', async () => {
      const title = editTitleInput.value.trim();
      if (!title) {
        editMessage.textContent = 'প্রোডাক্টের নাম আবশ্যক';
        editMessage.className = 'edit-message show-error';
        return;
      }

      const { error } = await supabase
        .from('listings')
        .update({
          title,
          description: editDescInput.value.trim(),
          price: editPriceInput.value.trim(),
        })
        .eq('id', editingId);

      if (error) {
        editMessage.textContent = 'সেভ ব্যর্থ: ' + error.message;
        editMessage.className = 'edit-message show-error';
        return;
      }

      editMessage.textContent = 'সেভ হয়েছে ✓';
      editMessage.className = 'edit-message show-success';
      setTimeout(() => {
        closeEdit();
        loadProducts();
      }, 700);
    });

    document.getElementById('openAddListing')?.addEventListener('click', () => {
      window.openListingModal?.('product');
    });

    init();
  </script>
</BaseLayout>