---
// ============================================================
// পেজ: পাবলিক ক্লাব ডিরেক্টরি (/clubs)
// সব active ক্লাব গ্রিড আকারে দেখায়, উপজেলা ফিল্টার সহ
// আপডেট: কার্ড এখন প্রিমিয়াম — কভার (ব্যানার) + গোল লোগো ওভারল্যাপ
// (Facebook Page কার্ডের স্টাইলে), শুধু single icon না
// ============================================================

export const prerender = false;

import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="ক্লাব সমূহ | স্মার্ট ফেনী">
  <div class="clubs-page">
    <div class="container">

      <div class="page-header">
        <h1><i class="fas fa-people-group"></i> ফেনীর ক্লাব সমূহ</h1>
        <p>জেলার বিভিন্ন ক্লাবের কার্যক্রম, অর্জন ও আয়োজন দেখুন</p>
      </div>

      <!-- ===== উপজেলা ফিল্টার ===== -->
      <div class="filter-row" id="filterRow">
        <button class="filter-chip active" data-upajila="all">সব</button>
        <button class="filter-chip" data-upajila="feni-sadar">ফেনী সদর</button>
        <button class="filter-chip" data-upajila="chhagalnaiya">ছাগলনাইয়া</button>
        <button class="filter-chip" data-upajila="daganbhuiyan">দাগনভূঞা</button>
        <button class="filter-chip" data-upajila="parshuram">পরশুরাম</button>
        <button class="filter-chip" data-upajila="fulgazi">ফুলগাজী</button>
        <button class="filter-chip" data-upajila="sonagazi">সোনাগাজী</button>
      </div>

      <div id="clubsGrid" class="clubs-grid"></div>

      <div id="loadingState" class="state-msg">
        <div class="spinner"></div>
        <p>লোড হচ্ছে...</p>
      </div>

      <div id="emptyState" class="state-msg" style="display:none;">
        <i class="fas fa-people-group"></i>
        <p>এই উপজেলায় এখনো কোনো ক্লাব নেই</p>
      </div>

    </div>
  </div>

  <style>
    .clubs-page {
      min-height: 70vh;
      padding: 40px 0 80px;
    }

    .page-header {
      margin-bottom: 24px;
    }

    .page-header h1 {
      font-size: 1.8rem;
      font-weight: 700;
      color: #1B2A4A;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .page-header h1 i {
      color: #FF6B35;
    }

    .page-header p {
      font-size: 0.95rem;
      color: #5A6E85;
      margin-top: 6px;
    }

    .filter-row {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 8px;
      margin-bottom: 24px;
      scrollbar-width: none;
    }

    .filter-row::-webkit-scrollbar {
      display: none;
    }

    .filter-chip {
      flex-shrink: 0;
      background: #fff;
      border: 1.5px solid #E5EAF0;
      color: #5A6E85;
      padding: 9px 18px;
      border-radius: 40px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }

    .filter-chip.active {
      background: #FF6B35;
      border-color: #FF6B35;
      color: #fff;
    }

    .clubs-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .club-card {
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
      text-decoration: none;
      display: block;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .club-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.1);
    }

    /* ===== কভার — ফিক্সড হাইট ফ্রেম, ফুল ভরাট ===== */
    .club-cover-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 16/9;
      background: #F4F7FC;
      overflow: hidden;
    }

    .club-cover-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .club-cover-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #FFF0EA, #F4F7FC);
    }

    /* ===== লোগো — কভারের নিচের-বাম কোণায় ওভারল্যাপ (FB Page কার্ড স্টাইল) ===== */
    .club-logo-wrap {
      position: absolute;
      left: 12px;
      bottom: -22px;
      z-index: 2;
    }

    .club-logo-img {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      object-fit: cover;
      background: #fff;
      border: 3px solid #fff;
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.18);
      display: block;
    }

    .club-logo-placeholder {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: #FFF0EA;
      color: #FF6B35;
      border: 3px solid #fff;
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.18);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
    }

    .club-body {
      padding: 30px 14px 14px;
    }

    .club-name {
      font-size: 0.9rem;
      font-weight: 700;
      color: #1B2A4A;
      display: flex;
      align-items: center;
      gap: 6px;
      line-height: 1.3;
    }

    .club-name .verified-badge {
      color: #2563EB;
      font-size: 0.75rem;
      flex-shrink: 0;
    }

    .club-upajila {
      font-size: 0.76rem;
      color: #8FA0BC;
      margin-top: 4px;
      font-weight: 600;
    }

    .state-msg {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 60px 0;
      color: #B0BCCB;
      text-align: center;
    }

    .state-msg i {
      font-size: 2.4rem;
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    @media (max-width: 480px) {
      .clubs-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }

      .club-logo-img,
      .club-logo-placeholder {
        width: 44px;
        height: 44px;
      }

      .club-body {
        padding: 26px 12px 12px;
      }
    }
  </style>

  <script>
    import { supabase } from '../lib/supabase.js';

    const UPAZILA_LABELS = {
      'feni-sadar': 'ফেনী সদর',
      'chhagalnaiya': 'ছাগলনাইয়া',
      'daganbhuiyan': 'দাগনভূঞা',
      'parshuram': 'পরশুরাম',
      'fulgazi': 'ফুলগাজী',
      'sonagazi': 'সোনাগাজী',
    };

    const grid = document.getElementById('clubsGrid');
    const loadingState = document.getElementById('loadingState');
    const emptyState = document.getElementById('emptyState');
    const filterRow = document.getElementById('filterRow');

    let allClubs = [];
    let currentFilter = 'all';

    function renderClubs() {
      const filtered = currentFilter === 'all'
        ? allClubs
        : allClubs.filter((c) => c.upajila === currentFilter);

      grid.innerHTML = '';

      if (filtered.length === 0) {
        emptyState.style.display = 'flex';
        return;
      }

      emptyState.style.display = 'none';

      filtered.forEach((club) => {
        const card = document.createElement('a');
        card.href = `/${club.slug}`;
        card.className = 'club-card';

        const upazilaLabel = club.upajila ? UPAZILA_LABELS[club.upajila] || club.upajila : '';

        const coverHtml = club.cover_image
          ? `<img class="club-cover-img" src="${club.cover_image}" alt="${club.name}" loading="lazy" />`
          : `<div class="club-cover-placeholder"></div>`;

        const logoHtml = club.logo_image
          ? `<img class="club-logo-img" src="${club.logo_image}" alt="${club.name}" loading="lazy" />`
          : `<div class="club-logo-placeholder"><i class="fas fa-users"></i></div>`;

        card.innerHTML = `
          <div class="club-cover-wrap">
            ${coverHtml}
            <div class="club-logo-wrap">${logoHtml}</div>
          </div>
          <div class="club-body">
            <p class="club-name">
              ${club.name}
              ${club.is_verified ? '<i class="fas fa-circle-check verified-badge"></i>' : ''}
            </p>
            ${upazilaLabel ? `<p class="club-upajila"><i class="fas fa-location-dot"></i> ${upazilaLabel}</p>` : ''}
          </div>
        `;

        grid.appendChild(card);
      });
    }

    filterRow.addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-chip');
      if (!btn) return;

      filterRow.querySelectorAll('.filter-chip').forEach((c) => c.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.dataset.upajila;
      renderClubs();
    });

    async function loadClubs() {
      const { data, error } = await supabase
        .from('clubs')
        .select('*')
        .eq('is_active', true)
        .order('created_at', { ascending: false });

      loadingState.style.display = 'none';

      if (error) {
        grid.innerHTML = `<p style="grid-column:1/-1;text-align:center;color:#D14343;padding:40px 0;">লোড করা যায়নি: ${error.message}</p>`;
        return;
      }

      allClubs = data || [];
      renderClubs();
    }

    loadClubs();
  </script>
</BaseLayout>