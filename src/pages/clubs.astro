---
// ============================================================
// পেজ: পাবলিক ক্লাব ডিরেক্টরি (/clubs)
// আপডেট: উপজেলা ফিল্টার চিপ সরিয়ে সার্চ ফিল্টার বসানো হলো — বাংলায়
// টাইপ করলে club.name (বাংলা নাম) থেকে, ইংরেজিতে টাইপ করলে club.slug
// (ইউজারনেম, যেমন kolmilota) থেকে ম্যাচ করে। উপজেলা-ভিত্তিক sort বুস্ট
// ও "আমার ক্লাব" পিনিং আগের মতোই আছে, শুধু ফিল্টার ইনপুট বদলেছে।
// ============================================================

export const prerender = false;

import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="ক্লাব সমূহ | স্মার্ট ফেনী">
  <div class="clubs-page">
    <div class="container">

      <div class="page-header">
        <h1><i class="fas fa-people-group"></i> ফেনীর ক্লাব সমূহ</h1>
        <p>জেলার বিভিন্ন ক্লাবের কার্যক্রম, অর্জন ও আয়োজন দেখুন</p>
      </div>

      <div class="club-search-box">
        <i class="fas fa-search"></i>
        <input
          type="text"
          id="clubSearchInput"
          placeholder="আপনার ক্লাবের নাম লিখে অনুসন্ধান করুন "
          autocomplete="off"
        />
      </div>

      <div id="clubsGrid" class="clubs-grid"></div>

      <div id="loadingState" class="state-msg">
        <div class="spinner"></div>
        <p>লোড হচ্ছে...</p>
      </div>

      <div id="emptyState" class="state-msg" style="display:none;">
        <i class="fas fa-magnifying-glass"></i>
        <p>এই নামে কোনো ক্লাব পাওয়া যায়নি</p>
      </div>

    </div>
  </div>

  <style>
    .clubs-page {
      min-height: 70vh;
      padding: 40px 0 80px;
    }

    .page-header {
      margin-bottom: 24px;
    }

    .page-header h1 {
      font-size: 1.8rem;
      font-weight: 700;
      color: #1B2A4A;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .page-header h1 i {
      color: #FF6B35;
    }

    .page-header p {
      font-size: 0.95rem;
      color: #5A6E85;
      margin-top: 6px;
    }

    /* ===== সার্চ ফিল্টার বক্স ===== */
    .club-search-box {
      position: relative;
      margin-bottom: 24px;
    }

    .club-search-box i {
      position: absolute;
      left: 18px;
      top: 50%;
      transform: translateY(-50%);
      color: #B0BCCB;
      font-size: 0.95rem;
    }

    .club-search-box input {
      width: 100%;
      padding: 14px 18px 14px 46px;
      border-radius: 40px;
      border: 1.5px solid #E5EAF0;
      background: #fff;
      font-size: 0.92rem;
      font-family: inherit;
      color: #1B2A4A;
      transition: all 0.2s ease;
    }

    .club-search-box input:focus {
      outline: none;
      border-color: #FF6B35;
      box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.1);
    }

    .state-msg {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 60px 0;
      color: #B0BCCB;
      text-align: center;
    }

    .state-msg i {
      font-size: 2.4rem;
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>

  <style is:global>
    .clubs-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .club-card {
      position: relative;
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
      text-decoration: none;
      display: block;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .club-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.1);
    }

    .club-cover-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 21/9;
      background: #F4F7FC;
    }

    .club-cover-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .club-cover-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #FFF0EA, #F4F7FC);
    }

    .my-club-badge {
      position: absolute;
      right: 12px;
      top: 12px;
      z-index: 3;
      background: #1B2A4A;
      color: #fff;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 5px 12px;
      border-radius: 40px;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .my-club-badge i {
      color: #FFD166;
      font-size: 0.7rem;
    }

    /* ===== লোগো — কভারের নিচে, নেগেটিভ margin দিয়ে ওভারল্যাপ (clipping এড়াতে কভার-wrap এর বাইরে) ===== */
    .club-logo-row {
      display: flex;
      align-items: flex-end;
      margin-top: -30px;
      padding: 0 16px;
      position: relative;
      z-index: 2;
    }

    .club-logo-img,
    .club-logo-placeholder {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      border: 3px solid #fff;
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.18);
      flex-shrink: 0;
      background: #fff;
    }

    .club-logo-img {
      object-fit: cover;
      display: block;
    }

    .club-logo-placeholder {
      color: #FF6B35;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
    }

    .club-body {
      padding: 10px 16px 18px;
    }

    .club-name {
      font-size: 1.05rem;
      font-weight: 700;
      color: #1B2A4A;
      display: flex;
      align-items: center;
      gap: 6px;
      line-height: 1.3;
    }

    .club-name .verified-badge {
      color: #2563EB;
      font-size: 0.85rem;
      flex-shrink: 0;
    }

    .club-upajila {
      font-size: 0.82rem;
      color: #8FA0BC;
      margin-top: 5px;
      font-weight: 600;
    }

    @media (max-width: 480px) {
      .club-logo-img,
      .club-logo-placeholder {
        width: 54px;
        height: 54px;
      }

      .club-logo-row {
        margin-top: -26px;
      }
    }
  </style>

  <script>
    import { supabase } from '../lib/supabase.js';

    const UPAZILA_LABELS = {
      'feni-sadar': 'ফেনী সদর',
      'chhagalnaiya': 'ছাগলনাইয়া',
      'daganbhuiyan': 'দাগনভূঞা',
      'parshuram': 'পরশুরাম',
      'fulgazi': 'ফুলগাজী',
      'sonagazi': 'সোনাগাজী',
    };

    const grid = document.getElementById('clubsGrid');
    const loadingState = document.getElementById('loadingState');
    const emptyState = document.getElementById('emptyState');
    const searchInput = document.getElementById('clubSearchInput');

    let allClubs = [];
    let searchQuery = '';
    let myClubIds = new Set();
    const savedUpazilaLabel = localStorage.getItem('smartfeni_upazila');
    // savedUpazilaLabel বাংলা লেবেল আকারে সেভ থাকে (যেমন "ফেনী সদর"),
    // upajila কলামে ইংরেজি slug থাকে (যেমন "feni-sadar") — ম্যাপ করে মেলাই
    const savedUpazilaSlug = Object.entries(UPAZILA_LABELS).find(([, label]) => label === savedUpazilaLabel)?.[0] || null;

    function sortClubs(list) {
      return [...list].sort((a, b) => {
        const aMine = myClubIds.has(a.id) ? 1 : 0;
        const bMine = myClubIds.has(b.id) ? 1 : 0;
        if (aMine !== bMine) return bMine - aMine;

        const aLocal = savedUpazilaSlug && a.upajila === savedUpazilaSlug ? 1 : 0;
        const bLocal = savedUpazilaSlug && b.upajila === savedUpazilaSlug ? 1 : 0;
        if (aLocal !== bLocal) return bLocal - aLocal;

        return 0; // বাকিটা আগের (created_at desc) অর্ডারই থাকবে
      });
    }

    // বাংলা নাম (club.name) ও ইংরেজি username (club.slug) — দুটোতেই
    // case-insensitive substring ম্যাচ করে। যেমন "কলমিলতা" লিখলে name
    // থেকে, "kolmilota" লিখলে slug থেকে ম্যাচ হবে — একই চেক দুটো
    // স্ক্রিপ্টেই কাজ করে, আলাদা লজিক লাগে না।
    function filterClubs(query) {
      const q = query.trim().toLowerCase();
      if (!q) return allClubs;
      return allClubs.filter((c) => {
        const nameMatch = (c.name || '').toLowerCase().includes(q);
        const slugMatch = (c.slug || '').toLowerCase().includes(q);
        return nameMatch || slugMatch;
      });
    }

    function renderClubs() {
      const filtered = filterClubs(searchQuery);
      const sorted = sortClubs(filtered);

      grid.innerHTML = '';

      if (sorted.length === 0) {
        emptyState.style.display = 'flex';
        return;
      }

      emptyState.style.display = 'none';

      sorted.forEach((club) => {
        const card = document.createElement('a');
        card.href = `/${club.slug}`;
        card.className = 'club-card';

        const upazilaLabel = club.upajila ? UPAZILA_LABELS[club.upajila] || club.upajila : '';

        const coverHtml = club.cover_image
          ? `<img class="club-cover-img" src="${club.cover_image}" alt="${club.name}" loading="lazy" />`
          : `<div class="club-cover-placeholder"></div>`;

        const logoHtml = club.logo_image
          ? `<img class="club-logo-img" src="${club.logo_image}" alt="${club.name}" loading="lazy" />`
          : `<div class="club-logo-placeholder"><i class="fas fa-users"></i></div>`;

        card.innerHTML = `
          <div class="club-cover-wrap">
            ${coverHtml}
            ${myClubIds.has(club.id) ? '<span class="my-club-badge"><i class="fas fa-star"></i> আমার ক্লাব</span>' : ''}
          </div>
          <div class="club-logo-row">${logoHtml}</div>
          <div class="club-body">
            <p class="club-name">
              ${club.name}
              ${club.is_verified ? '<i class="fas fa-circle-check verified-badge"></i>' : ''}
            </p>
            ${upazilaLabel ? `<p class="club-upajila"><i class="fas fa-location-dot"></i> ${upazilaLabel}</p>` : ''}
          </div>
        `;

        grid.appendChild(card);
      });
    }

    // টাইপ করার সাথে সাথে সার্চ (হালকা debounce দিয়ে)
    let debounceTimer;
    searchInput.addEventListener('input', (e) => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        searchQuery = e.target.value;
        renderClubs();
      }, 120);
    });

    async function loadMyClubIds() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;

      const { data } = await supabase
        .from('club_members')
        .select('club_id')
        .eq('user_id', session.user.id);

      (data || []).forEach((row) => myClubIds.add(row.club_id));
    }

    async function loadClubs() {
      await loadMyClubIds();

      const { data, error } = await supabase
        .from('clubs')
        .select('*')
        .eq('is_active', true)
        .order('created_at', { ascending: false });

      loadingState.style.display = 'none';

      if (error) {
        grid.innerHTML = `<p style="text-align:center;color:#D14343;padding:40px 0;">লোড করা যায়নি: ${error.message}</p>`;
        return;
      }

      allClubs = data || [];
      renderClubs();
    }

    loadClubs();
  </script>
</BaseLayout>