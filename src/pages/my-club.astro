---
export const prerender = false;

import BaseLayout from '../components/layout/BaseLayout.astro';
import ProfileEditTab from '../components/club-dashboard/ProfileEditTab.astro';
import MembersCommitteeTab from '../components/club-dashboard/MembersCommitteeTab.astro';
import PostsTab from '../components/club-dashboard/PostsTab.astro';
import NotificationsInbox from '../components/club-dashboard/NotificationsInbox.astro';
import JoinRequestsInbox from '../components/club-dashboard/JoinRequestsInbox.astro';
import BroadcastModal from '../components/club-dashboard/BroadcastModal.astro';
---

<BaseLayout title="আমার ক্লাব | স্মার্ট ফেনী">
  <div class="myclub-page">
    <div class="container">

      <div id="loadingState" class="loading-state">
        <div class="spinner"></div>
        <p>লোড হচ্ছে...</p>
      </div>

      <div id="guardedContent" class="myclub-content" style="display:none;">

        <div class="myclub-header">
          <h1 id="clubHeaderName"><i class="fas fa-people-group"></i> <span></span></h1>
        </div>

        <div class="myclub-tabs" id="myclubTabs">
          <button class="myclub-tab active" data-tab="profile"><i class="fas fa-id-card"></i> প্রোফাইল</button>
          <button class="myclub-tab" data-tab="members"><i class="fas fa-user-group"></i> সদস্য/কমিটি</button>
          <button class="myclub-tab" data-tab="posts"><i class="fas fa-newspaper"></i> পোস্ট</button>
          <button class="myclub-tab" data-tab="notifications"><i class="fas fa-bell"></i> নোটিফিকেশন <span class="tab-badge" id="notifBadge" style="display:none;"></span></button>
          <button class="myclub-tab" data-tab="joins"><i class="fas fa-user-plus"></i> জয়েন রিকোয়েস্ট <span class="tab-badge" id="joinBadge" style="display:none;"></span></button>
        </div>

        <div class="myclub-panel" data-panel="profile">
          <ProfileEditTab />
        </div>
        <div class="myclub-panel" data-panel="members" style="display:none;">
          <MembersCommitteeTab />
        </div>
        <div class="myclub-panel" data-panel="posts" style="display:none;">
          <PostsTab />
        </div>
        <div class="myclub-panel" data-panel="notifications" style="display:none;">
          <NotificationsInbox />
        </div>
        <div class="myclub-panel" data-panel="joins" style="display:none;">
          <JoinRequestsInbox />
        </div>

      </div>
    </div>
  </div>

  <BroadcastModal />

  <style is:global>
    .myclub-page {
      min-height: 70vh;
      padding: 32px 0 80px;
      background: #F8FAFC;
    }

    .loading-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .myclub-content {
      max-width: 720px;
      margin: 0 auto;
    }

    .myclub-header h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #1B2A4A;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 18px;
    }

    .myclub-header h1 i {
      color: #FF6B35;
    }

    .myclub-tabs {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 10px;
      margin-bottom: 20px;
      scrollbar-width: none;
    }

    .myclub-tabs::-webkit-scrollbar {
      display: none;
    }

    .myclub-tab {
      flex-shrink: 0;
      background: #fff;
      border: 1.5px solid #E5EAF0;
      color: #5A6E85;
      padding: 10px 16px;
      border-radius: 40px;
      font-size: 0.82rem;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }

    .myclub-tab.active {
      background: #FF6B35;
      border-color: #FF6B35;
      color: #fff;
    }

    .tab-badge {
      background: #D14343;
      color: #fff;
      font-size: 0.66rem;
      padding: 1px 6px;
      border-radius: 20px;
      font-weight: 700;
    }

    /* ===== কমন ফর্ম/কার্ড স্টাইল — সব ট্যাব কম্পোনেন্ট এগুলো ব্যবহার করে ===== */
    .dash-card {
      background: #fff;
      border-radius: 20px;
      padding: 22px 20px;
      margin-bottom: 18px;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    }

    .dash-card h3 {
      font-size: 0.98rem;
      font-weight: 700;
      color: #1B2A4A;
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .dash-card h3 i {
      color: #FF6B35;
    }

    .form-msg {
      display: none;
      font-size: 0.82rem;
      font-weight: 600;
      padding: 10px 14px;
      border-radius: 12px;
      margin-bottom: 12px;
      text-align: center;
    }

    .form-msg.show-error {
      display: block;
      background: #FFF0EA;
      color: #D14343;
    }

    .form-msg.show-success {
      display: block;
      background: #EAFBF0;
      color: #1B7A3C;
    }

    .form-label {
      display: block;
      font-size: 0.82rem;
      font-weight: 600;
      color: #1B2A4A;
      margin-bottom: 6px;
      margin-top: 14px;
    }

    .form-label:first-of-type {
      margin-top: 0;
    }

    .form-input {
      width: 100%;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1.5px solid #E5EAF0;
      font-size: 0.9rem;
      font-family: inherit;
      color: #1B2A4A;
      background: #FBFCFE;
      resize: vertical;
    }

    .form-input:focus {
      outline: none;
      border-color: #FF6B35;
      background: #fff;
    }

    .form-input:disabled {
      background: #F4F7FC;
      color: #9AA8BC;
      cursor: not-allowed;
    }

    .form-hint {
      font-size: 0.74rem;
      color: #9AA8BC;
      margin-top: 4px;
    }

    .primary-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #FF6B35;
      color: #fff;
      border: none;
      padding: 13px;
      border-radius: 14px;
      font-weight: 700;
      font-size: 0.9rem;
      cursor: pointer;
      margin-top: 16px;
    }

    .primary-btn:disabled {
      opacity: 0.65;
      cursor: not-allowed;
    }

    .secondary-btn {
      background: #F4F7FC;
      color: #1B2A4A;
      border: none;
      padding: 8px 14px;
      border-radius: 10px;
      font-size: 0.78rem;
      font-weight: 700;
      cursor: pointer;
    }

    .item-card {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #FBFCFE;
      border: 1px solid #EEF3F9;
      border-radius: 14px;
      padding: 10px 12px;
      margin-bottom: 10px;
    }

    .item-photo {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      object-fit: contain;
      background: #F4F7FC;
      flex-shrink: 0;
    }

    .item-photo-placeholder {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: #FFF0EA;
      color: #FF6B35;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }

    .item-body {
      flex: 1;
      min-width: 0;
    }

    .item-title {
      font-size: 0.86rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .item-sub {
      font-size: 0.75rem;
      color: #8FA0BC;
    }

    .item-actions {
      display: flex;
      gap: 6px;
      flex-shrink: 0;
    }

    .icon-btn {
      width: 32px;
      height: 32px;
      border-radius: 9px;
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 0.78rem;
    }

    .icon-btn.edit {
      background: #F4F7FC;
      color: #1B2A4A;
    }

    .icon-btn.delete {
      background: #FFF0EA;
      color: #D14343;
    }

    .empty-note {
      font-size: 0.84rem;
      color: #B0BCCB;
      text-align: center;
      padding: 20px 0;
    }

    .photo-upload-circle {
      position: relative;
      width: 80px;
      height: 80px;
      border-radius: 18px;
      background: #FFF0EA;
      border: 2px dashed #FFD3BC;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      overflow: hidden;
      margin: 0 auto 16px;
    }

    .photo-upload-circle img {
      display: none;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .photo-upload-circle.has-photo img {
      display: block;
    }

    .photo-upload-circle.has-photo i {
      display: none;
    }

    .photo-upload-circle i {
      color: #FF6B35;
      font-size: 1.4rem;
    }
  </style>

  <script>
    import { supabase } from '../lib/supabase.js';

    const loadingState = document.getElementById('loadingState');
    const guardedContent = document.getElementById('guardedContent');
    const tabsBar = document.getElementById('myclubTabs');

    async function init() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/';
        return;
      }

      const { data: profile } = await supabase
        .from('profiles')
        .select('is_club_owner, club_id')
        .eq('id', session.user.id)
        .single();

      if (!profile?.is_club_owner || !profile?.club_id) {
        window.location.href = '/';
        return;
      }

      const { data: club } = await supabase
        .from('clubs')
        .select('*')
        .eq('id', profile.club_id)
        .single();

      if (!club) {
        window.location.href = '/';
        return;
      }

      document.querySelector('#clubHeaderName span').textContent = club.name;

      loadingState.style.display = 'none';
      guardedContent.style.display = 'block';

      window.dispatchEvent(new CustomEvent('smartfeni:club-ready', { detail: { clubId: club.id, club } }));
    }

    tabsBar?.addEventListener('click', (e) => {
      const btn = e.target.closest('.myclub-tab');
      if (!btn) return;

      document.querySelectorAll('.myclub-tab').forEach((t) => t.classList.remove('active'));
      btn.classList.add('active');

      const target = btn.dataset.tab;
      document.querySelectorAll('.myclub-panel').forEach((p) => {
        p.style.display = p.dataset.panel === target ? 'block' : 'none';
      });
    });

    init();
  </script>
</BaseLayout>