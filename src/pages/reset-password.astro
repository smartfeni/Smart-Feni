---
export const prerender = false;

import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="পাসওয়ার্ড রিসেট করুন | স্মার্ট ফেনী">
  <section class="reset-section">
    <div class="reset-card">
      <div id="checkingState" class="state-box">
        <i class="fas fa-spinner fa-spin"></i>
        <p>যাচাই করা হচ্ছে...</p>
      </div>

      <div id="invalidState" class="state-box" style="display:none;">
        <i class="fas fa-triangle-exclamation" style="color:#EF4444;"></i>
        <p>লিংকটি অকার্যকর বা মেয়াদ শেষ হয়ে গেছে।</p>
        <span>নতুন করে "পাসওয়ার্ড ভুলে গেছেন?" থেকে চেষ্টা করুন।</span>
        <a href="/" class="btn-primary" style="margin-top:16px;">হোমে ফিরে যান</a>
      </div>

      <div id="formState" style="display:none;">
        <h1><i class="fas fa-lock"></i> নতুন পাসওয়ার্ড সেট করুন</h1>
        <p class="reset-sub">আপনার অ্যাকাউন্টের জন্য একটা নতুন পাসওয়ার্ড দিন</p>

        <label class="form-label">নতুন পাসওয়ার্ড</label>
        <input type="password" id="newPassword" class="form-input" placeholder="কমপক্ষে ৬ অক্ষর" />

        <label class="form-label">পাসওয়ার্ড আবার লিখুন</label>
        <input type="password" id="confirmPassword" class="form-input" placeholder="আবার লিখুন" />

        <p id="formMsg" class="form-msg"></p>

        <button id="submitBtn" class="btn-primary submit-btn" type="button">
          <span id="submitBtnText">পাসওয়ার্ড সেভ করুন</span>
        </button>
      </div>

      <div id="successState" class="state-box" style="display:none;">
        <i class="fas fa-circle-check" style="color:#22C55E;"></i>
        <p>পাসওয়ার্ড সফলভাবে বদলানো হয়েছে ✓</p>
        <span>এখন নতুন পাসওয়ার্ড দিয়ে লগইন করুন</span>
        <a href="/" class="btn-primary" style="margin-top:16px;">হোমে যান</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reset-section {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F8FAFC;
    padding: 40px 16px;
  }

  .reset-card {
    background: #fff;
    border-radius: 20px;
    border: 1px solid #EEF3F9;
    padding: 40px 28px;
    max-width: 420px;
    width: 100%;
    text-align: center;
  }

  .reset-card h1 {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 6px;
  }

  .reset-card h1 i {
    color: #FF6B35;
    margin-right: 6px;
  }

  .reset-sub {
    color: #5A6E85;
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  .state-box i {
    font-size: 2.2rem;
    margin-bottom: 12px;
    display: block;
  }

  .state-box p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .state-box span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .form-label {
    display: block;
    text-align: left;
    font-size: 0.85rem;
    font-weight: 700;
    color: #1B2A4A;
    margin: 14px 0 6px;
  }

  .form-input {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid #EEF3F9;
    border-radius: 12px;
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    box-sizing: border-box;
  }

  .form-input:focus {
    border-color: #FF6B35;
  }

  .form-msg {
    font-size: 0.82rem;
    min-height: 18px;
    margin: 10px 0 0;
  }

  .form-msg.show-error {
    color: #EF4444;
  }

  .form-msg.show-success {
    color: #22C55E;
  }

  .submit-btn {
    width: 100%;
    margin-top: 16px;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    display: inline-block;
    background: #FF6B35;
    color: #fff;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 12px 26px;
    border-radius: 40px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary:hover {
    background: #e85a28;
  }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const checkingState = document.getElementById('checkingState');
  const invalidState = document.getElementById('invalidState');
  const formState = document.getElementById('formState');
  const successState = document.getElementById('successState');

  const newPasswordInput = document.getElementById('newPassword');
  const confirmPasswordInput = document.getElementById('confirmPassword');
  const formMsg = document.getElementById('formMsg');
  const submitBtn = document.getElementById('submitBtn');
  const submitBtnText = document.getElementById('submitBtnText');

  function showMsg(text, type = 'error') {
    formMsg.textContent = text;
    formMsg.className = `form-msg ${type === 'error' ? 'show-error' : 'show-success'}`;
  }

  function showState(state) {
    checkingState.style.display = 'none';
    invalidState.style.display = 'none';
    formState.style.display = 'none';
    successState.style.display = 'none';
    state.style.display = 'block';
  }

  let recoveryReady = false;

  // ইমেইলের লিংকে থাকা রিকভারি টোকেন সুপাবেস অটো-পার্স করে
  // 'PASSWORD_RECOVERY' ইভেন্ট ফায়ার করে
  supabase.auth.onAuthStateChange((event) => {
    if (event === 'PASSWORD_RECOVERY') {
      recoveryReady = true;
      showState(formState);
    }
  });

  // fallback: স্ক্রিপ্ট লোড হওয়ার আগেই সেশন প্রসেস হয়ে থাকতে পারে
  setTimeout(async () => {
    if (recoveryReady) return;
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      recoveryReady = true;
      showState(formState);
    } else {
      showState(invalidState);
    }
  }, 1500);

  submitBtn?.addEventListener('click', async () => {
    const newPassword = newPasswordInput.value;
    const confirmPassword = confirmPasswordInput.value;

    if (!newPassword || newPassword.length < 6) {
      showMsg('পাসওয়ার্ড কমপক্ষে ৬ অক্ষরের হতে হবে');
      return;
    }
    if (newPassword !== confirmPassword) {
      showMsg('দুটো পাসওয়ার্ড মিলছে না');
      return;
    }

    submitBtnText.textContent = 'সেভ হচ্ছে...';
    submitBtn.disabled = true;

    const { error } = await supabase.auth.updateUser({ password: newPassword });

    if (error) {
      submitBtnText.textContent = 'পাসওয়ার্ড সেভ করুন';
      submitBtn.disabled = false;
      showMsg('ব্যর্থ: ' + error.message);
      return;
    }

    showState(successState);
  });
</script>