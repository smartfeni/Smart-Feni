  <div class="container" style="padding-top:60px; min-height:70vh;">
    <h1 style="font-size:2.8rem;">আমাদের সম্পর্কে</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:700px; margin-top:20px;">
      সহজি একটি হাইপার-কমিউনিটি প্ল্যাটফর্ম, যেখানে প্রতিটি সেবা এক ক্লিকে।
    </p>
  </div>
</BaseLayout>