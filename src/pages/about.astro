---
// src/pages/about.astro
import Layout from '../layout/BaseLayout.astro';
---

<Layout title="আমাদের সম্পর্কে | স্মার্ট ফেনী">
  <main style="max-width: 800px; margin: 0 auto; padding: 40px 20px; color: #1B2A4A; line-height: 1.8;">
    <h1 style="font-size: 28px; margin-bottom: 24px;">আমাদের সম্পর্কে</h1>

    <section style="margin-bottom: 28px;">
      <h2 style="font-size: 20px; margin-bottom: 10px;">স্মার্ট ফেনী কী?</h2>
      <p>স্মার্ট ফেনী ফেনী জেলার জন্য তৈরি একটি হাইপারলোকাল কমিউনিটি সার্ভিস প্ল্যাটফর্ম। আমাদের লক্ষ্য একটাই — ফেনীর ৬টা উপজেলার (ফেনী সদর, ছাগলনাইয়া, দাগনভূঞা, পরশুরাম, ফুলগাজী, সোনাগাজী) মানুষের প্রয়োজনীয় সব ধরনের স্থানীয় সেবা এক জায়গায় নিয়ে আসা।</p>
    </section>

    <section style="margin-bottom: 28px;">
      <h2 style="font-size: 20px; margin-bottom: 10px;">আমরা কী কী সেবা দিই</h2>
      <p>বাসা ভাড়া, চাকরির খবর, রিপেয়ার সার্ভিস, গাড়ি ভাড়া, ব্লাড ডোনার, হোম মেস ফুড, টিউশন, স্বাস্থ্য ও আইনি পরামর্শ, লস্ট এন্ড ফাউন্ড সহ ১৮+ ধরনের সেবা — সবকিছু একটা প্ল্যাটফর্মে, ফেনীর মানুষের জন্য, ফেনীর মানুষের হাতে।</p>
    </section>

    <section style="margin-bottom: 28px;">
      <h2 style="font-size: 20px; margin-bottom: 10px;">আমাদের লক্ষ্য</h2>
      <p>"প্রয়োজন আপনার, দায়িত্ব আমাদের" — এই স্লোগানকে সামনে রেখে আমরা কাজ করি। আমরা বিশ্বাস করি স্থানীয় সেবা খোঁজা সহজ হওয়া উচিত, আর সেই সেবা হওয়া উচিত বিশ্বমানের। এখান থেকেই আমাদের ট্যাগলাইন: "Global Standards. Local Service."</p>
    </section>

    <section>
      <h2 style="font-size: 20px; margin-bottom: 10px;">যোগাযোগ</h2>
      <p>কোনো মতামত, পরামর্শ বা প্রশ্ন থাকলে যোগাযোগ করুন: <a href="mailto:info@smartfeni.com" style="color: #FF6B35;">info@smartfeni.com</a></p>
    </section>
  </main>
</Layout>