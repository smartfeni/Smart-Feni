---
// ============================================================
// পেজ: অ্যাডমিন — ফিচার্ড ফটো আপলোড (/admin/featured-photo)
// আপলোড করা ছবি ব্রাউজারেই ক্যানভাস দিয়ে 1600x900 (16:9) এ রিসাইজ/ক্রপ
// করে JPEG বানিয়ে Supabase Storage-এ ফিক্সড পাথে (site/featured-photo.jpg)
// আপলোড হয় — homepage কোড কখনো বদলাতে হবে না
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
---

<BaseLayout title="ফিচার্ড ফটো | অ্যাডমিন">
  <div class="admin-page">
    <div class="container">

      <div id="adminLoadingState" class="admin-loading">
        <div class="admin-spinner"></div>
        <p>যাচাই করা হচ্ছে...</p>
      </div>

      <div id="adminGuardedContent" class="admin-content" style="display:none;">

        <a href="/admin" class="back-link"><i class="fas fa-arrow-left"></i> ড্যাশবোর্ড</a>

        <div class="admin-header">
          <h1>ফিচার্ড ফটো</h1>
          <p class="admin-subtitle">হোমপেজের ফিচার্ড ফটো এখান থেকে বদলান — আপলোড করলেই সাথে সাথে সাইটে দেখাবে</p>
        </div>

        <!-- ===== বর্তমান ছবি প্রিভিউ ===== -->
        <div class="preview-card">
          <p class="preview-label">বর্তমান ছবি</p>
          <div class="preview-frame">
            <img id="currentPhoto" src="" alt="বর্তমান ফিচার্ড ফটো" />
            <div id="previewLoading" class="preview-loading"><i class="fas fa-spinner fa-spin"></i></div>
          </div>
        </div>

        <!-- ===== নতুন ছবি আপলোড ===== -->
        <div class="upload-card">
          <label for="fileInput" class="upload-drop" id="uploadDrop">
            <i class="fas fa-cloud-arrow-up"></i>
            <p>নতুন ছবি বেছে নিতে এখানে ট্যাপ করুন</p>
            <span>যেকোনো সাইজ/ফরম্যাট চলবে — auto 1600×900 এ ক্রপ হয়ে যাবে</span>
          </label>
          <input type="file" id="fileInput" accept="image/*" style="display:none;" />

          <div id="newPreviewWrap" style="display:none;">
            <p class="preview-label">নতুন ছবি (ক্রপকৃত প্রিভিউ)</p>
            <div class="preview-frame">
              <canvas id="cropCanvas" width="1600" height="900"></canvas>
            </div>
            <button id="uploadBtn" class="upload-btn">
              <i class="fas fa-check"></i> <span id="uploadBtnText">আপলোড করুন</span>
            </button>
          </div>

          <p id="uploadMessage" class="upload-message"></p>
        </div>

      </div>
    </div>
  </div>

  <style>
    .admin-page {
      min-height: 60vh;
      padding: 32px 0 80px;
    }

    .admin-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .admin-spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #5A6E85;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.88rem;
      margin-bottom: 20px;
    }

    .back-link:hover {
      color: #FF6B35;
    }

    .admin-header {
      margin-bottom: 24px;
    }

    .admin-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .admin-subtitle {
      font-size: 0.85rem;
      color: #8FA0BC;
      margin-top: 4px;
      font-weight: 600;
    }

    .preview-card, .upload-card {
      background: #fff;
      border-radius: 20px;
      padding: 20px;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
      margin-bottom: 18px;
    }

    .preview-label {
      font-size: 0.8rem;
      font-weight: 700;
      color: #5A6E85;
      margin-bottom: 10px;
    }

    .preview-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 16px;
      overflow: hidden;
      background: #F4F7FC;
    }

    .preview-frame img, .preview-frame canvas {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .preview-loading {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #B0BCCB;
      font-size: 1.4rem;
    }

    .upload-drop {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      padding: 40px 20px;
      border: 2px dashed #D7E0EC;
      border-radius: 16px;
      cursor: pointer;
      text-align: center;
      transition: border-color 0.2s ease;
    }

    .upload-drop:hover {
      border-color: #FF6B35;
    }

    .upload-drop i {
      font-size: 1.8rem;
      color: #FF6B35;
    }

    .upload-drop p {
      font-weight: 700;
      color: #1B2A4A;
      font-size: 0.9rem;
    }

    .upload-drop span {
      font-size: 0.78rem;
      color: #8FA0BC;
    }

    .upload-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #FF6B35;
      color: #fff;
      border: none;
      padding: 14px;
      border-radius: 14px;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      margin-top: 14px;
    }

    .upload-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .upload-message {
      text-align: center;
      font-size: 0.85rem;
      font-weight: 600;
      margin-top: 12px;
    }

    .upload-message.success {
      color: #1B7A3C;
    }

    .upload-message.error {
      color: #D14343;
    }
  </style>

  <script>
    import { initAdminGuard } from '../../lib/adminGuard.js';
    import { supabase } from '../../lib/supabase.js';

    const BUCKET = 'listing-images';
    const STORAGE_PATH = 'site/featured-photo.jpg';

    const currentPhotoImg = document.getElementById('currentPhoto');
    const previewLoading = document.getElementById('previewLoading');
    const fileInput = document.getElementById('fileInput');
    const newPreviewWrap = document.getElementById('newPreviewWrap');
    const cropCanvas = document.getElementById('cropCanvas');
    const uploadBtn = document.getElementById('uploadBtn');
    const uploadBtnText = document.getElementById('uploadBtnText');
    const uploadMessage = document.getElementById('uploadMessage');

    let croppedBlob = null;

    function getPublicUrlWithCacheBust() {
      const { data } = supabase.storage.from(BUCKET).getPublicUrl(STORAGE_PATH);
      return `${data.publicUrl}?t=${Date.now()}`;
    }

    function loadCurrentPhoto() {
      currentPhotoImg.onload = () => {
        previewLoading.style.display = 'none';
      };
      currentPhotoImg.onerror = () => {
        previewLoading.innerHTML = '<i class="fas fa-image"></i>';
      };
      currentPhotoImg.src = getPublicUrlWithCacheBust();
    }

    // ============================================================
    // ছবি সিলেক্ট করলেই ক্যানভাসে 1600x900 (cover-fit) ক্রপ করা হয়
    // ============================================================
    fileInput.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (!file) return;

      const img = new Image();
      img.onload = () => {
        const ctx = cropCanvas.getContext('2d');
        const targetW = 1600;
        const targetH = 900;
        const targetRatio = targetW / targetH;
        const imgRatio = img.width / img.height;

        let sx, sy, sWidth, sHeight;

        if (imgRatio > targetRatio) {
          // ছবি বেশি চওড়া — উচ্চতা অনুযায়ী ক্রপ, মাঝ থেকে
          sHeight = img.height;
          sWidth = sHeight * targetRatio;
          sx = (img.width - sWidth) / 2;
          sy = 0;
        } else {
          // ছবি বেশি লম্বা — প্রস্থ অনুযায়ী ক্রপ, মাঝ থেকে
          sWidth = img.width;
          sHeight = sWidth / targetRatio;
          sx = 0;
          sy = (img.height - sHeight) / 2;
        }

        ctx.drawImage(img, sx, sy, sWidth, sHeight, 0, 0, targetW, targetH);

        cropCanvas.toBlob((blob) => {
          croppedBlob = blob;
        }, 'image/jpeg', 0.85);

        newPreviewWrap.style.display = 'block';
        uploadMessage.textContent = '';
        uploadMessage.className = 'upload-message';
      };
      img.src = URL.createObjectURL(file);
    });

    uploadBtn.addEventListener('click', async () => {
      if (!croppedBlob) return;

      uploadBtn.disabled = true;
      uploadBtnText.textContent = 'আপলোড হচ্ছে...';

      const { error } = await supabase.storage
        .from(BUCKET)
        .upload(STORAGE_PATH, croppedBlob, { upsert: true, contentType: 'image/jpeg' });

      uploadBtn.disabled = false;
      uploadBtnText.textContent = 'আপলোড করুন';

      if (error) {
        uploadMessage.textContent = 'আপলোড ব্যর্থ: ' + error.message;
        uploadMessage.className = 'upload-message error';
        return;
      }

      uploadMessage.textContent = 'সফলভাবে আপলোড হয়েছে! হোমপেজে রিফ্রেশ করলেই নতুন ছবি দেখা যাবে।';
      uploadMessage.className = 'upload-message success';

      newPreviewWrap.style.display = 'none';
      fileInput.value = '';
      croppedBlob = null;

      previewLoading.style.display = 'flex';
      previewLoading.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
      loadCurrentPhoto();
    });

    window.addEventListener('smartfeni:admin-ready', () => {
      loadCurrentPhoto();
    });

    initAdminGuard();
  </script>
</BaseLayout>