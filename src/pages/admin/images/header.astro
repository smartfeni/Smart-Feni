---
// ============================================================
// পেজ: অ্যাডমিন — হেডার ব্যাকগ্রাউন্ড ম্যানেজমেন্ট (/admin/images/header)
// ৭টা স্লট: 'header_default' (fallback, উপজেলা-নির্দিষ্ট ছবি না থাকলে
// এটাই দেখাবে) + ৬টা উপজেলার জন্য আলাদা 'header_<slug>' ছবি।
// কোনোটাই আপলোড না থাকলে বর্তমান প্লেইন হেডার-ই থাকবে (কিছু ভাঙবে না)।
// প্রতিটা ছবি ক্যানভাসে 1600x240 এ ক্রপ হয়ে site/header/ ফোল্ডারে যায়।
// ============================================================

export const prerender = false;

import BaseLayout from '../../../components/layout/BaseLayout.astro';

const upazilas = [
  { slug: 'default', name: 'ডিফল্ট (fallback)' },
  { slug: 'feni-sadar', name: 'ফেনী সদর' },
  { slug: 'chhagalnaiya', name: 'ছাগলনাইয়া' },
  { slug: 'daganbhuiyan', name: 'দাগনভূঞা' },
  { slug: 'parshuram', name: 'পরশুরাম' },
  { slug: 'fulgazi', name: 'ফুলগাজী' },
  { slug: 'sonagazi', name: 'সোনাগাজী' },
];
---

<BaseLayout title="হেডার ব্যাকগ্রাউন্ড | অ্যাডমিন">
  <div class="admin-page">
    <div class="container">

      <div id="adminLoadingState" class="admin-loading">
        <div class="admin-spinner"></div>
        <p>যাচাই করা হচ্ছে...</p>
      </div>

      <div id="adminGuardedContent" class="admin-content" style="display:none;">

        <a href="/admin/images" class="back-link"><i class="fas fa-arrow-left"></i> ছবি ম্যানেজমেন্ট</a>

        <div class="admin-header">
          <h1>হেডার ব্যাকগ্রাউন্ড</h1>
          <p class="admin-subtitle">প্রতিটা উপজেলার জন্য আলাদা হেডার ছবি — না থাকলে ডিফল্ট ছবি দেখাবে, সেটাও না থাকলে বর্তমান সাদা হেডার-ই থাকবে</p>
        </div>

        <div class="slots-container">
          {upazilas.map((u) => (
            <div class="slot-card" data-slug={u.slug}>
              <p class="slot-title">{u.name}</p>
              <div class="slot-preview-frame">
                <img class="slot-current-img" src="" alt={u.name} style="display:none;" />
                <div class="slot-empty-state"><i class="fas fa-image"></i><span>ছবি নেই</span></div>
              </div>
              <label class="slot-upload-btn">
                <i class="fas fa-cloud-arrow-up"></i> ছবি বেছে নিন
                <input type="file" accept="image/*" class="slot-file-input" style="display:none;" />
              </label>
              <div class="slot-new-preview" style="display:none;">
                <canvas class="slot-canvas" width="1600" height="240"></canvas>
                <div class="slot-new-actions">
                  <button class="slot-save-btn">আপডেট করুন</button>
                  <button class="slot-cancel-btn">বাতিল</button>
                </div>
              </div>
              <button class="slot-remove-btn" style="display:none;">মুছে ফেলুন</button>
              <p class="slot-message"></p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>

  <style>
    .admin-page {
      min-height: 60vh;
      padding: 32px 0 80px;
    }

    .admin-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .admin-spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #5A6E85;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.88rem;
      margin-bottom: 20px;
    }

    .back-link:hover {
      color: #FF6B35;
    }

    .admin-header {
      margin-bottom: 24px;
    }

    .admin-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .admin-subtitle {
      font-size: 0.85rem;
      color: #8FA0BC;
      margin-top: 4px;
      font-weight: 600;
    }

    .slots-container {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .slot-card {
      background: #fff;
      border-radius: 20px;
      padding: 18px;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
    }

    .slot-title {
      font-size: 0.9rem;
      font-weight: 700;
      color: #1B2A4A;
      margin-bottom: 10px;
    }

    .slot-preview-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 1600 / 240;
      border-radius: 14px;
      overflow: hidden;
      background: #F4F7FC;
      margin-bottom: 12px;
    }

    .slot-preview-frame img, .slot-canvas {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .slot-empty-state {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      color: #B0BCCB;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .slot-empty-state i {
      font-size: 1.3rem;
    }

    .slot-upload-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #F4F7FC;
      color: #1B2A4A;
      border: 1.5px dashed #D7E0EC;
      padding: 10px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
    }

    .slot-upload-btn:hover {
      border-color: #FF6B35;
    }

    .slot-new-preview {
      margin-top: 12px;
    }

    .slot-new-actions {
      display: flex;
      gap: 8px;
      margin-top: 10px;
    }

    .slot-save-btn {
      flex: 1;
      background: #FF6B35;
      color: #fff;
      border: none;
      padding: 10px;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.85rem;
      cursor: pointer;
    }

    .slot-save-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .slot-cancel-btn {
      background: #F4F7FC;
      color: #5A6E85;
      border: none;
      padding: 10px 16px;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.85rem;
      cursor: pointer;
    }

    .slot-remove-btn {
      width: 100%;
      background: #FFF0EA;
      color: #D14343;
      border: none;
      padding: 9px;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.8rem;
      cursor: pointer;
      margin-top: 10px;
    }

    .slot-message {
      text-align: center;
      font-size: 0.8rem;
      font-weight: 600;
      margin-top: 8px;
    }

    .slot-message.success {
      color: #1B7A3C;
    }

    .slot-message.error {
      color: #D14343;
    }
  </style>

  <script>
    import { initAdminGuard } from '../../../lib/adminGuard.js';
    import { supabase } from '../../../lib/supabase.js';

    const BUCKET = 'listing-images';

    function storagePath(slug) {
      return `site/header/${slug}.jpg`;
    }

    function imageKey(slug) {
      return `header_${slug}`;
    }

    function publicUrl(path) {
      const { data } = supabase.storage.from(BUCKET).getPublicUrl(path);
      return data.publicUrl;
    }

    const slotCards = document.querySelectorAll('.slot-card');

    slotCards.forEach((card) => {
      const slug = card.dataset.slug;
      const currentImg = card.querySelector('.slot-current-img');
      const emptyState = card.querySelector('.slot-empty-state');
      const fileInput = card.querySelector('.slot-file-input');
      const newPreviewWrap = card.querySelector('.slot-new-preview');
      const canvas = card.querySelector('.slot-canvas');
      const saveBtn = card.querySelector('.slot-save-btn');
      const cancelBtn = card.querySelector('.slot-cancel-btn');
      const removeBtn = card.querySelector('.slot-remove-btn');
      const messageEl = card.querySelector('.slot-message');

      let croppedBlob = null;
      let hasExisting = false;

      function showMessage(text, type) {
        messageEl.textContent = text;
        messageEl.className = `slot-message ${type}`;
        setTimeout(() => { messageEl.textContent = ''; messageEl.className = 'slot-message'; }, 4000);
      }

      async function loadCurrent() {
        const { data } = await supabase
          .from('site_images')
          .select('storage_path, updated_at')
          .eq('image_key', imageKey(slug))
          .maybeSingle();

        if (!data) {
          hasExisting = false;
          currentImg.style.display = 'none';
          emptyState.style.display = 'flex';
          removeBtn.style.display = 'none';
          return;
        }

        hasExisting = true;
        const cacheBust = data.updated_at ? new Date(data.updated_at).getTime() : Date.now();
        currentImg.src = `${publicUrl(data.storage_path)}?v=${cacheBust}`;
        currentImg.style.display = 'block';
        emptyState.style.display = 'none';
        removeBtn.style.display = 'block';
      }

      fileInput.addEventListener('change', () => {
        const file = fileInput.files?.[0];
        if (!file) return;

        const img = new Image();
        img.onload = () => {
          const ctx = canvas.getContext('2d');
          const targetW = 1600, targetH = 240;
          const targetRatio = targetW / targetH;
          const imgRatio = img.width / img.height;

          let sx, sy, sWidth, sHeight;
          if (imgRatio > targetRatio) {
            sHeight = img.height;
            sWidth = sHeight * targetRatio;
            sx = (img.width - sWidth) / 2;
            sy = 0;
          } else {
            sWidth = img.width;
            sHeight = sWidth / targetRatio;
            sx = 0;
            sy = (img.height - sHeight) / 2;
          }

          ctx.drawImage(img, sx, sy, sWidth, sHeight, 0, 0, targetW, targetH);
          canvas.toBlob((blob) => { croppedBlob = blob; }, 'image/jpeg', 0.85);

          newPreviewWrap.style.display = 'block';
        };
        img.src = URL.createObjectURL(file);
      });

      cancelBtn.addEventListener('click', () => {
        newPreviewWrap.style.display = 'none';
        fileInput.value = '';
        croppedBlob = null;
      });

      saveBtn.addEventListener('click', async () => {
        if (!croppedBlob) return;

        saveBtn.disabled = true;
        saveBtn.textContent = 'আপলোড হচ্ছে...';

        const path = storagePath(slug);

        const { error: uploadError } = await supabase.storage
          .from(BUCKET)
          .upload(path, croppedBlob, { upsert: true, contentType: 'image/jpeg' });

        if (uploadError) {
          showMessage('আপলোড ব্যর্থ: ' + uploadError.message, 'error');
          saveBtn.disabled = false;
          saveBtn.textContent = 'আপডেট করুন';
          return;
        }

        const { error: dbError } = await supabase
          .from('site_images')
          .upsert({ image_key: imageKey(slug), storage_path: path, updated_at: new Date().toISOString() });

        saveBtn.disabled = false;
        saveBtn.textContent = 'আপডেট করুন';

        if (dbError) {
          showMessage('সেভ ব্যর্থ: ' + dbError.message, 'error');
          return;
        }

        showMessage('আপডেট হয়েছে!', 'success');
        newPreviewWrap.style.display = 'none';
        fileInput.value = '';
        croppedBlob = null;
        loadCurrent();
      });

      let confirmingRemove = false;
      removeBtn.addEventListener('click', async () => {
        if (!confirmingRemove) {
          confirmingRemove = true;
          removeBtn.textContent = 'নিশ্চিত করুন?';
          return;
        }

        await supabase.storage.from(BUCKET).remove([storagePath(slug)]);
        await supabase.from('site_images').delete().eq('image_key', imageKey(slug));

        confirmingRemove = false;
        removeBtn.textContent = 'মুছে ফেলুন';
        showMessage('ছবি সরানো হয়েছে', 'success');
        loadCurrent();
      });

      card._loadCurrent = loadCurrent;
    });

    window.addEventListener('smartfeni:admin-ready', () => {
      slotCards.forEach((card) => card._loadCurrent?.());
    });

    initAdminGuard();
  </script>
</BaseLayout>