---
// ============================================================
// পেজ: অ্যাডমিন — ক্লাব ম্যানেজমেন্ট (/admin/clubs)
// নতুন ক্লাব ওউনার অ্যাকাউন্ট তৈরি (/api/create-club কল করে),
// active/verified টগল
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
---

<BaseLayout title="ক্লাব ম্যানেজমেন্ট | অ্যাডমিন">
  <div class="admin-page">
    <div class="container">

      <div id="adminLoadingState" class="admin-loading">
        <div class="admin-spinner"></div>
        <p>যাচাই করা হচ্ছে...</p>
      </div>

      <div id="adminGuardedContent" class="admin-content" style="display:none;">

        <a href="/admin" class="back-link"><i class="fas fa-arrow-left"></i> ড্যাশবোর্ড</a>

        <div class="admin-header">
          <h1>ক্লাব ম্যানেজমেন্ট</h1>
          <p class="admin-subtitle" id="resultCount"></p>
        </div>

        <!-- ===== নতুন ক্লাব তৈরির ফর্ম ===== -->
        <div class="create-card">
          <h2 class="create-title"><i class="fas fa-people-group"></i> নতুন ক্লাব যোগ করুন</h2>

          <p class="form-message" id="createMessage"></p>

          <label class="form-label">ক্লাবের নাম (বাংলা)</label>
          <input type="text" class="form-input" id="clubNameInput" placeholder="যেমন: ফেনী স্পোর্টিং ক্লাব" />

          <label class="form-label">স্লাগ (ইংরেজি, URL এ ব্যবহার হবে)</label>
          <input type="text" class="form-input" id="clubSlugInput" placeholder="feni-sporting-club" />
          <p class="url-preview" id="slugPreview">smartfeni.com/</p>

          <label class="form-label">উপজেলা</label>
          <select class="form-input" id="clubUpajilaInput">
            <option value="">নির্বাচন করুন</option>
            <option value="feni-sadar">ফেনী সদর</option>
            <option value="chhagalnaiya">ছাগলনাইয়া</option>
            <option value="daganbhuiyan">দাগনভূঞা</option>
            <option value="parshuram">পরশুরাম</option>
            <option value="fulgazi">ফুলগাজী</option>
            <option value="sonagazi">সোনাগাজী</option>
          </select>

          <label class="form-label">ফোন নম্বর (লগইন আইডি হিসেবে ব্যবহার হবে)</label>
          <input type="text" class="form-input" id="clubPhoneInput" placeholder="01xxxxxxxxx" />

          <label class="form-label">পাসওয়ার্ড</label>
          <input type="password" class="form-input" id="clubPasswordInput" placeholder="কমপক্ষে ৬ অক্ষর" />

          <button class="create-btn" id="createClubBtn" type="button">
            <i class="fas fa-plus"></i> <span id="createBtnText">ক্লাব তৈরি করুন</span>
          </button>
        </div>

        <!-- ===== ক্লাব তালিকা ===== -->
        <div id="clubsContainer" class="clubs-container"></div>

        <div id="emptyState" class="empty-state" style="display:none;">
          <i class="fas fa-people-group"></i>
          <p>এখনো কোনো ক্লাব যোগ করা হয়নি</p>
        </div>

      </div>
    </div>
  </div>

  <style>
    .admin-page {
      min-height: 60vh;
      padding: 32px 0 80px;
    }

    .admin-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .admin-spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #5A6E85;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.88rem;
      margin-bottom: 20px;
    }

    .back-link:hover {
      color: #FF6B35;
    }

    .admin-header {
      margin-bottom: 24px;
    }

    .admin-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .admin-subtitle {
      font-size: 0.85rem;
      color: #8FA0BC;
      margin-top: 4px;
      font-weight: 600;
    }

    .create-card {
      background: #fff;
      border-radius: 20px;
      padding: 24px 22px;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
      margin-bottom: 28px;
    }

    .create-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #1B2A4A;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .create-title i {
      color: #FF6B35;
    }

    .form-message {
      display: none;
      font-size: 0.82rem;
      font-weight: 600;
      padding: 10px 14px;
      border-radius: 12px;
      margin-bottom: 12px;
      text-align: center;
    }

    .form-message.show-error {
      display: block;
      background: #FFF0EA;
      color: #D14343;
    }

    .form-message.show-success {
      display: block;
      background: #EAFBF0;
      color: #1B7A3C;
    }

    .form-label {
      display: block;
      font-size: 0.82rem;
      font-weight: 600;
      color: #1B2A4A;
      margin-bottom: 6px;
      margin-top: 14px;
    }

    .form-label:first-of-type {
      margin-top: 0;
    }

    .form-input {
      width: 100%;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1.5px solid #E5EAF0;
      font-size: 0.9rem;
      font-family: inherit;
      color: #1B2A4A;
      background: #FBFCFE;
    }

    .form-input:focus {
      outline: none;
      border-color: #FF6B35;
      background: #fff;
    }

    .url-preview {
      font-size: 0.78rem;
      color: #8FA0BC;
      margin-top: 6px;
      font-weight: 600;
    }

    .url-preview span {
      color: #FF6B35;
    }

    .create-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #FF6B35;
      color: #fff;
      border: none;
      padding: 14px;
      border-radius: 14px;
      font-weight: 700;
      font-size: 0.92rem;
      cursor: pointer;
      margin-top: 20px;
    }

    .create-btn:disabled {
      opacity: 0.65;
      cursor: not-allowed;
    }

    .clubs-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 60px 0;
      color: #B0BCCB;
    }

    .empty-state i {
      font-size: 2.4rem;
    }
  </style>

  <script>
    import { initAdminGuard } from '../../lib/adminGuard.js';
    import { supabase } from '../../lib/supabase.js';

    const UPAZILA_LABELS = {
      'feni-sadar': 'ফেনী সদর',
      'chhagalnaiya': 'ছাগলনাইয়া',
      'daganbhuiyan': 'দাগনভূঞা',
      'parshuram': 'পরশুরাম',
      'fulgazi': 'ফুলগাজী',
      'sonagazi': 'সোনাগাজী',
    };

    const container = document.getElementById('clubsContainer');
    const emptyState = document.getElementById('emptyState');
    const resultCount = document.getElementById('resultCount');

    const createMessage = document.getElementById('createMessage');
    const createBtn = document.getElementById('createClubBtn');
    const createBtnText = document.getElementById('createBtnText');

    const slugInput = document.getElementById('clubSlugInput');
    const slugPreview = document.getElementById('slugPreview');

    slugInput?.addEventListener('input', () => {
      const val = slugInput.value.trim().toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-');
      slugPreview.innerHTML = `smartfeni.com/<span>${val || '...'}</span>`;
    });

    function showMsg(text, type = 'error') {
      createMessage.textContent = text;
      createMessage.className = `form-message ${type === 'error' ? 'show-error' : 'show-success'}`;
    }

    function clearMsg() {
      createMessage.textContent = '';
      createMessage.className = 'form-message';
    }

    createBtn?.addEventListener('click', async () => {
      clearMsg();

      const clubName = document.getElementById('clubNameInput').value.trim();
      const slug = document.getElementById('clubSlugInput').value.trim();
      const upajila = document.getElementById('clubUpajilaInput').value;
      const phone = document.getElementById('clubPhoneInput').value.trim();
      const password = document.getElementById('clubPasswordInput').value;

      if (!clubName || !slug || !phone || !password) {
        showMsg('সব ঘর পূরণ করুন');
        return;
      }

      createBtnText.textContent = 'তৈরি হচ্ছে...';
      createBtn.disabled = true;

      try {
        const res = await fetch('/api/create-club', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ clubName, slug, phone, password, upajila }),
        });
        const result = await res.json();

        if (!res.ok) {
          showMsg(result.error || 'ক্লাব তৈরি ব্যর্থ');
        } else {
          showMsg(`ক্লাব সফলভাবে তৈরি হয়েছে ✓ (smartfeni.com/${result.slug})`, 'success');
          document.getElementById('clubNameInput').value = '';
          document.getElementById('clubSlugInput').value = '';
          document.getElementById('clubUpajilaInput').value = '';
          document.getElementById('clubPhoneInput').value = '';
          document.getElementById('clubPasswordInput').value = '';
          slugPreview.innerHTML = 'smartfeni.com/';
          loadClubs();
        }
      } catch (err) {
        showMsg('নেটওয়ার্ক ত্রুটি: ' + err.message);
      }

      createBtnText.textContent = 'ক্লাব তৈরি করুন';
      createBtn.disabled = false;
    });

    function renderClub(club) {
      const card = document.createElement('div');
      card.style.cssText = `background:#fff;border-radius:16px;padding:16px 18px;box-shadow:0 4px 16px rgba(15,23,42,0.06);display:flex;align-items:center;gap:14px;${club.is_active ? '' : 'opacity:0.6;'}`;

      const upazilaLabel = club.upajila ? UPAZILA_LABELS[club.upajila] || club.upajila : '';

      card.innerHTML = `
        <div style="width:44px;height:44px;border-radius:12px;background:#FFF0EA;color:#FF6B35;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;">
          <i class="fas fa-people-group"></i>
        </div>
        <div style="flex:1;min-width:0;">
          <p style="font-size:0.95rem;font-weight:700;color:#1B2A4A;">
            ${club.name || '(নামহীন ক্লাব)'} ${club.is_verified ? '<i class="fas fa-circle-check" style="color:#FF6B35;font-size:0.8rem;"></i>' : ''}
          </p>
          <p style="font-size:0.8rem;color:#8FA0BC;">
            /${club.slug} ${upazilaLabel ? '· ' + upazilaLabel : ''} ${club.is_active ? '' : '· নিষ্ক্রিয়'}
          </p>
        </div>
        <div class="club-actions" style="display:flex;gap:6px;flex-shrink:0;flex-wrap:wrap;"></div>
      `;

      const actions = card.querySelector('.club-actions');

      const verifyBtn = document.createElement('button');
      verifyBtn.textContent = club.is_verified ? 'আনভেরিফাই' : 'ভেরিফাই';
      verifyBtn.style.cssText = club.is_verified
        ? 'background:#F4F7FC;color:#5A6E85;border:none;padding:8px 12px;border-radius:10px;font-size:0.76rem;font-weight:700;cursor:pointer;white-space:nowrap;'
        : 'background:#FFF0EA;color:#FF6B35;border:none;padding:8px 12px;border-radius:10px;font-size:0.76rem;font-weight:700;cursor:pointer;white-space:nowrap;';
      verifyBtn.addEventListener('click', () => toggleField(club.id, 'is_verified', !club.is_verified));
      actions.appendChild(verifyBtn);

      const toggleBtn = document.createElement('button');
      toggleBtn.textContent = club.is_active ? 'নিষ্ক্রিয় করুন' : 'সক্রিয় করুন';
      toggleBtn.style.cssText = club.is_active
        ? 'background:#FFF0EA;color:#D14343;border:none;padding:8px 12px;border-radius:10px;font-size:0.76rem;font-weight:700;cursor:pointer;white-space:nowrap;'
        : 'background:#EAFBF0;color:#1B7A3C;border:none;padding:8px 12px;border-radius:10px;font-size:0.76rem;font-weight:700;cursor:pointer;white-space:nowrap;';
      toggleBtn.addEventListener('click', () => toggleField(club.id, 'is_active', !club.is_active));
      actions.appendChild(toggleBtn);

      return card;
    }

    async function toggleField(id, field, newValue) {
      const { error } = await supabase.from('clubs').update({ [field]: newValue }).eq('id', id);
      if (error) {
        alert('আপডেট ব্যর্থ: ' + error.message);
        return;
      }
      loadClubs();
    }

    async function loadClubs() {
      container.innerHTML = '<p style="text-align:center;color:#8FA0BC;padding:40px 0;">লোড হচ্ছে...</p>';

      const { data, error } = await supabase
        .from('clubs')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) {
        container.innerHTML = `<p style="text-align:center;color:#D14343;padding:40px 0;">লোড করা যায়নি: ${error.message}</p>`;
        return;
      }

      const allClubs = data || [];
      resultCount.textContent = `মোট ${allClubs.length} টি ক্লাব`;
      container.innerHTML = '';

      if (allClubs.length === 0) {
        emptyState.style.display = 'flex';
        return;
      }

      emptyState.style.display = 'none';
      allClubs.forEach((club) => container.appendChild(renderClub(club)));
    }

    window.addEventListener('smartfeni:admin-ready', () => {
      loadClubs();
    });

    initAdminGuard();
  </script>
</BaseLayout>