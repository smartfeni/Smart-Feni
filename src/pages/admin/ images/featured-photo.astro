---
// ============================================================
// পেজ: অ্যাডমিন — ফিচার্ড ফটো স্লাইডশো ম্যানেজমেন্ট (/admin/images/featured-photo)
// একাধিক ছবি রাখা যায়, প্রতিটা আপলোডে ক্যানভাসে 1600x900 ক্রপ হয়ে
// Supabase Storage-এ (site/featured/) সেভ হয় এবং featured_photos
// টেবিলে সারি + sort_order যোগ হয়। হোমপেজে ৫ সেকেন্ড পরপর ক্রমানুসারে
// crossfade স্লাইডশো হিসেবে দেখা যায়।
// ============================================================

export const prerender = false;

import BaseLayout from '../../../components/layout/BaseLayout.astro';
---

<BaseLayout title="ফিচার্ড ফটো | অ্যাডমিন">
  <div class="admin-page">
    <div class="container">

      <div id="adminLoadingState" class="admin-loading">
        <div class="admin-spinner"></div>
        <p>যাচাই করা হচ্ছে...</p>
      </div>

      <div id="adminGuardedContent" class="admin-content" style="display:none;">

        <a href="/admin/images" class="back-link"><i class="fas fa-arrow-left"></i> ছবি ম্যানেজমেন্ট</a>

        <div class="admin-header">
          <h1>ফিচার্ড ফটো স্লাইডশো</h1>
          <p class="admin-subtitle">একাধিক ছবি যোগ করুন — হোমপেজে ৫ সেকেন্ড পরপর ক্রমানুসারে বদলাবে</p>
        </div>

        <!-- ===== আপলোড ===== -->
        <div class="upload-card">
          <label for="fileInput" class="upload-drop">
            <i class="fas fa-cloud-arrow-up"></i>
            <p>নতুন ছবি যোগ করতে ট্যাপ করুন</p>
            <span>যেকোনো সাইজ/ফরম্যাট চলবে — auto 1600×900 এ ক্রপ হয়ে যাবে</span>
          </label>
          <input type="file" id="fileInput" accept="image/*" style="display:none;" />

          <div id="newPreviewWrap" style="display:none;">
            <div class="preview-frame">
              <canvas id="cropCanvas" width="1600" height="900"></canvas>
            </div>
            <button id="uploadBtn" class="upload-btn">
              <i class="fas fa-plus"></i> <span id="uploadBtnText">লিস্টে যোগ করুন</span>
            </button>
          </div>

          <p id="uploadMessage" class="upload-message"></p>
        </div>

        <!-- ===== বর্তমান ছবির গ্রিড (অর্ডার সহ) ===== -->
        <p class="section-title">স্লাইডশো ক্রম (উপর থেকে নিচে যেভাবে দেখাবে)</p>
        <div id="photosContainer" class="photos-container"></div>
        <div id="emptyState" class="empty-state" style="display:none;">
          <i class="fas fa-images"></i>
          <p>এখনো কোনো ছবি যোগ করা হয়নি — হোমপেজে ডিফল্ট fallback ছবি দেখাবে</p>
        </div>

      </div>
    </div>
  </div>

  <style>
    .admin-page {
      min-height: 60vh;
      padding: 32px 0 80px;
    }

    .admin-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .admin-spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #5A6E85;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.88rem;
      margin-bottom: 20px;
    }

    .back-link:hover {
      color: #FF6B35;
    }

    .admin-header {
      margin-bottom: 24px;
    }

    .admin-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .admin-subtitle {
      font-size: 0.85rem;
      color: #8FA0BC;
      margin-top: 4px;
      font-weight: 600;
    }

    .upload-card {
      background: #fff;
      border-radius: 20px;
      padding: 20px;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
      margin-bottom: 28px;
    }

    .preview-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 16px;
      overflow: hidden;
      background: #F4F7FC;
      margin-bottom: 12px;
    }

    .preview-frame canvas {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .upload-drop {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      padding: 40px 20px;
      border: 2px dashed #D7E0EC;
      border-radius: 16px;
      cursor: pointer;
      text-align: center;
      transition: border-color 0.2s ease;
    }

    .upload-drop:hover {
      border-color: #FF6B35;
    }

    .upload-drop i {
      font-size: 1.8rem;
      color: #FF6B35;
    }

    .upload-drop p {
      font-weight: 700;
      color: #1B2A4A;
      font-size: 0.9rem;
    }

    .upload-drop span {
      font-size: 0.78rem;
      color: #8FA0BC;
    }

    .upload-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #FF6B35;
      color: #fff;
      border: none;
      padding: 14px;
      border-radius: 14px;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
    }

    .upload-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .upload-message {
      text-align: center;
      font-size: 0.85rem;
      font-weight: 600;
      margin-top: 12px;
    }

    .upload-message.success {
      color: #1B7A3C;
    }

    .upload-message.error {
      color: #D14343;
    }

    .section-title {
      font-size: 0.85rem;
      font-weight: 700;
      color: #5A6E85;
      margin-bottom: 12px;
    }

    .photos-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 50px 0;
      color: #B0BCCB;
      text-align: center;
    }

    .empty-state i {
      font-size: 2rem;
    }
  </style>

  <script>
    import { initAdminGuard } from '../../../lib/adminGuard.js';
    import { supabase } from '../../../lib/supabase.js';

    const BUCKET = 'listing-images';
    const FOLDER = 'site/featured';

    const fileInput = document.getElementById('fileInput');
    const newPreviewWrap = document.getElementById('newPreviewWrap');
    const cropCanvas = document.getElementById('cropCanvas');
    const uploadBtn = document.getElementById('uploadBtn');
    const uploadBtnText = document.getElementById('uploadBtnText');
    const uploadMessage = document.getElementById('uploadMessage');
    const photosContainer = document.getElementById('photosContainer');
    const emptyState = document.getElementById('emptyState');

    let croppedBlob = null;
    let photos = [];

    function publicUrl(path) {
      const { data } = supabase.storage.from(BUCKET).getPublicUrl(path);
      return data.publicUrl;
    }

    fileInput.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (!file) return;

      const img = new Image();
      img.onload = () => {
        const ctx = cropCanvas.getContext('2d');
        const targetW = 1600, targetH = 900;
        const targetRatio = targetW / targetH;
        const imgRatio = img.width / img.height;

        let sx, sy, sWidth, sHeight;
        if (imgRatio > targetRatio) {
          sHeight = img.height;
          sWidth = sHeight * targetRatio;
          sx = (img.width - sWidth) / 2;
          sy = 0;
        } else {
          sWidth = img.width;
          sHeight = sWidth / targetRatio;
          sx = 0;
          sy = (img.height - sHeight) / 2;
        }

        ctx.drawImage(img, sx, sy, sWidth, sHeight, 0, 0, targetW, targetH);
        cropCanvas.toBlob((blob) => { croppedBlob = blob; }, 'image/jpeg', 0.85);

        newPreviewWrap.style.display = 'block';
        uploadMessage.textContent = '';
        uploadMessage.className = 'upload-message';
      };
      img.src = URL.createObjectURL(file);
    });

    uploadBtn.addEventListener('click', async () => {
      if (!croppedBlob) return;

      uploadBtn.disabled = true;
      uploadBtnText.textContent = 'আপলোড হচ্ছে...';

      const path = `${FOLDER}/${Date.now()}.jpg`;

      const { error: uploadError } = await supabase.storage
        .from(BUCKET)
        .upload(path, croppedBlob, { contentType: 'image/jpeg' });

      if (uploadError) {
        uploadMessage.textContent = 'আপলোড ব্যর্থ: ' + uploadError.message;
        uploadMessage.className = 'upload-message error';
        uploadBtn.disabled = false;
        uploadBtnText.textContent = 'লিস্টে যোগ করুন';
        return;
      }

      const nextOrder = photos.length > 0 ? Math.max(...photos.map((p) => p.sort_order)) + 1 : 0;

      const { error: dbError } = await supabase
        .from('featured_photos')
        .insert({ storage_path: path, sort_order: nextOrder });

      uploadBtn.disabled = false;
      uploadBtnText.textContent = 'লিস্টে যোগ করুন';

      if (dbError) {
        uploadMessage.textContent = 'সেভ ব্যর্থ: ' + dbError.message;
        uploadMessage.className = 'upload-message error';
        return;
      }

      uploadMessage.textContent = 'ছবি স্লাইডশোতে যোগ হয়েছে!';
      uploadMessage.className = 'upload-message success';
      newPreviewWrap.style.display = 'none';
      fileInput.value = '';
      croppedBlob = null;

      loadPhotos();
    });

    function renderPhotoRow(photo, index) {
      const row = document.createElement('div');
      row.style.cssText = 'background:#fff;border-radius:16px;padding:12px;box-shadow:0 4px 16px rgba(15,23,42,0.06);display:flex;align-items:center;gap:12px;';

      row.innerHTML = `
        <img src="${publicUrl(photo.storage_path)}" style="width:80px;height:45px;border-radius:10px;object-fit:cover;flex-shrink:0;" />
        <div style="flex:1;min-width:0;font-size:0.8rem;color:#8FA0BC;font-weight:600;">ক্রম #${index + 1}</div>
        <div class="row-controls" style="display:flex;gap:6px;flex-shrink:0;"></div>
      `;

      const controls = row.querySelector('.row-controls');

      const upBtn = document.createElement('button');
      upBtn.innerHTML = '<i class="fas fa-chevron-up"></i>';
      upBtn.disabled = index === 0;
      upBtn.style.cssText = `background:#F4F7FC;color:#1B2A4A;border:none;width:34px;height:34px;border-radius:10px;font-size:0.8rem;cursor:pointer;${index === 0 ? 'opacity:0.4;cursor:not-allowed;' : ''}`;
      upBtn.addEventListener('click', () => moveOrder(index, -1));

      const downBtn = document.createElement('button');
      downBtn.innerHTML = '<i class="fas fa-chevron-down"></i>';
      downBtn.disabled = index === photos.length - 1;
      downBtn.style.cssText = `background:#F4F7FC;color:#1B2A4A;border:none;width:34px;height:34px;border-radius:10px;font-size:0.8rem;cursor:pointer;${index === photos.length - 1 ? 'opacity:0.4;cursor:not-allowed;' : ''}`;
      downBtn.addEventListener('click', () => moveOrder(index, 1));

      const deleteBtn = document.createElement('button');
      deleteBtn.innerHTML = '<i class="fas fa-trash"></i>';
      deleteBtn.style.cssText = 'background:#FFF0EA;color:#D14343;border:none;width:34px;height:34px;border-radius:10px;font-size:0.8rem;cursor:pointer;';
      let confirming = false;
      deleteBtn.addEventListener('click', () => {
        if (!confirming) {
          confirming = true;
          deleteBtn.style.cssText = 'background:#D14343;color:#fff;border:none;width:34px;height:34px;border-radius:10px;font-size:0.8rem;cursor:pointer;';
          deleteBtn.innerHTML = '<i class="fas fa-check"></i>';
          return;
        }
        deletePhoto(photo);
      });

      controls.appendChild(upBtn);
      controls.appendChild(downBtn);
      controls.appendChild(deleteBtn);

      return row;
    }

    async function moveOrder(index, direction) {
      const targetIndex = index + direction;
      if (targetIndex < 0 || targetIndex >= photos.length) return;

      const current = photos[index];
      const target = photos[targetIndex];

      await Promise.all([
        supabase.from('featured_photos').update({ sort_order: target.sort_order }).eq('id', current.id),
        supabase.from('featured_photos').update({ sort_order: current.sort_order }).eq('id', target.id),
      ]);

      loadPhotos();
    }

    async function deletePhoto(photo) {
      await supabase.storage.from(BUCKET).remove([photo.storage_path]);
      await supabase.from('featured_photos').delete().eq('id', photo.id);
      loadPhotos();
    }

    async function loadPhotos() {
      photosContainer.innerHTML = '<p style="text-align:center;color:#8FA0BC;padding:20px 0;">লোড হচ্ছে...</p>';

      const { data, error } = await supabase
        .from('featured_photos')
        .select('*')
        .order('sort_order', { ascending: true });

      if (error) {
        photosContainer.innerHTML = `<p style="color:#D14343;">লোড করা যায়নি: ${error.message}</p>`;
        return;
      }

      photos = data || [];
      photosContainer.innerHTML = '';

      if (photos.length === 0) {
        emptyState.style.display = 'flex';
        return;
      }

      emptyState.style.display = 'none';
      photos.forEach((p, i) => photosContainer.appendChild(renderPhotoRow(p, i)));
    }

    window.addEventListener('smartfeni:admin-ready', () => {
      loadPhotos();
    });

    initAdminGuard();
  </script>
</BaseLayout>