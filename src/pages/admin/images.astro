---
// ============================================================
// পেজ: অ্যাডমিন — ছবি ম্যানেজমেন্ট হাব (/admin/images)
// সাইটের সব ইমেজ (ফিচার্ড ফটো, হেডার ব্যাকগ্রাউন্ড, লোগো, ক্যাটাগরি কার্ড)
// এখান থেকে ম্যানেজ করার নেভিগেশন হাব
// আপডেট: "ক্যাটাগরি কার্ড ছবি" কার্ড যোগ হয়েছে
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
---

<BaseLayout title="ছবি ম্যানেজমেন্ট | অ্যাডমিন">
  <div class="admin-page">
    <div class="container">

      <div id="adminLoadingState" class="admin-loading">
        <div class="admin-spinner"></div>
        <p>যাচাই করা হচ্ছে...</p>
      </div>

      <div id="adminGuardedContent" class="admin-content" style="display:none;">

        <a href="/admin" class="back-link"><i class="fas fa-arrow-left"></i> ড্যাশবোর্ড</a>

        <div class="admin-header">
          <h1>ছবি ম্যানেজমেন্ট</h1>
          <p class="admin-subtitle">সাইটের সব ইমেজ এখান থেকে নিয়ন্ত্রণ করুন</p>
        </div>

        <div class="images-nav-grid">
          <a href="/admin/images/featured-photo" class="images-nav-card">
            <i class="fas fa-panorama"></i>
            <h3>ফিচার্ড ফটো স্লাইডশো</h3>
            <p>হোমপেজের স্লাইডশো ছবি আপলোড, ক্রম, ডিলিট</p>
          </a>

          <a href="/admin/images/header" class="images-nav-card">
            <i class="fas fa-image"></i>
            <h3>হেডার ব্যাকগ্রাউন্ড</h3>
            <p>প্রতিটা উপজেলার জন্য আলাদা হেডার ছবি</p>
          </a>

          <a href="/admin/images/categories" class="images-nav-card">
            <i class="fas fa-grip"></i>
            <h3>ক্যাটাগরি কার্ড ছবি</h3>
            <p>হোমপেজের ১৮টা ক্যাটাগরি কার্ডের ছবি আপলোড/বদলান</p>
          </a>

          <a href="/admin/images/logo" class="images-nav-card">
            <i class="fas fa-shield-halved"></i>
            <h3>লোগো</h3>
            <p>সাইটের প্রধান লোগো বদলান</p>
          </a>
        </div>

      </div>
    </div>
  </div>

  <style>
    .admin-page {
      min-height: 60vh;
      padding: 32px 0 80px;
    }

    .admin-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .admin-spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #5A6E85;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.88rem;
      margin-bottom: 20px;
    }

    .back-link:hover {
      color: #FF6B35;
    }

    .admin-header {
      margin-bottom: 28px;
    }

    .admin-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .admin-subtitle {
      font-size: 0.85rem;
      color: #8FA0BC;
      margin-top: 4px;
      font-weight: 600;
    }

    .images-nav-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .images-nav-card {
      background: #fff;
      border-radius: 20px;
      padding: 24px;
      text-decoration: none;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
      transition: all 0.2s ease;
    }

    .images-nav-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.12);
    }

    .images-nav-card i {
      font-size: 1.5rem;
      color: #FF6B35;
      margin-bottom: 10px;
      display: block;
    }

    .images-nav-card h3 {
      font-size: 1rem;
      font-weight: 700;
      color: #1B2A4A;
      margin-bottom: 4px;
    }

    .images-nav-card p {
      font-size: 0.82rem;
      color: #5A6E85;
    }

    @media (max-width: 640px) {
      .images-nav-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    import { initAdminGuard } from '../../lib/adminGuard.js';
    initAdminGuard();
  </script>
</BaseLayout>