---
// ============================================================
// পেজ: অ্যাডমিন — ইউজার ম্যানেজমেন্ট (/admin/users)
// সব প্রোফাইল, প্রতিটার listing সংখ্যা (ক্লিক করলে expand), ব্লক/আনব্লক
// আপডেট: "স্থায়ী ডিলিট" বাটন যোগ (শুধু admin, /api/delete-user কল করে)
//         + লিস্টিং expand প্যানেলে প্রতিটা লিস্টিংয়ের পাশে ডিলিট আইকন
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
---

<BaseLayout title="ইউজার ম্যানেজমেন্ট | অ্যাডমিন">
  <div class="admin-page">
    <div class="container">

      <div id="adminLoadingState" class="admin-loading">
        <div class="admin-spinner"></div>
        <p>যাচাই করা হচ্ছে...</p>
      </div>

      <div id="adminGuardedContent" class="admin-content" style="display:none;">

        <a href="/admin" class="back-link"><i class="fas fa-arrow-left"></i> ড্যাশবোর্ড</a>

        <div class="admin-header">
          <h1>ইউজার ম্যানেজমেন্ট</h1>
          <p class="admin-subtitle" id="resultCount"></p>
        </div>

        <div class="search-bar">
          <i class="fas fa-magnifying-glass"></i>
          <input type="text" id="searchInput" placeholder="নাম বা ফোন নম্বর দিয়ে খুঁজুন" />
        </div>

        <div id="usersContainer" class="users-container"></div>

        <div id="emptyState" class="empty-state" style="display:none;">
          <i class="fas fa-user-slash"></i>
          <p>কোনো ইউজার পাওয়া যায়নি</p>
        </div>

      </div>
    </div>
  </div>

  <style>
    .admin-page {
      min-height: 60vh;
      padding: 32px 0 80px;
    }

    .admin-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .admin-spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #5A6E85;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.88rem;
      margin-bottom: 20px;
    }

    .back-link:hover {
      color: #FF6B35;
    }

    .admin-header {
      margin-bottom: 20px;
    }

    .admin-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .admin-subtitle {
      font-size: 0.85rem;
      color: #8FA0BC;
      margin-top: 4px;
      font-weight: 600;
    }

    .search-bar {
      position: relative;
      margin-bottom: 22px;
    }

    .search-bar i {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: #B0BCCB;
      font-size: 0.85rem;
    }

    .search-bar input {
      width: 100%;
      padding: 13px 16px 13px 42px;
      border-radius: 14px;
      border: 1.5px solid #E5EAF0;
      font-size: 0.9rem;
      background: #fff;
    }

    .search-bar input:focus {
      outline: none;
      border-color: #FF6B35;
    }

    .users-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 80px 0;
      color: #B0BCCB;
    }

    .empty-state i {
      font-size: 2.4rem;
    }
  </style>

  <script>
    import { initAdminGuard } from '../../lib/adminGuard.js';
    import { supabase } from '../../lib/supabase.js';
    import { categories } from '../../data/services.js';

    const categoryNameMap = Object.fromEntries(categories.map((c) => [c.id, c.name]));

    const container = document.getElementById('usersContainer');
    const emptyState = document.getElementById('emptyState');
    const resultCount = document.getElementById('resultCount');
    const searchInput = document.getElementById('searchInput');

    let allUsers = [];
    let currentUserId = null;
    let currentUserRole = null;
    let currentAccessToken = null;

    const roleLabels = {
      admin: { text: 'অ্যাডমিন', bg: '#FFF0EA', color: '#FF6B35' },
      moderator: { text: 'মডারেটর', bg: '#EAF2FF', color: '#2563EB' },
      user: { text: 'ইউজার', bg: '#F4F7FC', color: '#5A6E85' },
    };

    const listingStatusLabels = {
      pending: { text: 'রিভিউ বাকি', bg: '#FFF3E0', color: '#B36B00' },
      active: { text: 'সক্রিয়', color: '#1B7A3C', bg: '#EAFBF0' },
      rejected: { text: 'বাতিল', color: '#D14343', bg: '#FFF0EA' },
    };

    function formatDate(iso) {
      if (!iso) return '';
      const d = new Date(iso);
      return d.toLocaleDateString('bn-BD', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    // moderator target user কে ব্লক/আনব্লক করার অনুমতি রাখে কিনা
    function canManageBlock(targetUser) {
      if (currentUserRole === 'admin') return true;
      if (currentUserRole === 'moderator') return targetUser.role === 'user';
      return false;
    }

    function renderUser(user) {
      const role = roleLabels[user.role] || roleLabels.user;
      const isMe = user.id === currentUserId;

      const card = document.createElement('div');
      card.style.cssText = `background:#fff;border-radius:18px;padding:16px 18px;box-shadow:0 4px 16px rgba(15,23,42,0.06);${user.is_blocked ? 'opacity:0.6;' : ''}`;

      card.innerHTML = `
        <div style="display:flex;align-items:center;gap:14px;">
          ${user.avatar_url
            ? `<img src="${user.avatar_url}" style="width:52px;height:52px;border-radius:50%;object-fit:cover;flex-shrink:0;" />`
            : `<div style="width:52px;height:52px;border-radius:50%;background:#F4F7FC;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#B0BCCB;font-size:1.2rem;"><i class="fas fa-user"></i></div>`
          }
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              <h3 style="font-size:0.95rem;font-weight:700;color:#1B2A4A;">${user.full_name || '(নামহীন)'}</h3>
              <span style="font-size:0.7rem;font-weight:700;padding:2px 9px;border-radius:20px;background:${role.bg};color:${role.color};">${role.text}</span>
              ${isMe ? `<span style="font-size:0.7rem;font-weight:700;padding:2px 9px;border-radius:20px;background:#F4F7FC;color:#8FA0BC;">আপনি</span>` : ''}
              ${user.is_blocked ? `<span style="font-size:0.7rem;font-weight:700;padding:2px 9px;border-radius:20px;background:#FFF0EA;color:#D14343;">ব্লকড</span>` : ''}
            </div>
            <p style="font-size:0.82rem;color:#8FA0BC;margin-top:3px;">
              ${user.phone || ''}${user.upazila ? ' · ' + user.upazila : ''}${user.blood_group ? ' · ' + user.blood_group : ''}
            </p>
            <button class="listing-count-toggle" style="font-size:0.78rem;color:#5A6E85;margin-top:4px;font-weight:600;background:none;border:none;padding:0;cursor:pointer;text-align:left;">
              <i class="fas fa-list-check" style="color:#FF6B35;"></i> ${user.listingCount} টি লিস্টিং পোস্ট করেছেন
              ${user.listingCount > 0 ? '<i class="fas fa-chevron-down" style="font-size:0.65rem;margin-left:4px;"></i>' : ''}
            </button>
          </div>
          <div class="user-action" style="flex-shrink:0;display:flex;flex-direction:column;gap:6px;align-items:flex-end;"></div>
        </div>
        <div class="listing-detail-panel" style="display:none;margin-top:14px;padding-top:14px;border-top:1px solid #F0F3F8;"></div>
      `;

      const detailPanel = card.querySelector('.listing-detail-panel');
      const countToggle = card.querySelector('.listing-count-toggle');

      if (user.listingCount > 0) {
        countToggle.addEventListener('click', () => {
          const isOpen = detailPanel.style.display !== 'none';
          detailPanel.style.display = isOpen ? 'none' : 'flex';
          detailPanel.style.flexDirection = 'column';
          detailPanel.style.gap = '8px';

          if (!isOpen) {
            renderListingDetailRows(detailPanel, user);
          }
        });
      }

      const actionWrap = card.querySelector('.user-action');

      if (!isMe) {
        if (canManageBlock(user)) {
          const toggleBtn = document.createElement('button');
          let confirming = false;

          function setBtnState() {
            if (user.is_blocked) {
              toggleBtn.textContent = 'আনব্লক করুন';
              toggleBtn.style.cssText = 'background:#EAFBF0;color:#1B7A3C;border:none;padding:8px 14px;border-radius:10px;font-size:0.78rem;font-weight:700;cursor:pointer;white-space:nowrap;';
            } else {
              toggleBtn.textContent = confirming ? 'নিশ্চিত?' : 'ব্লক করুন';
              toggleBtn.style.cssText = confirming
                ? 'background:#D14343;color:#fff;border:none;padding:8px 14px;border-radius:10px;font-size:0.78rem;font-weight:700;cursor:pointer;white-space:nowrap;'
                : 'background:#FFF0EA;color:#D14343;border:none;padding:8px 14px;border-radius:10px;font-size:0.78rem;font-weight:700;cursor:pointer;white-space:nowrap;';
            }
          }

          setBtnState();

          toggleBtn.addEventListener('click', () => {
            if (user.is_blocked) {
              toggleBlock(user.id, false);
              return;
            }
            if (!confirming) {
              confirming = true;
              setBtnState();
              return;
            }
            toggleBlock(user.id, true);
          });

          actionWrap.appendChild(toggleBtn);
        } else if (currentUserRole === 'moderator' && (user.role === 'admin' || user.role === 'moderator')) {
          // moderator কে admin/moderator এর উপর অনুমতি নেই — disabled label
          const label = document.createElement('span');
          label.textContent = 'অনুমতি নেই';
          label.style.cssText = 'font-size:0.76rem;color:#B0BCCB;font-weight:600;padding:8px 12px;white-space:nowrap;';
          actionWrap.appendChild(label);
        }

        // ===== স্থায়ী ডিলিট — শুধু admin, শুধু সাধারণ ইউজারের জন্য =====
        if (currentUserRole === 'admin' && user.role === 'user') {
          const deleteBtn = document.createElement('button');
          let deleteConfirming = false;

          function setDeleteBtnState() {
            deleteBtn.textContent = deleteConfirming ? 'নিশ্চিত? (স্থায়ী)' : 'স্থায়ী ডিলিট';
            deleteBtn.style.cssText = 'background:transparent;color:#D14343;border:1.5px solid #FFD3D3;padding:8px 14px;border-radius:10px;font-size:0.78rem;font-weight:700;cursor:pointer;white-space:nowrap;';
          }

          setDeleteBtnState();

          deleteBtn.addEventListener('click', () => {
            if (!deleteConfirming) {
              deleteConfirming = true;
              setDeleteBtnState();
              return;
            }
            permanentlyDeleteUser(user.id, deleteBtn);
          });

          actionWrap.appendChild(deleteBtn);
        }
      }

      return card;
    }

    function renderListingDetailRows(detailPanel, user) {
      detailPanel.innerHTML = '';
      user.userListings.forEach((l) => {
        const st = listingStatusLabels[l.status] || listingStatusLabels.pending;
        const row = document.createElement('div');
        row.style.cssText = 'display:flex;justify-content:space-between;align-items:center;gap:8px;background:#FBFCFE;padding:10px 12px;border-radius:12px;';
        row.innerHTML = `
          <div style="min-width:0;">
            <p style="font-size:0.85rem;font-weight:700;color:#1B2A4A;">${l.title || '(শিরোনামহীন)'}</p>
            <p style="font-size:0.76rem;color:#8FA0BC;">${categoryNameMap[l.category] || l.category} · ${formatDate(l.created_at)}</p>
          </div>
          <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
            <span style="font-size:0.7rem;font-weight:700;padding:3px 9px;border-radius:20px;white-space:nowrap;background:${st.bg};color:${st.color};">${st.text}</span>
            <button class="listing-delete-btn" style="background:#FFF0EA;color:#D14343;border:none;width:28px;height:28px;border-radius:8px;font-size:0.7rem;cursor:pointer;flex-shrink:0;"><i class="fas fa-trash"></i></button>
          </div>
        `;

        const delBtn = row.querySelector('.listing-delete-btn');
        let confirming = false;
        delBtn.addEventListener('click', () => {
          if (!confirming) {
            confirming = true;
            delBtn.style.background = '#D14343';
            delBtn.style.color = '#fff';
            delBtn.innerHTML = '<i class="fas fa-check"></i>';
            return;
          }
          deleteListingFromPanel(l.id, user);
        });

        detailPanel.appendChild(row);
      });
    }

    async function deleteListingFromPanel(listingId, user) {
      const { error } = await supabase.from('listings').delete().eq('id', listingId);
      if (error) {
        alert('লিস্টিং ডিলিট ব্যর্থ: ' + error.message);
        return;
      }
      user.userListings = user.userListings.filter((l) => l.id !== listingId);
      user.listingCount = user.userListings.length;
      loadUsers();
    }

    async function permanentlyDeleteUser(userId, btnEl) {
      btnEl.textContent = 'ডিলিট হচ্ছে...';
      btnEl.disabled = true;

      const res = await fetch('/api/delete-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targetUserId: userId, accessToken: currentAccessToken }),
      });
      const result = await res.json();

      if (!res.ok) {
        alert('ডিলিট ব্যর্থ: ' + (result.error || 'অজানা ত্রুটি'));
        btnEl.textContent = 'স্থায়ী ডিলিট';
        btnEl.disabled = false;
        return;
      }

      loadUsers();
    }

    async function toggleBlock(id, blockedState) {
      const { error } = await supabase.from('profiles').update({ is_blocked: blockedState }).eq('id', id);
      if (error) {
        alert('আপডেট ব্যর্থ: ' + error.message);
        return;
      }
      loadUsers();
    }

    function renderList(users) {
      container.innerHTML = '';
      resultCount.textContent = `মোট ${users.length} জন ইউজার`;

      if (users.length === 0) {
        emptyState.style.display = 'flex';
        return;
      }
      emptyState.style.display = 'none';
      users.forEach((u) => container.appendChild(renderUser(u)));
    }

    function applySearch() {
      const q = searchInput.value.trim().toLowerCase();
      if (!q) {
        renderList(allUsers);
        return;
      }
      const filtered = allUsers.filter((u) =>
        (u.full_name || '').toLowerCase().includes(q) || (u.phone || '').includes(q)
      );
      renderList(filtered);
    }

    async function loadUsers() {
      container.innerHTML = '<p style="text-align:center;color:#8FA0BC;padding:40px 0;">লোড হচ্ছে...</p>';

      const [{ data: profiles, error: profileError }, { data: listings, error: listingError }] = await Promise.all([
        supabase.from('profiles').select('*').order('created_at', { ascending: false }),
        supabase.from('listings').select('id, user_id, title, category, status, price, upazila, created_at').order('created_at', { ascending: false }),
      ]);

      if (profileError) {
        container.innerHTML = `<p style="text-align:center;color:#D14343;padding:40px 0;">লোড করা যায়নি: ${profileError.message}</p>`;
        return;
      }

      const countMap = {};
      const listingsByUser = {};
      (listings || []).forEach((l) => {
        countMap[l.user_id] = (countMap[l.user_id] || 0) + 1;
        if (!listingsByUser[l.user_id]) listingsByUser[l.user_id] = [];
        listingsByUser[l.user_id].push(l);
      });

      allUsers = (profiles || []).map((p) => ({
        ...p,
        listingCount: countMap[p.id] || 0,
        userListings: listingsByUser[p.id] || [],
      }));
      applySearch();
    }

    searchInput.addEventListener('input', applySearch);

    window.addEventListener('smartfeni:admin-ready', (e) => {
      currentUserId = e.detail.session.user.id;
      currentUserRole = e.detail.role;
      currentAccessToken = e.detail.session.access_token;
      loadUsers();
    });

    initAdminGuard();
  </script>
</BaseLayout>