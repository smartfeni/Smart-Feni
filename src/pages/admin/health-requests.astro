---
// ============================================================
// পেজ: অ্যাডমিন — স্বাস্থ্য পরামর্শ অনুরোধ (/admin/health-requests)
// health.astro ফর্ম থেকে জমা হওয়া সব অনুরোধ এখানে লিস্ট আকারে
// দেখা যাবে, স্ট্যাটাস আপডেট করা যাবে (pending → contacted → resolved)
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
---

<BaseLayout title="স্বাস্থ্য অনুরোধ | অ্যাডমিন">
  <div class="admin-page">
    <div class="container">

      <div id="adminLoadingState" class="admin-loading">
        <div class="admin-spinner"></div>
        <p>যাচাই করা হচ্ছে...</p>
      </div>

      <div id="adminGuardedContent" class="admin-content" style="display:none;">

        <a href="/admin" class="back-link"><i class="fas fa-arrow-left"></i> ড্যাশবোর্ড</a>

        <div class="admin-header">
          <h1>স্বাস্থ্য পরামর্শ অনুরোধ</h1>
          <p class="admin-subtitle" id="resultCount">লোড হচ্ছে...</p>
        </div>

        <div class="filter-bar">
          <div class="search-bar">
            <i class="fas fa-magnifying-glass"></i>
            <input type="text" id="searchInput" placeholder="নাম বা মোবাইল নম্বর খুঁজুন" />
          </div>

          <select id="statusFilter" class="filter-select">
            <option value="">সব স্ট্যাটাস</option>
            <option value="pending">নতুন</option>
            <option value="contacted">যোগাযোগ করা হয়েছে</option>
            <option value="resolved">সমাধান হয়েছে</option>
          </select>
        </div>

        <div id="requestsContainer" class="requests-container"></div>

        <div class="empty-state" id="emptyState" style="display:none;">
          <i class="fas fa-stethoscope"></i>
          <p>কোনো অনুরোধ পাওয়া যায়নি</p>
        </div>

      </div>
    </div>
  </div>

  <style>
    .admin-page {
      min-height: 60vh;
      padding: 32px 0 80px;
    }

    .admin-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .admin-spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #5A6E85;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.88rem;
      margin-bottom: 20px;
    }

    .back-link:hover {
      color: #FF6B35;
    }

    .admin-header {
      margin-bottom: 18px;
    }

    .admin-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .admin-subtitle {
      font-size: 0.85rem;
      color: #8FA0BC;
      margin-top: 4px;
      font-weight: 600;
    }

    .filter-bar {
      display: flex;
      gap: 10px;
      margin-bottom: 22px;
      flex-wrap: wrap;
    }

    .search-bar {
      position: relative;
      flex: 1;
      min-width: 200px;
    }

    .search-bar i {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: #B0BCCB;
      font-size: 0.85rem;
    }

    .search-bar input {
      width: 100%;
      padding: 13px 16px 13px 42px;
      border-radius: 14px;
      border: 1.5px solid #E5EAF0;
      font-size: 0.9rem;
      background: #fff;
    }

    .search-bar input:focus {
      outline: none;
      border-color: #FF6B35;
    }

    .filter-select {
      padding: 12px 14px;
      border-radius: 14px;
      border: 1.5px solid #E5EAF0;
      font-size: 0.85rem;
      font-weight: 600;
      color: #1B2A4A;
      background: #fff;
      cursor: pointer;
    }

    .filter-select:focus {
      outline: none;
      border-color: #FF6B35;
    }

    .requests-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 80px 0;
      color: #B0BCCB;
    }

    .empty-state i {
      font-size: 2.4rem;
    }
  </style>

  <script>
    import { initAdminGuard } from '../../lib/adminGuard.js';
    import { supabase } from '../../lib/supabase.js';

    const container = document.getElementById('requestsContainer');
    const emptyState = document.getElementById('emptyState');
    const resultCount = document.getElementById('resultCount');
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');

    let allRequests = [];

    const statusLabels = {
      pending: { text: 'নতুন', bg: '#FFF3E0', color: '#B36B00' },
      contacted: { text: 'যোগাযোগ করা হয়েছে', bg: '#EAF2FF', color: '#2563EB' },
      resolved: { text: 'সমাধান হয়েছে', bg: '#EAFBF0', color: '#1B7A3C' },
    };

    function formatDate(iso) {
      if (!iso) return '';
      const d = new Date(iso);
      return d.toLocaleDateString('bn-BD', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
    }

    function renderRequest(req) {
      const status = statusLabels[req.status] || statusLabels.pending;

      const card = document.createElement('div');
      card.style.cssText = 'background:#fff;border-radius:18px;padding:16px 18px;box-shadow:0 4px 16px rgba(15,23,42,0.06);';

      card.innerHTML = `
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;flex-wrap:wrap;">
          <div style="min-width:0;flex:1;">
            <h3 style="font-size:0.95rem;font-weight:700;color:#1B2A4A;">${req.full_name}</h3>
            <p style="font-size:0.82rem;color:#8FA0BC;margin-top:3px;">
              <i class="fas fa-phone" style="font-size:0.72rem;"></i> ${req.mobile_number} · ${formatDate(req.created_at)}
            </p>
            <p style="font-size:0.85rem;color:#4A5B6E;margin-top:8px;line-height:1.5;">${req.problem_details}</p>
          </div>
          <a href="tel:+880${req.mobile_number.slice(1)}" data-item-name="${req.full_name}" style="background:#FF6B35;color:#fff;border:none;width:38px;height:38px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;text-decoration:none;">
            <i class="fas fa-phone"></i>
          </a>
        </div>
        <div style="display:flex;align-items:center;gap:8px;margin-top:14px;padding-top:14px;border-top:1px solid #F0F3F8;flex-wrap:wrap;">
          <span style="font-size:0.72rem;font-weight:700;padding:3px 10px;border-radius:20px;background:${status.bg};color:${status.color};margin-right:auto;">${status.text}</span>
          ${req.status !== 'contacted' ? `<button class="status-btn" data-status="contacted" style="background:#EAF2FF;color:#2563EB;border:none;padding:7px 12px;border-radius:10px;font-size:0.75rem;font-weight:700;cursor:pointer;">যোগাযোগ করা হয়েছে</button>` : ''}
          ${req.status !== 'resolved' ? `<button class="status-btn" data-status="resolved" style="background:#EAFBF0;color:#1B7A3C;border:none;padding:7px 12px;border-radius:10px;font-size:0.75rem;font-weight:700;cursor:pointer;">সমাধান হয়েছে</button>` : ''}
        </div>
      `;

      card.querySelectorAll('.status-btn').forEach((btn) => {
        btn.addEventListener('click', () => updateStatus(req.id, btn.dataset.status));
      });

      return card;
    }

    async function updateStatus(id, newStatus) {
      const { error } = await supabase.from('health_requests').update({ status: newStatus }).eq('id', id);
      if (error) {
        alert('আপডেট ব্যর্থ: ' + error.message);
        return;
      }
      loadRequests();
    }

    function renderList(requests) {
      container.innerHTML = '';
      resultCount.textContent = `মোট ${requests.length} টি অনুরোধ`;

      if (requests.length === 0) {
        emptyState.style.display = 'flex';
        return;
      }
      emptyState.style.display = 'none';
      requests.forEach((r) => container.appendChild(renderRequest(r)));
    }

    function applyFilters() {
      const q = searchInput.value.trim().toLowerCase();
      const statusVal = statusFilter.value;

      let filtered = allRequests;
      if (statusVal) {
        filtered = filtered.filter((r) => r.status === statusVal);
      }
      if (q) {
        filtered = filtered.filter((r) =>
          (r.full_name || '').toLowerCase().includes(q) || (r.mobile_number || '').includes(q)
        );
      }
      renderList(filtered);
    }

    async function loadRequests() {
      container.innerHTML = '<p style="text-align:center;color:#8FA0BC;padding:40px 0;">লোড হচ্ছে...</p>';

      const { data, error } = await supabase
        .from('health_requests')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) {
        container.innerHTML = `<p style="text-align:center;color:#D14343;padding:40px 0;">লোড করা যায়নি: ${error.message}</p>`;
        return;
      }

      allRequests = data || [];
      applyFilters();
    }

    searchInput.addEventListener('input', applyFilters);
    statusFilter.addEventListener('change', applyFilters);

    window.addEventListener('smartfeni:admin-ready', () => {
      loadRequests();
    });

    initAdminGuard();
  </script>
</BaseLayout>