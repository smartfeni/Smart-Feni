---
// ============================================================
// পেজ: ব্লাড ডোনার লিস্ট
// ব্র্যান্ড: স্মার্ট ফেনী
// যেসব ইউজার প্রোফাইলে "ব্লাড ডোনার লিস্টে দেখাও" টগল অন করেছেন,
// তাদের তালিকা এখানে দেখানো হয় (নাম, ব্লাড গ্রুপ, উপজেলা, ফোন)
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import { supabase } from '../../lib/supabase.js';

const upazilas = [
  'ফেনী সদর',
  'ছাগলনাইয়া',
  'দাগনভূঞা',
  'পরশুরাম',
  'ফুলগাজী',
  'সোনাগাজী',
];

const { data: donorData } = await supabase
  .from('profiles')
  .select('full_name, phone, blood_group, upazila, avatar_url')
  .eq('is_blood_donor', true)
  .order('created_at', { ascending: false });

const donors = donorData || [];

const filters = [{ id: 'all', label: 'সব' }, ...upazilas.map((u) => ({ id: u, label: u }))];
---

<BaseLayout title="ব্লাড ডোনার | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-droplet"></i> ব্লাড ডোনার</span>
      <h1>ফেনীর <span class="accent">রক্তদাতা</span> খুঁজুন</h1>
      <p>জরুরি প্রয়োজনে ফেনীর স্বেচ্ছাসেবী রক্তদাতাদের সাথে সরাসরি যোগাযোগ করুন</p>
    </div>
  </section>

  <section class="donor-section">
    <div class="container">
      <div class="filter-tabs" id="filterTabs">
        {filters.map((f) => (
          <button class={`filter-tab ${f.id === 'all' ? 'active' : ''}`} data-filter={f.id}>
            {f.label}
          </button>
        ))}
      </div>

      {donors.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-droplet"></i>
          <p>এখনো কোনো রক্তদাতা তালিকাভুক্ত হননি</p>
          <span>প্রোফাইল থেকে "ব্লাড ডোনার লিস্টে দেখাও" অন করে প্রথম রক্তদাতা হোন</span>
        </div>
      ) : (
        <div class="donor-grid" id="donorGrid">
          {donors.map((donor) => (
            <div class="donor-card" data-upazila={donor.upazila || ''}>
              <div class="donor-card-top">
                <span class="donor-avatar">
                  {donor.avatar_url ? (
                    <img src={donor.avatar_url} alt={donor.full_name} />
                  ) : (
                    <i class="fas fa-circle-user"></i>
                  )}
                </span>
                <span class="blood-badge">{donor.blood_group || '—'}</span>
              </div>

              <h3 class="donor-name">{donor.full_name}</h3>

              {donor.upazila && (
                <p class="donor-location"><i class="fas fa-location-dot"></i> {donor.upazila}</p>
              )}

              <a href={`tel:${donor.phone}`} class="btn-contact">
                <i class="fas fa-phone"></i> যোগাযোগ করুন
              </a>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
  }

  .donor-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .filter-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 32px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .filter-tab {
    background: #fff;
    border: 1px solid #EEF3F9;
    color: #1B2A4A;
    padding: 10px 24px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-tab:hover {
    border-color: #FF6B35;
  }

  .filter-tab.active {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .donor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }

  .donor-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .donor-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .donor-card.hidden {
    display: none;
  }

  .donor-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 14px;
  }

  .donor-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #F4F7FC;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }

  .donor-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .donor-avatar i {
    color: #B0BCCB;
    font-size: 1.7rem;
  }

  .blood-badge {
    background: #FFF0EA;
    color: #D14343;
    font-weight: 800;
    font-size: 0.95rem;
    padding: 6px 14px;
    border-radius: 12px;
    white-space: nowrap;
  }

  .donor-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 6px;
  }

  .donor-location {
    color: #5A6E85;
    font-size: 0.85rem;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .donor-location i {
    color: #FF6B35;
    font-size: 0.75rem;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FF6B35;
  }

  @media (max-width: 768px) {
    .donor-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.donor-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      const filter = tab.dataset.filter;
      cards.forEach((card) => {
        if (filter === 'all' || card.dataset.upazila === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>