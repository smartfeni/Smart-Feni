---
// ============================================================
// পেজ: রক্তদাতা সার্ভিস
// ব্র্যান্ড: স্মার্ট ফেনী
// ============================================================

import BaseLayout from '../../components/layout/BaseLayout.astro';

// TODO: ডাটাবেজ কানেক্ট হলে এখানে রেজিস্টার্ড ডোনারদের ডেটা fetch করে বসাতে হবে
// যেমন: const donors = await db.donors.findAll();
// প্রতিটা ডোনার অবজেক্টে থাকবে: { id, name, bloodGroup, address, phone }
const donors = [];
---

<BaseLayout title="রক্তদাতা সেবা | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <h1>প্রয়োজনে <span class="accent">রক্তদাতা</span> খুঁজুন</h1>
      <p>নিবন্ধিত রক্তদাতাদের তালিকা থেকে সরাসরি যোগাযোগ করুন, অথবা নিজে রক্তদাতা হিসেবে যুক্ত হোন</p>

      <a href="/contact" class="btn-register">
        <i class="fas fa-droplet"></i> রক্তদাতা হিসেবে রেজিস্ট্রেশন করুন
      </a>
    </div>
  </section>

  <section class="donor-section">
    <div class="container">
      <h2 class="section-heading">নিবন্ধিত রক্তদাতাগণ</h2>

      {donors.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">
            <i class="fas fa-droplet"></i>
          </div>
          <h3>এখনো কোনো রক্তদাতা নিবন্ধিত হয়নি</h3>
          <p>প্রথম রক্তদাতা হিসেবে নিবন্ধন করে অন্যের জীবন বাঁচাতে এগিয়ে আসুন</p>
          <a href="/contact" class="btn-register-outline">
            <i class="fas fa-plus"></i> এখনই নিবন্ধন করুন
          </a>
        </div>
      ) : (
        <div class="donor-grid">
          {donors.map((donor) => (
            <div class="donor-card">
              <div class="donor-card-top">
                <span class="blood-badge">{donor.bloodGroup}</span>
              </div>

              <h3 class="donor-name">{donor.name}</h3>

              <p class="donor-address">
                <i class="fas fa-location-dot"></i> {donor.address}
              </p>

              <a href={`tel:${donor.phone}`} class="btn-call">
                <i class="fas fa-phone"></i> {donor.phone}
              </a>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    max-width: 560px;
    margin: 0 auto 24px;
  }

  .btn-register {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 40px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .btn-register:hover {
    background: #e85a28;
    transform: translateY(-2px);
  }

  .donor-section {
    padding: 40px 0 70px;
    background: #F8FAFC;
  }

  .section-heading {
    font-size: 1.4rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 24px;
  }

  /* খালি অবস্থা */
  .empty-state {
    background: #fff;
    border: 1px dashed #DCE4EC;
    border-radius: 20px;
    padding: 60px 24px;
    text-align: center;
  }

  .empty-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    margin: 0 auto 16px;
  }

  .empty-state h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 8px;
  }

  .empty-state p {
    color: #5A6E85;
    font-size: 0.95rem;
    max-width: 400px;
    margin: 0 auto 24px;
  }

  .btn-register-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: #FF6B35;
    border: 1.5px solid #FF6B35;
    text-decoration: none;
    padding: 10px 22px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .btn-register-outline:hover {
    background: #FF6B35;
    color: #fff;
  }

  /* ডোনার কার্ড গ্রিড (ডাটাবেজ থেকে ডেটা আসলে এটা দেখাবে) */
  .donor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }

  .donor-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .donor-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .donor-card-top {
    margin-bottom: 14px;
  }

  .blood-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 48px;
    background: rgba(255, 107, 53, 0.12);
    color: #FF6B35;
    font-weight: 800;
    font-size: 1rem;
    padding: 6px 14px;
    border-radius: 12px;
  }

  .donor-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 8px;
  }

  .donor-address {
    font-size: 0.85rem;
    color: #5A6E85;
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 16px;
  }

  .donor-address i {
    color: #FF6B35;
    font-size: 0.75rem;
  }

  .btn-call {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .btn-call:hover {
    background: #FF6B35;
  }

  @media (max-width: 768px) {
    .donor-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>