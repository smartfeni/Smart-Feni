---
// ===========================================================
// পেজ: লন্ড্রি সার্ভিস
// ব্র্যান্ড: স্মার্ট ফেনী
// কার্ট সিস্টেম: প্রতিটা আইটেমে কোয়ান্টিটি বসিয়ে টোটাল বিল
// দেখাবে, তারপর নাম/ফোন/ঠিকানা দিয়ে WhatsApp-এ অর্ডার পাঠাবে
// (wa.me লিংক, কোনো ডাটাবেজ/অ্যাডমিন প্যানেল নাই, ডেমো প্রাইস লিস্ট)
// ============================================================

import BaseLayout from '../../components/layout/BaseLayout.astro';

const WHATSAPP_NUMBER = '8801816355833';

const upazilas = ['ফেনী সদর', 'ছাগলনাইয়া', 'দাগনভূঞা', 'পরশুরাম', 'ফুলগাজী', 'সোনাগাজী'];

// ডেমো প্রাইস লিস্ট — পরে বদলাতে চাইলে শুধু এই array বদলালেই চলবে
const items = [
  { id: 'shirt', name: 'শার্ট', icon: 'fa-shirt', price: 30 },
  { id: 'pant', name: 'প্যান্ট', icon: 'fa-user-tie', price: 30 },
  { id: 'panjabi', name: 'পাঞ্জাবি', icon: 'fa-vest', price: 35 },
  { id: 'threepiece', name: 'থ্রি-পিস/সালোয়ার কামিজ', icon: 'fa-person-dress', price: 65 },
  { id: 'saree', name: 'শাড়ি', icon: 'fa-person-dress', price: 60 },
  { id: 'blanket', name: 'কম্বল', icon: 'fa-bed', price: 100 },
  { id: 'bedsheet', name: 'বেডশিট', icon: 'fa-bed', price: 60 },
];
---

<BaseLayout title="লন্ড্রি সার্ভিস | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-soap"></i> লন্ড্রি সার্ভিস</span>
      <h1>ফেনীতে <span class="accent">লন্ড্রি সার্ভিস</span></h1>
      <p>ওয়াশ ও আয়রন — আপনার দরজায় পিকআপ ও ডেলিভারি। আইটেম বেছে নিন, বিল দেখুন, WhatsApp-এ অর্ডার করুন।</p>
    </div>
  </section>

  <section class="laundry-section">
    <div class="container laundry-layout">
      <!-- ===== আইটেম লিস্ট ===== -->
      <div class="items-panel">
        <h3 class="panel-title"><i class="fas fa-list"></i> আইটেম বেছে নিন</h3>

        <div class="item-list">
          {items.map((item) => (
            <div class="item-row" data-item-id={item.id} data-price={item.price} data-name={item.name}>
              <div class="item-icon"><i class={`fas ${item.icon}`}></i></div>

              <div class="item-info">
                <p class="item-name">{item.name}</p>
                <p class="item-price">৳{item.price} / টি</p>
              </div>

              <div class="qty-stepper">
                <button type="button" class="qty-btn" data-action="minus">−</button>
                <span class="qty-value" data-role="qty">0</span>
                <button type="button" class="qty-btn" data-action="plus">+</button>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ===== কার্ট + অর্ডার ফর্ম ===== -->
      <div class="cart-panel">
        <h3 class="panel-title"><i class="fas fa-cart-shopping"></i> আপনার বিল</h3>

        <div id="cartEmpty" class="cart-empty">
          <i class="fas fa-basket-shopping"></i>
          <p>এখনো কোনো আইটেম যোগ করেননি</p>
        </div>

        <div id="cartSummary" class="cart-summary" style="display:none;">
          <div class="cart-lines" id="cartLines"></div>
          <div class="cart-total-row">
            <span>মোট বিল</span>
            <span id="cartTotal">৳0</span>
          </div>
        </div>

        <div class="order-form" id="orderForm" style="display:none;">
          <label class="form-label">নাম</label>
          <input type="text" class="form-input" id="custName" placeholder="আপনার নাম" />

          <label class="form-label">ফোন নম্বর</label>
          <input type="text" class="form-input" id="custPhone" placeholder="01xxxxxxxxx" />

          <label class="form-label">উপজেলা</label>
          <select class="form-input" id="custUpazila">
            {upazilas.map((u) => <option value={u}>{u}</option>)}
          </select>

          <label class="form-label">বিস্তারিত ঠিকানা</label>
          <textarea class="form-input" id="custAddress" rows="2" placeholder="বাসা/রোড নম্বর, এলাকার নাম"></textarea>

          <label class="form-label">পিকআপের পছন্দের সময় (ঐচ্ছিক)</label>
          <input type="text" class="form-input" id="custTime" placeholder="যেমন: আজ বিকেল ৫টা" />

          <p class="form-error" id="formError"></p>

          <button class="btn-whatsapp" id="sendWhatsapp" type="button">
            <i class="fab fa-whatsapp"></i> WhatsApp-এ অর্ডার পাঠান
          </button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .section-tag {
    display: inline-block;
    background: #FFF0EA;
    color: #FF6B35;
    padding: 6px 18px;
    border-radius: 40px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #1B2A4A;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .laundry-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .laundry-layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 24px;
    align-items: start;
  }

  .items-panel,
  .cart-panel {
    background: #fff;
    border-radius: 20px;
    padding: 24px;
    border: 1px solid #EEF3F9;
  }

  .cart-panel {
    position: sticky;
    top: 20px;
  }

  .panel-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .panel-title i {
    color: #FF6B35;
  }

  .item-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .item-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px;
    border-radius: 14px;
    background: #F8FAFC;
  }

  .item-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .item-info {
    flex: 1;
    min-width: 0;
  }

  .item-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: #1B2A4A;
  }

  .item-price {
    font-size: 0.8rem;
    color: #8FA0BC;
  }

  .qty-stepper {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .qty-btn {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1.5px solid #E5EAF0;
    background: #fff;
    color: #1B2A4A;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .qty-btn:hover {
    border-color: #FF6B35;
    color: #FF6B35;
  }

  .qty-value {
    min-width: 18px;
    text-align: center;
    font-weight: 700;
    color: #1B2A4A;
  }

  .cart-empty {
    text-align: center;
    padding: 30px 10px;
  }

  .cart-empty i {
    font-size: 1.8rem;
    color: #D7E0EC;
    margin-bottom: 10px;
  }

  .cart-empty p {
    color: #8FA0BC;
    font-size: 0.88rem;
  }

  .cart-lines {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 14px;
  }

  .cart-line {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    color: #4B5A70;
  }

  .cart-total-row {
    display: flex;
    justify-content: space-between;
    font-size: 1.1rem;
    font-weight: 800;
    color: #1B2A4A;
    padding-top: 12px;
    border-top: 1px solid #EEF3F9;
  }

  .cart-total-row span:last-child {
    color: #FF6B35;
  }

  .order-form {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #EEF3F9;
  }

  .form-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: #1B2A4A;
    margin-bottom: 6px;
    margin-top: 12px;
  }

  .form-label:first-child {
    margin-top: 0;
  }

  .form-input {
    width: 100%;
    padding: 11px 14px;
    border-radius: 12px;
    border: 1.5px solid #E5EAF0;
    font-size: 0.88rem;
    font-family: inherit;
    color: #1B2A4A;
    background: #FBFCFE;
  }

  .form-input:focus {
    outline: none;
    border-color: #FF6B35;
    background: #fff;
  }

  textarea.form-input {
    resize: vertical;
  }

  .form-error {
    display: none;
    background: #FFF0EA;
    color: #D14343;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 8px 12px;
    border-radius: 10px;
    margin-top: 12px;
  }

  .form-error.show {
    display: block;
  }

  .btn-whatsapp {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #25D366;
    color: #fff;
    border: none;
    padding: 14px;
    border-radius: 40px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    margin-top: 18px;
    box-shadow: 0 10px 24px rgba(37, 211, 102, 0.3);
    transition: all 0.2s ease;
  }

  .btn-whatsapp:hover {
    background: #1EBE57;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .laundry-layout {
      grid-template-columns: 1fr;
    }

    .cart-panel {
      position: static;
    }

    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  const WHATSAPP_NUMBER = '8801816355833';

  const cart = {}; // { itemId: { name, price, qty } }

  const itemRows = document.querySelectorAll('.item-row');
  const cartEmpty = document.getElementById('cartEmpty');
  const cartSummary = document.getElementById('cartSummary');
  const cartLines = document.getElementById('cartLines');
  const cartTotal = document.getElementById('cartTotal');
  const orderForm = document.getElementById('orderForm');
  const formError = document.getElementById('formError');

  function updateCartUI() {
    const entries = Object.entries(cart).filter(([, v]) => v.qty > 0);

    if (entries.length === 0) {
      cartEmpty.style.display = 'block';
      cartSummary.style.display = 'none';
      orderForm.style.display = 'none';
      return;
    }

    cartEmpty.style.display = 'none';
    cartSummary.style.display = 'block';
    orderForm.style.display = 'block';

    let total = 0;
    cartLines.innerHTML = '';

    entries.forEach(([, v]) => {
      const lineTotal = v.qty * v.price;
      total += lineTotal;
      const line = document.createElement('div');
      line.className = 'cart-line';
      line.innerHTML = `<span>${v.name} × ${v.qty}</span><span>৳${lineTotal}</span>`;
      cartLines.appendChild(line);
    });

    cartTotal.textContent = `৳${total}`;
  }

  itemRows.forEach((row) => {
    const id = row.dataset.itemId;
    const price = Number(row.dataset.price);
    const name = row.dataset.name;
    const qtyEl = row.querySelector('[data-role="qty"]');

    cart[id] = { name, price, qty: 0 };

    row.querySelector('[data-action="plus"]').addEventListener('click', () => {
      cart[id].qty++;
      qtyEl.textContent = cart[id].qty;
      updateCartUI();
    });

    row.querySelector('[data-action="minus"]').addEventListener('click', () => {
      if (cart[id].qty > 0) cart[id].qty--;
      qtyEl.textContent = cart[id].qty;
      updateCartUI();
    });
  });

  document.getElementById('sendWhatsapp')?.addEventListener('click', () => {
    formError.classList.remove('show');

    const name = document.getElementById('custName').value.trim();
    const phone = document.getElementById('custPhone').value.trim();
    const upazila = document.getElementById('custUpazila').value;
    const address = document.getElementById('custAddress').value.trim();
    const time = document.getElementById('custTime').value.trim();

    if (!name || !phone || !address) {
      formError.textContent = 'নাম, ফোন নম্বর ও ঠিকানা আবশ্যক';
      formError.classList.add('show');
      return;
    }

    const entries = Object.entries(cart).filter(([, v]) => v.qty > 0);
    let total = 0;
    const lines = entries.map(([, v]) => {
      const lineTotal = v.qty * v.price;
      total += lineTotal;
      return `${v.name} × ${v.qty} = ৳${lineTotal}`;
    });

    const message =
      `*নতুন লন্ড্রি অর্ডার — স্মার্ট ফেনী*\n\n` +
      `নাম: ${name}\n` +
      `ফোন: ${phone}\n` +
      `উপজেলা: ${upazila}\n` +
      `ঠিকানা: ${address}\n` +
      (time ? `পিকআপ সময়: ${time}\n` : '') +
      `\nঅর্ডার তালিকা:\n${lines.join('\n')}\n\n` +
      `*মোট বিল: ৳${total}*`;

    const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
    window.open(url, '_blank');
  });
</script>