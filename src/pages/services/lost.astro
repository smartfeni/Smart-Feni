---
import BaseLayout from '../../components/layout/BaseLayout.astro';
---
<BaseLayout title="হারানো-পাওয়া সেবা">
  <div class="container" style="padding-top:60px; min-height:70vh;">
    <h1 style="font-size:2.8rem; margin-bottom:20px;">🔍 হারানো-পাওয়া সেবা</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:700px; margin-bottom:40px;">
      হারিয়ে যাওয়া জিনিস খুঁজুন, পাওয়া জিনিস রিপোর্ট করুন।
    </p>
    
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(250px,1fr)); gap:20px;">
      <div style="background:#fff; padding:20px; border-radius:16px; border:1px solid #EEE;">
        <h4>📱 হারানো ফোন</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">মিরপুর-১২, কালো রঙের</p>
        <span style="background:#EFF5FF; padding:4px 16px; border-radius:40px; font-size:0.8rem;">৩ দিন আগে</span>
      </div>
      <div style="background:#fff; padding:20px; border-radius:16px; border:1px solid #EEE;">
        <h4>🐶 পাওয়া কুকুর</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">ধানমন্ডি লেক এলাকা</p>
        <span style="background:#EFF5FF; padding:4px 16px; border-radius:40px; font-size:0.8rem;">সাদা রঙের</span>
      </div>
    </div>

    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>
  </div>
</BaseLayout>