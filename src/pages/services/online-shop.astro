---
import BaseLayout from '../../components/layout/BaseLayout.astro';

const shops = [
  {
    name: 'রাফির হোম মেড কেক',
    category: 'কেক ও বেকারি',
    icon: 'fa-cake-candles',
    color: '#FF6B35',
    bg: '#FFF0EA',
    desc: 'জন্মদিন, বিয়ে ও যেকোনো অনুষ্ঠানের জন্য কাস্টম ডিজাইনের হোম মেড কেক, কাপকেক ও কুকিজ।',
    location: 'ফেনী সদর',
    phone: '01812345678',
  },
  {
    name: 'নকশী ফ্যাশন হাউজ',
    category: 'জামা কাপড়',
    icon: 'fa-shirt',
    color: '#7C3AED',
    bg: '#F3EBFF',
    desc: 'দেশীয় থ্রি-পিস, শাড়ি ও শিশুদের পোশাক — হাতের কাজ ও পছন্দমতো সাইজে তৈরি।',
    location: 'ফেনী শহর',
    phone: '01912345678',
  },
  {
    name: 'আম্মুর রান্নাঘর',
    category: 'হোম মেড ফুড',
    icon: 'fa-bowl-food',
    color: '#16A34A',
    bg: '#E9FBF0',
    desc: 'নাগরিক ব্যস্ততায় ঘরের স্বাদ — পিঠা, নাস্তা ও স্পেশাল পদের অর্ডার নেওয়া হয় প্রতিদিন।',
    location: 'ছাগলনাইয়া',
    phone: '01712345678',
  },
  {
    name: 'ফেনী ফ্রেশ ম্যাংগো',
    category: 'আম',
    icon: 'fa-apple-whole',
    color: '#F59E0B',
    bg: '#FFF6E5',
    desc: 'সাতক্ষীরা ও চাঁপাইনবাবগঞ্জ থেকে সরাসরি রাসায়নিকমুক্ত পাকা আম, পাইকারি ও খুচরা দুই দামেই।',
    location: 'সোনাগাজী',
    phone: '01612345678',
  },
  {
    name: 'খাঁটি মধু ঘর',
    category: 'মধু',
    icon: 'fa-jar',
    color: '#B45309',
    bg: '#FFF1DC',
    desc: 'সুন্দরবন ও সরিষা ফুলের ১০০% খাঁটি মধু, ল্যাব টেস্টেড ও ভেজালমুক্ত নিশ্চয়তাসহ।',
    location: 'দাগনভূঞা',
    phone: '01512345678',
  },
  {
    name: 'বাড়ির আচার ভান্ডার',
    category: 'আচার ও মুখরোচক',
    icon: 'fa-pepper-hot',
    color: '#DC2626',
    bg: '#FFEAEA',
    desc: 'আম, তেঁতুল, মরিচ ও মিক্সড আচার — একদম বাসার রেসিপিতে তৈরি, প্রিজারভেটিভ ছাড়া।',
    location: 'পরশুরাম',
    phone: '01312345678',
  },
];
---
<BaseLayout title="অনলাইন শপ | স্মার্ট ফেনী">
  <div class="container" style="padding-top:60px; min-height:70vh; padding-bottom:60px;">

    <h1 style="font-size:2.8rem; margin-bottom:16px;">🛍️ অনলাইন শপ</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:750px; margin-bottom:8px;">
      ফেনীর হোম মেড উদ্যোক্তাদের এক ঠিকানা। কেক, জামা কাপড়, ঘরে তৈরি খাবার, আম, মধু কিংবা আচার —
      যা প্রয়োজন, নিচের কার্ড থেকে বিক্রেতার সাথে সরাসরি যোগাযোগ করে অর্ডার করুন, পৌঁছে যাবে হোম ডেলিভারিতে।
    </p>

    <div style="display:flex; flex-wrap:wrap; gap:12px; margin:24px 0 40px;">
      <span style="background:#FFF0EA; color:#FF6B35; padding:8px 20px; border-radius:40px; font-weight:600; font-size:0.9rem;">
        <i class="fas fa-user-check"></i> যাচাইকৃত স্থানীয় বিক্রেতা
      </span>
      <span style="background:#EFF5FF; color:#1B2A4A; padding:8px 20px; border-radius:40px; font-weight:600; font-size:0.9rem;">
        <i class="fas fa-house"></i> সবই হোম মেড পণ্য
      </span>
      <span style="background:#EAFBF0; color:#1B7A3C; padding:8px 20px; border-radius:40px; font-weight:600; font-size:0.9rem;">
        <i class="fas fa-truck"></i> হোম ডেলিভারি সুবিধা
      </span>
    </div>

    <!-- শপ কার্ডসমূহ -->
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px,1fr)); gap:24px; margin-bottom:48px;">
      {shops.map((shop) => (
        <div style="background:#fff; padding:24px; border-radius:20px; box-shadow:0 4px 16px rgba(0,0,0,0.04); border:1px solid #EEE; display:flex; flex-direction:column;">
          <div style={`width:48px; height:48px; background:${shop.bg}; border-radius:14px; display:flex; align-items:center; justify-content:center; margin-bottom:16px;`}>
            <i class={`fas ${shop.icon}`} style={`color:${shop.color}; font-size:1.3rem;`}></i>
          </div>
          <span style={`display:inline-block; width:fit-content; background:${shop.bg}; color:${shop.color}; padding:3px 14px; border-radius:40px; font-size:0.78rem; font-weight:600; margin-bottom:10px;`}>
            {shop.category}
          </span>
          <h3 style="margin-bottom:8px;">{shop.name}</h3>
          <p style="color:#5A6E85; font-size:0.92rem; margin-bottom:12px; flex-grow:1;">{shop.desc}</p>
          <p style="color:#8FA0BC; font-size:0.85rem; margin-bottom:16px;">
            <i class="fas fa-location-dot"></i> {shop.location}
          </p>
          <a href={`tel:+880${shop.phone.slice(1)}`} class="btn-outline" style="justify-content:center; padding:10px 20px; font-size:0.9rem;">
            <i class="fas fa-phone"></i> যোগাযোগ করুন
          </a>
        </div>
      ))}
    </div>

    <!-- বিক্রেতা হতে চাইলে -->
    <div style="background:#1B2A4A; color:#fff; padding:36px; border-radius:24px; max-width:800px;">
      <h3 style="margin-bottom:10px;">🏪 আপনিও কি বিক্রেতা হতে চান?</h3>
      <p style="color:#C9D4E3; margin-bottom:20px;">আপনার হোম মেড পণ্য (কেক, কাপড়, খাবার, আম, মধু বা অন্য কিছু) স্মার্ট ফেনীতে তালিকাভুক্ত করতে যোগাযোগ করুন।</p>
      <a href="tel:+8801812345678" class="btn-primary" style="background:#FF6B35;">
        <i class="fas fa-phone"></i> ০১৮১২-৩৪৫৬৭৮
      </a>
      <p style="color:#8FA0BC; font-size:0.85rem; margin-top:14px;">* এটি একটি নমুনা নম্বর, চূড়ান্ত যোগাযোগ নম্বর শীঘ্রই যুক্ত করা হবে।</p>
    </div>

    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>

  </div>
</BaseLayout>