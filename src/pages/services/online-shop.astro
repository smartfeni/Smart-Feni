---
// ============================================================
// পেজ: অনলাইন শপ (মাল্টি-ভেন্ডর মার্কেটপ্লেস)
// ব্র্যান্ড: স্মার্ট ফেনী
// প্রতিটা প্রোডাক্টের সাথে শপের নাম দেখানো হয় (profiles জয়েন করে)
// শুধু shop_active=true এমন শপের প্রোডাক্ট দেখানো হয়
// ছবি ফ্রেমিং: aspect-ratio 4/3, object-fit contain (শেয়ারড ডিটেইল
// মোডাল সিস্টেমের সাথে সামঞ্জস্যপূর্ণ)
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import ListingDetailModal from '../../components/ui/ListingDetailModal.astro';
import { supabase } from '../../lib/supabase.js';

const { data: productListings, error: listingsError } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'online-shop')
  .eq('status', 'active')
  .order('created_at', { ascending: false });

if (listingsError) {
  console.error('online-shop listings fetch error:', listingsError.message);
}

const rawProducts = productListings || [];

// সেই সব প্রোডাক্টের ওউনার আইডি নিয়ে profiles থেকে শপের তথ্য আনা হচ্ছে
const ownerIds = [...new Set(rawProducts.map((p) => p.user_id))];

let shopMap = {};
if (ownerIds.length > 0) {
  const { data: shopProfiles, error: profilesError } = await supabase
    .from('profiles')
    .select('id, shop_name, shop_active, shop_order')
    .in('id', ownerIds);

  if (profilesError) {
    console.error('online-shop profiles fetch error:', profilesError.message);
  }

  (shopProfiles || []).forEach((s) => {
    shopMap[s.id] = s;
  });
}

// শুধু সক্রিয় শপের প্রোডাক্ট রাখা হচ্ছে, আর শপের নাম যোগ করা হচ্ছে
const listings = rawProducts
  .filter((p) => shopMap[p.user_id]?.shop_active !== false)
  .map((p) => ({
    ...p,
    shopName: shopMap[p.user_id]?.shop_name || 'অনলাইন শপ',
    shopOrder: shopMap[p.user_id]?.shop_order ?? 0,
  }))
  .sort((a, b) => a.shopOrder - b.shopOrder);
---

<BaseLayout title="অনলাইন শপ | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-store"></i> অনলাইন শপ</span>
      <h1>ফেনীর <span class="accent">অনলাইন বাজার</span></h1>
      <p>নিবন্ধিত শপ থেকে পণ্য দেখুন, পছন্দ হলে সরাসরি কল করে অর্ডার করুন</p>
    </div>
  </section>

  <section class="shop-section">
    <div class="container">
      <div class="search-box">
        <i class="fas fa-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="প্রোডাক্ট বা শপের নাম খুঁজুন..." />
      </div>

      {listings.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-store-slash"></i>
          <p>এখনো কোনো প্রোডাক্ট যোগ হয়নি</p>
          <span>নিবন্ধিত শপগুলো শীঘ্রই তাদের প্রোডাক্ট যোগ করবে</span>
        </div>
      ) : (
        <>
          <div class="shop-grid" id="shopGrid">
            {listings.map((item, i) => (
              <button
                type="button"
                class="shop-card"
                data-detail-index={i}
                data-search={`${item.title || ''} ${item.description || ''} ${item.shopName || ''}`.toLowerCase()}
              >
                {item.images && item.images.length > 0 ? (
                  <img src={item.images[0]} alt={item.title} class="shop-photo" />
                ) : (
                  <div class="shop-icon">
                    <i class="fas fa-box"></i>
                  </div>
                )}

                <div class="shop-card-body">
                  <span class="shop-badge"><i class="fas fa-store"></i> {item.shopName}</span>
                  <h3 class="shop-title">{item.title}</h3>
                  {item.price && <p class="shop-price">৳{item.price}</p>}
                  {item.upazila && <p class="location-tag"><i class="fas fa-location-dot"></i> {item.upazila}</p>}
                </div>
              </button>
            ))}
          </div>

          <p class="no-results" id="noResults" style="display:none;">কোনো ফলাফল পাওয়া যায়নি</p>
        </>
      )}
    </div>
  </section>

  <ListingDetailModal />

  <script type="application/json" id="listingsData" set:html={JSON.stringify(listings)} />
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    margin-bottom: 20px;
  }

  .shop-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .search-box {
    max-width: 480px;
    margin: 0 auto 32px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 40px;
    padding: 12px 20px;
  }

  .search-box i {
    color: #A0AFC0;
  }

  .search-box input {
    border: none;
    outline: none;
    flex: 1;
    font-size: 0.9rem;
    font-family: inherit;
    background: transparent;
    color: #1B2A4A;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .shop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }

  .shop-card {
    background: #fff;
    border-radius: 18px;
    border: 1px solid #EEF3F9;
    padding: 0;
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .shop-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .shop-card.hidden {
    display: none;
  }

  .shop-icon {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }

  .shop-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: contain;
    object-position: center;
    display: block;
    background: #F4F7FC;
  }

  .shop-card-body {
    padding: 14px;
  }

  .shop-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 6px;
    background: #F4F7FC;
    color: #5A6E85;
  }

  .shop-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .shop-price {
    font-size: 0.95rem;
    font-weight: 700;
    color: #FF6B35;
    margin-bottom: 4px;
  }

  .location-tag {
    font-size: 0.72rem;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .no-results {
    text-align: center;
    color: #A0AFC0;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  import { initListingDetailModal } from '../../lib/listingDetailModal.js';

  const dataEl = document.getElementById('listingsData');
  const listings = dataEl ? JSON.parse(dataEl.textContent) : [];

  const cards = document.querySelectorAll('.shop-card');
  const searchInput = document.getElementById('searchInput');
  const noResults = document.getElementById('noResults');

  searchInput?.addEventListener('input', () => {
    const keyword = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches = keyword === '' || (card.dataset.search || '').includes(keyword);
      if (matches) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }
  });

  // ডিটেইলস মডাল (শেয়ারড লজিক)
  initListingDetailModal({
    listings,
    typeNameMap: {},
    typeIcons: {},
    cardSelector: '.shop-card',
  });
</script>