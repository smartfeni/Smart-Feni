---
// ============================================================
// পেজ: বাসা ভাড়া সার্ভিস
// ব্র্যান্ড: স্মার্ট ফেনী
// ============================================================

import BaseLayout from '../../components/layout/BaseLayout.astro';

// প্লেসহোল্ডার ডেটা — পরে ডাটাবেজ থেকে আসবে, আপাতত mock ডেটা দিয়ে UI সাজানো হচ্ছে
const listings = [
  { id: 1, type: 'flat', typeName: 'ফ্ল্যাট', title: '৩ বেডরুম ফ্ল্যাট', bedrooms: 3, area: 1250, rent: 15000, upazila: 'ফেনী সদর', owner: 'রফিকুল ইসলাম', rating: 4.8 },
  { id: 2, type: 'house', typeName: 'বাসা', title: '২ তলা টিনশেড বাসা', bedrooms: 4, area: 1800, rent: 12000, upazila: 'ছাগলনাইয়া', owner: 'কামাল হোসেন', rating: 4.6 },
  { id: 3, type: 'mess', typeName: 'মেস', title: 'ছাত্র মেস (সিট ভাড়া)', bedrooms: 1, area: 150, rent: 2500, upazila: 'দাগনভূঞা', owner: 'আব্দুল করিম', rating: 4.3 },
  { id: 4, type: 'flat', typeName: 'ফ্ল্যাট', title: '২ বেডরুম অ্যাপার্টমেন্ট', bedrooms: 2, area: 900, rent: 9000, upazila: 'পরশুরাম', owner: 'শাহাদাত হোসেন', rating: 4.9 },
  { id: 5, type: 'shop', typeName: 'দোকান-অফিস', title: 'রাস্তার পাশে দোকান', bedrooms: 0, area: 200, rent: 6000, upazila: 'ফুলগাজী', owner: 'জসিম উদ্দিন', rating: 4.5 },
  { id: 6, type: 'house', typeName: 'বাসা', title: '১ তলা পাকা বাসা', bedrooms: 3, area: 1400, rent: 10000, upazila: 'সোনাগাজী', owner: 'নুরুল আমিন', rating: 4.2 },
];
---

<BaseLayout title="বাসা ভাড়া সার্ভিস | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-house"></i> আবাসন সেবা</span>
      <h1>ফেনীতে <span class="accent">বাসা ভাড়া</span> খুঁজুন</h1>
      <p>ফ্ল্যাট, বাসা, মেস ও দোকান — নির্ভরযোগ্য মালিকদের কাছ থেকে সরাসরি</p>

      <a href="/contact" class="btn-post-ad">
        <i class="fas fa-plus"></i> বাসা ভাড়ার বিজ্ঞাপন দিন
      </a>
    </div>
  </section>

  <section class="housing-section">
    <div class="container">
      <div class="housing-grid">
        {listings.map((item) => (
          <div class="housing-card">
            <div class="housing-card-top">
              <span class={`type-badge type-${item.type}`}>{item.typeName}</span>
              <span class="location-tag">
                <i class="fas fa-location-dot"></i> {item.upazila}
              </span>
            </div>

            <div class="housing-icon">
              <i class={`fas ${item.type === 'shop' ? 'fa-store' : item.type === 'mess' ? 'fa-bed' : 'fa-house'}`}></i>
            </div>

            <h3 class="housing-title">{item.title}</h3>

            <div class="housing-meta">
              {item.bedrooms > 0 && (
                <span class="meta-item"><i class="fas fa-bed"></i> {item.bedrooms} বেড</span>
              )}
              <span class="meta-item"><i class="fas fa-vector-square"></i> {item.area} বর্গফুট</span>
            </div>

            <p class="rent-amount">৳{item.rent.toLocaleString('bn-BD')} <span>/ মাস</span></p>

            <div class="owner-row">
              <div class="owner-avatar">{item.owner.charAt(0)}</div>
              <div class="owner-info">
                <p class="owner-name">{item.owner}</p>
                <div class="rating">
                  <i class="fas fa-star"></i>
                  <span>{item.rating}</span>
                </div>
              </div>
            </div>

            <a href="/contact" class="btn-contact">
              <i class="fas fa-phone"></i> যোগাযোগ করুন
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    margin-bottom: 24px;
  }

  .btn-post-ad {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 40px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .btn-post-ad:hover {
    background: #e85a28;
    transform: translateY(-2px);
  }

  .housing-section {
    padding: 40px 0 70px;
    background: #F8FAFC;
  }

  .housing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .housing-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .housing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .housing-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .type-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
  }

  .type-flat {
    background: rgba(9, 132, 227, 0.12);
    color: #0984E3;
  }

  .type-house {
    background: rgba(0, 184, 148, 0.12);
    color: #00B894;
  }

  .type-mess {
    background: rgba(108, 92, 231, 0.12);
    color: #6C5CE7;
  }

  .type-shop {
    background: rgba(253, 203, 110, 0.18);
    color: #B7791F;
  }

  .location-tag {
    font-size: 0.75rem;
    color: #7A8EA5;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .housing-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 12px;
  }

  .housing-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .housing-meta {
    display: flex;
    gap: 14px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .meta-item {
    font-size: 0.8rem;
    color: #5A6E85;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .meta-item i {
    color: #FF6B35;
    font-size: 0.75rem;
  }

  .rent-amount {
    font-size: 1.3rem;
    font-weight: 700;
    color: #FF6B35;
    margin-bottom: 16px;
  }

  .rent-amount span {
    font-size: 0.8rem;
    font-weight: 500;
    color: #A0AFC0;
  }

  .owner-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    padding-top: 14px;
    border-top: 1px solid #EEF3F9;
  }

  .owner-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #1B2A4A;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .owner-name {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .rating {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    color: #5A6E85;
  }

  .rating i {
    color: #FDCB6E;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FF6B35;
  }

  @media (max-width: 768px) {
    .housing-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>