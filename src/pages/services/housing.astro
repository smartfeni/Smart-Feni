---
// ============================================================
// পেজ: বাসা ভাড়া সার্ভিস
// ব্র্যান্ড: স্মার্ট ফেনী
// recycle প্যাটার্ন: হেডার CTA, সার্চ বক্স, কম্প্যাক্ট কার্ড,
// শেয়ারড ডিটেইলস মডাল, লোকেশন সর্ট
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AddListingModal from '../../components/ui/AddListingModal.astro';
import ListingDetailModal from '../../components/ui/ListingDetailModal.astro';
import { supabase } from '../../lib/supabase.js';

const typeOptions = [
  { id: 'flat', label: 'ফ্ল্যাট' },
  { id: 'house', label: 'বাসা' },
  { id: 'mess', label: 'মেস' },
  { id: 'shop', label: 'দোকান-অফিস' },
];

const typeNameMap = Object.fromEntries(typeOptions.map((t) => [t.id, t.label]));

const typeIcons = {
  flat: 'fa-building',
  house: 'fa-house',
  mess: 'fa-bed',
  shop: 'fa-store',
};

const { data: houses } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'housing')
  .eq('status', 'active')
  .order('created_at', { ascending: false });

const listings = houses || [];
---

<BaseLayout title="বাসা ভাড়া সার্ভিস | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-house"></i> আবাসন সেবা</span>
      <h1>ফেনীতে <span class="accent">বাসা ভাড়া</span> খুঁজুন</h1>
      <p>ফ্ল্যাট, বাসা, মেস ও দোকান — নির্ভরযোগ্য মালিকদের কাছ থেকে সরাসরি</p>
      <button class="cta-box" id="openAddListing" type="button">
        <i class="fas fa-plus"></i> ভাড়া দেওয়ার মতো বাসা/ফ্ল্যাট আছে? লিস্টিং দিন
      </button>
    </div>
  </section>

  <section class="housing-section">
    <div class="container">
      <div class="search-box">
        <i class="fas fa-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="ফ্ল্যাট, মেস বা যেকোনো এলাকা খুঁজুন..." />
      </div>

      {listings.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-house-circle-xmark"></i>
          <p>এখনো কোনো বাসা ভাড়ার লিস্টিং যোগ হয়নি</p>
          <span>প্রথম লিস্টিং যোগ করুন উপরের বাটনে ক্লিক করে</span>
        </div>
      ) : (
        <>
          <div class="housing-grid" id="housingGrid">
            {listings.map((item, i) => (
              <button
                type="button"
                class="housing-card"
                data-detail-index={i}
                data-upazila-name={item.upazila || ''}
                data-search={`${item.title || ''} ${item.description || ''} ${typeNameMap[item.type] || ''}`.toLowerCase()}
              >
                {item.images && item.images.length > 0 ? (
                  <img src={item.images[0]} alt={item.title} class="housing-photo" />
                ) : (
                  <div class="housing-icon">
                    <i class={`fas ${typeIcons[item.type] || 'fa-house'}`}></i>
                  </div>
                )}

                <div class="housing-card-body">
                  <span class="type-badge">{typeNameMap[item.type] || item.type}</span>
                  <h3 class="housing-title">{item.title}</h3>
                  {item.price && <p class="housing-price">৳{item.price}</p>}
                  <p class="location-tag"><i class="fas fa-location-dot"></i> {item.upazila}</p>
                </div>
              </button>
            ))}
          </div>

          <p class="no-results" id="noResults" style="display:none;">কোনো ফলাফল পাওয়া যায়নি</p>
        </>
      )}
    </div>
  </section>

  <ListingDetailModal />
  <AddListingModal category="housing" typeOptions={typeOptions} />

  <script type="application/json" id="listingsData" set:html={JSON.stringify(listings)} />
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    margin-bottom: 20px;
  }

  .cta-box {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFF0EA;
    border: 1.5px solid #FFD3BC;
    color: #FF6B35;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 12px 26px;
    border-radius: 40px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cta-box:hover {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
    transform: translateY(-2px);
  }

  .housing-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .search-box {
    max-width: 480px;
    margin: 0 auto 32px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 40px;
    padding: 12px 20px;
  }

  .search-box i {
    color: #A0AFC0;
  }

  .search-box input {
    border: none;
    outline: none;
    flex: 1;
    font-size: 0.9rem;
    font-family: inherit;
    background: transparent;
    color: #1B2A4A;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .housing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }

  .housing-card {
    background: #fff;
    border-radius: 18px;
    border: 1px solid #EEF3F9;
    padding: 0;
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .housing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .housing-card.hidden {
    display: none;
  }

  .housing-icon {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }

  .housing-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .housing-card-body {
    padding: 14px;
  }

  .type-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 6px;
    background: #F4F7FC;
    color: #5A6E85;
  }

  .housing-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .housing-price {
    font-size: 0.95rem;
    font-weight: 700;
    color: #FF6B35;
    margin-bottom: 4px;
  }

  .location-tag {
    font-size: 0.72rem;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .no-results {
    text-align: center;
    color: #A0AFC0;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  import { initListingDetailModal } from '../../lib/listingDetailModal.js';
  import { reorderByUserLocation } from '../../lib/locationSort.js';

  const typeNameMap = {
    flat: 'ফ্ল্যাট',
    house: 'বাসা',
    mess: 'মেস',
    shop: 'দোকান-অফিস',
  };

  const typeIcons = {
    flat: 'fa-building',
    house: 'fa-house',
    mess: 'fa-bed',
    shop: 'fa-store',
  };

  const dataEl = document.getElementById('listingsData');
  const listings = dataEl ? JSON.parse(dataEl.textContent) : [];

  const grid = document.getElementById('housingGrid');
  const cards = document.querySelectorAll('.housing-card');
  const searchInput = document.getElementById('searchInput');
  const noResults = document.getElementById('noResults');

  searchInput?.addEventListener('input', () => {
    const keyword = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches = keyword === '' || (card.dataset.search || '').includes(keyword);
      if (matches) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }
  });

  initListingDetailModal({ listings, typeNameMap, typeIcons, cardSelector: '.housing-card' });
  reorderByUserLocation(grid, 'upazilaName');
</script>