---
// ============================================================
// পেজ: বাসা ভাড়া সার্ভিস
// ব্র্যান্ড: স্মার্ট ফেনী
// Supabase থেকে রিয়েল লিস্টিং ডেটা fetch করা হয় (mock ডেটা বাদ)
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AddListingModal from '../../components/ui/AddListingModal.astro';
import { supabase } from '../../lib/supabase.js';

const typeOptions = [
  { id: 'flat', label: 'ফ্ল্যাট' },
  { id: 'house', label: 'বাসা' },
  { id: 'mess', label: 'মেস' },
  { id: 'shop', label: 'দোকান-অফিস' },
];

const typeNameMap = Object.fromEntries(typeOptions.map((t) => [t.id, t.label]));

const typeIcons = {
  flat: 'fa-building',
  house: 'fa-house',
  mess: 'fa-bed',
  shop: 'fa-store',
};

const { data: houses } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'housing')
  .eq('status', 'active')
  .order('created_at', { ascending: false });

const listings = houses || [];

const filters = [{ id: 'all', label: 'সব' }, ...typeOptions];
---

<BaseLayout title="বাসা ভাড়া সার্ভিস | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-house"></i> আবাসন সেবা</span>
      <h1>ফেনীতে <span class="accent">বাসা ভাড়া</span> খুঁজুন</h1>
      <p>ফ্ল্যাট, বাসা, মেস ও দোকান — নির্ভরযোগ্য মালিকদের কাছ থেকে সরাসরি</p>
    </div>
  </section>

  <section class="housing-section">
    <div class="container">
      <div class="filter-tabs" id="filterTabs">
        {filters.map((f) => (
          <button class={`filter-tab ${f.id === 'all' ? 'active' : ''}`} data-filter={f.id}>
            {f.label}
          </button>
        ))}
      </div>

      {listings.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-house-circle-xmark"></i>
          <p>এখনো কোনো বাসা ভাড়ার লিস্টিং যোগ হয়নি</p>
          <span>প্রথম লিস্টিং যোগ করুন নিচের বাটনে ক্লিক করে</span>
        </div>
      ) : (
        <div class="housing-grid" id="housingGrid">
          {listings.map((item) => (
            <div class="housing-card" data-type={item.type}>
              <div class="housing-card-top">
                <span class={`type-badge type-${item.type}`}>{typeNameMap[item.type] || item.type}</span>
                <span class="location-tag">
                  <i class="fas fa-location-dot"></i> {item.upazila}
                </span>
              </div>

              {item.images && item.images.length > 0 ? (
                <img src={item.images[0]} alt={item.title} class="housing-photo" />
              ) : (
                <div class="housing-icon">
                  <i class={`fas ${typeIcons[item.type] || 'fa-house'}`}></i>
                </div>
              )}

              <h3 class="housing-title">{item.title}</h3>
              {item.description && <p class="housing-desc">{item.description}</p>}
              {item.price && (
                <p class="housing-price"><i class="fas fa-coins"></i> {item.price}</p>
              )}

              <a href={`tel:${item.contact_phone}`} class="btn-contact">
                <i class="fas fa-phone"></i> যোগাযোগ করুন
              </a>
            </div>
          ))}
        </div>
      )}

      <div class="provider-cta">
        <div class="provider-cta-text">
          <h3><i class="fas fa-bullhorn"></i> আপনার কাছে ভাড়া দেওয়ার মতো বাসা/ফ্ল্যাট আছে?</h3>
          <p>বাড়িওয়ালা হিসেবে বিনামূল্যে লিস্টিং দিন</p>
        </div>
        <button class="provider-cta-btn" id="openAddListing" type="button">
          <i class="fas fa-plus"></i> লিস্টিং যোগ করুন
        </button>
      </div>
    </div>
  </section>

  <AddListingModal category="housing" typeOptions={typeOptions} />
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
  }

  .housing-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .filter-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 32px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .filter-tab {
    background: #fff;
    border: 1px solid #EEF3F9;
    color: #1B2A4A;
    padding: 10px 24px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-tab:hover {
    border-color: #FF6B35;
  }

  .filter-tab.active {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .housing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .housing-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .housing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .housing-card.hidden {
    display: none;
  }

  .housing-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    gap: 8px;
  }

  .type-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .type-flat {
    background: rgba(9, 132, 227, 0.12);
    color: #0984E3;
  }

  .type-house {
    background: rgba(0, 184, 148, 0.12);
    color: #00B894;
  }

  .type-mess {
    background: rgba(108, 92, 231, 0.12);
    color: #6C5CE7;
  }

  .type-shop {
    background: rgba(253, 203, 110, 0.18);
    color: #B7791F;
  }

  .location-tag {
    font-size: 0.75rem;
    color: #7A8EA5;
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  .housing-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 12px;
  }

  .housing-photo {
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: 14px;
    margin-bottom: 12px;
  }

  .housing-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .housing-desc {
    color: #5A6E85;
    font-size: 0.85rem;
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .housing-price {
    color: #FF6B35;
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 16px;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FF6B35;
  }

  .provider-cta {
    margin-top: 50px;
    background: #1B2A4A;
    border-radius: 24px;
    padding: 36px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .provider-cta-text h3 {
    color: #fff;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .provider-cta-text h3 i {
    color: #FF6B35;
  }

  .provider-cta-text p {
    color: #C4CEDD;
    font-size: 0.9rem;
  }

  .provider-cta-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #FF6B35;
    color: #fff;
    border: none;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 40px;
    font-weight: 700;
    font-size: 1rem;
    white-space: nowrap;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .provider-cta-btn:hover {
    background: #e85a2a;
  }

  @media (max-width: 768px) {
    .housing-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .page-header h1 {
      font-size: 1.7rem;
    }

    .provider-cta {
      flex-direction: column;
      text-align: center;
      padding: 28px 24px;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.housing-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      const filter = tab.dataset.filter;
      cards.forEach((card) => {
        if (filter === 'all' || card.dataset.type === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });

  document.getElementById('openAddListing')?.addEventListener('click', () => {
    window.openListingModal?.();
  });
</script>