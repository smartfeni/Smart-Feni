---
// ============================================================
// পেজ: ডেলিভারি হিরো (কুরিয়ার/রাইডার সার্ভিস)
// ব্র্যান্ড: স্মার্ট ফেনী
// Supabase থেকে রিয়েল রাইডার ডেটা fetch করা হয় (mock ডেটা বাদ)
// শুধু is_online=true এবং status='active' রাইডাররাই দেখানো হয়
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AddListingModal from '../../components/ui/AddListingModal.astro';
import { supabase } from '../../lib/supabase.js';

const upazilas = ['ফেনী সদর', 'ছাগলনাইয়া', 'দাগনভূঞা', 'পরশুরাম', 'ফুলগাজী', 'সোনাগাজী'];

const typeOptions = [{ id: 'rider', label: 'ডেলিভারি রাইডার' }];

const { data: riderListings } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'courier')
  .eq('status', 'active')
  .eq('is_online', true)
  .order('created_at', { ascending: false });

const riders = riderListings || [];

const filters = [{ id: 'সব', label: 'সব উপজেলা' }, ...upazilas.map((u) => ({ id: u, label: u }))];
---

<BaseLayout title="ডেলিভারি হিরো | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-motorcycle"></i> ডেলিভারি সার্ভিস</span>
      <h1>ফেনীর <span class="accent">ডেলিভারি হিরো</span></h1>
      <p>মোটরসাইকেল-চালিত ফ্রিল্যান্স রাইডার — সরাসরি কল করে ডেলিভারি রেট ঠিক করুন</p>
      <button class="post-rider-link" id="openCourierCta" type="button">
        <i class="fas fa-plus"></i> রাইডার হিসেবে যুক্ত হতে চান?
      </button>
    </div>
  </section>

  <section class="courier-section">
    <div class="container">
      <div class="filter-tabs" id="filterTabs">
        {filters.map((f) => (
          <button class={`filter-tab ${f.id === 'সব' ? 'active' : ''}`} data-filter={f.id}>
            {f.label}
          </button>
        ))}
      </div>

      {riders.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-motorcycle"></i>
          <p>এই মুহূর্তে কোনো রাইডার অনলাইনে নেই</p>
          <span>একটু পর আবার চেষ্টা করুন</span>
        </div>
      ) : (
        <div class="rider-grid" id="riderGrid">
          {riders.map((rider) => (
            <div class="rider-card" data-upazila={rider.upazila}>
              <div class="rider-card-top">
                <span class="online-badge">
                  <i class="fas fa-circle"></i> অনলাইন
                </span>
                <span class="location-tag">
                  <i class="fas fa-location-dot"></i> {rider.upazila}
                </span>
              </div>

              <div class="rider-icon">
                <i class="fas fa-motorcycle"></i>
              </div>

              <h3 class="rider-name">{rider.title}</h3>
              {rider.price && <p class="rider-vehicle"><i class="fas fa-motorcycle"></i> {rider.price}</p>}
              {rider.description && <p class="rider-desc">{rider.description}</p>}

              <a href={`tel:${rider.contact_phone}`} class="btn-contact">
                <i class="fas fa-phone"></i> কল করুন
              </a>
            </div>
          ))}
        </div>
      )}

      <div class="cta-card">
        <i class="fas fa-headset"></i>
        <p>রাইডার হিসেবে নিবন্ধন করতে স্মার্ট ফেনী কাস্টমার কেয়ারে যোগাযোগ করুন: <a href="tel:+8801816355833">০১৮১৬৩৫৫৮৩৩</a></p>
      </div>
    </div>
  </section>

  <AddListingModal
    category="courier"
    typeOptions={typeOptions}
    titleLabel="আপনার নাম"
    priceLabel="মোটরসাইকেল মডেল"
  />
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    margin-bottom: 14px;
  }

  .post-rider-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    color: #FF6B35;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    padding: 4px 0;
  }

  .post-rider-link:hover {
    text-decoration: underline;
  }

  .courier-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .filter-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 32px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .filter-tab {
    background: #fff;
    border: 1px solid #EEF3F9;
    color: #1B2A4A;
    padding: 10px 24px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-tab:hover {
    border-color: #FF6B35;
  }

  .filter-tab.active {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
    margin-bottom: 30px;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .rider-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }

  .rider-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .rider-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .rider-card.hidden {
    display: none;
  }

  .rider-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    gap: 8px;
  }

  .online-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
    white-space: nowrap;
    background: rgba(22, 163, 74, 0.12);
    color: #16A34A;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .online-badge i {
    font-size: 0.5rem;
  }

  .location-tag {
    font-size: 0.75rem;
    color: #7A8EA5;
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  .rider-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 12px;
  }

  .rider-name {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .rider-vehicle {
    color: #FF6B35;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 8px;
  }

  .rider-desc {
    color: #5A6E85;
    font-size: 0.85rem;
    margin-bottom: 14px;
    line-height: 1.5;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FF6B35;
  }

  .cta-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 16px;
    padding: 16px 20px;
    max-width: 620px;
    margin: 0 auto;
  }

  .cta-card i {
    color: #FF6B35;
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .cta-card p {
    font-size: 0.88rem;
    color: #5A6E85;
    margin: 0;
  }

  .cta-card a {
    color: #1B2A4A;
    font-weight: 700;
    text-decoration: none;
  }

  .cta-card a:hover {
    color: #FF6B35;
  }

  @media (max-width: 768px) {
    .rider-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .page-header h1 {
      font-size: 1.7rem;
    }

    .cta-card {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  const tabs = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.rider-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      const filter = tab.dataset.filter;
      cards.forEach((card) => {
        if (filter === 'সব' || card.dataset.upazila === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });

  // CTA: লগইন থাকলে লিস্টিং মোডাল, না থাকলে আগে লগইন মোডাল
  document.getElementById('openCourierCta')?.addEventListener('click', async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      window.openListingModal?.();
    } else {
      window.openAuthModal?.('login');
    }
  });
</script>