---
// ============================================================
// পেজ: ডেলিভারি হিরো (কুরিয়ার/রাইডার সার্ভিস)
// ব্র্যান্ড: স্মার্ট ফেনী
// recycle প্যাটার্ন: হেডার CTA, সার্চ বক্স (উপজেলা ফিল্টার ট্যাবের
// বদলে), কম্প্যাক্ট কার্ড, শেয়ারড ডিটেইলস মডাল, লোকেশন সর্ট
// শুধু is_online=true এবং status='active' রাইডাররাই দেখানো হয়
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AddListingModal from '../../components/ui/AddListingModal.astro';
import ListingDetailModal from '../../components/ui/ListingDetailModal.astro';
import { supabase } from '../../lib/supabase.js';

const typeOptions = [{ id: 'rider', label: 'ডেলিভারি রাইডার' }];

const { data: riderListings } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'courier')
  .eq('status', 'active')
  .eq('is_online', true)
  .order('created_at', { ascending: false });

const riders = riderListings || [];
---

<BaseLayout title="ডেলিভারি হিরো | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-motorcycle"></i> ডেলিভারি সার্ভিস</span>
      <h1>ফেনীর <span class="accent">ডেলিভারি হিরো</span></h1>
      <p>মোটরসাইকেল-চালিত ফ্রিল্যান্স রাইডার — সরাসরি কল করে ডেলিভারি রেট ঠিক করুন</p>
      <button class="cta-box" id="openCourierCta" type="button">
        <i class="fas fa-plus"></i> রাইডার হিসেবে যুক্ত হতে চান?
      </button>
    </div>
  </section>

  <section class="courier-section">
    <div class="container">
      <div class="search-box">
        <i class="fas fa-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="রাইডারের নাম বা এলাকা খুঁজুন..." />
      </div>

      {riders.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-motorcycle"></i>
          <p>এই মুহূর্তে কোনো রাইডার অনলাইনে নেই</p>
          <span>একটু পর আবার চেষ্টা করুন</span>
        </div>
      ) : (
        <>
          <div class="rider-grid" id="riderGrid">
            {riders.map((item, i) => (
              <button
                type="button"
                class="rider-card"
                data-detail-index={i}
                data-upazila-name={item.upazila || ''}
                data-search={`${item.title || ''} ${item.description || ''} ${item.price || ''}`.toLowerCase()}
              >
                <span class="online-badge"><i class="fas fa-circle"></i> অনলাইন</span>

                {item.images && item.images.length > 0 ? (
                  <img src={item.images[0]} alt={item.title} class="rider-photo" />
                ) : (
                  <div class="rider-icon">
                    <i class="fas fa-motorcycle"></i>
                  </div>
                )}

                <div class="rider-card-body">
                  <h3 class="rider-name">{item.title}</h3>
                  {item.price && <p class="rider-vehicle"><i class="fas fa-motorcycle"></i> {item.price}</p>}
                  <p class="location-tag"><i class="fas fa-location-dot"></i> {item.upazila}</p>
                </div>
              </button>
            ))}
          </div>

          <p class="no-results" id="noResults" style="display:none;">কোনো ফলাফল পাওয়া যায়নি</p>
        </>
      )}

      <div class="cta-card">
        <i class="fas fa-headset"></i>
        <p>রাইডার হিসেবে নিবন্ধন করতে স্মার্ট ফেনী কাস্টমার কেয়ারে যোগাযোগ করুন: <a href="tel:+8801816355833">০১৮১৬৩৫৫৮৩৩</a></p>
      </div>
    </div>
  </section>

  <ListingDetailModal />
  <AddListingModal
    category="courier"
    typeOptions={typeOptions}
    titleLabel="আপনার নাম"
    priceLabel="মোটরসাইকেল মডেল"
  />

  <script type="application/json" id="listingsData" set:html={JSON.stringify(riders)} />
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    margin-bottom: 20px;
  }

  .cta-box {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFF0EA;
    border: 1.5px solid #FFD3BC;
    color: #FF6B35;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 12px 26px;
    border-radius: 40px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cta-box:hover {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
    transform: translateY(-2px);
  }

  .courier-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .search-box {
    max-width: 480px;
    margin: 0 auto 32px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 40px;
    padding: 12px 20px;
  }

  .search-box i {
    color: #A0AFC0;
  }

  .search-box input {
    border: none;
    outline: none;
    flex: 1;
    font-size: 0.9rem;
    font-family: inherit;
    background: transparent;
    color: #1B2A4A;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
    margin-bottom: 30px;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .rider-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
    margin-bottom: 30px;
  }

  .rider-card {
    background: #fff;
    border-radius: 18px;
    border: 1px solid #EEF3F9;
    padding: 0;
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.2s ease;
    font-family: inherit;
    position: relative;
  }

  .rider-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .rider-card.hidden {
    display: none;
  }

  .online-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 1;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    background: rgba(22, 163, 74, 0.9);
    color: #fff;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .online-badge i {
    font-size: 0.4rem;
  }

  .rider-icon {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }

  .rider-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .rider-card-body {
    padding: 14px;
  }

  .rider-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rider-vehicle {
    font-size: 0.8rem;
    font-weight: 600;
    color: #FF6B35;
    margin-bottom: 4px;
  }

  .location-tag {
    font-size: 0.72rem;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .no-results {
    text-align: center;
    color: #A0AFC0;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  .cta-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 16px;
    padding: 16px 20px;
    max-width: 620px;
    margin: 0 auto;
  }

  .cta-card i {
    color: #FF6B35;
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .cta-card p {
    font-size: 0.88rem;
    color: #5A6E85;
    margin: 0;
  }

  .cta-card a {
    color: #1B2A4A;
    font-weight: 700;
    text-decoration: none;
  }

  .cta-card a:hover {
    color: #FF6B35;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 1.7rem;
    }

    .cta-card {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { initListingDetailModal } from '../../lib/listingDetailModal.js';
  import { reorderByUserLocation } from '../../lib/locationSort.js';

  const typeNameMap = { rider: 'ডেলিভারি রাইডার' };
  const typeIcons = { rider: 'fa-motorcycle' };

  const dataEl = document.getElementById('listingsData');
  const listings = dataEl ? JSON.parse(dataEl.textContent) : [];

  const grid = document.getElementById('riderGrid');
  const cards = document.querySelectorAll('.rider-card');
  const searchInput = document.getElementById('searchInput');
  const noResults = document.getElementById('noResults');

  searchInput?.addEventListener('input', () => {
    const keyword = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches = keyword === '' || (card.dataset.search || '').includes(keyword);
      if (matches) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }
  });

  initListingDetailModal({ listings, typeNameMap, typeIcons, cardSelector: '.rider-card' });
  reorderByUserLocation(grid, 'upazilaName');

  // CTA: লগইন থাকলে লিস্টিং মোডাল, না থাকলে আগে লগইন মোডাল
  document.getElementById('openCourierCta')?.addEventListener('click', async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      window.openListingModal?.();
    } else {
      window.openAuthModal?.('login');
    }
  });
</script>