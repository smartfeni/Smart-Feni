---
import BaseLayout from '../../components/layout/BaseLayout.astro';

const upazilas = ['ফেনী সদর', 'ছাগলনাইয়া', 'সোনাগাজী', 'দাগনভূঞা', 'পরশুরাম', 'ফুলগাজী'];

const riders = [
  { name: 'রাকিব হোসেন', upazila: 'ফেনী সদর', vehicle: 'হোন্ডা লিভো', online: true, phone: '01812345671' },
  { name: 'সোহেল রানা', upazila: 'ফেনী সদর', vehicle: 'বাজাজ পালসার', online: true, phone: '01812345672' },
  { name: 'মাসুদ আলম', upazila: 'ছাগলনাইয়া', vehicle: 'ইয়ামাহা এফজেড', online: true, phone: '01812345673' },
  { name: 'জসিম উদ্দিন', upazila: 'ছাগলনাইয়া', vehicle: 'হিরো স্প্লেন্ডর', online: false, phone: '01812345674' },
  { name: 'নাঈম ইসলাম', upazila: 'সোনাগাজী', vehicle: 'টিভিএস অ্যাপাচি', online: true, phone: '01812345675' },
  { name: 'আরিফুল ইসলাম', upazila: 'দাগনভূঞা', vehicle: 'হোন্ডা শাইন', online: true, phone: '01812345676' },
  { name: 'শাকিল আহমেদ', upazila: 'পরশুরাম', vehicle: 'বাজাজ ডিসকভার', online: false, phone: '01812345677' },
  { name: 'তানভীর হাসান', upazila: 'ফুলগাজী', vehicle: 'ইয়ামাহা স্যালুটো', online: true, phone: '01812345678' },
];
---
<BaseLayout title="ডেলিভারি হিরো | স্মার্ট ফেনী">
  <div class="container" style="padding-top:60px; min-height:70vh; padding-bottom:60px;">

    <h1 style="font-size:2.8rem; margin-bottom:16px;">🏍️ ডেলিভারি হিরো</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:750px; margin-bottom:8px;">
      ফেনী সদর ও উপজেলা শহরের মোটরসাইকেল-চালিত ফ্রিল্যান্স ডেলিভারি রাইডারদের প্ল্যাটফর্ম। রাইডাররা যখন ফ্রি থাকেন তখন
      নিজেই অনলাইন হন, কাস্টমার তার উপজেলার অনলাইন রাইডারদের দেখে সরাসরি কল করে ডেলিভারি রেট ঠিক করে নেন।
    </p>

    <div style="display:flex; flex-wrap:wrap; gap:12px; margin:24px 0 16px;">
      <span style="background:#FFF0EA; color:#FF6B35; padding:8px 20px; border-radius:40px; font-weight:600; font-size:0.9rem;">
        <i class="fas fa-shield-check"></i> ভেরিফাইড রাইডার
      </span>
      <span style="background:#EFF5FF; color:#1B2A4A; padding:8px 20px; border-radius:40px; font-weight:600; font-size:0.9rem;">
        <i class="fas fa-handshake"></i> রেট নির্ধারণ নিজেরাই
      </span>
      <span style="background:#EAFBF0; color:#1B7A3C; padding:8px 20px; border-radius:40px; font-weight:600; font-size:0.9rem;">
        <i class="fas fa-hand-holding-heart"></i> অলাভজনক প্ল্যাটফর্ম
      </span>
    </div>

    <p style="background:#FFF6E5; color:#8A5A00; padding:12px 18px; border-radius:12px; font-size:0.9rem; max-width:750px; margin-bottom:44px;">
      <i class="fas fa-circle-info"></i> এটি স্মার্ট ফেনী একটি বিনামূল্যের প্ল্যাটফর্ম মাত্র — আমরা শুধু ভেরিফাইড রাইডার ও কাস্টমারকে একসাথে করি।
      ডেলিভারি রেট, সময় ও শর্ত রাইডার-কাস্টমার নিজেরা কল করে ঠিক করে নেবেন।
    </p>

    <!-- কীভাবে কাজ করে -->
    <h3 style="font-size:1.6rem; margin-bottom:20px;">⚙️ কীভাবে কাজ করে</h3>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px,1fr)); gap:20px; margin-bottom:56px;">
      <div style="background:#fff; padding:22px; border-radius:18px; border:1px solid #EEE;">
        <div style="width:40px; height:40px; background:#FFF0EA; color:#FF6B35; border-radius:12px; display:flex; align-items:center; justify-content:center; font-weight:700; margin-bottom:12px;">১</div>
        <h4 style="margin-bottom:6px;">রাইডার অনলাইন হন</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">ফ্রি থাকলে রাইডার নিজের অ্যাকাউন্ট থেকে অনলাইন টগল অন করেন।</p>
      </div>
      <div style="background:#fff; padding:22px; border-radius:18px; border:1px solid #EEE;">
        <div style="width:40px; height:40px; background:#FFF0EA; color:#FF6B35; border-radius:12px; display:flex; align-items:center; justify-content:center; font-weight:700; margin-bottom:12px;">২</div>
        <h4 style="margin-bottom:6px;">কাস্টমার উপজেলা বাছাই করেন</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">নিজের উপজেলা সিলেক্ট করলে সেখানকার অনলাইন রাইডারদের তালিকা দেখা যায়।</p>
      </div>
      <div style="background:#fff; padding:22px; border-radius:18px; border:1px solid #EEE;">
        <div style="width:40px; height:40px; background:#FFF0EA; color:#FF6B35; border-radius:12px; display:flex; align-items:center; justify-content:center; font-weight:700; margin-bottom:12px;">৩</div>
        <h4 style="margin-bottom:6px;">সরাসরি কল করে রেট ঠিক করুন</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">পছন্দের রাইডারকে কল করে ডেলিভারির স্থান, সময় ও রেট বলে ডিল ফাইনাল করুন।</p>
      </div>
    </div>

    <!-- রাইডার নিজে টগল করার ডেমো -->
    <div style="background:#1B2A4A; padding:28px 32px; border-radius:24px; max-width:640px; margin-bottom:56px;">
      <p style="color:#8FA0BC; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:6px;">রাইডার প্রিভিউ (শুধু ডেমো)</p>
      <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
        <div style="display:flex; align-items:center; gap:14px;">
          <div style="width:52px; height:52px; background:#FF6B35; border-radius:50%; display:flex; align-items:center; justify-content:center; color:#fff; font-size:1.3rem;">
            <i class="fas fa-motorcycle"></i>
          </div>
          <div>
            <p style="color:#fff; font-weight:600;">আপনি (রাইডার হিসেবে)</p>
            <p id="demo-status-text" style="color:#4ADE80; font-size:0.9rem;"><i class="fas fa-circle" style="font-size:0.5rem;"></i> অনলাইন — কাস্টমাররা আপনাকে দেখতে পাচ্ছে</p>
          </div>
        </div>
        <label style="position:relative; display:inline-block; width:56px; height:30px; cursor:pointer;">
          <input type="checkbox" id="demo-toggle" checked style="opacity:0; width:0; height:0;" />
          <span id="demo-slider" style="position:absolute; inset:0; background:#4ADE80; border-radius:40px; transition:0.25s;"></span>
          <span id="demo-knob" style="position:absolute; top:3px; left:29px; width:24px; height:24px; background:#fff; border-radius:50%; transition:0.25s;"></span>
        </label>
      </div>
      <p style="color:#8FA0BC; font-size:0.78rem; margin-top:14px;">* এটি শুধু ডিজাইন প্রিভিউ — এই টগলের অবস্থা সংরক্ষণ হবে না। আসল অ্যাকাউন্ট চালু হলে এটি রিয়েল-টাইমে কাজ করবে।</p>
    </div>

    <!-- উপজেলা ফিল্টার + রাইডার তালিকা -->
    <h3 style="font-size:1.6rem; margin-bottom:20px;">📍 আপনার উপজেলার অনলাইন রাইডার</h3>
    <div id="upazila-filters" style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:28px;">
      <button class="upazila-btn active" data-upazila="সব">সব উপজেলা</button>
      {upazilas.map((u) => (
        <button class="upazila-btn" data-upazila={u}>{u}</button>
      ))}
    </div>

    <div id="riders-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px,1fr)); gap:20px; margin-bottom:48px;">
      {riders.map((r) => (
        <div class="rider-card" data-upazila={r.upazila} data-online={r.online ? '1' : '0'} style="background:#fff; padding:22px; border-radius:20px; box-shadow:0 4px 16px rgba(0,0,0,0.04); border:1px solid #EEE;">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px;">
            <div style="width:46px; height:46px; background:#F4F7FC; border-radius:50%; display:flex; align-items:center; justify-content:center; color:#1B2A4A; font-size:1.2rem;">
              <i class="fas fa-motorcycle"></i>
            </div>
            <div>
              <p style="font-weight:600; display:flex; align-items:center; gap:6px;">
                {r.name}
                <i class="fas fa-circle-check" style="color:#2563EB; font-size:0.8rem;" title="ভেরিফাইড"></i>
              </p>
              <p style="color:#8FA0BC; font-size:0.82rem;">{r.vehicle}</p>
            </div>
          </div>
          <p style="color:#5A6E85; font-size:0.88rem; margin-bottom:10px;">
            <i class="fas fa-location-dot"></i> {r.upazila}
          </p>
          {r.online ? (
            <p style="color:#16A34A; font-size:0.85rem; font-weight:600; margin-bottom:14px;">
              <i class="fas fa-circle" style="font-size:0.5rem;"></i> অনলাইন আছেন
            </p>
          ) : (
            <p style="color:#94A3B8; font-size:0.85rem; font-weight:600; margin-bottom:14px;">
              <i class="fas fa-circle" style="font-size:0.5rem;"></i> অফলাইন
            </p>
          )}
          {r.online ? (
            <a href={`tel:+880${r.phone.slice(1)}`} class="btn-outline" style="justify-content:center; width:100%; padding:10px 20px; font-size:0.9rem;">
              <i class="fas fa-phone"></i> কল করুন
            </a>
          ) : (
            <button disabled style="width:100%; padding:10px 20px; border-radius:60px; border:2px solid #E5EAF0; color:#B0BCCB; background:#F8FAFC; font-weight:600; cursor:not-allowed;">
              এখন অফলাইন
            </button>
          )}
        </div>
      ))}
    </div>

    <!-- রাইডার হতে চাইলে -->
    <div style="background:#1B2A4A; color:#fff; padding:36px; border-radius:24px; max-width:800px;">
      <h3 style="margin-bottom:10px;">🏍️ ডেলিভারি হিরো হতে চান?</h3>
      <p style="color:#C9D4E3; margin-bottom:20px;">নিজের মোটরসাইকেল থাকলে এবং ফ্রি সময়ে ডেলিভারি করে আয় করতে চাইলে ভেরিফাইড রাইডার হিসেবে নিবন্ধন করুন।</p>
      <a href="tel:+8801812345678" class="btn-primary" style="background:#FF6B35;">
        <i class="fas fa-phone"></i> ০১৮১২-৩৪৫৬৭৮
      </a>
      <p style="color:#8FA0BC; font-size:0.85rem; margin-top:14px;">* এটি একটি নমুনা নম্বর, চূড়ান্ত যোগাযোগ নম্বর শীঘ্রই যুক্ত করা হবে।</p>
    </div>

    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>

  </div>

  <style>
    .upazila-btn {
      background: #fff;
      border: 1px solid #E5EAF0;
      color: #4A5B6E;
      padding: 8px 20px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.88rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .upazila-btn:hover {
      border-color: #FF6B35;
      color: #FF6B35;
    }
    .upazila-btn.active {
      background: #FF6B35;
      border-color: #FF6B35;
      color: #fff;
    }
  </style>

  <script>
    // উপজেলা ফিল্টার (ক্লায়েন্ট-সাইড ডেমো)
    const filterButtons = document.querySelectorAll('.upazila-btn');
    const riderCards = document.querySelectorAll('.rider-card');

    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterButtons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const selected = btn.getAttribute('data-upazila');

        riderCards.forEach((card) => {
          const cardUpazila = card.getAttribute('data-upazila');
          card.style.display = selected === 'সব' || cardUpazila === selected ? '' : 'none';
        });
      });
    });

    // রাইডার অনলাইন/অফলাইন টগল (শুধু ভিজ্যুয়াল ডেমো, সংরক্ষণ হয় না)
    const demoToggle = document.getElementById('demo-toggle');
    const demoSlider = document.getElementById('demo-slider');
    const demoKnob = document.getElementById('demo-knob');
    const demoStatusText = document.getElementById('demo-status-text');

    demoToggle?.addEventListener('change', () => {
      if (demoToggle.checked) {
        demoSlider.style.background = '#4ADE80';
        demoKnob.style.left = '29px';
        demoStatusText.style.color = '#4ADE80';
        demoStatusText.innerHTML = '<i class="fas fa-circle" style="font-size:0.5rem;"></i> অনলাইন — কাস্টমাররা আপনাকে দেখতে পাচ্ছে';
      } else {
        demoSlider.style.background = '#5A6E85';
        demoKnob.style.left = '3px';
        demoStatusText.style.color = '#94A3B8';
        demoStatusText.innerHTML = '<i class="fas fa-circle" style="font-size:0.5rem;"></i> অফলাইন — কাস্টমাররা আপনাকে দেখতে পাচ্ছে না';
      }
    });
  </script>
</BaseLayout>