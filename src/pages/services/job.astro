---
import BaseLayout from '../../components/layout/BaseLayout.astro';
---
<BaseLayout title="চাকরি সেবা">
  <div class="container" style="padding-top:60px; min-height:70vh;">
    <h1 style="font-size:2.8rem; margin-bottom:20px;">💼 চাকরি সেবা</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:700px; margin-bottom:40px;">
      এই পেজে আপনি চাকরির লিস্টিং, ফিল্টার, ডিটেইলস — সবকিছু নিয়ে এক্সপেরিমেন্ট করতে পারবেন।
    </p>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px,1fr)); gap:24px;">
      <div style="background:#fff; padding:24px; border-radius:20px; box-shadow:0 4px 16px rgba(0,0,0,0.04);">
        <h3>সফটওয়্যার ইঞ্জিনিয়ার</h3>
        <p style="color:#FF6B35; font-weight:600;">বিকাশ লিমিটেড</p>
        <p style="color:#5A6E85; margin:8px 0;">ঢাকা, বাংলাদেশ</p>
        <span style="background:#EFF5FF; padding:4px 16px; border-radius:40px; font-size:0.8rem;">ফুল-টাইম</span>
      </div>
    </div>
    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>
  </div>
</BaseLayout>