---
// ============================================================
// পেজ: চাকরির খবর সার্ভিস
// ব্র্যান্ড: স্মার্ট ফেনী
// ============================================================

import BaseLayout from '../../components/layout/BaseLayout.astro';

// প্লেসহোল্ডার ডেটা — পরে ডাটাবেজ থেকে আসবে, আপাতত mock ডেটা দিয়ে UI সাজানো হচ্ছে
const jobs = [
  { id: 1, type: 'fulltime', typeName: 'ফুল-টাইম', title: 'সফটওয়্যার ইঞ্জিনিয়ার', company: 'বিকাশ লিমিটেড', salary: '৩৫,০০০ - ৫০,০০০', upazila: 'ফেনী সদর', experience: '২-৩ বছর', deadline: '৩০ জুলাই' },
  { id: 2, type: 'parttime', typeName: 'পার্ট-টাইম', title: 'গ্রাফিক ডিজাইনার', company: 'ক্রিয়েটিভ স্টুডিও', salary: '১৫,০০০ - ২০,০০০', upazila: 'ছাগলনাইয়া', experience: '১ বছর', deadline: '২৫ জুলাই' },
  { id: 3, type: 'internship', typeName: 'ইন্টার্নশিপ', title: 'মার্কেটিং ইন্টার্ন', company: 'দাগনভূঞা এগ্রো', salary: '৮,০০০', upazila: 'দাগনভূঞা', experience: 'ফ্রেশার', deadline: '১৫ আগস্ট' },
  { id: 4, type: 'fulltime', typeName: 'ফুল-টাইম', title: 'একাউন্ট্যান্ট', company: 'পরশুরাম ট্রেডার্স', salary: '২৫,০০০ - ৩০,০০০', upazila: 'পরশুরাম', experience: '৩-৫ বছর', deadline: '৫ আগস্ট' },
  { id: 5, type: 'fulltime', typeName: 'ফুল-টাইম', title: 'সেলস এক্সিকিউটিভ', company: 'ফুলগাজী ফার্মা', salary: '২০,০০০ - ২৫,০০০', upazila: 'ফুলগাজী', experience: '১-২ বছর', deadline: '২০ জুলাই' },
  { id: 6, type: 'parttime', typeName: 'পার্ট-টাইম', title: 'কন্টেন্ট রাইটার', company: 'সোনাগাজী মিডিয়া', salary: '১২,০০০ - ১৮,০০০', upazila: 'সোনাগাজী', experience: 'ফ্রেশার', deadline: '১০ আগস্ট' },
];
---

<BaseLayout title="চাকরির খবর | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <h1>ফেনীতে <span class="accent">চাকরির খবর</span></h1>
      <p>সরকারি-বেসরকারি প্রতিষ্ঠানের সর্বশেষ নিয়োগ বিজ্ঞপ্তি — এক জায়গায়</p>

      <a href="/contact" class="btn-post-ad">
        <i class="fas fa-plus"></i> চাকরি পোস্ট করুন
      </a>
    </div>
  </section>

  <section class="job-section">
    <div class="container">
      <div class="job-grid">
        {jobs.map((job) => (
          <div class="job-card">
            <div class="job-card-top">
              <span class={`type-badge type-${job.type}`}>{job.typeName}</span>
              <span class="location-tag">
                <i class="fas fa-location-dot"></i> {job.upazila}
              </span>
            </div>

            <div class="job-icon">
              <i class="fas fa-briefcase"></i>
            </div>

            <h3 class="job-title">{job.title}</h3>

            <div class="job-meta">
              <span class="meta-item"><i class="fas fa-user-clock"></i> {job.experience}</span>
              <span class="meta-item"><i class="fas fa-calendar-days"></i> {job.deadline}</span>
            </div>

            <p class="salary-amount">৳{job.salary} <span>/ মাস</span></p>

            <div class="company-row">
              <div class="company-avatar">{job.company.charAt(0)}</div>
              <div class="company-info">
                <p class="company-name">{job.company}</p>
              </div>
            </div>

            <a href="/contact" class="btn-apply">
              <i class="fas fa-paper-plane"></i> আবেদন করুন
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    margin-bottom: 24px;
  }

  .btn-post-ad {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 40px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .btn-post-ad:hover {
    background: #e85a28;
    transform: translateY(-2px);
  }

  .job-section {
    padding: 40px 0 70px;
    background: #F8FAFC;
  }

  .job-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .job-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .job-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .job-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .type-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
  }

  .type-fulltime {
    background: rgba(0, 184, 148, 0.12);
    color: #00B894;
  }

  .type-parttime {
    background: rgba(9, 132, 227, 0.12);
    color: #0984E3;
  }

  .type-internship {
    background: rgba(108, 92, 231, 0.12);
    color: #6C5CE7;
  }

  .location-tag {
    font-size: 0.75rem;
    color: #7A8EA5;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .job-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 12px;
  }

  .job-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .job-meta {
    display: flex;
    gap: 14px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .meta-item {
    font-size: 0.8rem;
    color: #5A6E85;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .meta-item i {
    color: #FF6B35;
    font-size: 0.75rem;
  }

  .salary-amount {
    font-size: 1.3rem;
    font-weight: 700;
    color: #FF6B35;
    margin-bottom: 16px;
  }

  .salary-amount span {
    font-size: 0.8rem;
    font-weight: 500;
    color: #A0AFC0;
  }

  .company-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    padding-top: 14px;
    border-top: 1px solid #EEF3F9;
  }

  .company-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #1B2A4A;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .company-name {
    font-size: 0.85rem;
    font-weight: 600;
  }

  .btn-apply {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .btn-apply:hover {
    background: #FF6B35;
  }

  @media (max-width: 768px) {
    .job-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>