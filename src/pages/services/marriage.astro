---
import BaseLayout from '../../components/layout/BaseLayout.astro';
---
<BaseLayout title="দাম্পত্য সেবা">
  <div class="container" style="padding-top:60px; min-height:70vh;">
    <h1 style="font-size:2.8rem; margin-bottom:20px;">💑 দাম্পত্য সেবা</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:700px; margin-bottom:40px;">
      বিয়ে সংক্রান্ত পরামর্শ, ম্যাচমেকিং, সম্পর্কের পরামর্শ—সব এখানে।
    </p>
    
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(250px,1fr)); gap:20px;">
      <div style="background:#fff; padding:20px; border-radius:16px; border:1px solid #EEE;">
        <h4>❤️ সম্পর্ক পরামর্শ</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">সাইকোলজিস্ট ডা. নাসরিন</p>
        <span style="background:#EFF5FF; padding:4px 16px; border-radius:40px; font-size:0.8rem;">অনলাইন সেশন</span>
      </div>
      <div style="background:#fff; padding:20px; border-radius:16px; border:1px solid #EEE;">
        <h4>💍 ম্যাচমেকিং</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">পেশাদার ম্যাচমেকার</p>
        <span style="background:#EFF5FF; padding:4px 16px; border-radius:40px; font-size:0.8rem;">ঢাকা ভিত্তিক</span>
      </div>
    </div>

    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>
  </div>
</BaseLayout>