---
import BaseLayout from '../../components/layout/BaseLayout.astro';
---
<BaseLayout title="অ্যাম্বুলেন্স সেবা">
  <div class="container" style="padding-top:60px; min-height:70vh;">
    <h1 style="font-size:2.8rem; margin-bottom:20px;">🚑 অ্যাম্বুলেন্স সেবা</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:700px; margin-bottom:40px;">
      জরুরি মুহূর্তে অ্যাম্বুলেন্স সেবা। ২৪/৭ প্রস্তুত। এই পেজে আপনি অ্যাম্বুলেন্স সংক্রান্ত সব তথ্য দিতে পারেন।
    </p>
    
    <div style="background:#FF6B35; color:#fff; padding:30px; border-radius:20px; text-align:center; margin-bottom:30px;">
      <h2 style="font-size:2rem;">📞 জরুরি হটলাইন: ৯৯৯</h2>
      <p style="margin-top:10px;">অথবা কল করুন: ০১৭১১-২২৩৩৪৪</p>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(250px,1fr)); gap:20px;">
      <div style="background:#fff; padding:20px; border-radius:16px; text-align:center; border:1px solid #EEE;">
        <i class="fas fa-ambulance" style="font-size:3rem; color:#FF6B35;"></i>
        <h4 style="margin:12px 0;">অ্যাম্বুলেন্স সেবা-১</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">ধানমন্ডি এলাকা</p>
      </div>
      <div style="background:#fff; padding:20px; border-radius:16px; text-align:center; border:1px solid #EEE;">
        <i class="fas fa-ambulance" style="font-size:3rem; color:#FF6B35;"></i>
        <h4 style="margin:12px 0;">অ্যাম্বুলেন্স সেবা-২</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">মিরপুর এলাকা</p>
      </div>
    </div>

    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>
  </div>
</BaseLayout>