---
// ============================================================
// পেজ: হারানো-পাওয়া সেবা
// ব্র্যান্ড: স্মার্ট ফেনী
// স্ট্রাকচার: ২টা ট্যাব (হারানো বিজ্ঞপ্তি / পাওয়া গিয়েছে)
// প্রতিটার উপরে "+ বিজ্ঞপ্তি দিন" বাটন (এখন শুধু UI মডাল, backend পরে যুক্ত হবে)
// ============================================================

import BaseLayout from '../../components/layout/BaseLayout.astro';

// প্লেসহোল্ডার ডেটা — পরে ডাটাবেজ থেকে আসবে
const lostItems = [
  { id: 1, title: 'হারানো স্মার্টফোন', desc: 'কালো রঙের স্যামসাং ফোন, স্ক্রিনে হালকা ফাটা দাগ আছে', upazila: 'ফেনী সদর', time: '২ দিন আগে' },
  { id: 2, title: 'হারানো মানিব্যাগ', desc: 'বাদামি চামড়ার মানিব্যাগ, ভেতরে NID কার্ড ছিল', upazila: 'ছাগলনাইয়া', time: '৪ দিন আগে' },
  { id: 3, title: 'হারানো পোষা বিড়াল', desc: 'সাদা-কমলা মিশ্রিত রঙের বিড়াল, গলায় লাল বেল্ট', upazila: 'দাগনভূঞা', time: '১ দিন আগে' },
  { id: 4, title: 'হারানো কলেজ আইডি কার্ড', desc: 'ফেনী সরকারি কলেজের স্টুডেন্ট আইডি', upazila: 'ফেনী সদর', time: '৫ দিন আগে' },
  { id: 5, title: 'হারানো কানের দুল', desc: 'সোনার ছোট দুল, পারিবারিক স্মৃতি হিসেবে গুরুত্বপূর্ণ', upazila: 'সোনাগাজী', time: '৩ দিন আগে' },
];

const foundItems = [
  { id: 1, title: 'পাওয়া মোবাইল ফোন', desc: 'সিএনজিতে একটা আইফোন পাওয়া গেছে', upazila: 'ফুলগাজী', time: '১ দিন আগে' },
  { id: 2, title: 'পাওয়া চাবির রিং', desc: '৪টা চাবি সহ একটা রিং, বাজার এলাকায় পাওয়া', upazila: 'পরশুরাম', time: '৩ দিন আগে' },
  { id: 3, title: 'পাওয়া কুকুরছানা', desc: 'বাদামি রঙের ছোট কুকুরছানা, খুবই বন্ধুত্বপূর্ণ', upazila: 'ফেনী সদর', time: '২ দিন আগে' },
  { id: 4, title: 'পাওয়া ব্যাগ', desc: 'কালো স্কুল ব্যাগ, ভেতরে বই-খাতা আছে', upazila: 'দাগনভূঞা', time: '৬ দিন আগে' },
  { id: 5, title: 'পাওয়া চশমা', desc: 'কালো ফ্রেমের চশমা, বাসস্ট্যান্ড এলাকায় পাওয়া', upazila: 'ছাগলনাইয়া', time: '৪ দিন আগে' },
];
---

<BaseLayout title="হারানো-পাওয়া সেবা | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-magnifying-glass"></i> হারানো-পাওয়া সেবা</span>
      <h1>কিছু <span class="accent">হারিয়েছে</span> বা <span class="accent">পেয়েছেন</span>?</h1>
      <p>ফেনী জেলার মানুষদের একে অপরকে সাহায্য করার সহজ মাধ্যম</p>
    </div>
  </section>

  <section class="lf-section">
    <div class="container">
      <div class="tabs" id="tabs">
        <button class="tab active" data-tab="lost">হারানো বিজ্ঞপ্তি</button>
        <button class="tab" data-tab="found">পাওয়া গিয়েছে</button>
      </div>

      <!-- হারানো ট্যাব -->
      <div class="tab-panel active" id="panel-lost">
        <button class="btn-post" onclick="alert('বিজ্ঞপ্তি ফর্ম শীঘ্রই যুক্ত হবে')">
          <i class="fas fa-plus"></i> হারানো বিজ্ঞপ্তি দিন
        </button>

        <div class="item-grid">
          {lostItems.map((item) => (
            <div class="item-card lost-card">
              <span class="status-badge lost-badge">হারানো</span>
              <h3>{item.title}</h3>
              <p class="item-desc">{item.desc}</p>
              <div class="item-meta">
                <span><i class="fas fa-location-dot"></i> {item.upazila}</span>
                <span><i class="fas fa-clock"></i> {item.time}</span>
              </div>
              <a href="/contact" class="btn-contact">
                <i class="fas fa-phone"></i> যোগাযোগ করুন
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- পাওয়া ট্যাব -->
      <div class="tab-panel" id="panel-found">
        <button class="btn-post" onclick="alert('বিজ্ঞপ্তি ফর্ম শীঘ্রই যুক্ত হবে')">
          <i class="fas fa-plus"></i> পাওয়ার বিজ্ঞপ্তি দিন
        </button>

        <div class="item-grid">
          {foundItems.map((item) => (
            <div class="item-card found-card">
              <span class="status-badge found-badge">পাওয়া গিয়েছে</span>
              <h3>{item.title}</h3>
              <p class="item-desc">{item.desc}</p>
              <div class="item-meta">
                <span><i class="fas fa-location-dot"></i> {item.upazila}</span>
                <span><i class="fas fa-clock"></i> {item.time}</span>
              </div>
              <a href="/contact" class="btn-contact">
                <i class="fas fa-phone"></i> যোগাযোগ করুন
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 50px 0 24px;
    background: #fff;
    text-align: center;
  }

  .section-tag {
    display: inline-block;
    background: #FFF0EA;
    color: #FF6B35;
    padding: 6px 18px;
    border-radius: 40px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #1B2A4A;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
  }

  .lf-section {
    padding: 20px 0 60px;
    background: #F8FAFC;
  }

  .tabs {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 28px;
  }

  .tab {
    background: #fff;
    border: 1px solid #EEF3F9;
    color: #1B2A4A;
    padding: 12px 28px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .tab.active {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .btn-post {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #1B2A4A;
    color: #fff;
    border: none;
    padding: 12px 24px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    margin: 0 auto 28px;
    transition: background 0.2s ease;
  }

  .btn-post:hover {
    background: #FF6B35;
  }

  .item-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 18px;
  }

  .item-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    position: relative;
    transition: all 0.25s ease;
  }

  .item-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .status-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  .lost-badge {
    background: rgba(214, 48, 49, 0.1);
    color: #D63031;
  }

  .found-badge {
    background: rgba(0, 184, 148, 0.12);
    color: #00B894;
  }

  .item-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 8px;
  }

  .item-desc {
    font-size: 0.88rem;
    color: #5A6E85;
    margin-bottom: 14px;
    line-height: 1.5;
  }

  .item-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.78rem;
    color: #7A8EA5;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 6px;
  }

  .item-meta i {
    color: #FF6B35;
    margin-right: 4px;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #F8FAFC;
    color: #1B2A4A;
    text-decoration: none;
    padding: 10px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.85rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FFF0EA;
    color: #FF6B35;
  }

  @media (max-width: 480px) {
    .item-grid {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .tabs {
      gap: 6px;
    }

    .tab {
      padding: 10px 16px;
      font-size: 0.85rem;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.tab');
  const panels = document.querySelectorAll('.tab-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');

      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      panels.forEach((panel) => {
        panel.classList.toggle('active', panel.id === `panel-${target}`);
      });
    });
  });
</script>