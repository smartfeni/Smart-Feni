---
// ============================================================
// পেজ: হারানো-পাওয়া সেবা
// ব্র্যান্ড: স্মার্ট ফেনী
// ২টা ট্যাব (হারানো/পাওয়া), Supabase লাইভ ডেটা, ডিটেইলস মডাল,
// লোকেশন সর্ট। সার্চ বক্স নাই।
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AddListingModal from '../../components/ui/AddListingModal.astro';
import ListingDetailModal from '../../components/ui/ListingDetailModal.astro';
import { supabase } from '../../lib/supabase.js';

const typeOptions = [
  { id: 'lost', label: 'হারিয়ে গিয়েছে' },
  { id: 'found', label: 'পাওয়া গিয়েছে' },
];

const typeNameMap = Object.fromEntries(typeOptions.map((t) => [t.id, t.label]));
const typeIcons = { lost: 'fa-magnifying-glass', found: 'fa-hand-holding-heart' };

const { data: lfListings } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'lost-found')
  .eq('status', 'active')
  .order('created_at', { ascending: false });

const listings = lfListings || [];
const lostItems = listings.filter((i) => i.type === 'lost');
const foundItems = listings.filter((i) => i.type === 'found');
---

<BaseLayout title="হারানো-পাওয়া সেবা | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-magnifying-glass"></i> হারানো-পাওয়া সেবা</span>
      <h1>কিছু <span class="accent">হারিয়েছে</span> বা <span class="accent">পেয়েছেন</span>?</h1>
      <p>ফেনী জেলার মানুষদের একে অপরকে সাহায্য করার সহজ মাধ্যম</p>
    </div>
  </section>

  <section class="lf-section">
    <div class="container">
      <div class="tabs" id="tabs">
        <button class="tab active" data-tab="lost">হারানো বিজ্ঞপ্তি</button>
        <button class="tab" data-tab="found">পাওয়া গিয়েছে</button>
      </div>

      <!-- হারানো ট্যাব -->
      <div class="tab-panel active" id="panel-lost">
        <button class="btn-post" id="openLostCta" type="button">
          <i class="fas fa-plus"></i> হারানো বিজ্ঞপ্তি দিন
        </button>

        {lostItems.length === 0 ? (
          <div class="empty-state">
            <i class="fas fa-magnifying-glass"></i>
            <p>এখনো কোনো হারানো বিজ্ঞপ্তি নেই</p>
          </div>
        ) : (
          <div class="item-grid" id="lostGrid">
            {lostItems.map((item, i) => (
              <button
                type="button"
                class="item-card lost-card"
                data-detail-index={i}
                data-upazila-name={item.upazila || ''}
              >
                <span class="status-badge lost-badge">হারানো</span>
                <h3>{item.title}</h3>
                {item.description && <p class="item-desc">{item.description}</p>}
                <div class="item-meta">
                  <span><i class="fas fa-location-dot"></i> {item.upazila}</span>
                </div>
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- পাওয়া ট্যাব -->
      <div class="tab-panel" id="panel-found">
        <button class="btn-post" id="openFoundCta" type="button">
          <i class="fas fa-plus"></i> পাওয়ার বিজ্ঞপ্তি দিন
        </button>

        {foundItems.length === 0 ? (
          <div class="empty-state">
            <i class="fas fa-hand-holding-heart"></i>
            <p>এখনো কোনো পাওয়ার বিজ্ঞপ্তি নেই</p>
          </div>
        ) : (
          <div class="item-grid" id="foundGrid">
            {foundItems.map((item, i) => (
              <button
                type="button"
                class="item-card found-card"
                data-detail-index={i}
                data-upazila-name={item.upazila || ''}
              >
                <span class="status-badge found-badge">পাওয়া গিয়েছে</span>
                <h3>{item.title}</h3>
                {item.description && <p class="item-desc">{item.description}</p>}
                <div class="item-meta">
                  <span><i class="fas fa-location-dot"></i> {item.upazila}</span>
                </div>
              </button>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <ListingDetailModal />
  <AddListingModal category="lost-found" typeOptions={typeOptions} titleLabel="আইটেমের নাম" priceLabel="" />

  <script type="application/json" id="lostData" set:html={JSON.stringify(lostItems)} />
  <script type="application/json" id="foundData" set:html={JSON.stringify(foundItems)} />
</BaseLayout>

<style>
  .page-header {
    padding: 50px 0 24px;
    background: #fff;
    text-align: center;
  }

  .section-tag {
    display: inline-block;
    background: #FFF0EA;
    color: #FF6B35;
    padding: 6px 18px;
    border-radius: 40px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #1B2A4A;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
  }

  .lf-section {
    padding: 20px 0 60px;
    background: #F8FAFC;
  }

  .tabs {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 28px;
  }

  .tab {
    background: #fff;
    border: 1px solid #EEF3F9;
    color: #1B2A4A;
    padding: 12px 28px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .tab.active {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .btn-post {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #1B2A4A;
    color: #fff;
    border: none;
    padding: 12px 24px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    margin: 0 auto 28px;
    transition: background 0.2s ease;
  }

  .btn-post:hover {
    background: #FF6B35;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
  }

  .item-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 18px;
  }

  .item-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    position: relative;
    transition: all 0.25s ease;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    width: 100%;
  }

  .item-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .status-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  .lost-badge {
    background: rgba(214, 48, 49, 0.1);
    color: #D63031;
  }

  .found-badge {
    background: rgba(0, 184, 148, 0.12);
    color: #00B894;
  }

  .item-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 8px;
  }

  .item-desc {
    font-size: 0.88rem;
    color: #5A6E85;
    margin-bottom: 14px;
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .item-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.78rem;
    color: #7A8EA5;
    flex-wrap: wrap;
    gap: 6px;
  }

  .item-meta i {
    color: #FF6B35;
    margin-right: 4px;
  }

  @media (max-width: 480px) {
    .item-grid {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .tabs {
      gap: 6px;
    }

    .tab {
      padding: 10px 16px;
      font-size: 0.85rem;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { initListingDetailModal } from '../../lib/listingDetailModal.js';
  import { reorderByUserLocation } from '../../lib/locationSort.js';

  // ট্যাব সুইচ
  const tabs = document.querySelectorAll('.tab');
  const panels = document.querySelectorAll('.tab-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      panels.forEach((panel) => {
        panel.classList.toggle('active', panel.id === `panel-${target}`);
      });
    });
  });

  // দুইটা গ্রিড আলাদাভাবে লোকেশন-সর্ট
  reorderByUserLocation(document.getElementById('lostGrid'), 'upazilaName');
  reorderByUserLocation(document.getElementById('foundGrid'), 'upazilaName');

  // ডিটেইলস মডাল — lost ও found দুইটা আলাদা ডেটাসেট, তাই আলাদাভাবে init
  const typeNameMap = { lost: 'হারানো', found: 'পাওয়া গিয়েছে' };
  const typeIcons = { lost: 'fa-magnifying-glass', found: 'fa-hand-holding-heart' };

  const lostData = JSON.parse(document.getElementById('lostData')?.textContent || '[]');
  const foundData = JSON.parse(document.getElementById('foundData')?.textContent || '[]');

  initListingDetailModal({ listings: lostData, typeNameMap, typeIcons, cardSelector: '#lostGrid .item-card' });
  initListingDetailModal({ listings: foundData, typeNameMap, typeIcons, cardSelector: '#foundGrid .item-card' });

  // পোস্ট বাটন: লগইন চেক + প্রিসেট টাইপ
  async function openWithPreset(presetType) {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      window.openListingModal?.(presetType);
    } else {
      window.openAuthModal?.('login');
    }
  }

  document.getElementById('openLostCta')?.addEventListener('click', () => openWithPreset('lost'));
  document.getElementById('openFoundCta')?.addEventListener('click', () => openWithPreset('found'));
</script>