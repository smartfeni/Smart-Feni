---
import BaseLayout from '../../components/layout/BaseLayout.astro';

const upazilas = ['ফেনী সদর', 'ছাগলনাইয়া', 'সোনাগাজী', 'দাগনভূঞা', 'পরশুরাম', 'ফুলগাজী'];

// নমুনা টিউটর তালিকা ("পড়াতে চাই" ফর্ম থেকে জমা হওয়া বলে ধরে নেওয়া হয়েছে)
const tutors = [
  { name: 'রাফসান আহমেদ', subjects: 'গণিত, উচ্চতর গণিত', classes: 'ক্লাস ৯-১০', upazila: 'ফেনী সদর', mode: 'বাসায় গিয়ে', qualification: 'বুয়েট, ইইই', phone: '01812345671' },
  { name: 'সাদিয়া ইসলাম', subjects: 'ইংরেজি', classes: 'ক্লাস ৬-৮', upazila: 'ফেনী সদর', mode: 'অনলাইন', qualification: 'ইংরেজি সাহিত্যে স্নাতক', phone: '01812345672' },
  { name: 'তানজিল হাসান', subjects: 'পদার্থবিজ্ঞান, রসায়ন', classes: 'এইচএসসি', upazila: 'ছাগলনাইয়া', mode: 'বাসায় গিয়ে', qualification: 'ফেনী সরকারি কলেজ', phone: '01812345673' },
  { name: 'নুসরাত জাহান', subjects: 'বাংলা, সমাজবিজ্ঞান', classes: 'ক্লাস ৩-৫', upazila: 'সোনাগাজী', mode: 'বাসায় গিয়ে ও অনলাইন', qualification: 'অনার্স, বাংলা', phone: '01812345674' },
];

// নমুনা "শিক্ষক লাগবে" পোস্ট
const requests = [
  { guardian: 'আব্দুল করিম', studentClass: 'ক্লাস ৮', subject: 'গণিত, বিজ্ঞান', upazila: 'ফেনী সদর', mode: 'বাসায় গিয়ে', budget: '৳২,৫০০/মাস', phone: '01912345671' },
  { guardian: 'ফারজানা বেগম', studentClass: 'ক্লাস ৫', subject: 'ইংরেজি', upazila: 'দাগনভূঞা', mode: 'অনলাইন', budget: '৳১,৫০০/মাস', phone: '01912345672' },
  { guardian: 'মাহবুব আলম', studentClass: 'এসএসসি', subject: 'সকল বিষয় (ব্যাচ)', upazila: 'পরশুরাম', mode: 'বাসায় গিয়ে', budget: '৳৪,০০০/মাস', phone: '01912345673' },
];
---
<BaseLayout title="টিউশন খুঁজুন | স্মার্ট ফেনী">
  <div class="container" style="padding-top:60px; min-height:70vh; padding-bottom:60px;">

    <h1 style="font-size:2.8rem; margin-bottom:16px;">📚 টিউশন খুঁজুন</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:750px; margin-bottom:40px;">
      নিজে পড়াতে চান, নাকি সন্তানের জন্য শিক্ষক খুঁজছেন? দুটোই এক জায়গায় — ফর্ম পূরণ করে পোস্ট করুন,
      নিচে থেকে ফিল্টার করে পছন্দের টিউটর বা টিউশনি খুঁজে নিন।
    </p>

    <!-- ক্যাটাগরি ট্যাব -->
    <div class="tuition-tabs">
      <button class="tuition-tab active" data-tab="teach" type="button">
        <i class="fas fa-chalkboard-user"></i> পড়াতে চাই
      </button>
      <button class="tuition-tab" data-tab="need" type="button">
        <i class="fas fa-graduation-cap"></i> শিক্ষক লাগবে
      </button>
    </div>

    <!-- ===== ফর্ম ১: পড়াতে চাই ===== -->
    <div class="tuition-form-pane active" id="teachPane">
      <div class="tuition-form-card">
        <h3 style="margin-bottom:4px;"><i class="fas fa-chalkboard-user" style="color:#FF6B35;"></i> টিউটর হিসেবে নিবন্ধন করুন</h3>
        <p style="color:#8FA0BC; font-size:0.88rem; margin-bottom:22px;">আপনার তথ্য পূরণ করুন, শিক্ষার্থী/অভিভাবক আপনাকে খুঁজে পাবেন।</p>

        <div class="tuition-grid">
          <div>
            <label class="tuition-label">পূর্ণ নাম</label>
            <input type="text" class="tuition-input" placeholder="আপনার নাম" />
          </div>
          <div>
            <label class="tuition-label">ফোন নম্বর</label>
            <input type="text" class="tuition-input" placeholder="01xxxxxxxxx" />
          </div>
          <div>
            <label class="tuition-label">শিক্ষাগত যোগ্যতা</label>
            <input type="text" class="tuition-input" placeholder="যেমন: বুয়েট, ইইই / এইচএসসি" />
          </div>
          <div>
            <label class="tuition-label">অভিজ্ঞতা</label>
            <input type="text" class="tuition-input" placeholder="যেমন: ২ বছর" />
          </div>
          <div>
            <label class="tuition-label">কোন কোন বিষয় পড়ান</label>
            <input type="text" class="tuition-input" placeholder="যেমন: গণিত, ইংরেজি" />
          </div>
          <div>
            <label class="tuition-label">কোন ক্লাস পর্যন্ত</label>
            <select class="tuition-input">
              <option>প্রাথমিক (ক্লাস ১-৫)</option>
              <option>মাধ্যমিক (ক্লাস ৬-১০)</option>
              <option>এইচএসসি</option>
              <option>বিশ্ববিদ্যালয় ভর্তি প্রস্তুতি</option>
            </select>
          </div>
          <div>
            <label class="tuition-label">উপজেলা</label>
            <select class="tuition-input">
              {upazilas.map((u) => <option>{u}</option>)}
            </select>
          </div>
          <div>
            <label class="tuition-label">পড়ানোর ধরন</label>
            <select class="tuition-input">
              <option>বাসায় গিয়ে</option>
              <option>অনলাইন</option>
              <option>বাসায় গিয়ে ও অনলাইন</option>
            </select>
          </div>
        </div>

        <button class="tuition-submit" type="button" data-role="teach">
          <i class="fas fa-paper-plane"></i> টিউটর হিসেবে পোস্ট করুন
        </button>
      </div>
    </div>

    <!-- ===== ফর্ম ২: শিক্ষক লাগবে ===== -->
    <div class="tuition-form-pane" id="needPane">
      <div class="tuition-form-card">
        <h3 style="margin-bottom:4px;"><i class="fas fa-graduation-cap" style="color:#FF6B35;"></i> শিক্ষক খুঁজছেন?</h3>
        <p style="color:#8FA0BC; font-size:0.88rem; margin-bottom:22px;">আপনার প্রয়োজন জানান, উপযুক্ত টিউটর যোগাযোগ করবেন।</p>

        <div class="tuition-grid">
          <div>
            <label class="tuition-label">অভিভাবকের নাম</label>
            <input type="text" class="tuition-input" placeholder="আপনার নাম" />
          </div>
          <div>
            <label class="tuition-label">ফোন নম্বর</label>
            <input type="text" class="tuition-input" placeholder="01xxxxxxxxx" />
          </div>
          <div>
            <label class="tuition-label">শিক্ষার্থীর ক্লাস</label>
            <select class="tuition-input">
              <option>প্রাথমিক (ক্লাস ১-৫)</option>
              <option>মাধ্যমিক (ক্লাস ৬-১০)</option>
              <option>এইচএসসি</option>
              <option>বিশ্ববিদ্যালয় ভর্তি প্রস্তুতি</option>
            </select>
          </div>
          <div>
            <label class="tuition-label">কোন কোন বিষয়ে দরকার</label>
            <input type="text" class="tuition-input" placeholder="যেমন: গণিত, বিজ্ঞান" />
          </div>
          <div>
            <label class="tuition-label">উপজেলা</label>
            <select class="tuition-input">
              {upazilas.map((u) => <option>{u}</option>)}
            </select>
          </div>
          <div>
            <label class="tuition-label">পড়ানোর ধরন পছন্দ</label>
            <select class="tuition-input">
              <option>বাসায় গিয়ে</option>
              <option>অনলাইন</option>
              <option>যেকোনো একটি হলেই চলবে</option>
            </select>
          </div>
          <div>
            <label class="tuition-label">মাসিক বাজেট</label>
            <input type="text" class="tuition-input" placeholder="যেমন: ৳২,০০০ - ৳৩,০০০" />
          </div>
        </div>

        <button class="tuition-submit" type="button" data-role="need">
          <i class="fas fa-paper-plane"></i> প্রয়োজন পোস্ট করুন
        </button>
      </div>
    </div>

    <p class="tuition-note"><i class="fas fa-circle-info"></i> এই মুহূর্তে ফর্মটি শুধু ডিজাইন প্রিভিউ, সাবমিট করলে এখনো ডেটা সংরক্ষণ হয় না — শীঘ্রই ফাংশনাল করা হবে।</p>

    <!-- ================= নিচে আলাদা ব্রাউজ + ফিল্টার সেকশন ================= -->
    <hr class="tuition-divider" />

    <!-- ব্রাউজ: টিউটর তালিকা -->
    <h3 style="font-size:1.6rem; margin-bottom:6px;">🧑‍🏫 উপলব্ধ টিউটর খুঁজুন</h3>
    <p style="color:#8FA0BC; font-size:0.9rem; margin-bottom:20px;">যারা "পড়াতে চাই" ফর্মে পোস্ট করেছেন, তাদের তালিকা — উপজেলা অনুযায়ী ফিল্টার করুন।</p>

    <div class="filter-row" id="tutorFilters">
      <button class="filter-btn active" data-scope="tutor" data-upazila="সব">সব উপজেলা</button>
      {upazilas.map((u) => (
        <button class="filter-btn" data-scope="tutor" data-upazila={u}>{u}</button>
      ))}
    </div>

    <div class="listing-grid" id="tutorGrid">
      {tutors.map((t) => (
        <div class="listing-card tutor-card" data-upazila={t.upazila}>
          <div class="listing-top">
            <div class="listing-avatar"><i class="fas fa-user-graduate"></i></div>
            <div>
              <p class="listing-name">{t.name}</p>
              <p class="listing-sub">{t.qualification}</p>
            </div>
          </div>
          <p class="listing-tag"><i class="fas fa-book"></i> {t.subjects}</p>
          <p class="listing-tag"><i class="fas fa-layer-group"></i> {t.classes}</p>
          <p class="listing-tag"><i class="fas fa-location-dot"></i> {t.upazila} • {t.mode}</p>
          <a href={`tel:+880${t.phone.slice(1)}`} class="btn-outline listing-call">
            <i class="fas fa-phone"></i> কল করুন
          </a>
        </div>
      ))}
    </div>

    <!-- ব্রাউজ: শিক্ষক প্রয়োজন তালিকা -->
    <h3 style="font-size:1.6rem; margin:48px 0 6px;">🙋 শিক্ষক প্রয়োজন — খোলা পোস্ট</h3>
    <p style="color:#8FA0BC; font-size:0.9rem; margin-bottom:20px;">যেসব অভিভাবক/শিক্ষার্থী শিক্ষক খুঁজছেন, তাদের পোস্ট — উপজেলা অনুযায়ী ফিল্টার করুন।</p>

    <div class="filter-row" id="requestFilters">
      <button class="filter-btn active" data-scope="request" data-upazila="সব">সব উপজেলা</button>
      {upazilas.map((u) => (
        <button class="filter-btn" data-scope="request" data-upazila={u}>{u}</button>
      ))}
    </div>

    <div class="listing-grid" id="requestGrid">
      {requests.map((r) => (
        <div class="listing-card request-card" data-upazila={r.upazila}>
          <div class="listing-top">
            <div class="listing-avatar" style="background:#F3EBFF; color:#7C3AED;"><i class="fas fa-house-user"></i></div>
            <div>
              <p class="listing-name">{r.guardian}</p>
              <p class="listing-sub">{r.studentClass}</p>
            </div>
          </div>
          <p class="listing-tag"><i class="fas fa-book"></i> {r.subject}</p>
          <p class="listing-tag"><i class="fas fa-money-bill-wave"></i> {r.budget}</p>
          <p class="listing-tag"><i class="fas fa-location-dot"></i> {r.upazila} • {r.mode}</p>
          <a href={`tel:+880${r.phone.slice(1)}`} class="btn-outline listing-call">
            <i class="fas fa-phone"></i> কল করুন
          </a>
        </div>
      ))}
    </div>

    <div style="margin-top:56px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>

  </div>

  <style>
    /* ===== ক্যাটাগরি ট্যাব ===== */
    .tuition-tabs {
      display: inline-flex;
      background: #F4F7FC;
      border-radius: 40px;
      padding: 5px;
      margin-bottom: 28px;
      gap: 4px;
    }
    .tuition-tab {
      border: none;
      background: transparent;
      padding: 12px 24px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.92rem;
      color: #5A6E85;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: all 0.2s ease;
    }
    .tuition-tab.active {
      background: #1B2A4A;
      color: #fff;
    }

    /* ===== ফর্ম ===== */
    .tuition-form-pane {
      display: none;
    }
    .tuition-form-pane.active {
      display: block;
      animation: fadeIn 0.2s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; } to { opacity: 1; }
    }
    .tuition-form-card {
      background: #fff;
      padding: 32px;
      border-radius: 24px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.04);
      border: 1px solid #EEE;
      max-width: 820px;
    }
    .tuition-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 18px;
    }
    .tuition-label {
      display: block;
      font-size: 0.82rem;
      font-weight: 600;
      color: #1B2A4A;
      margin-bottom: 6px;
    }
    .tuition-input {
      width: 100%;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1.5px solid #E5EAF0;
      font-size: 0.9rem;
      font-family: inherit;
      color: #1B2A4A;
      background: #FBFCFE;
    }
    .tuition-input:focus {
      outline: none;
      border-color: #FF6B35;
      background: #fff;
      box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.1);
    }
    .tuition-submit {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #FF6B35;
      color: #fff;
      border: none;
      padding: 14px 28px;
      border-radius: 40px;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      margin-top: 24px;
      box-shadow: 0 10px 24px rgba(255, 107, 53, 0.25);
    }
    .tuition-note {
      color: #B0BCCB;
      font-size: 0.8rem;
      margin-top: 16px;
      max-width: 820px;
    }
    .tuition-divider {
      border: none;
      border-top: 1px solid #EEF3F9;
      margin: 48px 0 40px;
    }

    /* ===== ফিল্টার ===== */
    .filter-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 24px;
    }
    .filter-btn {
      background: #fff;
      border: 1px solid #E5EAF0;
      color: #4A5B6E;
      padding: 8px 20px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.86rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .filter-btn:hover {
      border-color: #FF6B35;
      color: #FF6B35;
    }
    .filter-btn.active {
      background: #FF6B35;
      border-color: #FF6B35;
      color: #fff;
    }

    /* ===== লিস্টিং কার্ড ===== */
    .listing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 20px;
      margin-bottom: 12px;
    }
    .listing-card {
      background: #fff;
      padding: 22px;
      border-radius: 20px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.04);
      border: 1px solid #EEE;
    }
    .listing-top {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
    }
    .listing-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: #FFF0EA;
      color: #FF6B35;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .listing-name {
      font-weight: 700;
      color: #1B2A4A;
    }
    .listing-sub {
      color: #8FA0BC;
      font-size: 0.82rem;
    }
    .listing-tag {
      color: #5A6E85;
      font-size: 0.86rem;
      margin-bottom: 6px;
    }
    .listing-call {
      justify-content: center;
      width: 100%;
      padding: 9px 20px;
      font-size: 0.88rem;
      margin-top: 12px;
    }
  </style>

  <script>
    // ===== ক্যাটাগরি ট্যাব সুইচ (পড়াতে চাই / শিক্ষক লাগবে) =====
    const tuitionTabs = document.querySelectorAll('.tuition-tab');
    const tuitionPanes = document.querySelectorAll('.tuition-form-pane');

    tuitionTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tuitionTabs.forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
        const target = tab.getAttribute('data-tab');
        tuitionPanes.forEach((pane) => {
          pane.classList.toggle('active', pane.id === `${target}Pane`);
        });
      });
    });

    // ===== ডেমো সাবমিট (UI only, ব্যাকএন্ড নেই এখনো) =====
    document.querySelectorAll('.tuition-submit').forEach((btn) => {
      btn.addEventListener('click', () => {
        const role = btn.getAttribute('data-role');
        const msg = role === 'teach'
          ? 'ধন্যবাদ! টিউটর ফর্ম গ্রহণ করা হয়েছে (ডেমো) — শীঘ্রই সরাসরি তালিকায় যুক্ত হবে।'
          : 'ধন্যবাদ! আপনার প্রয়োজন গ্রহণ করা হয়েছে (ডেমো) — শীঘ্রই সরাসরি তালিকায় যুক্ত হবে।';
        alert(msg);
      });
    });

    // ===== উপজেলা ফিল্টার (টিউটর ও রিকোয়েস্ট আলাদাভাবে) =====
    function setupFilter(scope, gridId) {
      const buttons = document.querySelectorAll(`.filter-btn[data-scope="${scope}"]`);
      const cards = document.querySelectorAll(`#${gridId} .listing-card`);

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          buttons.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          const selected = btn.getAttribute('data-upazila');
          cards.forEach((card) => {
            const cardUpazila = card.getAttribute('data-upazila');
            card.style.display = selected === 'সব' || cardUpazila === selected ? '' : 'none';
          });
        });
      });
    }

    setupFilter('tutor', 'tutorGrid');
    setupFilter('request', 'requestGrid');
  </script>
</BaseLayout>