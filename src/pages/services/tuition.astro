---
import BaseLayout from '../../components/layout/BaseLayout.astro';
---
<BaseLayout title="টিউশন সেবা">
  <div class="container" style="padding-top:60px; min-height:70vh;">
    <h1 style="font-size:2.8rem; margin-bottom:20px;">📚 টিউশন সেবা</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:700px; margin-bottom:40px;">
      টিউটর খুঁজুন, শিক্ষার্থী খুঁজুন—শিক্ষা সংক্রান্ত সব সেবা এখানে। আপনার প্রয়োজনমতো এক্সপেরিমেন্ট করুন।
    </p>
    
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px,1fr)); gap:24px;">
      <div style="background:#fff; padding:24px; border-radius:20px; box-shadow:0 4px 16px rgba(0,0,0,0.04); border:1px solid #EEE;">
        <h3>গণিত টিউটর</h3>
        <p style="color:#FF6B35; font-weight:600;">ক্লাস ৯-১০</p>
        <p style="color:#5A6E85; margin:8px 0;">বাড্ডা, ঢাকা</p>
        <span style="background:#EFF5FF; padding:4px 16px; border-radius:40px; font-size:0.8rem;">বুয়েট ছাত্র</span>
      </div>
      <div style="background:#fff; padding:24px; border-radius:20px; box-shadow:0 4px 16px rgba(0,0,0,0.04); border:1px solid #EEE;">
        <h3>ইংরেজি টিউটর</h3>
        <p style="color:#FF6B35; font-weight:600;">ক্লাস ৬-৮</p>
        <p style="color:#5A6E85; margin:8px 0;">মিরপুর, ঢাকা</p>
        <span style="background:#EFF5FF; padding:4px 16px; border-radius:40px; font-size:0.8rem;">ইংরেজি সাহিত্যে স্নাতক</span>
      </div>
    </div>

    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>
  </div>
</BaseLayout>