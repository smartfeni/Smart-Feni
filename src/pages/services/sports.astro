---
// ============================================================
// পেজ: খেলাধুলা ও ইভেন্ট সেবা
// ব্র্যান্ড: স্মার্ট ফেনী
// প্যাটার্ন: recycle/courier পেজের মতো হেডার CTA, সার্চ বক্স,
// কার্ড গ্রিড, লোকেশন সর্ট, এবং ডিটেইল মডাল
// শেয়ারড 'listings' টেবিল ব্যবহার করে (category = 'sports')
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AddListingModal from '../../components/ui/AddListingModal.astro';
import ListingDetailModal from '../../components/ui/ListingDetailModal.astro';
import { supabase } from '../../lib/supabase.js';

// ইভেন্ট টাইপ (খেলা/ওয়াজ/সাংস্কৃতিক ইত্যাদি)
const typeOptions = [
  { id: 'sports', label: 'খেলা' },
  { id: 'religious', label: 'ওয়াজ মাহফিল' },
  { id: 'cultural', label: 'সাংস্কৃতিক' },
  { id: 'education', label: 'শিক্ষা' },
  { id: 'health', label: 'স্বাস্থ্য' },
  { id: 'other', label: 'অন্যান্য' },
];

const typeNameMap = Object.fromEntries(typeOptions.map((t) => [t.id, t.label]));

const typeIcons = {
  sports: 'fa-futbol',
  religious: 'fa-mosque',
  cultural: 'fa-music',
  education: 'fa-graduation-cap',
  health: 'fa-heartbeat',
  other: 'fa-calendar-alt',
};

// listings টেবিল থেকে শুধু sports ক্যাটাগরির ডেটা আনা
const { data: sportsListings } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'sports')
  .eq('status', 'active')
  .order('created_at', { ascending: false });

const events = sportsListings || [];
---

<BaseLayout title="খেলাধুলা ও ইভেন্ট | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-calendar-check"></i> ইভেন্ট কর্নার</span>
      <h1>ফেনীতে <span class="accent">খেলা ও ইভেন্ট</span></h1>
      <p>খেলা, ওয়াজ মাহফিল, সাংস্কৃতিক অনুষ্ঠান — ফেনীর সকল পাবলিক ইভেন্ট এখানে</p>
      <button class="cta-box" id="openAddListing" type="button">
        <i class="fas fa-plus"></i> নতুন ইভেন্ট জমা দিন
      </button>
    </div>
  </section>

  <section class="event-section">
    <div class="container">
      <!-- সার্চ বক্স (recycle/courier-এর মতো) -->
      <div class="search-box">
        <i class="fas fa-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="ইভেন্টের নাম বা স্থান খুঁজুন..." />
      </div>

      {events.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-calendar-plus"></i>
          <p>এখনো কোনো ইভেন্ট তালিকাভুক্ত হয়নি</p>
          <span>আপনার ইভেন্টটি জমা দিন এবং ফেনীবাসীকে জানান</span>
        </div>
      ) : (
        <>
          <div class="sports-grid" id="sportsGrid">
            {events.map((item, i) => (
              <button
                type="button"
                class="sports-card"
                data-detail-index={i}
                data-upazila-name={item.upazila || ''}
                data-search={`${item.title || ''} ${item.description || ''} ${item.type || ''}`.toLowerCase()}
              >
                {item.images && item.images.length > 0 ? (
                  <img src={item.images[0]} alt={item.title} class="event-photo" />
                ) : (
                  <div class="event-icon">
                    <i class={`fas ${typeIcons[item.type] || 'fa-calendar-alt'}`}></i>
                  </div>
                )}

                <div class="event-card-body">
                  <span class={`type-badge type-${item.type}`}>{typeNameMap[item.type] || item.type}</span>
                  <h3 class="event-title">{item.title}</h3>
                  {item.price && <p class="event-date"><i class="fas fa-calendar-day"></i> {item.price}</p>}
                  <p class="location-tag"><i class="fas fa-location-dot"></i> {item.upazila}</p>
                </div>
              </button>
            ))}
          </div>

          <p class="no-results" id="noResults" style="display:none;">কোনো ইভেন্ট পাওয়া যায়নি</p>
        </>
      )}
    </div>
  </section>

  <ListingDetailModal />
  <AddListingModal category="sports" typeOptions={typeOptions} />

  <script type="application/json" id="listingsData" set:html={JSON.stringify(events)} />
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    margin-bottom: 20px;
  }

  .section-tag {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #FF6B35;
    background: #FFF0EA;
    padding: 4px 14px;
    border-radius: 40px;
    margin-bottom: 6px;
  }

  .cta-box {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFF0EA;
    border: 1.5px solid #FFD3BC;
    color: #FF6B35;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 12px 26px;
    border-radius: 40px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cta-box:hover {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
    transform: translateY(-2px);
  }

  .event-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .search-box {
    max-width: 480px;
    margin: 0 auto 32px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 40px;
    padding: 12px 20px;
  }

  .search-box i {
    color: #A0AFC0;
  }

  .search-box input {
    border: none;
    outline: none;
    flex: 1;
    font-size: 0.9rem;
    font-family: inherit;
    background: transparent;
    color: #1B2A4A;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 20px;
  }

  .sports-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }

  .sports-card {
    background: #fff;
    border-radius: 18px;
    border: 1px solid #EEF3F9;
    padding: 0;
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .sports-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .sports-card.hidden {
    display: none;
  }

  .event-icon {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }

  .event-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .event-card-body {
    padding: 14px;
  }

  .type-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 6px;
    background: #F4F7FC;
    color: #5A6E85;
  }

  .type-badge.type-sports { background: #D1FAE5; color: #065F46; }
  .type-badge.type-religious { background: #FEF3C7; color: #92400E; }
  .type-badge.type-cultural { background: #FCE7F3; color: #9D174D; }
  .type-badge.type-education { background: #DBEAFE; color: #1E40AF; }
  .type-badge.type-health { background: #FEE2E2; color: #991B1B; }

  .event-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .event-date {
    font-size: 0.82rem;
    color: #FF6B35;
    font-weight: 600;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .location-tag {
    font-size: 0.72rem;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .no-results {
    text-align: center;
    color: #A0AFC0;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 1.7rem;
    }
    .sports-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
  }
</style>

<script>
  import { initListingDetailModal } from '../../lib/listingDetailModal.js';
  import { reorderByUserLocation } from '../../lib/locationSort.js';

  const typeNameMap = {
    sports: 'খেলা',
    religious: 'ওয়াজ মাহফিল',
    cultural: 'সাংস্কৃতিক',
    education: 'শিক্ষা',
    health: 'স্বাস্থ্য',
    other: 'অন্যান্য'
  };

  const typeIcons = {
    sports: 'fa-futbol',
    religious: 'fa-mosque',
    cultural: 'fa-music',
    education: 'fa-graduation-cap',
    health: 'fa-heartbeat',
    other: 'fa-calendar-alt'
  };

  const dataEl = document.getElementById('listingsData');
  const events = dataEl ? JSON.parse(dataEl.textContent) : [];

  const grid = document.getElementById('sportsGrid');
  const cards = document.querySelectorAll('.sports-card');
  const searchInput = document.getElementById('searchInput');
  const noResults = document.getElementById('noResults');

  if (searchInput && cards.length) {
    searchInput.addEventListener('input', () => {
      const keyword = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const matches = keyword === '' || (card.dataset.search || '').includes(keyword);
        if (matches) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      if (noResults) {
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    });
  }

  initListingDetailModal({ listings: events, typeNameMap, typeIcons, cardSelector: '.sports-card' });
  reorderByUserLocation(grid, 'upazilaName');

  document.getElementById('openAddListing')?.addEventListener('click', () => {
    window.openListingModal?.();
  });
</script>