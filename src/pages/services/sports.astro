---
import BaseLayout from '../../components/layout/BaseLayout.astro';
---
<BaseLayout title="খেলাধুলা সেবা">
  <div class="container" style="padding-top:60px; min-height:70vh;">
    <h1 style="font-size:2.8rem; margin-bottom:20px;">⚽ খেলাধুলা সেবা</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:700px; margin-bottom:40px;">
      খেলার মাঠ, টিম, ইভেন্ট—সব খেলা সংক্রান্ত সেবা এখানে।
    </p>
    
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(250px,1fr)); gap:20px;">
      <div style="background:#fff; padding:20px; border-radius:16px; border:1px solid #EEE;">
        <h4>⚽ ফুটবল টিম</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">শনিবার, সকাল ৭টা</p>
        <span style="background:#EFF5FF; padding:4px 16px; border-radius:40px; font-size:0.8rem;">মিরপুর স্টেডিয়াম</span>
      </div>
      <div style="background:#fff; padding:20px; border-radius:16px; border:1px solid #EEE;">
        <h4>🏏 ক্রিকেট টিম</h4>
        <p style="color:#5A6E85; font-size:0.9rem;">শুক্রবার, বিকাল ৩টা</p>
        <span style="background:#EFF5FF; padding:4px 16px; border-radius:40px; font-size:0.8rem;">ধানমন্ডি মাঠ</span>
      </div>
    </div>

    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>
  </div>
</BaseLayout>