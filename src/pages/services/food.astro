---
import BaseLayout from '../../components/layout/BaseLayout.astro';
---
<BaseLayout title="খাবার সেবা">
  <div class="container" style="padding-top:60px; min-height:70vh;">
    <h1 style="font-size:2.8rem; margin-bottom:20px;">🍽️ খাবার সেবা</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:700px; margin-bottom:40px;">
      রেস্টুরেন্ট মেনু, ফুড ডেলিভারি—খাবার সংক্রান্ত সব সেবা এখানে। আপনার পছন্দমতো এক্সপেরিমেন্ট করুন।
    </p>
    
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(250px,1fr)); gap:20px;">
      <div style="background:#fff; padding:20px; border-radius:16px; border:1px solid #EEE;">
        <h4>🍕 পিৎজা হাট</h4>
        <p style="color:#FF6B35; font-weight:600;">৩০% ছাড়</p>
        <p style="color:#5A6E85; font-size:0.9rem;">ধানমন্ডি</p>
      </div>
      <div style="background:#fff; padding:20px; border-radius:16px; border:1px solid #EEE;">
        <h4>🍔 বার্গার কিং</h4>
        <p style="color:#FF6B35; font-weight:600;">কম্বো অফার</p>
        <p style="color:#5A6E85; font-size:0.9rem;">মিরপুর</p>
      </div>
    </div>

    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>
  </div>
</BaseLayout>