---
import BaseLayout from '../../components/layout/BaseLayout.astro';
---
<BaseLayout title="হোম মেস ফুড | স্মার্ট ফেনী">
  <div class="container" style="padding-top:60px; min-height:70vh; padding-bottom:60px;">

    <h1 style="font-size:2.8rem; margin-bottom:16px;">🍱 হোম মেস ফুড</h1>
    <p style="font-size:1.2rem; color:#4A5B6E; max-width:750px; margin-bottom:8px;">
      ফেনী শহরে চাকরি, ব্যবসা কিংবা পড়াশোনার সূত্রে মেসে বা হোস্টেলে থাকেন? অথবা দুপুরে-রাতে কাজের কারণে ফেনীতেই থাকতে হয়?
      এখন আর হোটেলের তেল-মশলার খাবার নয় — পাবেন একদম <strong>মায়ের হাতের রান্নার আসল স্বাদ</strong>, সরাসরি আমাদের নিবন্ধিত হোম মেস থেকে।
    </p>

    <!-- বিশ্বস্ততার ব্যাজ -->
    <div style="display:flex; flex-wrap:wrap; gap:12px; margin:24px 0 40px;">
      <span style="background:#FFF0EA; color:#FF6B35; padding:8px 20px; border-radius:40px; font-weight:600; font-size:0.9rem;">
        <i class="fas fa-check-circle"></i> ১০০% অথেনটিক গৃহিণীর হাতের রান্না
      </span>
      <span style="background:#EFF5FF; color:#1B2A4A; padding:8px 20px; border-radius:40px; font-weight:600; font-size:0.9rem;">
        <i class="fas fa-leaf"></i> প্রতিদিন তাজা ও ঘরোয়া উপকরণ
      </span>
      <span style="background:#EAFBF0; color:#1B7A3C; padding:8px 20px; border-radius:40px; font-weight:600; font-size:0.9rem;">
        <i class="fas fa-truck"></i> গরম গরম হোম ডেলিভারি
      </span>
    </div>

    <!-- অফার কার্ডসমূহ -->
    <h3 style="font-size:1.6rem; margin-bottom:20px;">🍽️ মিল প্যাকেজ ও দাম</h3>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px,1fr)); gap:24px; margin-bottom:48px;">

      <!-- প্রতি মিল -->
      <div style="background:#fff; padding:28px 24px; border-radius:20px; box-shadow:0 4px 16px rgba(0,0,0,0.04); border:1px solid #EEE;">
        <div style="width:48px; height:48px; background:#FFF0EA; border-radius:14px; display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
          <i class="fas fa-bowl-food" style="color:#FF6B35; font-size:1.3rem;"></i>
        </div>
        <h3 style="margin-bottom:6px;">প্রতি মিল</h3>
        <p style="color:#5A6E85; font-size:0.9rem; margin-bottom:16px;">যখন প্রয়োজন তখন অর্ডার করুন</p>
        <p style="font-size:1.8rem; font-weight:700; color:#FF6B35;">৳১০০<span style="font-size:0.95rem; color:#5A6E85; font-weight:500;"> / মিল</span></p>
      </div>

      <!-- ১ বেলা দৈনিক -->
      <div style="background:#fff; padding:28px 24px; border-radius:20px; box-shadow:0 4px 16px rgba(0,0,0,0.04); border:2px solid #FF6B35; position:relative;">
        <span style="position:absolute; top:-14px; right:20px; background:#FF6B35; color:#fff; padding:4px 16px; border-radius:40px; font-size:0.75rem; font-weight:600;">জনপ্রিয়</span>
        <div style="width:48px; height:48px; background:#FFF0EA; border-radius:14px; display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
          <i class="fas fa-calendar-day" style="color:#FF6B35; font-size:1.3rem;"></i>
        </div>
        <h3 style="margin-bottom:6px;">১ বেলা দৈনিক</h3>
        <p style="color:#5A6E85; font-size:0.9rem; margin-bottom:16px;">মাসিক প্যাকেজ (দুপুর অথবা রাত)</p>
        <p style="font-size:1.8rem; font-weight:700; color:#FF6B35;">৳২,০০০<span style="font-size:0.95rem; color:#5A6E85; font-weight:500;"> / মাস</span></p>
      </div>

      <!-- ২ বেলা দৈনিক -->
      <div style="background:#fff; padding:28px 24px; border-radius:20px; box-shadow:0 4px 16px rgba(0,0,0,0.04); border:1px solid #EEE;">
        <div style="width:48px; height:48px; background:#FFF0EA; border-radius:14px; display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
          <i class="fas fa-calendar-week" style="color:#FF6B35; font-size:1.3rem;"></i>
        </div>
        <h3 style="margin-bottom:6px;">২ বেলা দৈনিক</h3>
        <p style="color:#5A6E85; font-size:0.9rem; margin-bottom:16px;">মাসিক প্যাকেজ (দুপুর ও রাত)</p>
        <p style="font-size:1.8rem; font-weight:700; color:#FF6B35;">৳৩,৫০০<span style="font-size:0.95rem; color:#5A6E85; font-weight:500;"> / মাস</span></p>
      </div>

    </div>

    <!-- বিস্তারিত -->
    <div style="background:#fff; padding:32px; border-radius:24px; box-shadow:0 4px 16px rgba(0,0,0,0.04); max-width:800px; margin-bottom:40px;">
      <h3 style="margin-bottom:14px;"><i class="fas fa-circle-info" style="color:#FF6B35;"></i> কেন হোম মেস ফুড বেছে নেবেন?</h3>
      <ul style="color:#4A5B6E; line-height:1.9; padding-left:20px;">
        <li>হোটেলের বাসি-বাসি খাবার নয়, প্রতিদিন তৈরি হয় বাসার মতো টাটকা রান্না</li>
        <li>অতিরিক্ত তেল-মশলা ছাড়া স্বাস্থ্যসম্মত ও ঘরোয়া স্বাদ</li>
        <li>নির্ধারিত সময়ে গরম খাবার পৌঁছে যাবে আপনার মেস বা কর্মস্থলে</li>
        <li>মাসিক প্যাকেজে বাঁচবে সময় ও টাকা দুটোই</li>
      </ul>
    </div>

    <!-- যোগাযোগ -->
    <div style="background:#1B2A4A; color:#fff; padding:36px; border-radius:24px; max-width:800px;">
      <h3 style="margin-bottom:10px;">📞 অর্ডার করতে যোগাযোগ করুন</h3>
      <p style="color:#C9D4E3; margin-bottom:20px;">আপনার পছন্দের প্যাকেজ বলুন, আজই শুরু করুন মায়ের হাতের রান্নার স্বাদ নেওয়া।</p>
      <a href="tel:+8801812345678" class="btn-primary" style="background:#FF6B35;">
        <i class="fas fa-phone"></i> ০১৮১২-৩৪৫৬৭৮
      </a>
      <p style="color:#8FA0BC; font-size:0.85rem; margin-top:14px;">* এটি একটি নমুনা নম্বর, চূড়ান্ত যোগাযোগ নম্বর শীঘ্রই যুক্ত করা হবে।</p>
    </div>

    <div style="margin-top:50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>

  </div>
</BaseLayout>