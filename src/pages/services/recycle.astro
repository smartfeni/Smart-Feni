---
// ============================================================
// পেজ: রিসাইকেল মার্কেটপ্লেস (পুরাতন জিনিস বিক্রয়)
// ব্র্যান্ড: স্মার্ট ফেনী
// Supabase থেকে রিয়েল লিস্টিং ডেটা fetch করা হয় (mock ডেটা বাদ)
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AddListingModal from '../../components/ui/AddListingModal.astro';
import { supabase } from '../../lib/supabase.js';

const typeOptions = [
  { id: 'mobile', label: 'মোবাইল' },
  { id: 'bike', label: 'বাইক' },
  { id: 'electronics', label: 'ইলেকট্রনিক্স' },
  { id: 'furniture', label: 'আসবাবপত্র' },
  { id: 'other', label: 'অন্যান্য' },
];

const typeNameMap = Object.fromEntries(typeOptions.map((t) => [t.id, t.label]));

const typeIcons = {
  mobile: 'fa-mobile-screen',
  bike: 'fa-motorcycle',
  electronics: 'fa-plug',
  furniture: 'fa-couch',
  other: 'fa-box',
};

const { data: recycleListings } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'recycle')
  .eq('status', 'active')
  .order('created_at', { ascending: false });

const listings = recycleListings || [];

const filters = [{ id: 'all', label: 'সব' }, ...typeOptions];
---

<BaseLayout title="রিসাইকেল মার্কেটপ্লেস | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-recycle"></i> রিসাইকেল মার্কেট</span>
      <h1>পুরাতন জিনিস <span class="accent">কেনা-বেচা</span></h1>
      <p>মোবাইল, বাইক, ইলেকট্রনিক্স, আসবাবপত্র — খুঁজুন অথবা বিক্রি করুন সহজে</p>
      <button class="post-item-link" id="openAddListing" type="button">
        <i class="fas fa-plus"></i> পুরাতন জিনিস বিক্রি করতে চান?
      </button>
    </div>
  </section>

  <section class="recycle-section">
    <div class="container">
      <div class="search-box">
        <i class="fas fa-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="মোবাইল, বাইক বা যেকোনো কিছু খুঁজুন..." />
      </div>

      <div class="filter-tabs" id="filterTabs">
        {filters.map((f) => (
          <button class={`filter-tab ${f.id === 'all' ? 'active' : ''}`} data-filter={f.id}>
            {f.label}
          </button>
        ))}
      </div>

      {listings.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-box-open"></i>
          <p>এখনো কোনো লিস্টিং যোগ হয়নি</p>
          <span>প্রথম লিস্টিং যোগ করুন উপরের বাটনে ক্লিক করে</span>
        </div>
      ) : (
        <>
          <div class="recycle-grid" id="recycleGrid">
            {listings.map((item) => (
              <div
                class="recycle-card"
                data-type={item.type}
                data-search={`${item.title || ''} ${item.description || ''}`.toLowerCase()}
              >
                <div class="recycle-card-top">
                  <span class={`type-badge type-${item.type}`}>{typeNameMap[item.type] || item.type}</span>
                  <span class="location-tag">
                    <i class="fas fa-location-dot"></i> {item.upazila}
                  </span>
                </div>

                {item.images && item.images.length > 0 ? (
                  <img src={item.images[0]} alt={item.title} class="recycle-photo" />
                ) : (
                  <div class="recycle-icon">
                    <i class={`fas ${typeIcons[item.type] || 'fa-box'}`}></i>
                  </div>
                )}

                <h3 class="recycle-title">{item.title}</h3>
                {item.description && <p class="recycle-desc">{item.description}</p>}
                {item.price && (
                  <p class="recycle-price"><i class="fas fa-coins"></i> {item.price}</p>
                )}

                <a href={`tel:${item.contact_phone}`} class="btn-contact">
                  <i class="fas fa-phone"></i> যোগাযোগ করুন
                </a>
              </div>
            ))}
          </div>

          <p class="no-results" id="noResults" style="display:none;">কোনো ফলাফল পাওয়া যায়নি</p>
        </>
      )}
    </div>
  </section>

  <AddListingModal category="recycle" typeOptions={typeOptions} />
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    margin-bottom: 14px;
  }

  .post-item-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    color: #FF6B35;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    padding: 4px 0;
  }

  .post-item-link:hover {
    text-decoration: underline;
  }

  .recycle-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .search-box {
    max-width: 480px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 40px;
    padding: 12px 20px;
  }

  .search-box i {
    color: #A0AFC0;
  }

  .search-box input {
    border: none;
    outline: none;
    flex: 1;
    font-size: 0.9rem;
    font-family: inherit;
    background: transparent;
    color: #1B2A4A;
  }

  .filter-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 32px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .filter-tab {
    background: #fff;
    border: 1px solid #EEF3F9;
    color: #1B2A4A;
    padding: 10px 24px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-tab:hover {
    border-color: #FF6B35;
  }

  .filter-tab.active {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .recycle-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .recycle-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .recycle-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .recycle-card.hidden {
    display: none;
  }

  .recycle-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    gap: 8px;
  }

  .type-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .type-mobile { background: rgba(9, 132, 227, 0.12); color: #0984E3; }
  .type-bike { background: rgba(0, 184, 148, 0.12); color: #00B894; }
  .type-electronics { background: rgba(108, 92, 231, 0.12); color: #6C5CE7; }
  .type-furniture { background: rgba(214, 132, 62, 0.15); color: #A0522D; }
  .type-other { background: rgba(253, 203, 110, 0.18); color: #B7791F; }

  .location-tag {
    font-size: 0.75rem;
    color: #7A8EA5;
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  .recycle-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 12px;
  }

  .recycle-photo {
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: 14px;
    margin-bottom: 12px;
  }

  .recycle-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .recycle-desc {
    color: #5A6E85;
    font-size: 0.85rem;
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .recycle-price {
    color: #FF6B35;
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 16px;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FF6B35;
  }

  .no-results {
    text-align: center;
    color: #A0AFC0;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  @media (max-width: 768px) {
    .recycle-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.recycle-card');
  const searchInput = document.getElementById('searchInput');
  const noResults = document.getElementById('noResults');

  let activeFilter = 'all';

  function applyFilters() {
    const keyword = (searchInput?.value || '').trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matchesType = activeFilter === 'all' || card.dataset.type === activeFilter;
      const matchesKeyword = keyword === '' || (card.dataset.search || '').includes(keyword);

      if (matchesType && matchesKeyword) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      activeFilter = tab.dataset.filter;
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', applyFilters);

  document.getElementById('openAddListing')?.addEventListener('click', () => {
    window.openListingModal?.();
  });
</script>