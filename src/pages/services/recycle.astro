---
// ============================================================
// পেজ: রিসাইকেল মার্কেটপ্লেস (কেনা-বেচা)
// ব্র্যান্ড: স্মার্ট ফেনী
// ============================================================

import BaseLayout from '../../components/layout/BaseLayout.astro';

// প্লেসহোল্ডার ডেটা — পরে ডাটাবেজ থেকে আসবে, আপাতত mock ডেটা দিয়ে UI সাজানো হচ্ছে
const listings = [
  { id: 1, deal: 'sell', category: 'মোবাইল', title: 'স্যামসাং গ্যালাক্সি A52', price: '১৮,০০০', upazila: 'ফেনী সদর', name: 'রফিকুল ইসলাম', phone: '01711223344' },
  { id: 2, deal: 'buy', category: 'বাইক', title: 'ব্যবহৃত বাইক খুঁজছি (১২৫সিসি)', price: '৭০,০০০ পর্যন্ত', upazila: 'ছাগলনাইয়া', name: 'কামাল হোসেন', phone: '01711223355' },
  { id: 3, deal: 'sell', category: 'ইলেকট্রনিক্স', title: 'ওয়ালটন ফ্রিজ (২৫০ লিটার)', price: '২২,০০০', upazila: 'দাগনভূঞা', name: 'আব্দুল করিম', phone: '01711223366' },
  { id: 4, deal: 'sell', category: 'বাইক', title: 'হিরো হোন্ডা স্প্লেন্ডার', price: '৫৫,০০০', upazila: 'পরশুরাম', name: 'শাহাদাত হোসেন', phone: '01711223377' },
  { id: 5, deal: 'buy', category: 'মোবাইল', title: 'আইফোন খুঁজছি (যেকোনো মডেল)', price: '৩০,০০০ পর্যন্ত', upazila: 'ফুলগাজী', name: 'জসিম উদ্দিন', phone: '01711223388' },
  { id: 6, deal: 'sell', category: 'আসবাবপত্র', title: 'কাঠের সোফা সেট (৫ সিটার)', price: '১৫,০০০', upazila: 'সোনাগাজী', name: 'নুরুল আমিন', phone: '01711223399' },
  { id: 7, deal: 'buy', category: 'ইলেকট্রনিক্স', title: 'পুরাতন এসি কিনতে চাই', price: '২৫,০০০ পর্যন্ত', upazila: 'ফেনী সদর', name: 'মিজানুর রহমান', phone: '01711223400' },
  { id: 8, deal: 'sell', category: 'অন্যান্য', title: 'সাইকেল (ভালো অবস্থা)', price: '৩,৫০০', upazila: 'দাগনভূঞা', name: 'ফরহাদ হোসেন', phone: '01711223411' },
];
---

<BaseLayout title="রিসাইকেল মার্কেটপ্লেস | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <h1>রিসাইকেল <span class="accent">মার্কেটপ্লেস</span></h1>
      <p>পুরাতন জিনিস কেনা-বেচা করুন সহজে — মোবাইল, বাইক, ইলেকট্রনিক্স, আসবাবপত্র আরও অনেক কিছু</p>
      <a href="#post-form" class="btn-post-ad">
        <i class="fas fa-plus"></i> বিজ্ঞাপন দিন
      </a>
    </div>
  </section>

  <!-- বিজ্ঞাপন পোস্ট ফর্ম -->
  <section class="form-section" id="post-form">
    <div class="container">
      <div class="post-form-card">
        <div class="deal-toggle">
          <button type="button" class="deal-toggle-btn active" data-deal="sell">
            <i class="fas fa-tag"></i> বিক্রি করতে চাই
          </button>
          <button type="button" class="deal-toggle-btn" data-deal="buy">
            <i class="fas fa-magnifying-glass-dollar"></i> কিনতে চাই
          </button>
        </div>

        <form class="post-form">
          <div class="form-row">
            <label for="itemTitle" id="itemTitleLabel">আইটেমের নাম</label>
            <input type="text" id="itemTitle" placeholder="যেমন: স্যামসাং গ্যালাক্সি A52" />
          </div>

          <div class="form-row-split">
            <div class="form-row">
              <label for="itemCategory">ক্যাটাগরি</label>
              <select id="itemCategory">
                <option>মোবাইল</option>
                <option>বাইক</option>
                <option>ইলেকট্রনিক্স</option>
                <option>আসবাবপত্র</option>
                <option>অন্যান্য</option>
              </select>
            </div>
            <div class="form-row">
              <label for="itemPrice" id="itemPriceLabel">দাম (টাকা)</label>
              <input type="text" id="itemPrice" placeholder="যেমন: ১৮,০০০" />
            </div>
          </div>

          <div class="form-row">
            <label for="itemDesc">বিস্তারিত বর্ণনা</label>
            <textarea id="itemDesc" rows="3" placeholder="অবস্থা, ব্যবহারের সময়কাল ইত্যাদি লিখুন"></textarea>
          </div>

          <div class="form-row-split">
            <div class="form-row">
              <label for="itemUpazila">উপজেলা</label>
              <select id="itemUpazila">
                <option>ফেনী সদর</option>
                <option>ছাগলনাইয়া</option>
                <option>দাগনভূঞা</option>
                <option>পরশুরাম</option>
                <option>ফুলগাজী</option>
                <option>সোনাগাজী</option>
              </select>
            </div>
            <div class="form-row">
              <label for="itemPhone">ফোন নাম্বার</label>
              <input type="tel" id="itemPhone" placeholder="01XXXXXXXXX" />
            </div>
          </div>

          <button type="button" class="btn-submit-ad" id="submitAdBtn">
            <i class="fas fa-paper-plane" id="submitAdIcon"></i> <span id="submitAdText">বিজ্ঞাপন পোস্ট করুন (বিক্রয়)</span>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- সার্চ + ফিল্টার + লিস্টিং -->
  <section class="listing-section">
    <div class="container">
      <div class="search-filter-bar">
        <div class="search-box">
          <i class="fas fa-magnifying-glass"></i>
          <input type="text" id="searchInput" placeholder="মোবাইল, বাইক বা যেকোনো কিছু খুঁজুন..." />
        </div>
        <div class="filter-tabs" id="filterTabs">
          <button class="filter-tab active" data-filter="all">সব</button>
          <button class="filter-tab" data-filter="sell">বিক্রয়</button>
          <button class="filter-tab" data-filter="buy">ক্রয়</button>
        </div>
      </div>

      <div class="listing-grid" id="listingGrid">
        {listings.map((item) => (
          <div class="listing-card" data-deal={item.deal} data-title={item.title.toLowerCase()} data-category={item.category.toLowerCase()}>
            <div class="listing-card-top">
              <span class={`deal-badge deal-${item.deal}`}>
                {item.deal === 'sell' ? 'বিক্রয়' : 'ক্রয়'}
              </span>
              <span class="location-tag">
                <i class="fas fa-location-dot"></i> {item.upazila}
              </span>
            </div>

            <span class="category-tag">{item.category}</span>
            <h3 class="listing-title">{item.title}</h3>
            <p class="listing-price">৳{item.price}</p>

            <div class="poster-row">
              <div class="poster-avatar">{item.name.charAt(0)}</div>
              <div class="poster-info">
                <p class="poster-name">{item.name}</p>
              </div>
            </div>

            <a href={`tel:${item.phone}`} class="btn-contact">
              <i class="fas fa-phone"></i> যোগাযোগ করুন
            </a>
          </div>
        ))}
      </div>

      <p class="no-results" id="noResults" style="display:none;">কোনো ফলাফল পাওয়া যায়নি</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto 24px;
  }

  .btn-post-ad {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 40px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .btn-post-ad:hover {
    background: #e85a28;
    transform: translateY(-2px);
  }

  /* ফর্ম সেকশন */
  .form-section {
    padding: 20px 0 50px;
    background: #fff;
  }

  .post-form-card {
    max-width: 600px;
    margin: 0 auto;
    background: #F8FAFC;
    border: 1px solid #EEF3F9;
    border-radius: 24px;
    padding: 28px;
  }

  .deal-toggle {
    display: flex;
    gap: 10px;
    margin-bottom: 24px;
    background: #EEF3F9;
    padding: 6px;
    border-radius: 40px;
  }

  .deal-toggle-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: transparent;
    border: none;
    color: #5A6E85;
    padding: 12px;
    border-radius: 34px;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .deal-toggle-btn.active {
    background: #FF6B35;
    color: #fff;
  }

  .post-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .form-row-split {
    display: flex;
    gap: 16px;
  }

  .form-row label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #1B2A4A;
  }

  .form-row input,
  .form-row select,
  .form-row textarea {
    background: #fff;
    border: 1px solid #DCE4EC;
    border-radius: 12px;
    padding: 12px 14px;
    font-size: 0.9rem;
    font-family: inherit;
    color: #1B2A4A;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus {
    border-color: #FF6B35;
  }

  .form-row textarea {
    resize: vertical;
  }

  .btn-submit-ad {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #1B2A4A;
    color: #fff;
    border: none;
    padding: 14px;
    border-radius: 40px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    margin-top: 8px;
    transition: background 0.2s ease;
  }

  .btn-submit-ad:hover {
    background: #FF6B35;
  }

  /* সার্চ + ফিল্টার */
  .listing-section {
    padding: 20px 0 70px;
    background: #F8FAFC;
  }

  .search-filter-bar {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
  }

  .search-box {
    flex: 1;
    min-width: 240px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 40px;
    padding: 12px 20px;
  }

  .search-box i {
    color: #A0AFC0;
  }

  .search-box input {
    border: none;
    outline: none;
    flex: 1;
    font-size: 0.9rem;
    font-family: inherit;
    background: transparent;
  }

  .filter-tabs {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .filter-tab {
    background: #fff;
    border: 1px solid #EEF3F9;
    color: #1B2A4A;
    padding: 10px 22px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-tab:hover {
    border-color: #FF6B35;
  }

  .filter-tab.active {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  /* লিস্টিং কার্ড */
  .listing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
  }

  .listing-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .listing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .listing-card.hidden {
    display: none;
  }

  .listing-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .deal-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
  }

  .deal-sell {
    background: rgba(0, 184, 148, 0.12);
    color: #00B894;
  }

  .deal-buy {
    background: rgba(9, 132, 227, 0.12);
    color: #0984E3;
  }

  .location-tag {
    font-size: 0.75rem;
    color: #7A8EA5;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .category-tag {
    display: inline-block;
    font-size: 0.7rem;
    color: #FF6B35;
    background: #FFF0EA;
    padding: 3px 10px;
    border-radius: 10px;
    margin-bottom: 10px;
    font-weight: 600;
  }

  .listing-title {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 8px;
  }

  .listing-price {
    font-size: 1.15rem;
    font-weight: 700;
    color: #FF6B35;
    margin-bottom: 16px;
  }

  .poster-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    padding-top: 14px;
    border-top: 1px solid #EEF3F9;
  }

  .poster-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #1B2A4A;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .poster-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #1B2A4A;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FF6B35;
  }

  .no-results {
    text-align: center;
    color: #A0AFC0;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  @media (max-width: 768px) {
    .listing-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .form-row-split {
      flex-direction: column;
    }

    .page-header h1 {
      font-size: 1.7rem;
    }

    .search-filter-bar {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

<script>
  // ফর্মের টগল: বিক্রি করতে চাই / কিনতে চাই
  const dealButtons = document.querySelectorAll('.deal-toggle-btn');
  const itemTitleLabel = document.getElementById('itemTitleLabel');
  const itemPriceLabel = document.getElementById('itemPriceLabel');
  const submitAdText = document.getElementById('submitAdText');

  dealButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      dealButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      const deal = btn.dataset.deal;
      if (deal === 'sell') {
        itemTitleLabel.textContent = 'আইটেমের নাম';
        itemPriceLabel.textContent = 'দাম (টাকা)';
        submitAdText.textContent = 'বিজ্ঞাপন পোস্ট করুন (বিক্রয়)';
      } else {
        itemTitleLabel.textContent = 'কি খুঁজছেন';
        itemPriceLabel.textContent = 'বাজেট (টাকা)';
        submitAdText.textContent = 'বিজ্ঞাপন পোস্ট করুন (ক্রয়)';
      }
    });
  });

  // ফিল্টার ট্যাব (সব/বিক্রয়/ক্রয়) + কীওয়ার্ড সার্চ — একসাথে কাজ করবে
  const filterTabs = document.querySelectorAll('.filter-tab');
  const searchInput = document.getElementById('searchInput');
  const cards = document.querySelectorAll('.listing-card');
  const noResults = document.getElementById('noResults');

  let activeFilter = 'all';

  function applyFilters() {
    const keyword = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matchesDeal = activeFilter === 'all' || card.dataset.deal === activeFilter;
      const matchesKeyword =
        keyword === '' ||
        card.dataset.title.includes(keyword) ||
        card.dataset.category.includes(keyword);

      if (matchesDeal && matchesKeyword) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    noResults.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  filterTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      filterTabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      activeFilter = tab.dataset.filter;
      applyFilters();
    });
  });

  searchInput.addEventListener('input', applyFilters);
</script>