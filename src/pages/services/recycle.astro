---
// ============================================================
// পেজ: রিসাইকেল মার্কেটপ্লেস (পুরাতন জিনিস বিক্রয়)
// ব্র্যান্ড: স্মার্ট ফেনী
// Supabase থেকে রিয়েল লিস্টিং ডেটা fetch করা হয় (mock ডেটা বাদ)
// শুধু সার্চ বক্স (ফিল্টার ট্যাব বাদ) + কম্প্যাক্ট কার্ড + Detail Modal
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AddListingModal from '../../components/ui/AddListingModal.astro';
import { supabase } from '../../lib/supabase.js';

const typeOptions = [
  { id: 'mobile', label: 'মোবাইল' },
  { id: 'bike', label: 'বাইক' },
  { id: 'electronics', label: 'ইলেকট্রনিক্স' },
  { id: 'furniture', label: 'আসবাবপত্র' },
  { id: 'other', label: 'অন্যান্য' },
];

const typeNameMap = Object.fromEntries(typeOptions.map((t) => [t.id, t.label]));

const typeIcons = {
  mobile: 'fa-mobile-screen',
  bike: 'fa-motorcycle',
  electronics: 'fa-plug',
  furniture: 'fa-couch',
  other: 'fa-box',
};

const { data: recycleListings } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'recycle')
  .eq('status', 'active')
  .order('created_at', { ascending: false });

const listings = recycleListings || [];
---

<BaseLayout title="রিসাইকেল মার্কেটপ্লেস | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-recycle"></i> রিসাইকেল মার্কেট</span>
      <h1>পুরাতন জিনিস <span class="accent">কেনা-বেচা</span></h1>
      <p>মোবাইল, বাইক, ইলেকট্রনিক্স, আসবাবপত্র — খুঁজুন অথবা বিক্রি করুন সহজে</p>
      <button class="cta-box" id="openAddListing" type="button">
        <i class="fas fa-plus"></i> পুরাতন জিনিস বিক্রি করতে চান?
      </button>
    </div>
  </section>

  <section class="recycle-section">
    <div class="container">
      <div class="search-box">
        <i class="fas fa-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="মোবাইল, বাইক বা যেকোনো কিছু খুঁজুন..." />
      </div>

      {listings.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-box-open"></i>
          <p>এখনো কোনো লিস্টিং যোগ হয়নি</p>
          <span>প্রথম লিস্টিং যোগ করুন উপরের বাটনে ক্লিক করে</span>
        </div>
      ) : (
        <>
          <div class="recycle-grid" id="recycleGrid">
            {listings.map((item, i) => (
              <button
                type="button"
                class="recycle-card"
                data-index={i}
                data-search={`${item.title || ''} ${item.description || ''}`.toLowerCase()}
              >
                {item.images && item.images.length > 0 ? (
                  <img src={item.images[0]} alt={item.title} class="recycle-photo" />
                ) : (
                  <div class="recycle-icon">
                    <i class={`fas ${typeIcons[item.type] || 'fa-box'}`}></i>
                  </div>
                )}

                <div class="recycle-card-body">
                  <span class={`type-badge type-${item.type}`}>{typeNameMap[item.type] || item.type}</span>
                  <h3 class="recycle-title">{item.title}</h3>
                  {item.price && <p class="recycle-price">৳{item.price}</p>}
                  <p class="location-tag"><i class="fas fa-location-dot"></i> {item.upazila}</p>
                </div>
              </button>
            ))}
          </div>

          <p class="no-results" id="noResults" style="display:none;">কোনো ফলাফল পাওয়া যায়নি</p>
        </>
      )}
    </div>
  </section>

  <!-- ===== Detail Modal ===== -->
  <div class="detail-overlay" id="detailOverlay">
    <div class="detail-modal">
      <button class="detail-close" id="detailClose" aria-label="বন্ধ করুন">
        <i class="fas fa-xmark"></i>
      </button>

      <div id="detailImageWrap"></div>

      <div class="detail-body">
        <span class="type-badge" id="detailType"></span>
        <h2 class="detail-title" id="detailTitle"></h2>
        <p class="detail-price" id="detailPrice"></p>
        <p class="detail-location"><i class="fas fa-location-dot"></i> <span id="detailUpazila"></span></p>
        <p class="detail-desc" id="detailDesc"></p>
        <a href="#" class="btn-contact" id="detailContact">
          <i class="fas fa-phone"></i> যোগাযোগ করুন
        </a>
      </div>
    </div>
  </div>

  <AddListingModal category="recycle" typeOptions={typeOptions} />

  <script type="application/json" id="listingsData" set:html={JSON.stringify(listings)} />
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    margin-bottom: 20px;
  }

  .cta-box {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFF0EA;
    border: 1.5px solid #FFD3BC;
    color: #FF6B35;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 12px 26px;
    border-radius: 40px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cta-box:hover {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
    transform: translateY(-2px);
  }

  .recycle-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .search-box {
    max-width: 480px;
    margin: 0 auto 32px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 40px;
    padding: 12px 20px;
  }

  .search-box i {
    color: #A0AFC0;
  }

  .search-box input {
    border: none;
    outline: none;
    flex: 1;
    font-size: 0.9rem;
    font-family: inherit;
    background: transparent;
    color: #1B2A4A;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .recycle-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }

  .recycle-card {
    background: #fff;
    border-radius: 18px;
    border: 1px solid #EEF3F9;
    padding: 0;
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .recycle-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .recycle-card.hidden {
    display: none;
  }

  .recycle-icon {
    width: 100%;
    height: 100px;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }

  .recycle-photo {
    width: 100%;
    height: 100px;
    object-fit: cover;
  }

  .recycle-card-body {
    padding: 14px;
  }

  .type-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 6px;
    background: #F4F7FC;
    color: #5A6E85;
  }

  .recycle-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .recycle-price {
    font-size: 0.95rem;
    font-weight: 700;
    color: #FF6B35;
    margin-bottom: 4px;
  }

  .location-tag {
    font-size: 0.72rem;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .no-results {
    text-align: center;
    color: #A0AFC0;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  /* ===== Detail Modal ===== */
  .detail-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow-y: auto;
  }

  .detail-overlay.open {
    display: flex;
  }

  .detail-modal {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 460px;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.25);
    margin: auto;
    max-height: 90vh;
    overflow-y: auto;
  }

  .detail-close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: rgba(255,255,255,0.9);
    border: none;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #5A6E85;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .detail-close:hover {
    background: #FF6B35;
    color: #fff;
  }

  #detailImageWrap img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }

  #detailImageWrap .detail-icon-fallback {
    width: 100%;
    height: 180px;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
  }

  .detail-body {
    padding: 26px 26px 30px;
  }

  .detail-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1B2A4A;
    margin: 8px 0 6px;
  }

  .detail-price {
    font-size: 1.4rem;
    font-weight: 700;
    color: #FF6B35;
    margin-bottom: 10px;
  }

  .detail-location {
    font-size: 0.85rem;
    color: #8FA0BC;
    margin-bottom: 14px;
  }

  .detail-desc {
    font-size: 0.9rem;
    color: #5A6E85;
    line-height: 1.6;
    margin-bottom: 24px;
    white-space: pre-line;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 14px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FF6B35;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  const typeNameMap = {
    mobile: 'মোবাইল',
    bike: 'বাইক',
    electronics: 'ইলেকট্রনিক্স',
    furniture: 'আসবাবপত্র',
    other: 'অন্যান্য',
  };

  const typeIcons = {
    mobile: 'fa-mobile-screen',
    bike: 'fa-motorcycle',
    electronics: 'fa-plug',
    furniture: 'fa-couch',
    other: 'fa-box',
  };

  const dataEl = document.getElementById('listingsData');
  const listings = dataEl ? JSON.parse(dataEl.textContent) : [];

  const cards = document.querySelectorAll('.recycle-card');
  const searchInput = document.getElementById('searchInput');
  const noResults = document.getElementById('noResults');

  searchInput?.addEventListener('input', () => {
    const keyword = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches = keyword === '' || (card.dataset.search || '').includes(keyword);
      if (matches) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }
  });

  // ===== Detail Modal =====
  const detailOverlay = document.getElementById('detailOverlay');
  const detailClose = document.getElementById('detailClose');
  const detailImageWrap = document.getElementById('detailImageWrap');
  const detailType = document.getElementById('detailType');
  const detailTitle = document.getElementById('detailTitle');
  const detailPrice = document.getElementById('detailPrice');
  const detailUpazila = document.getElementById('detailUpazila');
  const detailDesc = document.getElementById('detailDesc');
  const detailContact = document.getElementById('detailContact');

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const item = listings[Number(card.dataset.index)];
      if (!item) return;

      if (item.images && item.images.length > 0) {
        detailImageWrap.innerHTML = `<img src="${item.images[0]}" alt="${item.title || ''}" />`;
      } else {
        detailImageWrap.innerHTML = `<div class="detail-icon-fallback"><i class="fas ${typeIcons[item.type] || 'fa-box'}"></i></div>`;
      }

      detailType.textContent = typeNameMap[item.type] || item.type || '';
      detailTitle.textContent = item.title || '';
      detailPrice.textContent = item.price ? `৳${item.price}` : '';
      detailPrice.style.display = item.price ? 'block' : 'none';
      detailUpazila.textContent = item.upazila || '';
      detailDesc.textContent = item.description || '';
      detailDesc.style.display = item.description ? 'block' : 'none';
      detailContact.href = `tel:${item.contact_phone || ''}`;

      detailOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeDetail() {
    detailOverlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  detailClose?.addEventListener('click', closeDetail);
  detailOverlay?.addEventListener('click', (e) => {
    if (e.target === detailOverlay) closeDetail();
  });

  document.getElementById('openAddListing')?.addEventListener('click', () => {
    window.openListingModal?.();
  });
</script>