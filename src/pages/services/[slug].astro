---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { categories } from '../../data/services.js';

export async function getStaticPaths() {
  // getStaticPaths() নিজের আলাদা isolated scope-এ চলে — ফাংশনের বাইরের
  // কোনো ভ্যারিয়েবল (import ছাড়া) অ্যাক্সেস করতে পারে না। তাই
  // customPageSlugs এখানে ফাংশনের ভেতরেই ডিফাইন করা হলো।
  //
  // ফিক্স: 'repair' যোগ করা হলো — repair.astro কাস্টম ফাইল থাকায়
  // এটা বাদ না দিলে রুট কনফ্লিক্ট হচ্ছিল, ফলে লাইভ সাইটে পুরনো
  // জেনেরিক পেজ দেখাচ্ছিল।
  //
  // নতুন: 'laundry' ও 'event' যোগ করা হলো — দুটোরই কাস্টম পেজ
  // (laundry.astro, event.astro) বানানো হয়েছে।
  const customPageSlugs = [
    'housing',
    'job',
    'blood',
    'recycle',
    'car-rental',
    'courier',
    'health',
    'home-food',
    'online-shop',
    'lost-found',
    'tuition',
    'repair',
    'laundry',
    'event',
  ];

  return categories
    .filter((cat) => !customPageSlugs.includes(cat.slug))
    .map((cat) => ({
      params: { slug: cat.slug },
      props: { category: cat },
    }));
}

const { category } = Astro.props;
---

<BaseLayout title={`${category.name} | স্মার্ট ফেনী`}>
  <div class="container" style="padding-top: 60px; min-height: 70vh;">
    <h1 style="font-size: 2.8rem; margin-bottom: 20px;">
      <i class={`fas ${category.icon}`} style="color: #FF6B35;"></i> {category.name}
    </h1>
    <p style="font-size: 1.2rem; color: #4A5B6E; max-width: 700px; margin-bottom: 40px;">
      {category.desc} — এই পেজটি ডাইনামিকভাবে তৈরি হয়েছে। আপনি এখানে প্রতিটি ক্যাটাগরির জন্য আলাদা কন্টেন্ট যোগ করতে পারেন।
    </p>
    
    <div style="background: #fff; padding: 40px; border-radius: 24px; box-shadow: 0 4px 16px rgba(0,0,0,0.04);">
      <h3>📌 {category.name} - সেবাসমূহ</h3>
      <p style="color: #5A6E85; margin-top: 12px;">এই ক্যাটাগরির আওতায় যেকোনো সেবা লিস্টিং, ফিল্টার, বা ডিটেইলস পেজ আপনি এখানে ডিজাইন করতে পারেন।</p>
      <div style="margin-top: 24px; display: flex; gap: 12px; flex-wrap: wrap;">
        <span style="background: #F4F7FC; padding: 8px 20px; border-radius: 40px;">সেবা #১</span>
        <span style="background: #F4F7FC; padding: 8px 20px; border-radius: 40px;">সেবা #২</span>
        <span style="background: #F4F7FC; padding: 8px 20px; border-radius: 40px;">সেবা #৩</span>
      </div>
    </div>

    <div style="margin-top: 50px;">
      <a href="/" class="btn-outline"><i class="fas fa-arrow-left"></i> ল্যান্ডিং পেজে ফিরে যান</a>
    </div>
  </div>
</BaseLayout>