---
// ============================================================
// পেজ: গাড়ি ভাড়া সার্ভিস
// ব্র্যান্ড: স্মার্ট ফেনী
// সিএনজি, কার, পিকআপ ভ্যান, ট্রাক — সব ধরনের গাড়ি সার্ভিস।
// টাইপ ব্যাজ নাই (এক ড্রাইভার একাধিক গাড়ির সার্ভিস দিতে পারে)।
// সার্চ বক্সে এলাকার নাম লিখলে description (সার্ভিস এরিয়া) এর
// সাথে ম্যাচ করে ড্রাইভার খুঁজে দেয়। প্রোফাইল এডিট থেকে ড্রাইভার
// নিজের অনলাইন/অফলাইন স্ট্যাটাস ও তথ্য বদলাতে পারবে (courier-এর মতো)।
// শুধু status='active' লিস্টিংই এখানে দেখানো হয় (অ্যাডমিন অ্যাপ্রুভ করলে)।
// ============================================================

export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import AddListingModal from '../../components/ui/AddListingModal.astro';
import ListingDetailModal from '../../components/ui/ListingDetailModal.astro';
import { supabase } from '../../lib/supabase.js';

const typeOptions = [
  { id: 'cng', label: 'সিএনজি' },
  { id: 'car', label: 'কার' },
  { id: 'pickup', label: 'পিকআপ ভ্যান' },
  { id: 'truck', label: 'ট্রাক' },
  { id: 'microbus', label: 'মাইক্রোবাস' },
  { id: 'other', label: 'অন্যান্য' },
];

const { data: carListings } = await supabase
  .from('listings')
  .select('*')
  .eq('category', 'car-rental')
  .eq('status', 'active')
  .order('created_at', { ascending: false });

const listings = carListings || [];
---

<BaseLayout title="গাড়ি ভাড়া সার্ভিস | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-car"></i> গাড়ি ভাড়া সার্ভিস</span>
      <h1>ফেনীর <span class="accent">গাড়ি ভাড়া</span> সার্ভিস</h1>
      <p>সিএনজি, কার, পিকআপ ভ্যান, ট্রাক — যেকোনো ধরনের গাড়ি সার্ভিস এক জায়গায়। সরাসরি ড্রাইভারের সাথে কল করে ভাড়া ঠিক করুন।</p>
      <button class="cta-box" id="openCarCta" type="button">
        <i class="fas fa-plus"></i> আমি ড্রাইভার/গাড়ি মালিক, লিস্টিং দিতে চাই
      </button>
    </div>
  </section>

  <section class="car-section">
    <div class="container">
      <div class="search-box">
        <i class="fas fa-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="আপনার এলাকার নাম লিখে ড্রাইভার খুঁজুন..." />
      </div>

      {listings.length === 0 ? (
        <div class="empty-state">
          <i class="fas fa-car-side"></i>
          <p>এখনো কোনো গাড়ি ভাড়া লিস্টিং যোগ হয়নি</p>
          <span>প্রথম লিস্টিং যোগ করুন উপরের বাটনে ক্লিক করে</span>
        </div>
      ) : (
        <>
          <div class="car-grid" id="carGrid">
            {listings.map((item, i) => (
              <button
                type="button"
                class="car-card"
                data-detail-index={i}
                data-upazila-name={item.upazila || ''}
                data-search={`${item.title || ''} ${item.description || ''} ${item.upazila || ''}`.toLowerCase()}
              >
                {item.images && item.images.length > 0 ? (
                  <img src={item.images[0]} alt={item.title} class="car-photo" />
                ) : (
                  <div class="car-icon">
                    <i class="fas fa-car"></i>
                  </div>
                )}

                <div class="car-card-body">
                  <h3 class="car-title">{item.title}</h3>
                  {item.price && <p class="car-price">{item.price}</p>}
                  <p class="location-tag"><i class="fas fa-location-dot"></i> {item.upazila}</p>
                </div>
              </button>
            ))}
          </div>

          <p class="no-results" id="noResults" style="display:none;">কোনো ফলাফল পাওয়া যায়নি</p>
        </>
      )}
    </div>
  </section>

  <ListingDetailModal />
  <AddListingModal
    category="car-rental"
    typeOptions={typeOptions}
    titleLabel="আপনার নাম / গাড়ির নাম"
    priceLabel="গাড়ির ধরন/মডেল"
  />

  <script type="application/json" id="listingsData" set:html={JSON.stringify(listings)} />
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
    max-width: 620px;
    margin: 0 auto 20px;
  }

  .cta-box {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFF0EA;
    border: 1.5px solid #FFD3BC;
    color: #FF6B35;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 12px 26px;
    border-radius: 40px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cta-box:hover {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
    transform: translateY(-2px);
  }

  .car-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .search-box {
    max-width: 480px;
    margin: 0 auto 32px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #EEF3F9;
    border-radius: 40px;
    padding: 12px 20px;
  }

  .search-box i {
    color: #A0AFC0;
  }

  .search-box input {
    border: none;
    outline: none;
    flex: 1;
    font-size: 0.9rem;
    font-family: inherit;
    background: transparent;
    color: #1B2A4A;
  }

  .empty-state {
    text-align: center;
    background: #fff;
    border-radius: 20px;
    padding: 50px 24px;
    border: 1px dashed #E5EAF0;
  }

  .empty-state i {
    font-size: 2rem;
    color: #D7E0EC;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
  }

  .empty-state span {
    color: #8FA0BC;
    font-size: 0.85rem;
  }

  .car-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }

  .car-card {
    background: #fff;
    border-radius: 18px;
    border: 1px solid #EEF3F9;
    padding: 0;
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .car-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .car-card.hidden {
    display: none;
  }

  .car-icon {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }

  .car-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .car-card-body {
    padding: 14px;
  }

  .car-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .car-price {
    font-size: 0.85rem;
    font-weight: 600;
    color: #FF6B35;
    margin-bottom: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .location-tag {
    font-size: 0.72rem;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .no-results {
    text-align: center;
    color: #A0AFC0;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { initListingDetailModal } from '../../lib/listingDetailModal.js';
  import { reorderByUserLocation } from '../../lib/locationSort.js';

  const typeNameMap = {
    cng: 'সিএনজি',
    car: 'কার',
    pickup: 'পিকআপ ভ্যান',
    truck: 'ট্রাক',
    microbus: 'মাইক্রোবাস',
    other: 'অন্যান্য',
  };

  const typeIcons = {
    cng: 'fa-car',
    car: 'fa-car',
    pickup: 'fa-truck-pickup',
    truck: 'fa-truck',
    microbus: 'fa-van-shuttle',
    other: 'fa-car',
  };

  const dataEl = document.getElementById('listingsData');
  const listings = dataEl ? JSON.parse(dataEl.textContent) : [];

  const grid = document.getElementById('carGrid');
  const cards = document.querySelectorAll('.car-card');
  const searchInput = document.getElementById('searchInput');
  const noResults = document.getElementById('noResults');

  searchInput?.addEventListener('input', () => {
    const keyword = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches = keyword === '' || (card.dataset.search || '').includes(keyword);
      if (matches) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }
  });

  initListingDetailModal({ listings, typeNameMap, typeIcons, cardSelector: '.car-card' });
  reorderByUserLocation(grid, 'upazilaName');

  // CTA: লগইন থাকলে লিস্টিং মোডাল, না থাকলে আগে লগইন মোডাল
  document.getElementById('openCarCta')?.addEventListener('click', async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      window.openListingModal?.();
    } else {
      window.openAuthModal?.('login');
    }
  });
</script>