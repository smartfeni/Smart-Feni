---
// ============================================================
// পেজ: গাড়ি ভাড়া সার্ভিস
// ব্র্যান্ড: স্মার্ট ফেনী
// ============================================================

import BaseLayout from '../../components/layout/BaseLayout.astro';

// প্লেসহোল্ডার ডেটা — পরে ডাটাবেজ থেকে আসবে, আপাতত mock ডেটা দিয়ে UI সাজানো হচ্ছে
const cars = [
  { id: 1, type: 'private', typeName: 'প্রাইভেট কার', model: 'টয়োটা প্রিমিও', upazila: 'ফেনী সদর', owner: 'রফিকুল ইসলাম', rating: 4.8, reviews: 24 },
  { id: 2, type: 'micro', typeName: 'মাইক্রোবাস', model: 'হাইএস', upazila: 'ছাগলনাইয়া', owner: 'কামাল হোসেন', rating: 4.6, reviews: 18 },
  { id: 3, type: 'cng', typeName: 'সিএনজি অটো', model: 'সিএনজি অটোরিকশা', upazila: 'দাগনভূঞা', owner: 'আব্দুল করিম', rating: 4.3, reviews: 31 },
  { id: 4, type: 'private', typeName: 'প্রাইভেট কার', model: 'হুন্দাই এক্সেন্ট', upazila: 'পরশুরাম', owner: 'শাহাদাত হোসেন', rating: 4.9, reviews: 12 },
  { id: 5, type: 'micro', typeName: 'মাইক্রোবাস', model: 'নোহা', upazila: 'ফুলগাজী', owner: 'জসিম উদ্দিন', rating: 4.5, reviews: 9 },
  { id: 6, type: 'cng', typeName: 'সিএনজি অটো', model: 'সিএনজি অটোরিকশা', upazila: 'সোনাগাজী', owner: 'নুরুল আমিন', rating: 4.2, reviews: 15 },
  { id: 7, type: 'private', typeName: 'প্রাইভেট কার', model: 'টয়োটা এক্সিও', upazila: 'ফেনী সদর', owner: 'মিজানুর রহমান', rating: 4.7, reviews: 21 },
  { id: 8, type: 'micro', typeName: 'মাইক্রোবাস', model: 'হাইএস', upazila: 'দাগনভূঞা', owner: 'ফরহাদ হোসেন', rating: 4.4, reviews: 7 },
];

const filters = [
  { id: 'all', label: 'সব' },
  { id: 'private', label: 'প্রাইভেট' },
  { id: 'micro', label: 'মাইক্রো' },
  { id: 'cng', label: 'সিএনজি' },
];
---

<BaseLayout title="গাড়ি ভাড়া সার্ভিস | স্মার্ট ফেনী">
  <section class="page-header">
    <div class="container">
      <span class="section-tag"><i class="fas fa-car"></i> গাড়ি ভাড়া সার্ভিস</span>
      <h1>ফেনীর <span class="accent">গাড়ি ভাড়া</span> খুঁজুন</h1>
      <p>প্রাইভেট কার, মাইক্রোবাস ও সিএনজি — নির্ভরযোগ্য চালক ও মালিকদের কাছ থেকে</p>
    </div>
  </section>

  <section class="car-section">
    <div class="container">
      <div class="filter-tabs" id="filterTabs">
        {filters.map((f) => (
          <button class={`filter-tab ${f.id === 'all' ? 'active' : ''}`} data-filter={f.id}>
            {f.label}
          </button>
        ))}
      </div>

      <div class="car-grid" id="carGrid">
        {cars.map((car) => (
          <div class="car-card" data-type={car.type}>
            <div class="car-card-top">
              <span class={`type-badge type-${car.type}`}>{car.typeName}</span>
              <span class="location-tag">
                <i class="fas fa-location-dot"></i> {car.upazila}
              </span>
            </div>

            <div class="car-icon">
              <i class={`fas ${car.type === 'cng' ? 'fa-taxi' : car.type === 'micro' ? 'fa-shuttle-van' : 'fa-car-side'}`}></i>
            </div>

            <h3 class="car-model">{car.model}</h3>

            <div class="owner-row">
              <div class="owner-avatar">{car.owner.charAt(0)}</div>
              <div class="owner-info">
                <p class="owner-name">{car.owner}</p>
                <div class="rating">
                  <i class="fas fa-star"></i>
                  <span>{car.rating}</span>
                  <span class="review-count">({car.reviews} রিভিউ)</span>
                </div>
              </div>
            </div>

            <a href="/contact" class="btn-contact">
              <i class="fas fa-phone"></i> যোগাযোগ করুন
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 60px 0 30px;
    background: #fff;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 12px 0 8px;
  }

  .page-header .accent {
    color: #FF6B35;
  }

  .page-header p {
    color: #5A6E85;
    font-size: 1.05rem;
  }

  .car-section {
    padding: 30px 0 70px;
    background: #F8FAFC;
  }

  .filter-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 32px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .filter-tab {
    background: #fff;
    border: 1px solid #EEF3F9;
    color: #1B2A4A;
    padding: 10px 24px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-tab:hover {
    border-color: #FF6B35;
  }

  .filter-tab.active {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  .car-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .car-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .car-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .car-card.hidden {
    display: none;
  }

  .car-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .type-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
  }

  .type-private {
    background: rgba(9, 132, 227, 0.12);
    color: #0984E3;
  }

  .type-micro {
    background: rgba(108, 92, 231, 0.12);
    color: #6C5CE7;
  }

  .type-cng {
    background: rgba(0, 184, 148, 0.12);
    color: #00B894;
  }

  .location-tag {
    font-size: 0.75rem;
    color: #7A8EA5;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .car-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 12px;
  }

  .car-model {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .owner-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    padding-top: 14px;
    border-top: 1px solid #EEF3F9;
  }

  .owner-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #1B2A4A;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .owner-name {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .rating {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    color: #5A6E85;
  }

  .rating i {
    color: #FDCB6E;
  }

  .review-count {
    color: #A0AFC0;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FF6B35;
  }

  @media (max-width: 768px) {
    .car-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .page-header h1 {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.car-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      const filter = tab.dataset.filter;
      cards.forEach((card) => {
        if (filter === 'all' || card.dataset.type === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>