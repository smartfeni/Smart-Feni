---
// ============================================================
// পেজ: রাইডার প্রোফাইল (/rider-profile)
// শুধুমাত্র লগইন করা রাইডারদের জন্য — যাদের category='courier'
// লিস্টিং আছে। এখানে নিজের অনলাইন/অফলাইন স্ট্যাটাস, মোটরসাইকেল
// মডেল ও বিবরণ এডিট করতে পারবেন।
// ============================================================

export const prerender = false;

import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="রাইডার প্রোফাইল | স্মার্ট ফেনী">
  <div class="rider-page">
    <div class="container">

      <div id="loadingState" class="loading-state">
        <div class="spinner"></div>
        <p>লোড হচ্ছে...</p>
      </div>

      <div id="guardedContent" class="rider-content" style="display:none;">

        <a href="/" class="back-link"><i class="fas fa-arrow-left"></i> হোমে ফিরুন</a>

        <div class="rider-header">
          <div class="rider-icon">
            <i class="fas fa-motorcycle"></i>
          </div>
          <div>
            <h1 id="riderName">—</h1>
            <p id="riderMeta">—</p>
          </div>
        </div>

        <p class="save-message" id="saveMessage"></p>

        <!-- ===== অনলাইন/অফলাইন টগল ===== -->
        <div class="status-card">
          <div>
            <p class="status-label">আপনার স্ট্যাটাস</p>
            <p class="status-text" id="statusText">
              <i class="fas fa-circle"></i> <span>লোড হচ্ছে...</span>
            </p>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="onlineToggle" />
            <span class="toggle-slider"></span>
          </label>
        </div>

        <!-- ===== এডিট ফর্ম ===== -->
        <div class="edit-card">
          <label class="field-label">মোটরসাইকেল মডেল</label>
          <input type="text" class="field-input" id="vehicleInput" placeholder="যেমন: হোন্ডা লিভো" />

          <label class="field-label">বিবরণ</label>
          <p class="field-hint">আপনি কী সেবা দিচ্ছেন সংক্ষেপে লিখুন — কাস্টমার এটা দেখে আইডিয়া পাবেন</p>
          <textarea class="field-input" id="descriptionInput" rows="4" placeholder=""></textarea>

          <button class="save-btn" id="saveBtn" type="button">
            <i class="fas fa-check"></i> <span id="saveBtnText">সেভ করুন</span>
          </button>
        </div>

      </div>
    </div>
  </div>

  <style>
    .rider-page {
      min-height: 70vh;
      padding: 40px 0 80px;
      background: #F8FAFC;
    }

    .loading-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 120px 0;
      color: #5A6E85;
      font-weight: 600;
    }

    .spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #E5EAF0;
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .rider-content {
      max-width: 520px;
      margin: 0 auto;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #5A6E85;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.88rem;
      margin-bottom: 24px;
    }

    .back-link:hover {
      color: #FF6B35;
    }

    .rider-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 24px;
    }

    .rider-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: #FFF0EA;
      color: #FF6B35;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      flex-shrink: 0;
    }

    .rider-header h1 {
      font-size: 1.3rem;
      font-weight: 700;
      color: #1B2A4A;
    }

    .rider-header p {
      font-size: 0.85rem;
      color: #8FA0BC;
    }

    .save-message {
      display: none;
      font-size: 0.85rem;
      font-weight: 600;
      padding: 10px 14px;
      border-radius: 12px;
      margin-bottom: 16px;
      text-align: center;
    }

    .save-message.show-error {
      display: block;
      background: #FFF0EA;
      color: #D14343;
    }

    .save-message.show-success {
      display: block;
      background: #EAFBF0;
      color: #1B7A3C;
    }

    .status-card {
      background: #fff;
      border-radius: 20px;
      padding: 20px 22px;
      border: 1px solid #EEF3F9;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 20px;
    }

    .status-label {
      font-size: 0.78rem;
      color: #8FA0BC;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .status-text {
      font-size: 0.98rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .status-text i {
      font-size: 0.6rem;
    }

    .status-text.online {
      color: #16A34A;
    }

    .status-text.offline {
      color: #94A3B8;
    }

    .toggle-switch {
      position: relative;
      display: inline-block;
      width: 56px;
      height: 30px;
      flex-shrink: 0;
      cursor: pointer;
    }

    .toggle-switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .toggle-slider {
      position: absolute;
      inset: 0;
      background: #D7E0EC;
      border-radius: 40px;
      transition: 0.25s;
    }

    .toggle-slider::before {
      content: '';
      position: absolute;
      top: 3px;
      left: 3px;
      width: 24px;
      height: 24px;
      background: #fff;
      border-radius: 50%;
      transition: 0.25s;
    }

    .toggle-switch input:checked + .toggle-slider {
      background: #4ADE80;
    }

    .toggle-switch input:checked + .toggle-slider::before {
      transform: translateX(26px);
    }

    .edit-card {
      background: #fff;
      border-radius: 20px;
      padding: 24px 22px;
      border: 1px solid #EEF3F9;
    }

    .field-label {
      display: block;
      font-size: 0.82rem;
      font-weight: 600;
      color: #1B2A4A;
      margin-bottom: 6px;
      margin-top: 16px;
    }

    .field-label:first-child {
      margin-top: 0;
    }

    .field-hint {
      font-size: 0.78rem;
      color: #8FA0BC;
      margin-bottom: 8px;
    }

    .field-input {
      width: 100%;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1.5px solid #E5EAF0;
      font-size: 0.9rem;
      font-family: inherit;
      color: #1B2A4A;
      background: #FBFCFE;
    }

    .field-input:focus {
      outline: none;
      border-color: #FF6B35;
      background: #fff;
    }

    textarea.field-input {
      resize: vertical;
    }

    .save-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #FF6B35;
      color: #fff;
      border: none;
      padding: 14px;
      border-radius: 14px;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      margin-top: 22px;
      box-shadow: 0 10px 24px rgba(255, 107, 53, 0.28);
    }

    .save-btn:disabled {
      opacity: 0.65;
      cursor: not-allowed;
    }
  </style>

  <script>
    import { supabase } from '../lib/supabase.js';

    const loadingState = document.getElementById('loadingState');
    const guardedContent = document.getElementById('guardedContent');
    const riderName = document.getElementById('riderName');
    const riderMeta = document.getElementById('riderMeta');
    const saveMessage = document.getElementById('saveMessage');
    const statusText = document.getElementById('statusText');
    const onlineToggle = document.getElementById('onlineToggle');
    const vehicleInput = document.getElementById('vehicleInput');
    const descriptionInput = document.getElementById('descriptionInput');
    const saveBtn = document.getElementById('saveBtn');
    const saveBtnText = document.getElementById('saveBtnText');

    let currentListing = null;

    function showMessage(text, type = 'error') {
      saveMessage.textContent = text;
      saveMessage.className = `save-message ${type === 'error' ? 'show-error' : 'show-success'}`;
    }

    function clearMessage() {
      saveMessage.textContent = '';
      saveMessage.className = 'save-message';
    }

    function renderStatus(isOnline) {
      statusText.className = `status-text ${isOnline ? 'online' : 'offline'}`;
      statusText.innerHTML = isOnline
        ? '<i class="fas fa-circle"></i> <span>অনলাইন — কাস্টমাররা আপনাকে দেখতে পাচ্ছেন</span>'
        : '<i class="fas fa-circle"></i> <span>অফলাইন — কাস্টমাররা আপনাকে দেখছেন না</span>';
    }

    async function init() {
      const { data: { session } } = await supabase.auth.getSession();

      if (!session) {
        window.location.href = '/';
        return;
      }

      const { data: listing } = await supabase
        .from('listings')
        .select('*')
        .eq('user_id', session.user.id)
        .eq('category', 'courier')
        .maybeSingle();

      if (!listing) {
        window.location.href = '/';
        return;
      }

      currentListing = listing;

      riderName.textContent = listing.title || 'রাইডার';
      riderMeta.textContent = `${listing.upazila || ''}${listing.contact_phone ? ' · ' + listing.contact_phone : ''}`;

      onlineToggle.checked = listing.is_online !== false;
      renderStatus(onlineToggle.checked);

      vehicleInput.value = listing.price || '';
      descriptionInput.value = listing.description || '';

      loadingState.style.display = 'none';
      guardedContent.style.display = 'block';
    }

    onlineToggle?.addEventListener('change', async () => {
      const isOnline = onlineToggle.checked;
      renderStatus(isOnline);
      clearMessage();

      const { error } = await supabase
        .from('listings')
        .update({ is_online: isOnline })
        .eq('id', currentListing.id);

      if (error) {
        showMessage('স্ট্যাটাস আপডেট ব্যর্থ: ' + error.message);
        onlineToggle.checked = !isOnline;
        renderStatus(!isOnline);
        return;
      }

      currentListing.is_online = isOnline;
    });

    saveBtn?.addEventListener('click', async () => {
      clearMessage();

      const vehicle = vehicleInput.value.trim();
      const description = descriptionInput.value.trim();

      saveBtnText.textContent = 'সেভ হচ্ছে...';
      saveBtn.disabled = true;

      const { error } = await supabase
        .from('listings')
        .update({ price: vehicle, description })
        .eq('id', currentListing.id);

      saveBtnText.textContent = 'সেভ করুন';
      saveBtn.disabled = false;

      if (error) {
        showMessage('সেভ ব্যর্থ: ' + error.message);
        return;
      }

      showMessage('তথ্য সফলভাবে সেভ হয়েছে!', 'success');
      currentListing.price = vehicle;
      currentListing.description = description;
    });

    init();
  </script>
</BaseLayout>