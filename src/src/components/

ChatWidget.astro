---
import ChatWidget from 'astro-chat/components/ChatWidget.astro';
---

<div class="chat-footer-wrapper">
  <ChatWidget
    welcomeMessage="হ্যালো! কীভাবে সাহায্য করতে পারি?"
    apiPath="/api/chat"
    placeholder="আপনার প্রশ্ন লিখুন..."
    suggestionQueries={[
      "আপনার পরিষেবা কী কী?",
      "কীভাবে যোগাযোগ করব?"
    ]}
  />
</div>

<style>
  .chat-footer-wrapper {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
  }
</style>