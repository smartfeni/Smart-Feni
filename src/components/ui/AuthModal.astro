---
// ============================================================
// কম্পোনেন্ট: অথ মোডাল (লগইন / নতুন অ্যাকাউন্ট)
// এই মুহূর্তে শুধু UI — কোনো ব্যাকএন্ড/Firebase কানেক্ট করা হয়নি।
// "লগইন করুন" ও "অ্যাকাউন্ট তৈরি করুন" বাটনে ক্লিক করলে শুধু মোডাল বন্ধ
// হবে এবং প্রোফাইল সার্কেলে (ডেমো হিসেবে) আপলোড করা ছবি/নাম বসবে।
// আসল অথেন্টিকেশন যুক্ত হলে script অংশের TODO কমেন্টগুলো পরিবর্তন করলেই হবে।
// ============================================================
---

<div class="auth-overlay" id="authOverlay">
  <div class="auth-modal">
    <button class="auth-close" id="authClose" aria-label="বন্ধ করুন">
      <i class="fas fa-xmark"></i>
    </button>

    <div class="auth-brand">
      <img src="/logo.png" alt="স্মার্ট ফেনী" class="auth-logo" />
    </div>

    <div class="auth-tabs">
      <button class="auth-tab active" data-tab="login" type="button">লগইন</button>
      <button class="auth-tab" data-tab="signup" type="button">নতুন অ্যাকাউন্ট</button>
    </div>

    <!-- ===== লগইন প্যানেল ===== -->
    <div class="auth-pane active" id="loginPane">
      <h2 class="auth-title">স্বাগতম ফিরে আসার জন্য</h2>
      <p class="auth-subtitle">আপনার অ্যাকাউন্টে লগইন করুন</p>

      <label class="auth-label">ফোন নম্বর / ইমেইল</label>
      <div class="auth-input-wrap">
        <i class="fas fa-user auth-input-icon"></i>
        <input type="text" class="auth-input" placeholder="01xxxxxxxxx অথবা ইমেইল" />
      </div>

      <label class="auth-label">পাসওয়ার্ড</label>
      <div class="auth-input-wrap">
        <i class="fas fa-lock auth-input-icon"></i>
        <input type="password" class="auth-input" placeholder="••••••••" />
        <i class="fas fa-eye auth-input-eye"></i>
      </div>

      <a href="#" class="auth-forgot">পাসওয়ার্ড ভুলে গেছেন?</a>

      <button class="auth-submit" id="loginSubmit" type="button">
        <i class="fas fa-right-to-bracket"></i> লগইন করুন
      </button>

      <p class="auth-switch">
        নতুন এখানে? <button class="auth-link" data-tab="signup" type="button">অ্যাকাউন্ট খুলুন</button>
      </p>
    </div>

    <!-- ===== সাইনআপ প্যানেল ===== -->
    <div class="auth-pane" id="signupPane">
      <h2 class="auth-title">নতুন অ্যাকাউন্ট খুলুন</h2>
      <p class="auth-subtitle">স্মার্ট ফেনীর সব সেবা ব্যবহার করতে যুক্ত হোন</p>

      <div class="auth-photo-upload">
        <label for="photoInput" class="auth-photo-circle" id="photoPreviewCircle">
          <img id="photoPreviewImg" src="" alt="প্রোফাইল ছবি" />
          <i class="fas fa-camera" id="photoPlaceholderIcon"></i>
          <span class="auth-photo-edit"><i class="fas fa-pen"></i></span>
        </label>
        <input type="file" id="photoInput" accept="image/*" style="display:none;" />
        <span class="auth-photo-label">প্রোফাইল ছবি যোগ করুন</span>
      </div>

      <label class="auth-label">পূর্ণ নাম</label>
      <div class="auth-input-wrap">
        <i class="fas fa-id-card auth-input-icon"></i>
        <input type="text" class="auth-input" id="signupName" placeholder="আপনার পূর্ণ নাম" />
      </div>

      <label class="auth-label">ফোন নম্বর</label>
      <div class="auth-input-wrap">
        <i class="fas fa-phone auth-input-icon"></i>
        <input type="text" class="auth-input" placeholder="01xxxxxxxxx" />
      </div>

      <label class="auth-label">পাসওয়ার্ড</label>
      <div class="auth-input-wrap">
        <i class="fas fa-lock auth-input-icon"></i>
        <input type="password" class="auth-input" placeholder="কমপক্ষে ৬ অক্ষর" />
        <i class="fas fa-eye auth-input-eye"></i>
      </div>

      <button class="auth-submit" id="signupSubmit" type="button">
        <i class="fas fa-user-plus"></i> অ্যাকাউন্ট তৈরি করুন
      </button>

      <p class="auth-switch">
        আগে থেকেই অ্যাকাউন্ট আছে? <button class="auth-link" data-tab="login" type="button">লগইন করুন</button>
      </p>
    </div>

    <p class="auth-note"><i class="fas fa-circle-info"></i> এই মুহূর্তে এটি শুধু ডিজাইন প্রিভিউ, শীঘ্রই সম্পূর্ণ ফাংশনাল হবে।</p>
  </div>
</div>

<style>
  .auth-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow-y: auto;
  }

  .auth-overlay.open {
    display: flex;
  }

  .auth-modal {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 420px;
    border-radius: 28px;
    padding: 36px 32px 28px;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.25);
    margin: auto;
    animation: authPop 0.22s ease;
  }

  @keyframes authPop {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .auth-close {
    position: absolute;
    top: 18px;
    right: 18px;
    background: #F4F7FC;
    border: none;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #5A6E85;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .auth-close:hover {
    background: #FF6B35;
    color: #fff;
  }

  .auth-brand {
    display: flex;
    justify-content: center;
    margin-bottom: 10px;
  }

  .auth-logo {
    height: 44px;
    width: auto;
  }

  .auth-tabs {
    display: flex;
    background: #F4F7FC;
    border-radius: 40px;
    padding: 4px;
    margin: 18px 0 26px;
  }

  .auth-tab {
    flex: 1;
    border: none;
    background: transparent;
    padding: 10px 12px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    color: #5A6E85;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .auth-tab.active {
    background: #1B2A4A;
    color: #fff;
  }

  .auth-pane {
    display: none;
  }

  .auth-pane.active {
    display: block;
    animation: authFade 0.2s ease;
  }

  @keyframes authFade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .auth-title {
    font-size: 1.4rem;
    color: #1B2A4A;
    margin-bottom: 4px;
    text-align: center;
  }

  .auth-subtitle {
    color: #8FA0BC;
    font-size: 0.88rem;
    text-align: center;
    margin-bottom: 24px;
  }

  .auth-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: #1B2A4A;
    margin-bottom: 6px;
    margin-top: 16px;
  }

  .auth-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .auth-input-icon {
    position: absolute;
    left: 16px;
    color: #B0BCCB;
    font-size: 0.9rem;
  }

  .auth-input-eye {
    position: absolute;
    right: 16px;
    color: #B0BCCB;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .auth-input {
    width: 100%;
    padding: 13px 16px 13px 44px;
    border-radius: 14px;
    border: 1.5px solid #E5EAF0;
    font-size: 0.92rem;
    font-family: inherit;
    color: #1B2A4A;
    background: #FBFCFE;
    transition: all 0.2s ease;
  }

  .auth-input:focus {
    outline: none;
    border-color: #FF6B35;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.1);
  }

  .auth-forgot {
    display: block;
    text-align: right;
    font-size: 0.82rem;
    color: #FF6B35;
    text-decoration: none;
    font-weight: 600;
    margin-top: 10px;
  }

  .auth-submit {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    border: none;
    padding: 14px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    margin-top: 22px;
    box-shadow: 0 10px 24px rgba(255, 107, 53, 0.28);
    transition: all 0.2s ease;
  }

  .auth-submit:hover {
    background: #e85a2a;
    transform: translateY(-2px);
  }

  .auth-switch {
    text-align: center;
    font-size: 0.86rem;
    color: #5A6E85;
    margin-top: 20px;
  }

  .auth-link {
    background: none;
    border: none;
    color: #1B2A4A;
    font-weight: 700;
    font-size: 0.86rem;
    cursor: pointer;
    text-decoration: underline;
  }

  .auth-note {
    text-align: center;
    font-size: 0.75rem;
    color: #B0BCCB;
    margin-top: 22px;
  }

  /* ===== প্রোফাইল ছবি আপলোড (সাইনআপ) ===== */
  .auth-photo-upload {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .auth-photo-circle {
    position: relative;
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: #F4F7FC;
    border: 2px dashed #D7E0EC;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .auth-photo-circle:hover {
    border-color: #FF6B35;
  }

  .auth-photo-circle #photoPlaceholderIcon {
    color: #B0BCCB;
    font-size: 1.3rem;
  }

  .auth-photo-circle img {
    display: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .auth-photo-circle.has-photo #photoPlaceholderIcon {
    display: none;
  }

  .auth-photo-circle.has-photo img {
    display: block;
  }

  .auth-photo-edit {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 26px;
    height: 26px;
    background: #FF6B35;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    border: 2px solid #fff;
  }

  .auth-photo-label {
    font-size: 0.8rem;
    color: #8FA0BC;
    font-weight: 600;
  }

  @media (max-width: 480px) {
    .auth-modal {
      padding: 28px 22px 22px;
      border-radius: 22px;
    }
  }
</style>

<script>
  // ============================================================
  // এই স্ক্রিপ্ট শুধু UI ইন্টার‌্যাকশনের জন্য (ট্যাব সুইচ, মোডাল
  // খোলা/বন্ধ, ছবি প্রিভিউ, প্রোফাইল সার্কেল আপডেট)।
  // TODO: Firebase Auth যুক্ত হলে loginSubmit/signupSubmit-এর
  // ভেতরের ডেমো লজিক আসল অথেন্টিকেশন কল দিয়ে বদলে দিতে হবে।
  // ============================================================

  const overlay = document.getElementById('authOverlay');
  const closeBtn = document.getElementById('authClose');
  const tabs = document.querySelectorAll('.auth-tab');
  const panes = document.querySelectorAll('.auth-pane');
  const switchLinks = document.querySelectorAll('.auth-link');

  function openAuthModal(defaultTab = 'login') {
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
    setTab(defaultTab);
  }

  function closeAuthModal() {
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }

  function setTab(tabName) {
    tabs.forEach((t) => t.classList.toggle('active', t.getAttribute('data-tab') === tabName));
    panes.forEach((p) => p.classList.toggle('active', p.id === `${tabName}Pane`));
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => setTab(tab.getAttribute('data-tab')));
  });

  switchLinks.forEach((link) => {
    link.addEventListener('click', () => setTab(link.getAttribute('data-tab')));
  });

  closeBtn?.addEventListener('click', closeAuthModal);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeAuthModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAuthModal();
  });

  // পাসওয়ার্ড শো/হাইড
  document.querySelectorAll('.auth-input-eye').forEach((eye) => {
    eye.addEventListener('click', () => {
      const input = eye.parentElement?.querySelector('.auth-input');
      if (!input) return;
      if (input.getAttribute('type') === 'password') {
        input.setAttribute('type', 'text');
        eye.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.setAttribute('type', 'password');
        eye.classList.replace('fa-eye-slash', 'fa-eye');
      }
    });
  });

  // প্রোফাইল ছবি প্রিভিউ (সাইনআপ ফর্মে)
  const photoInput = document.getElementById('photoInput');
  const photoCircle = document.getElementById('photoPreviewCircle');
  const photoImg = document.getElementById('photoPreviewImg');
  let uploadedPhotoDataUrl = '';

  photoInput?.addEventListener('change', () => {
    const file = photoInput.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      uploadedPhotoDataUrl = reader.result;
      photoImg.src = uploadedPhotoDataUrl;
      photoCircle?.classList.add('has-photo');
    };
    reader.readAsDataURL(file);
  });

  // ডেমো সাইনআপ সাবমিট — প্রোফাইল সার্কেলে ছবি/নাম বসানো (UI only)
  const signupSubmit = document.getElementById('signupSubmit');
  signupSubmit?.addEventListener('click', () => {
    const name = document.getElementById('signupName')?.value?.trim();
    // TODO: এখানে Firebase createUserWithEmailAndPassword ইত্যাদি কল হবে
    window.dispatchEvent(new CustomEvent('smartfeni:auth-demo-login', {
      detail: { name: name || 'নতুন ইউজার', photo: uploadedPhotoDataUrl || '' },
    }));
    closeAuthModal();
  });

  // ডেমো লগইন সাবমিট (UI only)
  const loginSubmit = document.getElementById('loginSubmit');
  loginSubmit?.addEventListener('click', () => {
    // TODO: এখানে Firebase signInWithEmailAndPassword ইত্যাদি কল হবে
    window.dispatchEvent(new CustomEvent('smartfeni:auth-demo-login', {
      detail: { name: 'ইউজার', photo: '' },
    }));
    closeAuthModal();
  });

  // গ্লোবালি অ্যাক্সেসযোগ্য করা হলো যাতে Header.astro থেকে খোলা যায়
  window.openAuthModal = openAuthModal;
</script>