---
// ============================================================
// শেয়ারড কম্পোনেন্ট: লিস্টিং ডিটেইলস মডাল
// যেকোনো লিস্টিং পেজে (recycle, housing, car-rental ইত্যাদি) বসিয়ে
// src/lib/listingDetailModal.js এর initListingDetailModal() কল করলেই
// কাজ করবে। ছবি ফিক্সড ফ্রেমে (aspect-ratio 4:3, object-fit: contain)
// দেখাবে — কোনো ক্রপ হবে না।
// ============================================================
---

<div class="detail-overlay" id="detailOverlay">
  <div class="detail-modal">
    <button class="detail-close" id="detailClose" aria-label="বন্ধ করুন">
      <i class="fas fa-xmark"></i>
    </button>

    <div id="detailImageWrap"></div>

    <div class="detail-body">
      <span class="type-badge" id="detailType"></span>
      <h2 class="detail-title" id="detailTitle"></h2>
      <p class="detail-price" id="detailPrice"></p>
      <p class="detail-location"><i class="fas fa-location-dot"></i> <span id="detailUpazila"></span></p>
      <p class="detail-desc" id="detailDesc"></p>
      <a href="#" class="btn-contact" id="detailContact">
        <i class="fas fa-phone"></i> যোগাযোগ করুন
      </a>
    </div>
  </div>
</div>

<style>
  .detail-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow-y: auto;
  }

  .detail-overlay.open {
    display: flex;
  }

  .detail-modal {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 460px;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.25);
    margin: auto;
    max-height: 90vh;
    overflow-y: auto;
  }

  .detail-close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #5A6E85;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .detail-close:hover {
    background: #FF6B35;
    color: #fff;
  }

  .detail-body {
    padding: 26px 26px 30px;
  }

  .type-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    background: #F4F7FC;
    color: #5A6E85;
  }

  .detail-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1B2A4A;
    margin: 8px 0 6px;
  }

  .detail-price {
    font-size: 1.4rem;
    font-weight: 700;
    color: #FF6B35;
    margin-bottom: 10px;
  }

  .detail-location {
    font-size: 0.85rem;
    color: #8FA0BC;
    margin-bottom: 14px;
  }

  .detail-desc {
    font-size: 0.9rem;
    color: #5A6E85;
    line-height: 1.6;
    margin-bottom: 24px;
    white-space: pre-line;
  }

  .btn-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #1B2A4A;
    color: #fff;
    text-decoration: none;
    padding: 14px;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s ease;
  }

  .btn-contact:hover {
    background: #FF6B35;
  }
</style>