---
// ============================================================
// কম্পোনেন্ট: ফিচার্ড ফটো (শুধু ছবি, কোনো টাইটেল/ক্যাপশন টেক্সট নাই)
// ব্যবহার: /public/featured/featured-photo.jpg বদলালেই ছবি বদলাবে
// ছবির সাইজ: 1600x900px (16:9), JPG/WebP, 400KB এর নিচে
// টেক্সট লাগলে ছবির ভেতরেই বসিয়ে দিও (Canva দিয়ে)
// ============================================================

const photo = {
  src: '/featured/featured-photo.jpg',
};
---

<section class="featured-photo-section">
  <div class="container">
    <div class="photo-card">
      <img src={photo.src} alt="স্মার্ট ফেনী কমিউনিটি ফটো" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .featured-photo-section {
    padding: 24px 0 40px;
    background: #fff;
  }

  .photo-card {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 24px;
    overflow: hidden;
    background: #F4F7FC;
  }

  .photo-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 480px) {
    .photo-card {
      border-radius: 16px;
    }
  }
</style>