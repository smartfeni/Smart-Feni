---
// ============================================================
// কম্পোনেন্ট: ফিচার্ড ফটো (শুধু ছবি, কোনো টাইটেল/ক্যাপশন টেক্সট নাই)
// ছবি Supabase Storage থেকে ডায়নামিকভাবে লোড হয়
// (/admin/featured-photo থেকে আপলোড করলেই সাথে সাথে বদলায়, rebuild লাগে না)
// public/featured/featured-photo.jpg fallback হিসেবে থাকছে (JS লোড হওয়ার
// আগ পর্যন্ত বা Storage fetch ব্যর্থ হলে দেখাবে)
// আপডেট: dual-image crossfade — নতুন ছবি ধীরে fade-in হয়, হঠাৎ swap না
// করে, যাতে glitch/flash চোখে না পড়ে
// ============================================================

const fallbackSrc = '/featured/featured-photo.jpg';
---

<section class="featured-photo-section">
  <div class="container">
    <div class="photo-card">
      <img class="photo-layer photo-base" src={fallbackSrc} alt="স্মার্ট ফেনী কমিউনিটি ফটো" loading="lazy" />
      <img id="featuredPhotoOverlay" class="photo-layer photo-overlay" alt="" />
    </div>
  </div>
</section>

<style>
  .featured-photo-section {
    padding: 24px 0 40px;
    background: #fff;
  }

  .photo-card {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 24px;
    overflow: hidden;
    background: #F4F7FC;
  }

  .photo-layer {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .photo-overlay.loaded {
    opacity: 1;
  }

  @media (max-width: 480px) {
    .photo-card {
      border-radius: 16px;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  const BUCKET = 'listing-images';
  const STORAGE_PATH = 'site/featured-photo.jpg';

  async function loadDynamicFeaturedPhoto() {
    const overlay = document.getElementById('featuredPhotoOverlay');
    if (!overlay) return;

    const { data: fileList } = await supabase.storage.from(BUCKET).list('site', {
      search: 'featured-photo.jpg',
    });

    const fileInfo = fileList?.find((f) => f.name === 'featured-photo.jpg');
    if (!fileInfo) return; // এখনো কোনো কাস্টম ছবি আপলোড হয়নি, fallback-ই থাকবে

    const { data } = supabase.storage.from(BUCKET).getPublicUrl(STORAGE_PATH);
    const cacheBust = fileInfo.updated_at ? new Date(fileInfo.updated_at).getTime() : Date.now();

    overlay.onload = () => {
      overlay.classList.add('loaded');
    };
    overlay.src = `${data.publicUrl}?v=${cacheBust}`;
  }

  loadDynamicFeaturedPhoto();
</script>