---
// ============================================================
// কম্পোনেন্ট: ফিচার্ড ফটো (শুধু ছবি, কোনো টাইটেল/ক্যাপশন টেক্সট নাই)
// আপডেট: এখন ছবি Supabase Storage থেকে ডায়নামিকভাবে লোড হয়
// (/admin/featured-photo থেকে আপলোড করলেই সাথে সাথে বদলায়, rebuild লাগে না)
// public/featured/featured-photo.jpg শুধু fallback হিসেবে থাকছে
// (JS লোড হওয়ার আগ পর্যন্ত বা Storage fetch ব্যর্থ হলে দেখাবে)
// ============================================================

const fallbackSrc = '/featured/featured-photo.jpg';
---

<section class="featured-photo-section">
  <div class="container">
    <div class="photo-card">
      <img id="featuredPhotoImg" src={fallbackSrc} alt="স্মার্ট ফেনী কমিউনিটি ফটো" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .featured-photo-section {
    padding: 24px 0 40px;
    background: #fff;
  }

  .photo-card {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 24px;
    overflow: hidden;
    background: #F4F7FC;
  }

  .photo-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 480px) {
    .photo-card {
      border-radius: 16px;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  const BUCKET = 'listing-images';
  const STORAGE_PATH = 'site/featured-photo.jpg';

  async function loadDynamicFeaturedPhoto() {
    const img = document.getElementById('featuredPhotoImg');
    if (!img) return;

    const { data: fileList } = await supabase.storage.from(BUCKET).list('site', {
      search: 'featured-photo.jpg',
    });

    const fileInfo = fileList?.find((f) => f.name === 'featured-photo.jpg');
    if (!fileInfo) return; // এখনো কোনো কাস্টম ছবি আপলোড হয়নি, fallback-ই থাকবে

    const { data } = supabase.storage.from(BUCKET).getPublicUrl(STORAGE_PATH);
    const cacheBust = fileInfo.updated_at ? new Date(fileInfo.updated_at).getTime() : Date.now();

    const newImg = new Image();
    newImg.onload = () => {
      img.src = `${data.publicUrl}?v=${cacheBust}`;
    };
    newImg.src = `${data.publicUrl}?v=${cacheBust}`;
  }

  loadDynamicFeaturedPhoto();
</script>