---
// ============================================================
// কম্পোনেন্ট: ফিচার্ড ফটো (একটা বড় কমিউনিটি ছবি)
// ব্যবহার: /public/featured/featured-photo.jpg বদলালেই ছবি বদলাবে
// ছবির সাইজ: 1600x900px (16:9), JPG/WebP, 400KB এর নিচে
// ============================================================

const photo = {
  src: '/featured/featured-photo.jpg',
  caption: '',
};
---

<section class="featured-photo-section">
  <div class="container">
    <h2 class="section-title">কমিউনিটি মুহূর্ত</h2>

    <div class="photo-card">
      <img src={photo.src} alt={photo.caption || 'স্মার্ট ফেনী কমিউনিটি ফটো'} loading="lazy" />
      {photo.caption && <p class="photo-caption">{photo.caption}</p>}
    </div>
  </div>
</section>

<style>
  .featured-photo-section {
    padding: 40px 0 60px;
    background: #fff;
  }

  .section-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 20px;
    text-align: center;
  }

  .photo-card {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 24px;
    overflow: hidden;
    background: #F4F7FC;
  }

  .photo-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    margin: 0;
    padding: 16px 20px;
    font-size: 0.9rem;
    color: #fff;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  }

  @media (max-width: 480px) {
    .photo-card {
      border-radius: 16px;
    }
  }
</style>