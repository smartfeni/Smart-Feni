---
// ============================================================
// কম্পোনেন্ট: ফিচার্ড ফটো স্লাইডশো
// featured_photos টেবিল থেকে ক্রমানুসারে ছবি এনে প্রতি ৫ সেকেন্ডে
// crossfade করে বদলায়। কোনো ছবি না থাকলে fallback static ছবি দেখায়।
// ============================================================

const fallbackSrc = '/featured/featured-photo.jpg';
const SLIDE_INTERVAL_MS = 5000;
---

<section class="featured-photo-section">
  <div class="container">
    <div class="photo-card">
      <img class="photo-layer photo-base" src={fallbackSrc} alt="স্মার্ট ফেনী কমিউনিটি ফটো" loading="lazy" />
      <img class="photo-layer photo-slide" data-slide-a alt="" />
      <img class="photo-layer photo-slide" data-slide-b alt="" />
    </div>
  </div>
</section>

<style>
  .featured-photo-section {
    padding: 24px 0 40px;
    background: #fff;
  }

  .photo-card {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 24px;
    overflow: hidden;
    background: #F4F7FC;
  }

  .photo-layer {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .photo-slide.visible {
    opacity: 1;
  }

  @media (max-width: 480px) {
    .photo-card {
      border-radius: 16px;
    }
  }
</style>

<script define:vars={{ SLIDE_INTERVAL_MS }}>
  import('../../lib/supabase.js').then(async ({ supabase }) => {
    const BUCKET = 'listing-images';
    const layerA = document.querySelector('[data-slide-a]');
    const layerB = document.querySelector('[data-slide-b]');
    if (!layerA || !layerB) return;

    const { data: photos, error } = await supabase
      .from('featured_photos')
      .select('storage_path')
      .order('sort_order', { ascending: true });

    if (error || !photos || photos.length === 0) return;

    const urls = photos.map((p) => supabase.storage.from(BUCKET).getPublicUrl(p.storage_path).data.publicUrl);

    let currentIndex = 0;
    let activeLayer = layerA;
    let inactiveLayer = layerB;

    function preload(url) {
      return new Promise((resolve) => {
        const img = new Image();
        img.onload = () => resolve();
        img.onerror = () => resolve();
        img.src = url;
      });
    }

    await preload(urls[0]);
    activeLayer.src = urls[0];
    activeLayer.classList.add('visible');

    if (urls.length <= 1) return;

    async function showNext() {
      currentIndex = (currentIndex + 1) % urls.length;
      const nextUrl = urls[currentIndex];

      await preload(nextUrl);
      inactiveLayer.src = nextUrl;
      inactiveLayer.classList.add('visible');
      activeLayer.classList.remove('visible');

      const temp = activeLayer;
      activeLayer = inactiveLayer;
      inactiveLayer = temp;
    }

    setInterval(showNext, SLIDE_INTERVAL_MS);
  });
</script>