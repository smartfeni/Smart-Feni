// ============================================================
// কম্পোনেন্ট: সিটিএ (অ্যাকশন কল)
// স্টাইল: Urban Company Style
// ============================================================
---

<section class="cta-section">
  <div class="container">
    <div class="cta-box">
      <h2>আজই <span class="accent">যোগ দিন</span> স্মার্ট ফেনী পরিবারে</h2>
      <p>আপনার সেবা দিন, বা সেবা নিন – শুরু করুন মাত্র একটি ক্লিকে</p>
      <a href="/signup" class="btn-primary">
        <i class="fas fa-user-plus"></i> ফ্রি অ্যাকাউন্ট খুলুন
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 70px 0;
    background: #fff;
  }

  .cta-box {
    background: linear-gradient(135deg, #1B2A4A 0%, #0F1A2E 100%);
    padding: 60px 40px;
    border-radius: 32px;
    text-align: center;
    color: #fff;
  }

  .cta-box h2 {
    font-size: 2.4rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .cta-box h2 .accent {
    color: #FF6B35;
  }

  .cta-box p {
    font-size: 1.1rem;
    opacity: 0.8;
    margin-bottom: 28px;
  }

  .cta-box .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #FF6B35;
    color: #fff;
    padding: 14px 36px;
    border-radius: 60px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.3);
  }

  .cta-box .btn-primary:hover {
    background: #e85a2a;
    transform: translateY(-3px);
  }

  @media (max-width: 768px) {
    .cta-box {
      padding: 40px 24px;
    }

    .cta-box h2 {
      font-size: 1.8rem;
    }
  }
</style>