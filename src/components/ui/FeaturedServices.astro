---
// ============================================================
// কম্পোনেন্ট: ফিচার্ড সার্ভিসেস (জনপ্রিয় সেবা)
// ============================================================

import { featuredServices } from '../../data/services.js';
---

<section class="featured-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">🔥 জনপ্রিয়</span>
      <h2>সর্বাধিক <span class="accent">চাহিদাসম্পন্ন</span> সেবা</h2>
      <p>ফেনী জেলায় এখন সবচেয়ে বেশি চাহিদা রয়েছে</p>
    </div>

    <div class="featured-grid">
      {featuredServices.map((service) => (
        <a href={`/services/${service.slug}`} class="featured-card">
          <div class="card-top">
            <div class="card-icon">
              <i class={`fas ${service.icon}`}></i>
            </div>
            <span class="card-tag">{service.tag}</span>
          </div>
          <h4>{service.title}</h4>
          <p>{service.desc}</p>
          <div class="card-meta">
            <span><i class="far fa-clock"></i> {service.time}</span>
            <span><i class="fas fa-map-pin"></i> {service.location}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-section {
    padding: 70px 0;
    background: #F8FAFC;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 28px;
  }

  .featured-card {
    background: #fff;
    padding: 24px;
    border-radius: 24px;
    text-decoration: none;
    color: #1B2A4A;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .featured-card:hover {
    transform: translateY(-6px);
    border-color: #FF6B35;
    box-shadow: 0 12px 40px rgba(255, 107, 53, 0.06);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-icon {
    width: 48px;
    height: 48px;
    background: #F4F7FC;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: #FF6B35;
  }

  .card-tag {
    background: #EFF5FF;
    color: #1B2A4A;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 14px;
    border-radius: 40px;
  }

  .featured-card h4 {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .featured-card p {
    color: #4A5B6E;
    font-size: 0.9rem;
    line-height: 1.5;
    flex: 1;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: #7A8EA5;
    border-top: 1px solid #EEF3F9;
    padding-top: 14px;
  }

  .card-meta i {
    margin-right: 6px;
  }

  @media (max-width: 768px) {
    .featured-section {
      padding: 50px 0;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>