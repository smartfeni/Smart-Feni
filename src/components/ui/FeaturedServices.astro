---
import { featuredServices } from '../../data/services.js';
---
<div class="container">
  <h2 class="section-title">জনপ্রিয় <span>সেবা</span></h2>
  <p class="section-sub">আপনার এলাকায় এখন সবচেয়ে বেশি চাহিদা রয়েছে</p>
  <div class="featured-grid">
    {featuredServices.map((service) => (
      <div class="featured-card">
        <div class="top"><i class={`fas ${service.icon}`}></i><h3>{service.title}</h3></div>
        <span class="tag">{service.tag}</span>
        <p>{service.desc}</p>
        <div class="meta"><span><i class="far fa-clock"></i> {service.time}</span><span><i class="fas fa-map-pin"></i> {service.location}</span></div>
      </div>
    ))}
  </div>
</div>

<style>
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
    margin: 40px 0 70px;
  }
  .featured-card {
    background: #fff;
    border-radius: 32px;
    padding: 28px;
    box-shadow: 0 8px 28px rgba(27,42,74,0.04);
    border: 1px solid #EEF3F9;
    transition: 0.25s ease;
    display: flex;
    flex-direction: column;
  }
  .featured-card:hover {
    border-color: #FF6B35;
    box-shadow: 0 16px 48px rgba(255,107,53,0.06);
  }
  .featured-card .top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 14px;
  }
  .featured-card .top i {
    font-size: 2rem;
    width: 56px;
    height: 56px;
    background: #F4F7FC;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FF6B35;
  }
  .featured-card h3 { font-size: 1.2rem; font-weight: 600; }
  .featured-card .tag {
    background: #EFF5FF;
    color: #1B2A4A;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 14px;
    border-radius: 40px;
    align-self: flex-start;
    margin: 8px 0 12px;
  }
  .featured-card p { color: #4A5B6E; font-size: 0.9rem; margin-bottom: 18px; flex: 1; }
  .featured-card .meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: #7A8EA5;
    border-top: 1px solid #EEF3F9;
    padding-top: 16px;
  }
</style>