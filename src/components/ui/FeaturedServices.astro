---
// ============================================================
// কম্পোনেন্ট: ফিচার্ড সার্ভিসেস (জনপ্রিয় সেবা)
// স্টাইল: Urban Company Card Style
// ============================================================

import { featuredServices } from '../../data/services.js';
---

<section class="featured-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">🔥 জনপ্রিয়</span>
      <h2>সর্বাধিক <span class="accent">চাহিদাসম্পন্ন</span> সেবা</h2>
      <p>ফেনী জেলায় এখন সবচেয়ে বেশি চাহিদা রয়েছে</p>
    </div>

    <div class="featured-grid">
      {featuredServices.map((service) => (
        <a href={`/services/${service.slug}`} class="featured-card">
          <div class="card-image">
            <i class={`fas ${service.icon}`}></i>
          </div>
          <div class="card-body">
            <span class="card-tag">{service.tag}</span>
            <h4>{service.title}</h4>
            <p>{service.desc}</p>
            <div class="card-meta">
              <span><i class="far fa-clock"></i> {service.time}</span>
              <span><i class="fas fa-map-pin"></i> {service.location}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-section {
    padding: 70px 0;
    background: #fff;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-tag {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #FF6B35;
    background: #FFF0EA;
    padding: 4px 16px;
    border-radius: 40px;
    margin-bottom: 12px;
  }

  .section-header h2 {
    font-size: 2.4rem;
    font-weight: 700;
  }

  .section-header h2 .accent {
    color: #FF6B35;
  }

  .section-header p {
    color: #5A6E85;
    font-size: 1.1rem;
    margin-top: 8px;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .featured-card {
    background: #F8FAFC;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: #1B2A4A;
    transition: all 0.25s ease;
    border: 1px solid transparent;
  }

  .featured-card:hover {
    transform: translateY(-6px);
    border-color: #FF6B35;
    box-shadow: 0 12px 40px rgba(255, 107, 53, 0.06);
    background: #fff;
  }

  .card-image {
    background: linear-gradient(135deg, #FF6B35 0%, #FF8A5C 100%);
    padding: 32px;
    text-align: center;
    font-size: 2.5rem;
    color: #fff;
  }

  .card-body {
    padding: 20px 24px 24px;
  }

  .card-tag {
    display: inline-block;
    background: #EFF5FF;
    color: #1B2A4A;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 14px;
    border-radius: 40px;
    margin-bottom: 10px;
  }

  .featured-card h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .featured-card p {
    color: #4A5B6E;
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: #7A8EA5;
    border-top: 1px solid #EEF3F9;
    padding-top: 14px;
  }

  .card-meta i {
    margin-right: 6px;
  }

  @media (max-width: 768px) {
    .featured-section {
      padding: 50px 0;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>