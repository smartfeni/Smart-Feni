<section class="search-section">
  <div class="container">
    <form class="search-card" onsubmit="handleSearchSubmit(event)">
      <i class="fas fa-search"></i>
      <input 
        type="text" 
        id="searchInput"
        placeholder="কী সার্ভিস দরকার? (যেমন: প্লাম্বার, ডাক্তার, টিউশন)" 
        oninput="handleSearch(this.value)"
      />
      <button type="submit" class="btn-primary">
        <i class="fas fa-arrow-right"></i> খুঁজুন
      </button>
    </form>
    <div id="searchResults" style="margin-top: 20px; display: none;"></div>
  </div>
</section>

<script>
  // সম্পূর্ণ সার্ভিস লিস্ট (আমি আগের বার যে বড় লিস্ট দিয়েছিলাম, সেটা এখানে বসান)
  const services = [
    { name: 'আবাসন বন্ধু', category: 'বাড়ি ভাড়া/ক্রয়', slug: 'housing' },
    { name: 'কর্মসংস্থান', category: 'চাকরি পোস্ট/খোঁজ', slug: 'job' },
    { name: 'স্বাস্থ্য সাথী', category: 'ডাক্তার/হাসপাতাল', slug: 'health' },
    { name: 'শিক্ষা সন্ধানী', category: 'টিউটর/স্টুডেন্ট', slug: 'tuition' },
    { name: 'গৃহস্থালী কারিগর', category: 'প্লাম্বিং, ইলেকট্রিক', slug: 'plumbing' },
    { name: 'জীবন রক্ষা', category: 'অ্যাম্বুলেন্স', slug: 'ambulance' },
    { name: 'খাবারের ঠিকানা', category: 'রেস্টুরেন্ট মেনু', slug: 'food' },
    { name: 'প্রেরণ সেবা', category: 'ডেলিভারি/কুরিয়ার', slug: 'courier' },
    { name: 'রক্তবন্ধু', category: 'রক্ত দান/সংগ্রহ', slug: 'blood' },
    { name: 'পুনঃব্যবহার বাজার', category: 'পুরনো মাল কিনি/বিক্রি', slug: 'used' },
    { name: 'প্রাণচাঞ্চল্য', category: 'স্পোর্টস/বিনোদন', slug: 'sports' },
    { name: 'হারানো-পাওয়া', category: 'লস্ট অ্যান্ড ফাউন্ড', slug: 'lost' },
    { name: 'দাম্পত্য সহায়িকা', category: 'বিয়ে সংক্রান্ত', slug: 'marriage' },
    { name: 'আইনি সঙ্গী', category: 'পরামর্শ ও নথি', slug: 'legal' },
    { name: 'আয়োজন বিশেষজ্ঞ', category: 'ইভেন্ট ম্যানেজমেন্ট', slug: 'event' },
    { name: 'পরিচ্ছন্ন বাসস্থান', category: 'ঘর পরিষ্কার', slug: 'cleaning' },
    { name: 'যন্ত্রবন্ধু', category: 'মেরামত সার্ভিস', slug: 'electronics' },
    { name: 'অর্থমিত্র', category: 'ব্যাংকিং/লেনদেন', slug: 'finance' },
    { name: 'পশুবন্ধু', category: 'পোষ্যদের সেবা', slug: 'pet' },
    { name: 'মানসিক সাথী', category: 'কাউন্সেলিং', slug: 'mental' },
    { name: 'নৈপুণ্য সেবা', category: 'শিল্প/বিনোদন', slug: 'entertainment' },
    { name: 'আমাদের আয়োজন', category: 'স্থানীয় ইভেন্ট', slug: 'local-event' },
    { name: 'জরুরি যোগাযোগ', category: 'পুলিশ, ফায়ার', slug: 'emergency' },
    { name: 'ঘর সংস্কার', category: 'রেনোভেশন সার্ভিস', slug: 'renovation' },
    { name: 'যানবাহন', category: 'মেকানিক, ওয়াশ', slug: 'vehicle' }
  ];

  function handleSearch(query) {
    const resultsContainer = document.getElementById('searchResults');
    
    if (!query || query.trim() === '') {
      resultsContainer.style.display = 'none';
      return;
    }

    const filtered = services.filter(service => 
      service.name.includes(query) || 
      service.category.includes(query)
    );

    if (filtered.length === 0) {
      resultsContainer.innerHTML = `<p style="color: #5A6E85;">🔍 কোনো সেবা পাওয়া যায়নি</p>`;
    } else {
      resultsContainer.innerHTML = filtered.map(service => `
        <a href="/services/${service.slug}" style="display: block; padding: 12px; background: #fff; border-radius: 12px; margin-bottom: 8px; text-decoration: none; color: #1B2A4A; border: 1px solid #EEE;">
          <strong>${service.name}</strong>
          <span style="color: #FF6B35; font-size: 0.8rem;">${service.category}</span>
        </a>
      `).join('');
    }
    
    resultsContainer.style.display = 'block';
  }

  function handleSearchSubmit(event) {
    event.preventDefault(); // পেজ রিলোড বন্ধ
    const input = document.getElementById('searchInput');
    handleSearch(input.value);
  }

  window.handleSearch = handleSearch;
  window.handleSearchSubmit = handleSearchSubmit;
</script>

<style>
  .search-section { margin-top: -40px; position: relative; z-index: 10; }
  .search-card {
    background: #fff;
    padding: 20px 28px;
    border-radius: 80px;
    box-shadow: 0 20px 50px rgba(27,42,74,0.08);
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  .search-card i { color: #FF6B35; font-size: 1.2rem; }
  .search-card input {
    flex: 1;
    min-width: 200px;
    border: none;
    padding: 14px 8px;
    font-size: 1rem;
    outline: none;
    background: transparent;
  }
  .search-card input::placeholder { color: #A0B3C9; }
  .search-card .btn-primary { padding: 12px 36px; }
  #searchResults {
    background: #fff;
    border-radius: 20px;
    padding: 16px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    margin-top: 16px;
  }
  #searchResults a:hover {
    background: #F4F7FC;
    border-color: #FF6B35;
  }
  @media (max-width: 768px) {
    .search-card { border-radius: 40px; flex-direction: column; }
  }
</style>