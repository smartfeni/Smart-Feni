---
// ফ্রন্টম্যাটার - এখানে কোনো ডাটা নেই
---

<section class="search-section">
  <div class="container">
    <div class="search-card">
      <i class="fas fa-search"></i>
      <input 
        type="text" 
        id="searchInput"
        placeholder="কী সার্ভিস দরকার? (যেমন: প্লাম্বার, ডাক্তার, টিউশন)" 
        oninput="handleSearch(this.value)"
      />
      <button class="btn-primary" onclick="handleSearch(document.getElementById('searchInput').value)">
        <i class="fas fa-arrow-right"></i> খুঁজুন
      </button>
    </div>
    <!-- সার্চ রেজাল্ট দেখানোর জন্য -->
    <div id="searchResults" style="margin-top: 20px; display: none;"></div>
  </div>
</section>

<script>
  // সার্চ ফাংশন
  function handleSearch(query) {
    const resultsContainer = document.getElementById('searchResults');
    
    if (!query || query.trim() === '') {
      resultsContainer.style.display = 'none';
      return;
    }

    // ডাইনামিকভাবে সব সেবা লোড করুন (এখানে ডেমো ডাটা)
    const services = [
      { name: 'আবাসন বন্ধু', category: 'আবাসন', slug: 'housing' },
      { name: 'কর্মসংস্থান', category: 'চাকরি', slug: 'job' },
      { name: 'স্বাস্থ্য সাথী', category: 'স্বাস্থ্য', slug: 'health' },
      { name: 'শিক্ষা সন্ধানী', category: 'টিউশন', slug: 'tuition' },
      { name: 'গৃহস্থালী কারিগর', category: 'গৃহস্থালী', slug: 'plumbing' },
      { name: 'জীবন রক্ষা', category: 'অ্যাম্বুলেন্স', slug: 'ambulance' },
      { name: 'খাবারের ঠিকানা', category: 'খাবার', slug: 'food' },
      { name: 'প্রেরণ সেবা', category: 'কুরিয়ার', slug: 'courier' },
      { name: 'রক্তবন্ধু', category: 'রক্তদান', slug: 'blood' },
      { name: 'পুনঃব্যবহার বাজার', category: 'বাজার', slug: 'used' },
      // ... আপনার সব ক্যাটাগরি যোগ করুন
    ];

    const filtered = services.filter(service => 
      service.name.includes(query) || 
      service.category.includes(query)
    );

    if (filtered.length === 0) {
      resultsContainer.innerHTML = `<p style="color: #5A6E85;">🔍 কোনো সেবা পাওয়া যায়নি</p>`;
    } else {
      resultsContainer.innerHTML = filtered.map(service => `
        <a href="/services/${service.slug}" style="display: block; padding: 12px; background: #fff; border-radius: 12px; margin-bottom: 8px; text-decoration: none; color: #1B2A4A; border: 1px solid #EEE;">
          <strong>${service.name}</strong>
          <span style="color: #FF6B35; font-size: 0.8rem;">${service.category}</span>
        </a>
      `).join('');
    }
    
    resultsContainer.style.display = 'block';
  }

  // গ্লোবাল স্কোপে ফাংশন পাঠান
  window.handleSearch = handleSearch;
</script>

<style>
  .search-section { margin-top: -40px; position: relative; z-index: 10; }
  .search-card {
    background: #fff;
    padding: 20px 28px;
    border-radius: 80px;
    box-shadow: 0 20px 50px rgba(27,42,74,0.08);
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  .search-card i { color: #FF6B35; font-size: 1.2rem; }
  .search-card input {
    flex: 1;
    min-width: 200px;
    border: none;
    padding: 14px 8px;
    font-size: 1rem;
    outline: none;
    background: transparent;
  }
  .search-card input::placeholder { color: #A0B3C9; }
  .search-card .btn-primary { padding: 12px 36px; }
  #searchResults {
    background: #fff;
    border-radius: 20px;
    padding: 16px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    margin-top: 16px;
  }
  #searchResults a:hover {
    background: #F4F7FC;
    border-color: #FF6B35;
  }
  @media (max-width: 768px) {
    .search-card { border-radius: 40px; flex-direction: column; }
  }
</style>