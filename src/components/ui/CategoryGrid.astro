---
// ============================================================
// কম্পোনেন্ট: ক্যাটাগরি গ্রিড
// আপডেট: courier, car-rental, online-shop এখন "জনপ্রিয়" সেকশনে
//         আলাদা কার্ড স্টাইল ও আলাদা ক্লিক-কাউন্ট দিয়ে দেখানো হয়
// ============================================================

import { categories } from '../../data/services.js';
import CategoryCard from '../shared/CategoryCard.astro';
import CategoryCardPopular from '../shared/CategoryCardPopular.astro';

const popularSlugs = ['courier', 'car-rental', 'online-shop'];

const popularCategories = popularSlugs
  .map(slug => categories.find(c => c.slug === slug))
  .filter(Boolean);

const otherCategories = categories.filter(c => !popularSlugs.includes(c.slug));
---

<section class="category-section">
  <div class="container">

    <div class="popular-label">
      <i class="fas fa-fire"></i> জনপ্রিয়
    </div>
    <div class="category-grid category-grid-popular" id="categoryGridPopular">
      {popularCategories.map((cat) => (
        <CategoryCardPopular cat={cat} />
      ))}
    </div>

    <div class="category-grid" id="categoryGrid">
      {otherCategories.map((cat) => (
        <CategoryCard cat={cat} />
      ))}
    </div>

  </div>
</section>

<script>
  function sortGridByCount(gridId, storageKey) {
    const grid = document.getElementById(gridId);
    if (!grid) return;
    const cards = Array.from(grid.children);
    const counts = JSON.parse(localStorage.getItem(storageKey) || '{}');
    cards.sort((a, b) => {
      const idA = a.dataset.categoryId;
      const idB = b.dataset.categoryId;
      const countA = counts[idA] || 0;
      const countB = counts[idB] || 0;
      return countB - countA;
    });
    cards.forEach(card => grid.appendChild(card));
  }

  document.addEventListener('DOMContentLoaded', () => {
    sortGridByCount('categoryGridPopular', 'service_counts_popular');
    sortGridByCount('categoryGrid', 'service_counts');
  });
</script>

<style>
  .category-section {
    padding: 20px 0 60px;
    background: #fff;
  }

  .popular-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    font-weight: 700;
    color: #FF6B35;
    margin: 0 0 12px 4px;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .category-grid-popular {
    margin-bottom: 32px;
  }

  @media (max-width: 768px) {
    .category-grid {
      gap: 10px;
    }
  }

  @media (max-width: 480px) {
    .category-grid {
      gap: 8px;
    }
  }
</style>