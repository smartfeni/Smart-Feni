---
// ============================================================
// কম্পোনেন্ট: ক্যাটাগরি গ্রিড
// ============================================================

import { categories } from '../../data/services.js';
import CategoryCard from '../shared/CategoryCard.astro';
---

<section class="category-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">📋 সেবাসমূহ</span>
      <h2>২৫+ <span class="accent">ক্যাটাগরি</span></h2>
      <p>আপনার দৈনন্দিন জীবনের সব সেবা</p>
    </div>

    <div class="category-grid">
      {categories.map((cat) => (
        <CategoryCard cat={cat} />
      ))}
    </div>
  </div>
</section>

<style>
  .category-section {
    padding: 70px 0;
    background: #fff;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 20px;
  }

  @media (max-width: 768px) {
    .category-section {
      padding: 50px 0;
    }

    .category-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    }
  }
</style>