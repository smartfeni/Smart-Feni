---
// ============================================================
// কম্পোনেন্ট: ক্যাটাগরি গ্রিড — প্রতি লাইনে ৩টা করে
// ============================================================

import { categories } from '../../data/services.js';
import CategoryCard from '../shared/CategoryCard.astro';
---

<section class="category-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">📋 সেবাসমূহ</span>
      <h2>১৭+ <span class="accent">ক্যাটাগরি</span></h2>
      <p>আপনার দৈনন্দিন জীবনের সব সেবা</p>
    </div>

    <div class="category-grid">
      {categories.map((cat) => (
        <CategoryCard cat={cat} />
      ))}
    </div>
  </div>
</section>

<style>
  .category-section {
    padding: 70px 0;
    background: #fff;
  }

  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-tag {
    display: inline-block;
    background: #FFF0EA;
    color: #FF6B35;
    padding: 6px 18px;
    border-radius: 40px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .section-header h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 8px;
  }

  .section-header h2 .accent {
    color: #FF6B35;
  }

  .section-header p {
    color: #5A6E85;
    font-size: 1rem;
  }

  /* ===== প্রতি লাইনে ৩টা করে ফিক্সড কলাম ===== */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 768px) {
    .category-section {
      padding: 50px 0;
    }

    .category-grid {
      gap: 10px;
    }
  }

  @media (max-width: 480px) {
    .category-grid {
      gap: 8px;
    }
  }
</style>