---
// ============================================================
// কম্পোনেন্ট: ক্যাটাগরি গ্রিড — শুধু কার্ড, কোনো হেডার টেক্সট নাই
// ============================================================

import { categories } from '../../data/services.js';
import CategoryCard from '../shared/CategoryCard.astro';
---

<section class="category-section">
  <div class="container">
    <div class="category-grid">
      {categories.map((cat) => (
        <CategoryCard cat={cat} />
      ))}
    </div>
  </div>
</section>

<style>
  .category-section {
    padding: 20px 0 60px;
    background: #fff;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 768px) {
    .category-grid {
      gap: 10px;
    }
  }

  @media (max-width: 480px) {
    .category-grid {
      gap: 8px;
    }
  }
</style>