---
import { categories } from '../../data/services.js';
import CategoryCard from '../shared/CategoryCard.astro';
---
<div class="container">
  <h2 class="section-title">সেবা <span>ক্যাটাগরি</span></h2>
  <p class="section-sub">আপনার দৈনন্দিন চাহিদা মেটাতে ২৫+ ক্যাটাগরি</p>
  <div class="category-grid">
    {categories.map((cat) => (
      <CategoryCard {cat} />
    ))}
  </div>
</div>

<style>
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 28px;
    margin-bottom: 40px;
  }
</style>