---
// ============================================================
// কম্পোনেন্ট: লোকেশন সিলেক্টর (উপজেলা অটো-ডিটেক্ট + ম্যানুয়াল ফলব্যাক)
// ফিক্স ১: ব্যাকগ্রাউন্ড বক্স সরিয়ে মিনিমাল (শুধু পিন+নাম), বাম কোণায়
// ফিক্স ২: ড্রপডাউন এখন header-এর exact নিচ থেকে, বাম পাশে fixed —
//          প্রতিবার খোলার সময় লাইভ measurement দিয়ে position বসে,
//          তাই প্রথমবার লোড হওয়ার সময়ও ঠিকভাবে দেখাবে (আর ড্র্যাগ
//          করে ঠিক করা লাগবে না)
// ============================================================
---

<div class="location-selector" id="locationSelector">
  <button class="location-btn" id="locationBtn" type="button">
    <i class="fas fa-location-dot"></i>
    <span id="locationLabel">লোকেশন নির্ণয় হচ্ছে...</span>
    <i class="fas fa-chevron-down chevron"></i>
  </button>

  <div class="location-dropdown" id="locationDropdown">
    <p class="dropdown-title">আপনার উপজেলা বেছে নিন</p>
    <button class="upazila-option" data-upazila="feni-sadar">ফেনী সদর</button>
    <button class="upazila-option" data-upazila="chhagalnaiya">ছাগলনাইয়া</button>
    <button class="upazila-option" data-upazila="daganbhuiyan">দাগনভূঞা</button>
    <button class="upazila-option" data-upazila="parshuram">পরশুরাম</button>
    <button class="upazila-option" data-upazila="fulgazi">ফুলগাজী</button>
    <button class="upazila-option" data-upazila="sonagazi">সোনাগাজী</button>
    <button class="detect-again" id="detectAgainBtn">
      <i class="fas fa-crosshairs"></i> বর্তমান লোকেশন দিয়ে নির্ণয় করুন
    </button>
  </div>
</div>

<style>
  .location-selector {
    position: relative;
    /* container-এর 24px padding কাটিয়ে একদম বাম কোণায় নিয়ে যাওয়া হলো */
    margin-left: -24px;
  }

  /* ===== মিনিমাল বাটন — কোনো ব্যাকগ্রাউন্ড বক্স নেই ===== */
  .location-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    color: #1B2A4A;
    border: none;
    padding: 8px 10px 8px 14px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: color 0.2s ease;
    white-space: nowrap;
    max-width: 160px;
    overflow: hidden;
  }

  .location-btn span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .location-btn:hover {
    color: #FF6B35;
  }

  .location-btn i.fa-location-dot {
    color: #FF6B35;
    flex-shrink: 0;
    font-size: 0.9rem;
  }

  .chevron {
    font-size: 0.6rem;
    margin-left: 1px;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .location-selector.open .chevron {
    transform: rotate(180deg);
  }

  /* ===== ডেস্কটপ: বাটনের নিচে normal absolute dropdown ===== */
  .location-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 14px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
    padding: 12px;
    width: 240px;
    z-index: 1000;
    border: 1px solid #EEF3F9;
  }

  .location-selector.open .location-dropdown {
    display: block;
  }

  .dropdown-title {
    font-size: 0.75rem;
    color: #7A8EA5;
    font-weight: 600;
    padding: 4px 12px 8px;
  }

  .upazila-option {
    display: block;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #1B2A4A;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .upazila-option:hover {
    background: #F8FAFC;
  }

  .upazila-option.active {
    background: #FFF0EA;
    color: #FF6B35;
  }

  .detect-again {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    background: none;
    border: none;
    border-top: 1px solid #EEF3F9;
    margin-top: 8px;
    padding: 10px 12px 4px;
    font-size: 0.8rem;
    color: #5A6E85;
    cursor: pointer;
  }

  .detect-again:hover {
    color: #FF6B35;
  }

  /* ===== মোবাইল: header-এর exact নিচ থেকে, বাম পাশে fixed =====
     top এর মান JS দিয়ে প্রতিবার খোলার সময় বসানো হয় (live measurement),
     তাই স্ক্রিন সাইজ/address bar যাই থাকুক ঠিকভাবে বসবে ===== */
  @media (max-width: 768px) {
    .location-btn {
      max-width: 130px;
      padding: 6px 8px 6px 12px;
    }

    .location-dropdown {
      position: fixed;
      left: 8px;
      top: 70px; /* fallback, JS দিয়ে override হবে */
      width: calc(100vw - 16px);
      max-width: 280px;
      max-height: calc(100vh - 90px);
      overflow-y: auto;
      z-index: 1000;
    }
  }
</style>

<script>
  const UPAZILAS = [
    { id: 'feni-sadar', name: 'ফেনী সদর', lat: 23.0159, lng: 91.3976 },
    { id: 'chhagalnaiya', name: 'ছাগলনাইয়া', lat: 23.0389, lng: 91.5194 },
    { id: 'daganbhuiyan', name: 'দাগনভূঞা', lat: 22.9833, lng: 91.1833 },
    { id: 'parshuram', name: 'পরশুরাম', lat: 23.2250, lng: 91.4500 },
    { id: 'fulgazi', name: 'ফুলগাজী', lat: 23.0700, lng: 91.4500 },
    { id: 'sonagazi', name: 'সোনাগাজী', lat: 22.8500, lng: 91.3917 },
  ];

  const DEFAULT_UPAZILA = 'feni-sadar';
  const STORAGE_KEY = 'smartfeni_upazila';
  const MAX_DISTANCE_KM = 40;
  const FENI_CENTER = { lat: 23.0159, lng: 91.3976 };

  const selector = document.getElementById('locationSelector');
  const btn = document.getElementById('locationBtn');
  const label = document.getElementById('locationLabel');
  const detectAgainBtn = document.getElementById('detectAgainBtn');
  const dropdown = document.getElementById('locationDropdown');
  const options = document.querySelectorAll('.upazila-option');

  function haversineDistance(lat1: number, lng1: number, lat2: number, lng2: number) {
    const R = 6371;
    const dLat = ((lat2 - lat1) * Math.PI) / 180;
    const dLng = ((lng2 - lng1) * Math.PI) / 180;
    const a =
      Math.sin(dLat / 2) ** 2 +
      Math.cos((lat1 * Math.PI) / 180) *
        Math.cos((lat2 * Math.PI) / 180) *
        Math.sin(dLng / 2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  function findNearestUpazila(lat: number, lng: number) {
    let nearest = UPAZILAS[0];
    let minDist = Infinity;
    for (const u of UPAZILAS) {
      const d = haversineDistance(lat, lng, u.lat, u.lng);
      if (d < minDist) {
        minDist = d;
        nearest = u;
      }
    }
    return { nearest, distance: minDist };
  }

  function setUpazila(id: string, save = true) {
    const upazila = UPAZILAS.find((u) => u.id === id) || UPAZILAS.find((u) => u.id === DEFAULT_UPAZILA)!;
    label!.textContent = upazila.name;
    options.forEach((opt) => {
      opt.classList.toggle('active', (opt as HTMLElement).dataset.upazila === upazila.id);
    });
    if (save) {
      localStorage.setItem(STORAGE_KEY, upazila.id);
    }
  }

  function openManualSelection() {
    label!.textContent = 'উপজেলা বেছে নিন';
    selector!.classList.add('open');
    updateDropdownPosition();
  }

  function detectLocation() {
    label!.textContent = 'লোকেশন নির্ণয় হচ্ছে...';
    if (!navigator.geolocation) {
      openManualSelection();
      return;
    }
    navigator.geolocation.getCurrentPosition(
      (position) => {
        const { latitude, longitude } = position.coords;
        const distanceFromFeni = haversineDistance(latitude, longitude, FENI_CENTER.lat, FENI_CENTER.lng);

        if (distanceFromFeni > MAX_DISTANCE_KM) {
          setUpazila(DEFAULT_UPAZILA, false);
          openManualSelection();
          return;
        }

        const { nearest } = findNearestUpazila(latitude, longitude);
        setUpazila(nearest.id);
      },
      () => {
        setUpazila(DEFAULT_UPAZILA, false);
        openManualSelection();
      },
      { timeout: 8000 }
    );
  }

  // ===== dropdown-কে header-এর exact নিচে, বাম পাশে বসায় (লাইভ measurement) =====
  function updateDropdownPosition() {
    if (window.innerWidth > 768) {
      // ডেস্কটপে CSS absolute positioning নিজেই সামলাবে
      dropdown!.style.top = '';
      dropdown!.style.left = '';
      return;
    }
    const navbar = document.querySelector('.navbar') as HTMLElement | null;
    if (!navbar) return;
    const navRect = navbar.getBoundingClientRect();
    dropdown!.style.top = `${Math.round(navRect.bottom)}px`;
    dropdown!.style.left = '8px';
  }

  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) {
    setUpazila(saved, false);
  } else {
    detectLocation();
  }

  btn!.addEventListener('click', () => {
    const willOpen = !selector!.classList.contains('open');
    selector!.classList.toggle('open');
    if (willOpen) {
      updateDropdownPosition();
    }
  });

  document.addEventListener('click', (e) => {
    if (!selector!.contains(e.target as Node)) {
      selector!.classList.remove('open');
    }
  });

  window.addEventListener('resize', () => {
    if (selector!.classList.contains('open')) {
      updateDropdownPosition();
    }
  });

  options.forEach((opt) => {
    opt.addEventListener('click', () => {
      setUpazila((opt as HTMLElement).dataset.upazila!);
      selector!.classList.remove('open');
    });
  });

  detectAgainBtn!.addEventListener('click', () => {
    detectLocation();
    selector!.classList.remove('open');
  });
</script>