---
// ============================================================
// কম্পোনেন্ট: নতুন লিস্টিং যোগ করার মোডাল (রিইউজেবল)
// প্রতিটা ক্যাটাগরি পেজ থেকে <AddListingModal category="repair" typeOptions={...} />
// আকারে কল হবে। লগইন করা না থাকলে প্রথমে AuthModal খুলবে।
// titleLabel/priceLabel দিয়ে লেবেল কাস্টমাইজ করা যাবে (যেমন job এ "পদবী"/"বেতন")
// companyLabel দিলে একটা এক্সট্রা ইনপুট দেখাবে, যেটা সাবমিটের সময় description এর শুরুতে জুড়ে যাবে
// নতুন: openListingModal('tutor') এর মতো প্যারামিটার দিলে "সার্ভিসের ধরন"
// ড্রপডাউনে সেই ভ্যালু আগে থেকেই সিলেক্ট করা থাকবে (tuition পেজের ২টা CTA-র জন্য)
// ============================================================

export interface Props {
  category: string;
  typeOptions: { id: string; label: string }[];
  titleLabel?: string;
  priceLabel?: string;
  companyLabel?: string;
}

const {
  category,
  typeOptions,
  titleLabel = 'টাইটেল',
  priceLabel = 'দাম / রেট',
  companyLabel,
} = Astro.props;

const upazilas = ['ফেনী সদর', 'ছাগলনাইয়া', 'দাগনভূঞা', 'পরশুরাম', 'ফুলগাজী', 'সোনাগাজী'];
---

<div class="listing-overlay" id="listingOverlay" data-category={category} data-company-label={companyLabel || ''}>
  <div class="listing-modal">
    <button class="listing-close" id="listingClose" aria-label="বন্ধ করুন">
      <i class="fas fa-xmark"></i>
    </button>

    <h2 class="listing-title"><i class="fas fa-plus-circle"></i> নতুন লিস্টিং যোগ করুন</h2>
    <p class="listing-subtitle">তথ্য পূরণ করুন, সবাই দেখতে পাবে</p>

    <p class="listing-message" id="listingMessage"></p>

    <label class="listing-label">সার্ভিসের ধরন</label>
    <select class="listing-input" id="listingType">
      {typeOptions.map((t) => (
        <option value={t.id}>{t.label}</option>
      ))}
    </select>

    {companyLabel && (
      <>
        <label class="listing-label">{companyLabel}</label>
        <input type="text" class="listing-input" id="listingCompany" placeholder="" />
      </>
    )}

    <label class="listing-label">{titleLabel}</label>
    <input type="text" class="listing-input" id="listingTitle" placeholder="" />

    <label class="listing-label">বিবরণ (ঐচ্ছিক)</label>
    <textarea class="listing-input" id="listingDescription" rows="3" placeholder=""></textarea>

    <label class="listing-label">{priceLabel}</label>
    <input type="text" class="listing-input" id="listingPrice" placeholder="" />

    <label class="listing-label">উপজেলা</label>
    <select class="listing-input" id="listingUpazila">
      {upazilas.map((u) => (
        <option value={u}>{u}</option>
      ))}
    </select>

    <label class="listing-label">যোগাযোগ নাম্বার</label>
    <input type="text" class="listing-input" id="listingPhone" placeholder="01xxxxxxxxx" />

    <label class="listing-label">ছবি (ঐচ্ছিক, একাধিক দেওয়া যাবে)</label>
    <input type="file" id="listingImages" accept="image/*" multiple />
    <div class="listing-image-preview" id="listingImagePreview"></div>

    <button class="listing-submit" id="listingSubmit" type="button">
      <i class="fas fa-check"></i> <span class="listing-submit-text">লিস্টিং পোস্ট করুন</span>
    </button>
  </div>
</div>

<style>
  .listing-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow-y: auto;
  }

  .listing-overlay.open {
    display: flex;
  }

  .listing-modal {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 460px;
    border-radius: 28px;
    padding: 36px 32px 28px;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.25);
    margin: auto;
    max-height: 90vh;
    overflow-y: auto;
  }

  .listing-close {
    position: absolute;
    top: 18px;
    right: 18px;
    background: #F4F7FC;
    border: none;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #5A6E85;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .listing-close:hover {
    background: #FF6B35;
    color: #fff;
  }

  .listing-title {
    font-size: 1.3rem;
    color: #1B2A4A;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .listing-title i {
    color: #FF6B35;
  }

  .listing-subtitle {
    color: #8FA0BC;
    font-size: 0.85rem;
    margin-bottom: 18px;
  }

  .listing-message {
    display: none;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 10px 14px;
    border-radius: 12px;
    margin-bottom: 12px;
    text-align: center;
  }

  .listing-message.show-error {
    display: block;
    background: #FFF0EA;
    color: #D14343;
  }

  .listing-message.show-success {
    display: block;
    background: #EAFBF0;
    color: #1B7A3C;
  }

  .listing-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: #1B2A4A;
    margin-bottom: 6px;
    margin-top: 14px;
  }

  .listing-input {
    width: 100%;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1.5px solid #E5EAF0;
    font-size: 0.9rem;
    font-family: inherit;
    color: #1B2A4A;
    background: #FBFCFE;
  }

  .listing-input:focus {
    outline: none;
    border-color: #FF6B35;
    background: #fff;
  }

  textarea.listing-input {
    resize: vertical;
  }

  .listing-image-preview {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .listing-image-preview img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid #E5EAF0;
  }

  .listing-submit {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    border: none;
    padding: 14px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    margin-top: 22px;
    box-shadow: 0 10px 24px rgba(255, 107, 53, 0.28);
  }

  .listing-submit:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  @media (max-width: 480px) {
    .listing-modal {
      padding: 28px 22px 22px;
      border-radius: 22px;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  const overlay = document.getElementById('listingOverlay');
  const closeBtn = document.getElementById('listingClose');
  const messageEl = document.getElementById('listingMessage');
  const submitBtn = document.getElementById('listingSubmit');
  const typeSelect = document.getElementById('listingType');
  const category = overlay?.dataset.category || '';
  const companyLabel = overlay?.dataset.companyLabel || '';

  // presetType দিলে "সার্ভিসের ধরন" ড্রপডাউনে সেই ভ্যালু আগে থেকেই সিলেক্ট থাকবে
  function openListingModal(presetType) {
    clearMessage();
    if (presetType && typeSelect) {
      typeSelect.value = presetType;
    }
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeListingModal() {
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }

  function showMessage(text, type = 'error') {
    if (!messageEl) return;
    messageEl.textContent = text;
    messageEl.className = `listing-message ${type === 'error' ? 'show-error' : 'show-success'}`;
  }

  function clearMessage() {
    if (!messageEl) return;
    messageEl.textContent = '';
    messageEl.className = 'listing-message';
  }

  closeBtn?.addEventListener('click', closeListingModal);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeListingModal();
  });

  // নির্বাচিত ছবি প্রিভিউ
  const imagesInput = document.getElementById('listingImages');
  const imagePreview = document.getElementById('listingImagePreview');
  let selectedFiles = [];

  imagesInput?.addEventListener('change', () => {
    selectedFiles = Array.from(imagesInput.files || []);
    imagePreview.innerHTML = '';
    selectedFiles.forEach((file) => {
      const reader = new FileReader();
      reader.onload = () => {
        const img = document.createElement('img');
        img.src = reader.result;
        imagePreview.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  });

  async function uploadImages(userId) {
    const urls = [];
    for (const file of selectedFiles) {
      const fileExt = file.name.split('.').pop();
      const filePath = `${category}/${userId}-${Date.now()}-${Math.random().toString(36).slice(2, 7)}.${fileExt}`;
      const { error } = await supabase.storage.from('listing-images').upload(filePath, file);
      if (!error) {
        const { data } = supabase.storage.from('listing-images').getPublicUrl(filePath);
        if (data?.publicUrl) urls.push(data.publicUrl);
      }
    }
    return urls;
  }

  submitBtn?.addEventListener('click', async () => {
    clearMessage();

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      closeListingModal();
      window.openAuthModal?.('login');
      return;
    }

    const type = typeSelect?.value;
    const title = document.getElementById('listingTitle')?.value?.trim();
    let description = document.getElementById('listingDescription')?.value?.trim();
    const price = document.getElementById('listingPrice')?.value?.trim();
    const upazila = document.getElementById('listingUpazila')?.value;
    const phone = document.getElementById('listingPhone')?.value?.trim();
    const companyInput = document.getElementById('listingCompany');
    const company = companyInput?.value?.trim();

    if (!title || !phone) {
      showMessage('টাইটেল ও যোগাযোগ নাম্বার আবশ্যক');
      return;
    }

    if (companyLabel && company) {
      description = `${companyLabel}: ${company}${description ? '\n' + description : ''}`;
    }

    const textEl = submitBtn.querySelector('.listing-submit-text');
    const originalText = textEl.textContent;
    textEl.textContent = 'পোস্ট হচ্ছে...';
    submitBtn.disabled = true;

    const imageUrls = selectedFiles.length ? await uploadImages(session.user.id) : [];

    const { error } = await supabase.from('listings').insert({
      user_id: session.user.id,
      category,
      type,
      title,
      description,
      price,
      upazila,
      images: imageUrls,
      contact_phone: phone,
    });

    textEl.textContent = originalText;
    submitBtn.disabled = false;

    if (error) {
      showMessage('পোস্ট করা যায়নি: ' + error.message);
      return;
    }

    showMessage('লিস্টিং সফলভাবে পোস্ট হয়েছে!', 'success');
    setTimeout(() => {
      closeListingModal();
      window.location.reload();
    }, 1200);
  });

  window.openListingModal = openListingModal;
</script>