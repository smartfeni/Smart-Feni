---
// ============================================================
// কম্পোনেন্ট: স্ট্যাটস
// স্টাইল: Urban Company Style
// ============================================================
---

<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <h2>২৫+</h2>
        <p>সেবা ক্যাটাগরি</p>
      </div>
      <div class="stat-item">
        <h2>১,২০০+</h2>
        <p>সক্রিয় সেবাদাতা</p>
      </div>
      <div class="stat-item">
        <h2>৯৮%</h2>
        <p>সন্তুষ্টি হার</p>
      </div>
      <div class="stat-item">
        <h2>২৪/৭</h2>
        <p>সহায়তা</p>
      </div>
    </div>
  </div>
</section>

<style>
  .stats-section {
    padding: 60px 0;
    background: #1B2A4A;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    text-align: center;
  }

  .stat-item h2 {
    font-size: 2.8rem;
    font-weight: 700;
    color: #FF6B35;
    margin-bottom: 4px;
  }

  .stat-item p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }

    .stat-item h2 {
      font-size: 2rem;
    }
  }
</style>