---
// ============================================================
// কম্পোনেন্ট: প্রোফাইল ড্রপডাউন মেনু
// লগইন করা থাকলে হেডারের প্রোফাইল বাটনের নিচে এটা খোলে।
// দেখায়: ছবি+নাম, ব্লাড গ্রুপ, উপজেলা (দুটোই ঐচ্ছিক, অটো-সেভ),
// সবার নিচে লগ আউট বাটন (ব্রাউজার পপআপ ছাড়া, ইনলাইন কনফার্ম)।
// ============================================================

const bloodGroups = ['A+', 'A-', 'B+', 'B-', 'AB+', 'AB-', 'O+', 'O-'];

const upazilas = [
  'ফেনী সদর',
  'ছাগলনাইয়া',
  'দাগনভূঞা',
  'পরশুরাম',
  'ফুলগাজী',
  'সোনাগাজী',
];
---

<div class="profile-menu" id="profileMenu">
  <div class="profile-menu-header">
    <span class="profile-menu-avatar" id="menuAvatar">
      <img id="menuAvatarImg" src="" alt="প্রোফাইল ছবি" />
      <i class="fas fa-circle-user" id="menuDefaultIcon"></i>
    </span>
    <span class="profile-menu-name" id="menuName">ইউজার</span>
  </div>

  <div class="profile-menu-divider"></div>

  <div class="profile-menu-field">
    <label for="menuBloodGroup"><i class="fas fa-droplet"></i> ব্লাড গ্রুপ</label>
    <select id="menuBloodGroup">
      <option value="">নির্বাচন করুন</option>
      {bloodGroups.map((bg) => <option value={bg}>{bg}</option>)}
    </select>
  </div>

  <div class="profile-menu-field">
    <label for="menuUpazila"><i class="fas fa-location-dot"></i> উপজেলা</label>
    <select id="menuUpazila">
      <option value="">নির্বাচন করুন</option>
      {upazilas.map((u) => <option value={u}>{u}</option>)}
    </select>
  </div>

  <span class="profile-menu-savenote" id="menuSaveNote"></span>

  <div class="profile-menu-divider"></div>

  <button class="profile-menu-logout" id="menuLogoutBtn" type="button">
    <i class="fas fa-arrow-right-from-bracket"></i>
    <span id="menuLogoutText">লগ আউট</span>
  </button>
</div>

<style>
  .profile-menu {
    display: none;
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: 250px;
    background: #fff;
    border-radius: 18px;
    border: 1px solid #EEF3F9;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.14);
    padding: 18px;
    z-index: 1200;
    animation: menuPop 0.16s ease;
  }

  .profile-menu.open {
    display: block;
  }

  @keyframes menuPop {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .profile-menu-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }

  .profile-menu-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #FFF0EA;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }

  .profile-menu-avatar #menuDefaultIcon {
    color: #FF6B35;
    font-size: 1.4rem;
  }

  .profile-menu-avatar img {
    display: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-menu-avatar.has-photo #menuDefaultIcon {
    display: none;
  }

  .profile-menu-avatar.has-photo img {
    display: block;
  }

  .profile-menu-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: #1B2A4A;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .profile-menu-divider {
    height: 1px;
    background: #EEF3F9;
    margin: 14px 0;
  }

  .profile-menu-field {
    margin-bottom: 12px;
  }

  .profile-menu-field label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #5A6E85;
    margin-bottom: 6px;
  }

  .profile-menu-field label i {
    color: #FF6B35;
    font-size: 0.75rem;
    width: 12px;
  }

  .profile-menu-field select {
    width: 100%;
    padding: 9px 10px;
    border-radius: 10px;
    border: 1.5px solid #E5EAF0;
    font-size: 0.85rem;
    font-family: inherit;
    color: #1B2A4A;
    background: #FBFCFE;
    cursor: pointer;
  }

  .profile-menu-field select:focus {
    outline: none;
    border-color: #FF6B35;
  }

  .profile-menu-savenote {
    display: block;
    font-size: 0.72rem;
    color: #1B7A3C;
    font-weight: 600;
    min-height: 14px;
    margin-top: -4px;
    margin-bottom: 4px;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .profile-menu-savenote.show {
    opacity: 1;
  }

  .profile-menu-logout {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #FFF0EA;
    color: #D14343;
    border: none;
    padding: 11px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.86rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .profile-menu-logout:hover {
    background: #D14343;
    color: #fff;
  }

  .profile-menu-logout.confirming {
    background: #D14343;
    color: #fff;
  }

  @media (max-width: 480px) {
    .profile-menu {
      width: 230px;
      right: -8px;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  const menu = document.getElementById('profileMenu');
  const menuAvatarWrap = document.getElementById('menuAvatar');
  const menuAvatarImg = document.getElementById('menuAvatarImg');
  const menuName = document.getElementById('menuName');
  const bloodGroupSelect = document.getElementById('menuBloodGroup');
  const upazilaSelect = document.getElementById('menuUpazila');
  const saveNote = document.getElementById('menuSaveNote');
  const logoutBtn = document.getElementById('menuLogoutBtn');
  const logoutText = document.getElementById('menuLogoutText');

  let isOpen = false;
  let logoutConfirming = false;

  function openMenu() {
    menu?.classList.add('open');
    isOpen = true;
    loadProfileIntoMenu();
  }

  function closeMenu() {
    menu?.classList.remove('open');
    isOpen = false;
    resetLogoutState();
  }

  function toggleMenu() {
    isOpen ? closeMenu() : openMenu();
  }

  function resetLogoutState() {
    logoutConfirming = false;
    logoutBtn?.classList.remove('confirming');
    if (logoutText) logoutText.textContent = 'লগ আউট';
  }

  function showSaveNote(text) {
    if (!saveNote) return;
    saveNote.textContent = text;
    saveNote.classList.add('show');
    setTimeout(() => saveNote.classList.remove('show'), 1800);
  }

  async function loadProfileIntoMenu() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;

    const { data: profile } = await supabase
      .from('profiles')
      .select('full_name, avatar_url, blood_group, upazila')
      .eq('id', session.user.id)
      .single();

    if (!profile) return;

    if (menuName) menuName.textContent = profile.full_name || 'ইউজার';
    if (profile.avatar_url) {
      menuAvatarImg.src = profile.avatar_url;
      menuAvatarWrap?.classList.add('has-photo');
    }
    if (bloodGroupSelect) bloodGroupSelect.value = profile.blood_group || '';
    if (upazilaSelect) upazilaSelect.value = profile.upazila || '';
  }

  async function saveField(field, value) {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;

    const { error } = await supabase
      .from('profiles')
      .update({ [field]: value || null })
      .eq('id', session.user.id);

    if (!error) showSaveNote('সেভ হয়েছে ✓');
  }

  bloodGroupSelect?.addEventListener('change', () => saveField('blood_group', bloodGroupSelect.value));
  upazilaSelect?.addEventListener('change', () => saveField('upazila', upazilaSelect.value));

  logoutBtn?.addEventListener('click', async () => {
    if (!logoutConfirming) {
      logoutConfirming = true;
      logoutBtn.classList.add('confirming');
      if (logoutText) logoutText.textContent = 'নিশ্চিত করুন?';
      return;
    }
    await supabase.auth.signOut();
    closeMenu();
    window.dispatchEvent(new CustomEvent('smartfeni:logged-out'));
  });

  // মেনুর বাইরে ক্লিক করলে বন্ধ হবে
  document.addEventListener('click', (e) => {
    if (!isOpen) return;
    const target = e.target as Node;
    if (menu && !menu.contains(target) && !(e.target as HTMLElement).closest('#profileBtn')) {
      closeMenu();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });

  // Header.astro থেকে অ্যাক্সেসযোগ্য করা হলো
  window.toggleProfileMenu = toggleMenu;
  window.closeProfileMenu = closeMenu;
</script>