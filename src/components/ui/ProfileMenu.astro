---
// ============================================================
// কম্পোনেন্ট: প্রোফাইল ড্রপডাউন মেনু (রিডিজাইন — v2)
// রেফারেন্স: Google / Fiverr / LinkedIn প্যাটার্ন
// এখন ব্লাড গ্রুপ/উপজেলা এডিট করার ড্রপডাউন নেই (সাইনআপেই নেওয়া
// হচ্ছে) — শুধু তথ্য দেখানো হয় + "প্রোফাইল এডিট করুন" লিংক।
// লগ আউট নিউট্রাল স্টাইলে, alert-red না।
// ============================================================
---

<div class="profile-menu" id="profileMenu">
  <div class="profile-menu-top">
    <span class="profile-menu-avatar" id="menuAvatar">
      <img id="menuAvatarImg" src="" alt="প্রোফাইল ছবি" />
      <i class="fas fa-circle-user" id="menuDefaultIcon"></i>
    </span>
    <span class="profile-menu-name" id="menuName">ইউজার</span>
    <span class="profile-menu-phone" id="menuPhone"></span>
  </div>

  <div class="profile-menu-info">
    <div class="profile-menu-info-item">
      <i class="fas fa-droplet"></i>
      <span id="menuBloodGroup">ব্লাড গ্রুপ যোগ করা হয়নি</span>
    </div>
    <div class="profile-menu-info-item">
      <i class="fas fa-location-dot"></i>
      <span id="menuUpazila">উপজেলা যোগ করা হয়নি</span>
    </div>
  </div>

  <button class="profile-menu-edit" id="menuEditBtn" type="button">
    প্রোফাইল এডিট করুন
  </button>

  <div class="profile-menu-divider"></div>

  <button class="profile-menu-logout" id="menuLogoutBtn" type="button">
    <i class="fas fa-arrow-right-from-bracket"></i>
    <span id="menuLogoutText">লগ আউট</span>
  </button>
</div>

<style>
  .profile-menu {
    display: none;
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    width: 268px;
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.16), 0 4px 12px rgba(15, 23, 42, 0.06);
    padding: 28px 22px 18px;
    z-index: 1200;
    animation: menuPop 0.18s ease;
  }

  .profile-menu.open {
    display: block;
  }

  @keyframes menuPop {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== উপরে: অ্যাভাটার + নাম, সেন্টার-অ্যালাইনড (Google-style) ===== */
  .profile-menu-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 20px;
  }

  .profile-menu-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #FFF0EA;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    margin-bottom: 12px;
  }

  .profile-menu-avatar #menuDefaultIcon {
    color: #FF6B35;
    font-size: 2.2rem;
  }

  .profile-menu-avatar img {
    display: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-menu-avatar.has-photo #menuDefaultIcon {
    display: none;
  }

  .profile-menu-avatar.has-photo img {
    display: block;
  }

  .profile-menu-name {
    font-weight: 700;
    font-size: 1.05rem;
    color: #1B2A4A;
    line-height: 1.3;
  }

  .profile-menu-phone {
    font-size: 0.8rem;
    color: #8FA0BC;
    margin-top: 2px;
  }

  /* ===== তথ্য সেকশন (ব্লাড গ্রুপ / উপজেলা) — শুধু দেখানো, এডিট না ===== */
  .profile-menu-info {
    background: #F8FAFC;
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 16px;
  }

  .profile-menu-info-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.83rem;
    color: #4B5A70;
    font-weight: 600;
  }

  .profile-menu-info-item + .profile-menu-info-item {
    margin-top: 10px;
  }

  .profile-menu-info-item i {
    color: #FF6B35;
    font-size: 0.85rem;
    width: 14px;
    text-align: center;
    flex-shrink: 0;
  }

  /* ===== এডিট বাটন — আউটলাইনড, নিউট্রাল ===== */
  .profile-menu-edit {
    width: 100%;
    background: transparent;
    border: 1.5px solid #E5EAF0;
    color: #1B2A4A;
    padding: 11px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .profile-menu-edit:hover {
    border-color: #FF6B35;
    color: #FF6B35;
  }

  .profile-menu-divider {
    height: 1px;
    background: #EEF3F9;
    margin: 16px 0 14px;
  }

  /* ===== লগ আউট — নিউট্রাল, শুধু hover-এ হালকা রঙ (alert-red না) ===== */
  .profile-menu-logout {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: transparent;
    color: #5A6E85;
    border: none;
    padding: 10px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .profile-menu-logout:hover {
    background: #F4F7FC;
    color: #1B2A4A;
  }

  .profile-menu-logout.confirming {
    background: #FFF0EA;
    color: #D14343;
  }

  @media (max-width: 480px) {
    .profile-menu {
      width: 240px;
      right: -8px;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  const menu = document.getElementById('profileMenu');
  const menuAvatarWrap = document.getElementById('menuAvatar');
  const menuAvatarImg = document.getElementById('menuAvatarImg');
  const menuName = document.getElementById('menuName');
  const menuPhone = document.getElementById('menuPhone');
  const menuBloodGroup = document.getElementById('menuBloodGroup');
  const menuUpazila = document.getElementById('menuUpazila');
  const editBtn = document.getElementById('menuEditBtn');
  const logoutBtn = document.getElementById('menuLogoutBtn');
  const logoutText = document.getElementById('menuLogoutText');

  let isOpen = false;
  let logoutConfirming = false;

  function openMenu() {
    menu?.classList.add('open');
    isOpen = true;
    loadProfileIntoMenu();
  }

  function closeMenu() {
    menu?.classList.remove('open');
    isOpen = false;
    resetLogoutState();
  }

  function toggleMenu() {
    isOpen ? closeMenu() : openMenu();
  }

  function resetLogoutState() {
    logoutConfirming = false;
    logoutBtn?.classList.remove('confirming');
    if (logoutText) logoutText.textContent = 'লগ আউট';
  }

  async function loadProfileIntoMenu() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;

    const { data: profile } = await supabase
      .from('profiles')
      .select('full_name, avatar_url, blood_group, upazila, phone')
      .eq('id', session.user.id)
      .single();

    if (!profile) return;

    if (menuName) menuName.textContent = profile.full_name || 'ইউজার';
    if (menuPhone) menuPhone.textContent = profile.phone || '';
    if (profile.avatar_url) {
      menuAvatarImg.src = profile.avatar_url;
      menuAvatarWrap?.classList.add('has-photo');
    }
    if (menuBloodGroup) {
      menuBloodGroup.textContent = profile.blood_group || 'ব্লাড গ্রুপ যোগ করা হয়নি';
    }
    if (menuUpazila) {
      menuUpazila.textContent = profile.upazila || 'উপজেলা যোগ করা হয়নি';
    }
  }

  // আপাতত এডিট বাটন ভবিষ্যতের পূর্ণ প্রোফাইল-এডিট পেজ/মোডালের জন্য প্লেসহোল্ডার
  editBtn?.addEventListener('click', () => {
    window.location.href = '/profile/edit';
  });

  logoutBtn?.addEventListener('click', async () => {
    if (!logoutConfirming) {
      logoutConfirming = true;
      logoutBtn.classList.add('confirming');
      if (logoutText) logoutText.textContent = 'নিশ্চিত করুন?';
      return;
    }
    await supabase.auth.signOut();
    closeMenu();
    window.dispatchEvent(new CustomEvent('smartfeni:logged-out'));
  });

  // মেনুর বাইরে ক্লিক করলে বন্ধ হবে
  document.addEventListener('click', (e) => {
    if (!isOpen) return;
    const target = e.target as Node;
    if (menu && !menu.contains(target) && !(e.target as HTMLElement).closest('#profileBtn')) {
      closeMenu();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });

  window.toggleProfileMenu = toggleMenu;
  window.closeProfileMenu = closeMenu;
</script>