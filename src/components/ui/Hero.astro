---
// ============================================================
// কম্পোনেন্ট: হিরো (শীর্ষ অংশ)
// ============================================================
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-badges">
        <span class="badge"><i class="fas fa-check-circle"></i> ২৪/৭ সক্রিয়</span>
        <span class="badge"><i class="fas fa-shield-alt"></i> যাচাইকৃত</span>
        <span class="badge"><i class="fas fa-map-pin"></i> ফেনী জেলা</span>
      </div>

      <h1>
        <span class="highlight">স্মার্ট ফেনী</span><br />
        আপনার শহরের <span class="accent">ডিজিটাল</span> সেবা
      </h1>

      <p class="subtitle">
        আবাসন, চাকরি, স্বাস্থ্য, টিউশন, গাড়ি – ফেনীর সব সেবা এখন
        <span class="bold">এক ক্লিকে</span>
      </p>

      <div class="hero-actions">
        <a href="/services" class="btn-primary">
          <i class="fas fa-search"></i> সেবা খুঁজুন
        </a>
        <a href="/how-it-works" class="btn-outline">
          <i class="fas fa-play-circle"></i> কীভাবে কাজ করে
        </a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-illustration">
        <i class="fas fa-city"></i>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 60px 0 80px;
    background: linear-gradient(135deg, #F8FAFC 0%, #EEF2F7 100%);
    overflow: hidden;
    position: relative;
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .badge {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
    padding: 8px 18px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #1B2A4A;
    border: 1px solid rgba(255, 107, 53, 0.15);
  }

  .badge i {
    color: #FF6B35;
    margin-right: 8px;
  }

  .hero h1 {
    font-size: 3.2rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1px;
    margin-bottom: 16px;
  }

  .hero h1 .highlight {
    color: #1B2A4A;
  }

  .hero h1 .accent {
    color: #FF6B35;
    position: relative;
  }

  .hero h1 .accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 4px;
    width: 100%;
    height: 12px;
    background: rgba(255, 107, 53, 0.15);
    border-radius: 20px;
    z-index: -1;
  }

  .subtitle {
    font-size: 1.2rem;
    color: #4A5B6E;
    margin-bottom: 36px;
    max-width: 480px;
    line-height: 1.6;
  }

  .subtitle .bold {
    font-weight: 600;
    color: #1B2A4A;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-illustration {
    width: 100%;
    max-width: 400px;
    height: 300px;
    background: linear-gradient(135deg, #E2EAF5 0%, #D5E0ED 100%);
    border-radius: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: #1B2A4A;
    opacity: 0.9;
    box-shadow: 0 20px 60px rgba(27, 42, 74, 0.08);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 40px 0 60px;
    }

    .hero .container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }

    .hero-badges {
      justify-content: center;
    }

    .hero h1 {
      font-size: 2.4rem;
    }

    .subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-illustration {
      height: 200px;
      font-size: 4rem;
    }
  }
</style>