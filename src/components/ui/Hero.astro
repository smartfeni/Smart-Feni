---
// ============================================================
// কম্পোনেন্ট: হিরো (শুধু সার্চ বার — বাকি সব সরানো হয়েছে)
// ব্র্যান্ড: স্মার্ট ফেনী
// ফিক্স: ইংরেজিতে সার্চ করলে কিছু আসছিল না — প্রতিটা সার্ভিসে
//        ইংরেজি keyword/alias যোগ করা হলো, আর case-insensitive
//        matching করা হলো (বাংলা+ইংরেজি দুটোতেই কাজ করবে)
// ============================================================
---

<section class="hero">
  <div class="container">
    <div class="hero-search">
      <div class="search-card">
        <i class="fas fa-search"></i>
        <input
          type="text"
          id="searchInput"
          placeholder="কী সেবা দরকার? (যেমন: প্লাম্বার, ডাক্তার, টিউশন)"
          oninput="handleSearch(this.value)"
        />
        <button class="btn-primary" onclick="handleSearchButtonClick()">
          <i class="fas fa-arrow-right"></i> খুঁজুন
        </button>
      </div>
      <div id="searchResults" class="search-results"></div>
    </div>
  </div>
</section>

<script>
  const services = [
    { name: 'বাসা ভাড়া', category: 'বাড়ি ভাড়া/ক্রয়', slug: 'housing', keywords: ['house rent', 'rent', 'housing', 'flat', 'apartment', 'basa vara'] },
    { name: 'চাকরির খবর', category: 'চাকরি পোস্ট/খোঁজ', slug: 'job', keywords: ['job', 'jobs', 'vacancy', 'career', 'chakri'] },
    { name: 'রিপেয়ার সার্ভিস', category: 'মেরামত সার্ভিস', slug: 'repair', keywords: ['repair', 'fix', 'service', 'maintenance', 'mistri'] },
    { name: 'গাড়ি ভাড়া সার্ভিস', category: 'গাড়ি/মাইক্রো/সিএনজি', slug: 'car-rental', keywords: ['car rental', 'car rent', 'car', 'cng', 'microbus', 'gari vara'] },
    { name: 'কুরিয়ার/ডেলিভারি সার্ভিস', category: 'ডেলিভারি', slug: 'courier', keywords: ['courier', 'delivery', 'parcel', 'shipment'] },
    { name: 'ইমার্জেন্সি কন্টাক্ট', category: 'জরুরি যোগাযোগ', slug: 'emergency', keywords: ['emergency', 'emergency contact', 'urgent', 'help', 'sos'] },
    { name: 'ব্লাড ডোনার', category: 'রক্ত দান/সংগ্রহ', slug: 'blood', keywords: ['blood', 'blood donor', 'donate blood', 'donor'] },
    { name: 'হোম মেস ফুড', category: 'বাসার তৈরি খাবার', slug: 'home-food', keywords: ['home food', 'mess food', 'food', 'tiffin', 'catering'] },
    { name: 'রিসাইকেল মার্কেট', category: 'পুরনো মাল কেনাবেচা', slug: 'recycle', keywords: ['recycle', 'second hand', 'used', 'old items', 'market'] },
    { name: 'টিউশন খুঁজুন', category: 'টিউটর/স্টুডেন্ট', slug: 'tuition', keywords: ['tuition', 'tutor', 'teacher', 'study', 'coaching'] },
    { name: 'খেলাধুলা ও ইভেন্টস', category: 'স্পোর্টস/বিনোদন', slug: 'sports', keywords: ['sports', 'events', 'game', 'entertainment', 'khela'] },
    { name: 'লস্ট এন্ড ফাউন্ড', category: 'হারানো-পাওয়া', slug: 'lost-found', keywords: ['lost and found', 'lost', 'found', 'missing'] },
    { name: 'স্বাস্থ্য পরামর্শ', category: 'ডাক্তার/পরামর্শ', slug: 'health', keywords: ['health', 'health advice', 'consultation', 'doctor advice', 'shastho'] },
    { name: 'আইনি পরামর্শ', category: 'আইনি পরামর্শ ও নথি', slug: 'legal', keywords: ['legal', 'lawyer', 'law', 'legal advice', 'document'] },
    { name: 'ইভেন্ট ম্যানেজমেন্ট', category: 'অনুষ্ঠান আয়োজন', slug: 'event', keywords: ['event management', 'event', 'party', 'organizer', 'wedding'] },
    { name: 'লন্ড্রি সার্ভিস', category: 'কাপড় ধোলাই', slug: 'laundry', keywords: ['laundry', 'laundry service', 'wash', 'dry clean', 'clothes'] },
    { name: 'ডাক্তার ও হাসপাতাল ডিরেক্টরি', category: 'ডাক্তার ডিরেক্টরি', slug: 'doctor-directory', keywords: ['doctor', 'hospital', 'doctor directory', 'clinic', 'physician'] },
  ];

  function handleSearch(query: string) {
    const resultsContainer = document.getElementById('searchResults');
    if (!resultsContainer) return;

    if (!query || query.trim() === '') {
      resultsContainer.style.display = 'none';
      return;
    }

    const q = query.trim().toLowerCase();

    const filtered = services.filter((service) => {
      const nameMatch = service.name.toLowerCase().includes(q);
      const categoryMatch = service.category.toLowerCase().includes(q);
      const keywordMatch = service.keywords.some((k) => k.toLowerCase().includes(q));
      return nameMatch || categoryMatch || keywordMatch;
    });

    if (filtered.length === 0) {
      resultsContainer.innerHTML = `<p style="color: #5A6E85; padding: 8px 4px;">🔍 কোনো সেবা পাওয়া যায়নি</p>`;
    } else {
      resultsContainer.innerHTML = filtered
        .map(
          (service) => `
        <a href="/services/${service.slug}" class="result-item">
          <strong>${service.name}</strong>
          <span class="result-category">${service.category}</span>
        </a>
      `
        )
        .join('');
    }

    resultsContainer.style.display = 'block';
  }

  function handleSearchButtonClick() {
    const input = document.getElementById('searchInput') as HTMLInputElement;
    if (input) handleSearch(input.value);
  }

  (window as any).handleSearch = handleSearch;
  (window as any).handleSearchButtonClick = handleSearchButtonClick;
</script>

<style>
  .hero {
    padding: 28px 0 32px;
    background: #F8FAFC;
  }

  .hero-search {
    max-width: 640px;
    margin: 0 auto;
    position: relative;
  }

  .search-card {
    background: #fff;
    padding: 8px 8px 8px 22px;
    border-radius: 60px;
    box-shadow: 0 12px 32px rgba(27, 42, 74, 0.1);
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .search-card i {
    color: #FF6B35;
    font-size: 1.05rem;
  }

  .search-card input {
    flex: 1;
    min-width: 0;
    border: none;
    padding: 12px 4px;
    font-size: 0.95rem;
    outline: none;
    background: transparent;
    color: #1B2A4A;
  }

  .search-card input::placeholder {
    color: #A0B3C9;
  }

  .search-card .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    padding: 12px 24px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.9rem;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease;
  }

  .search-card .btn-primary:hover {
    background: #e85a2a;
  }

  .search-results {
    display: none;
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    right: 0;
    background: #fff;
    border-radius: 20px;
    padding: 12px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    z-index: 20;
    max-height: 320px;
    overflow-y: auto;
  }

  .search-results :global(.result-item) {
    display: flex;
    flex-direction: column;
    padding: 12px 14px;
    background: #F8FAFC;
    border-radius: 12px;
    margin-bottom: 6px;
    text-decoration: none;
    color: #1B2A4A;
  }

  .search-results :global(.result-item:hover) {
    background: #FFF0EA;
  }

  .search-results :global(.result-category) {
    color: #FF6B35;
    font-size: 0.78rem;
    margin-top: 2px;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 20px 0 24px;
    }

    .search-card {
      border-radius: 40px;
      padding: 6px 6px 6px 16px;
    }
  }
</style>