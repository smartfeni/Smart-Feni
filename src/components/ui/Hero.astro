---
// ============================================================
// কম্পোনেন্ট: হিরো
// স্টাইল: Urban Company Inspired
// ব্র্যান্ড: স্মার্ট ফেনী
// ============================================================
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-badges">
        <span class="badge"><i class="fas fa-check-circle"></i> ২৪/৭ সক্রিয়</span>
        <span class="badge"><i class="fas fa-shield-alt"></i> যাচাইকৃত</span>
        <span class="badge"><i class="fas fa-map-pin"></i> ফেনী জেলা</span>
      </div>

      <h1>
        <span class="highlight">স্মার্ট ফেনী</span><br />
        আপনার শহরের <span class="accent">ডিজিটাল</span> সেবা
      </h1>

      <p class="subtitle">
        আবাসন, চাকরি, স্বাস্থ্য, টিউশন, গাড়ি – ফেনীর সব সেবা এখন <span class="bold">এক ক্লিকে</span>
      </p>

      <div class="hero-actions">
        <a href="/services" class="btn-primary">
          <i class="fas fa-search"></i> সেবা খুঁজুন
        </a>
        <a href="/how-it-works" class="btn-outline">
          <i class="fas fa-play-circle"></i> কীভাবে কাজ করে
        </a>
      </div>

      <div class="hero-trust">
        <span><i class="fas fa-star"></i> ৪.৯ রেটিং</span>
        <span><i class="fas fa-users"></i> ১,২০০+ সেবাদাতা</span>
        <span><i class="fas fa-clock"></i> ২৪/৭</span>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-illustration">
        <div class="illustration-bg">
          <i class="fas fa-city"></i>
        </div>
        <div class="float-icon float-1">🏠</div>
        <div class="float-icon float-2">💼</div>
        <div class="float-icon float-3">🩺</div>
        <div class="float-icon float-4">📚</div>
        <div class="float-icon float-5">🚗</div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ===== হিরো স্টাইল ===== */
  .hero {
    padding: 60px 0 80px;
    background: linear-gradient(135deg, #F8FAFC 0%, #EEF2F7 100%);
    position: relative;
    overflow: hidden;
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .badge {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
    padding: 8px 18px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #1B2A4A;
    border: 1px solid rgba(255, 107, 53, 0.15);
  }

  .badge i {
    color: #FF6B35;
    margin-right: 8px;
  }

  .hero h1 {
    font-size: 3.2rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1px;
    margin-bottom: 16px;
  }

  .hero h1 .highlight {
    color: #1B2A4A;
  }

  .hero h1 .accent {
    color: #FF6B35;
    position: relative;
  }

  .hero h1 .accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 4px;
    width: 100%;
    height: 12px;
    background: rgba(255, 107, 53, 0.15);
    border-radius: 20px;
    z-index: -1;
  }

  .subtitle {
    font-size: 1.2rem;
    color: #4A5B6E;
    margin-bottom: 28px;
    max-width: 480px;
    line-height: 1.6;
  }

  .subtitle .bold {
    font-weight: 600;
    color: #1B2A4A;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #FF6B35;
    color: #fff;
    padding: 14px 32px;
    border-radius: 60px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.25);
  }

  .btn-primary:hover {
    background: #e85a2a;
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(255, 107, 53, 0.35);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    color: #1B2A4A;
    padding: 14px 32px;
    border-radius: 60px;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid #1B2A4A;
    transition: all 0.25s ease;
  }

  .btn-outline:hover {
    background: #1B2A4A;
    color: #fff;
  }

  .hero-trust {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    font-size: 0.9rem;
    color: #5A6E85;
  }

  .hero-trust i {
    color: #FFB800;
    margin-right: 6px;
  }

  .hero-trust span {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-illustration {
    position: relative;
    width: 100%;
    max-width: 420px;
    height: 320px;
  }

  .illustration-bg {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #E2EAF5 0%, #D5E0ED 100%);
    border-radius: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: #1B2A4A;
    opacity: 0.9;
    box-shadow: 0 20px 60px rgba(27, 42, 74, 0.08);
  }

  .float-icon {
    position: absolute;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    padding: 12px;
    border-radius: 16px;
    font-size: 1.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    animation: float 3s ease-in-out infinite;
  }

  .float-1 { top: -10px; left: -20px; animation-delay: 0s; }
  .float-2 { top: 20%; right: -30px; animation-delay: 0.5s; }
  .float-3 { bottom: 10%; left: -15px; animation-delay: 1s; }
  .float-4 { bottom: -10px; right: 10%; animation-delay: 1.5s; }
  .float-5 { top: 60%; right: -10px; animation-delay: 2s; }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 40px 0 60px;
    }

    .hero .container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }

    .hero-badges {
      justify-content: center;
    }

    .hero h1 {
      font-size: 2.4rem;
    }

    .subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-trust {
      justify-content: center;
    }

    .hero-illustration {
      height: 220px;
    }

    .illustration-bg {
      font-size: 4rem;
    }

    .float-icon {
      display: none;
    }
  }
</style>