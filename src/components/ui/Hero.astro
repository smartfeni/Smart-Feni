---
// ============================================================
// কম্পোনেন্ট: হিরো (সার্চ বার সহ, Urban Company inspired)
// ব্র্যান্ড: স্মার্ট ফেনী
// ============================================================
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-badges">
        <span class="badge"><i class="fas fa-check-circle"></i> ২৪/৭ সক্রিয়</span>
        <span class="badge"><i class="fas fa-shield-alt"></i> যাচাইকৃত</span>
        <span class="badge"><i class="fas fa-map-pin"></i> ফেনী জেলা</span>
      </div>

      <h1>
        <span class="highlight">স্মার্ট ফেনী</span><br />
        আপনার শহরের <span class="accent">ডিজিটাল</span> সেবা
      </h1>

      <p class="subtitle">
        আবাসন, চাকরি, স্বাস্থ্য, টিউশন, গাড়ি – ফেনীর সব সেবা এখন <span class="bold">এক ক্লিকে</span>
      </p>

      <!-- প্রমিনেন্ট সার্চ বার — হিরোর মধ্যেই -->
      <div class="hero-search">
        <div class="search-card">
          <i class="fas fa-search"></i>
          <input
            type="text"
            id="searchInput"
            placeholder="কী সেবা দরকার? (যেমন: প্লাম্বার, ডাক্তার, টিউশন)"
            oninput="handleSearch(this.value)"
          />
          <button class="btn-primary" onclick="handleSearchButtonClick()">
            <i class="fas fa-arrow-right"></i> খুঁজুন
          </button>
        </div>
        <div id="searchResults" class="search-results"></div>
      </div>

      <div class="hero-actions">
        <a href="/how-it-works" class="btn-outline">
          <i class="fas fa-play-circle"></i> কীভাবে কাজ করে
        </a>
      </div>

      <div class="hero-trust">
        <span><i class="fas fa-star"></i> ৪.৯ রেটিং</span>
        <span><i class="fas fa-users"></i> ১,২০০+ সেবাদাতা</span>
        <span><i class="fas fa-clock"></i> ২৪/৭</span>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-illustration">
        <div class="illustration-bg">
          <i class="fas fa-city"></i>
        </div>
        <div class="float-icon float-1">🏠</div>
        <div class="float-icon float-2">💼</div>
        <div class="float-icon float-3">🩺</div>
        <div class="float-icon float-4">📚</div>
        <div class="float-icon float-5">🚗</div>
      </div>
    </div>
  </div>
</section>

<script>
  // সব সেবা (সার্চের জন্য) — services.js এর categories এর সাথে মিলিয়ে রাখা হয়েছে
  const services = [
    { name: 'বাসা ভাড়া', category: 'বাড়ি ভাড়া/ক্রয়', slug: 'housing' },
    { name: 'চাকরির খবর', category: 'চাকরি পোস্ট/খোঁজ', slug: 'job' },
    { name: 'রিপেয়ার সার্ভিস', category: 'মেরামত সার্ভিস', slug: 'repair' },
    { name: 'গাড়ি ভাড়া সার্ভিস', category: 'গাড়ি/মাইক্রো/সিএনজি', slug: 'car-rental' },
    { name: 'কুরিয়ার/ডেলিভারি সার্ভিস', category: 'ডেলিভারি', slug: 'courier' },
    { name: 'ইমার্জেন্সি কন্টাক্ট', category: 'জরুরি যোগাযোগ', slug: 'emergency' },
    { name: 'ব্লাড ডোনার', category: 'রক্ত দান/সংগ্রহ', slug: 'blood' },
    { name: 'হোম মেস ফুড', category: 'বাসার তৈরি খাবার', slug: 'home-food' },
    { name: 'রিসাইকেল মার্কেট', category: 'পুরনো মাল কেনাবেচা', slug: 'recycle' },
    { name: 'টিউশন খুঁজুন', category: 'টিউটর/স্টুডেন্ট', slug: 'tuition' },
    { name: 'খেলাধুলা ও ইভেন্টস', category: 'স্পোর্টস/বিনোদন', slug: 'sports' },
    { name: 'লস্ট এন্ড ফাউন্ড', category: 'হারানো-পাওয়া', slug: 'lost-found' },
    { name: 'স্বাস্থ্য পরামর্শ', category: 'ডাক্তার/পরামর্শ', slug: 'health' },
    { name: 'আইনি পরামর্শ', category: 'আইনি পরামর্শ ও নথি', slug: 'legal' },
    { name: 'ইভেন্ট ম্যানেজমেন্ট', category: 'অনুষ্ঠান আয়োজন', slug: 'event' },
    { name: 'লন্ড্রি সার্ভিস', category: 'কাপড় ধোলাই', slug: 'laundry' },
    { name: 'ডাক্তার ও হাসপাতাল ডিরেক্টরি', category: 'ডাক্তার ডিরেক্টরি', slug: 'doctor-directory' },
  ];

  function handleSearch(query: string) {
    const resultsContainer = document.getElementById('searchResults');
    if (!resultsContainer) return;

    if (!query || query.trim() === '') {
      resultsContainer.style.display = 'none';
      return;
    }

    const filtered = services.filter(
      (service) => service.name.includes(query) || service.category.includes(query)
    );

    if (filtered.length === 0) {
      resultsContainer.innerHTML = `<p style="color: #5A6E85; padding: 8px 4px;">🔍 কোনো সেবা পাওয়া যায়নি</p>`;
    } else {
      resultsContainer.innerHTML = filtered
        .map(
          (service) => `
        <a href="/services/${service.slug}" class="result-item">
          <strong>${service.name}</strong>
          <span class="result-category">${service.category}</span>
        </a>
      `
        )
        .join('');
    }

    resultsContainer.style.display = 'block';
  }

  function handleSearchButtonClick() {
    const input = document.getElementById('searchInput') as HTMLInputElement;
    if (input) handleSearch(input.value);
  }

  (window as any).handleSearch = handleSearch;
  (window as any).handleSearchButtonClick = handleSearchButtonClick;
</script>

<style>
  /* ===== হিরো স্টাইল ===== */
  .hero {
    padding: 60px 0 80px;
    background: linear-gradient(135deg, #F8FAFC 0%, #EEF2F7 100%);
    position: relative;
    overflow: hidden;
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .badge {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
    padding: 8px 18px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #1B2A4A;
    border: 1px solid rgba(255, 107, 53, 0.15);
  }

  .badge i {
    color: #FF6B35;
    margin-right: 8px;
  }

  .hero h1 {
    font-size: 3.2rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1px;
    margin-bottom: 16px;
  }

  .hero h1 .highlight {
    color: #1B2A4A;
  }

  .hero h1 .accent {
    color: #FF6B35;
    position: relative;
  }

  .hero h1 .accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 4px;
    width: 100%;
    height: 12px;
    background: rgba(255, 107, 53, 0.15);
    border-radius: 20px;
    z-index: -1;
  }

  .subtitle {
    font-size: 1.2rem;
    color: #4A5B6E;
    margin-bottom: 28px;
    max-width: 480px;
    line-height: 1.6;
  }

  .subtitle .bold {
    font-weight: 600;
    color: #1B2A4A;
  }

  /* ===== সার্চ বার (হিরোর মধ্যে) ===== */
  .hero-search {
    margin-bottom: 20px;
    max-width: 560px;
    position: relative;
  }

  .search-card {
    background: #fff;
    padding: 8px 8px 8px 22px;
    border-radius: 60px;
    box-shadow: 0 12px 32px rgba(27, 42, 74, 0.1);
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .search-card i {
    color: #FF6B35;
    font-size: 1.05rem;
  }

  .search-card input {
    flex: 1;
    min-width: 0;
    border: none;
    padding: 12px 4px;
    font-size: 0.95rem;
    outline: none;
    background: transparent;
    color: #1B2A4A;
  }

  .search-card input::placeholder {
    color: #A0B3C9;
  }

  .search-card .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    padding: 12px 24px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.9rem;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease;
  }

  .search-card .btn-primary:hover {
    background: #e85a2a;
  }

  .search-results {
    display: none;
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    right: 0;
    background: #fff;
    border-radius: 20px;
    padding: 12px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    z-index: 20;
    max-height: 320px;
    overflow-y: auto;
  }

  .search-results :global(.result-item) {
    display: flex;
    flex-direction: column;
    padding: 12px 14px;
    background: #F8FAFC;
    border-radius: 12px;
    margin-bottom: 6px;
    text-decoration: none;
    color: #1B2A4A;
  }

  .search-results :global(.result-item:hover) {
    background: #FFF0EA;
  }

  .search-results :global(.result-category) {
    color: #FF6B35;
    font-size: 0.78rem;
    margin-top: 2px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    color: #1B2A4A;
    padding: 14px 32px;
    border-radius: 60px;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid #1B2A4A;
    transition: all 0.25s ease;
  }

  .btn-outline:hover {
    background: #1B2A4A;
    color: #fff;
  }

  .hero-trust {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    font-size: 0.9rem;
    color: #5A6E85;
  }

  .hero-trust i {
    color: #FFB800;
    margin-right: 6px;
  }

  .hero-trust span {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-illustration {
    position: relative;
    width: 100%;
    max-width: 420px;
    height: 320px;
  }

  .illustration-bg {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #E2EAF5 0%, #D5E0ED 100%);
    border-radius: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: #1B2A4A;
    opacity: 0.9;
    box-shadow: 0 20px 60px rgba(27, 42, 74, 0.08);
  }

  .float-icon {
    position: absolute;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    padding: 12px;
    border-radius: 16px;
    font-size: 1.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    animation: float 3s ease-in-out infinite;
  }

  .float-1 { top: -10px; left: -20px; animation-delay: 0s; }
  .float-2 { top: 20%; right: -30px; animation-delay: 0.5s; }
  .float-3 { bottom: 10%; left: -15px; animation-delay: 1s; }
  .float-4 { bottom: -10px; right: 10%; animation-delay: 1.5s; }
  .float-5 { top: 60%; right: -10px; animation-delay: 2s; }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 40px 0 60px;
    }

    .hero .container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }

    .hero-badges {
      justify-content: center;
    }

    .hero h1 {
      font-size: 2.4rem;
    }

    .subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-search {
      margin-left: auto;
      margin-right: auto;
    }

    .search-card {
      border-radius: 40px;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-trust {
      justify-content: center;
    }

    .hero-illustration {
      height: 220px;
    }

    .illustration-bg {
      font-size: 4rem;
    }

    .float-icon {
      display: none;
    }
  }
</style>