---
// ============================================================
// কম্পোনেন্ট: টেস্টিমোনিয়ালস
// স্টাইল: Urban Company Style
// ============================================================
---

<section class="testimonials">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">💬 ব্যবহারকারীর মতামত</span>
      <h2>আমাদের <span class="accent">ব্যবহারকারীরা</span> কী বলেন</h2>
    </div>

    <div class="testimonial-grid">
      <div class="testimonial-card">
        <div class="stars">⭐⭐⭐⭐⭐</div>
        <p>"স্মার্ট ফেনী আমার বাসা ভাড়া পেতে অনেক সাহায্য করেছে!"</p>
        <div class="user">
          <strong>রহিম মিয়া</strong>
          <span>ফেনী সদর</span>
        </div>
      </div>

      <div class="testimonial-card">
        <div class="stars">⭐⭐⭐⭐⭐</div>
        <p>"চাকরি পেতে খুব সহজ হয়েছে। দারুণ একটি প্ল্যাটফর্ম!"</p>
        <div class="user">
          <strong>নাসরিন আক্তার</strong>
          <span>ছাগলনাইয়া</span>
        </div>
      </div>

      <div class="testimonial-card">
        <div class="stars">⭐⭐⭐⭐⭐</div>
        <p>"ডাক্তার খুঁজে পেতে আর ঘোরাঘুরি করতে হয় না। অসাধারণ!"</p>
        <div class="user">
          <strong>আব্দুল করিম</strong>
          <span>পারশুরাম</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 70px 0;
    background: #F8FAFC;
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .testimonial-card {
    background: #fff;
    padding: 28px;
    border-radius: 20px;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
  }

  .testimonial-card:hover {
    border-color: #FF6B35;
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.04);
  }

  .stars {
    color: #FFB800;
    font-size: 1.1rem;
    margin-bottom: 12px;
  }

  .testimonial-card p {
    font-size: 1rem;
    line-height: 1.6;
    color: #1B2A4A;
    margin-bottom: 16px;
  }

  .user strong {
    display: block;
    font-weight: 600;
  }

  .user span {
    font-size: 0.85rem;
    color: #7A8EA5;
  }
</style>