---
const { members } = Astro.props;

function formatDob(dob) {
  if (!dob) return null;
  const d = new Date(dob);
  return d.toLocaleDateString('bn-BD', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

{members.length > 0 && (
  <div class="section-card">
    <h3><i class="fas fa-user-group"></i> সদস্য তালিকা <span class="count-badge">{members.length}</span></h3>
    <div class="member-grid">
      {members.map((m) => (
        <div class="member-item">
          {m.photo ? (
            <img src={m.photo} alt={m.name} class="member-photo" />
          ) : (
            <div class="member-photo-placeholder"><i class="fas fa-user"></i></div>
          )}
          <p class="member-name">{m.name}</p>
          {m.dob && <p class="member-dob">{formatDob(m.dob)}</p>}
        </div>
      ))}
    </div>
  </div>
)}

<style>
  .section-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .count-badge {
    background: #FFF0EA;
    color: #FF6B35;
    font-size: 0.72rem;
    padding: 2px 10px;
    border-radius: 40px;
    margin-left: auto;
  }

  .member-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .member-photo {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 16px;
    object-fit: contain;
    background: #F4F7FC;
  }

  .member-photo-placeholder {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 16px;
    background: #F4F7FC;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
  }

  .member-name {
    font-size: 0.8rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-top: 8px;
    text-align: center;
  }

  .member-dob {
    font-size: 0.7rem;
    color: #8FA0BC;
    text-align: center;
  }

  @media (max-width: 400px) {
    .member-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>