---
const { members } = Astro.props;

const preview = members.slice(0, 3);
const rest = members.slice(3);

function formatDob(dob) {
  if (!dob) return null;
  const d = new Date(dob);
  return d.toLocaleDateString('bn-BD', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

{members.length > 0 && (
  <div class="section-card">
    <div class="section-head">
      <h3><i class="fas fa-user-group"></i> সদস্য তালিকা <span class="count-badge">{members.length}</span></h3>
      {members.length > 3 && (
        <button class="see-more-btn" id="memberSeeMoreBtn">সব দেখুন <i class="fas fa-arrow-right"></i></button>
      )}
    </div>

    <div class="member-grid">
      {preview.map((m) => (
        <div class="member-item">
          {m.photo ? (
            <img src={m.photo} alt={m.name} class="member-photo" />
          ) : (
            <div class="member-photo-placeholder"><i class="fas fa-user"></i></div>
          )}
          <p class="member-name">{m.name}</p>
          {m.dob && <p class="member-dob">{formatDob(m.dob)}</p>}
        </div>
      ))}
    </div>
  </div>
)}

{members.length > 3 && (
  <div class="member-modal" id="memberModal">
    <div class="member-modal-backdrop" id="memberModalBackdrop"></div>
    <div class="member-modal-body">
      <button class="member-modal-close" id="memberModalClose"><i class="fas fa-xmark"></i></button>
      <h3><i class="fas fa-user-group"></i> সব সদস্য <span class="count-badge">{members.length}</span></h3>

      <div class="member-grid modal-grid">
        {members.map((m) => (
          <div class="member-item">
            {m.photo ? (
              <img src={m.photo} alt={m.name} class="member-photo" />
            ) : (
              <div class="member-photo-placeholder"><i class="fas fa-user"></i></div>
            )}
            <p class="member-name">{m.name}</p>
            {m.dob && <p class="member-dob">{formatDob(m.dob)}</p>}
          </div>
        ))}
      </div>
    </div>
  </div>
)}

<style>
  .section-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    gap: 8px;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .count-badge {
    background: #FFF0EA;
    color: #FF6B35;
    font-size: 0.72rem;
    padding: 2px 10px;
    border-radius: 40px;
    flex-shrink: 0;
  }

  .see-more-btn {
    background: #FFF0EA;
    color: #FF6B35;
    border: none;
    padding: 7px 14px;
    border-radius: 40px;
    font-size: 0.76rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .member-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .member-photo {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 16px;
    object-fit: cover;
    background: #F4F7FC;
  }

  .member-photo-placeholder {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 16px;
    background: #F4F7FC;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
  }

  .member-name {
    font-size: 0.8rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-top: 8px;
    text-align: center;
  }

  .member-dob {
    font-size: 0.7rem;
    color: #8FA0BC;
    text-align: center;
  }

  /* ===== মোডাল ===== */
  .member-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 300;
    align-items: flex-end;
    justify-content: center;
  }

  .member-modal.open {
    display: flex;
  }

  .member-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
  }

  .member-modal-body {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 560px;
    max-height: 86vh;
    overflow-y: auto;
    border-radius: 24px 24px 0 0;
    padding: 26px 20px 34px;
  }

  .member-modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: #F4F7FC;
    border: none;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #5A6E85;
    cursor: pointer;
    z-index: 2;
  }

  .member-modal-body h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .member-modal-body h3 i {
    color: #FF6B35;
  }

  .modal-grid {
    gap: 16px 14px;
  }

  @media (max-width: 400px) {
    .member-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
  }
</style>

<script>
  const btn = document.getElementById('memberSeeMoreBtn');
  const modal = document.getElementById('memberModal');
  const backdrop = document.getElementById('memberModalBackdrop');
  const closeBtn = document.getElementById('memberModalClose');

  btn?.addEventListener('click', () => modal?.classList.add('open'));
  backdrop?.addEventListener('click', () => modal?.classList.remove('open'));
  closeBtn?.addEventListener('click', () => modal?.classList.remove('open'));
</script>