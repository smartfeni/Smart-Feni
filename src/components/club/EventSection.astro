---
const { events } = Astro.props;

const today = new Date().toISOString().split('T')[0];
const upcoming = events.filter((e) => e.event_date && e.event_date >= today);
const past = events.filter((e) => !e.event_date || e.event_date < today);

function formatDate(dateStr) {
  if (!dateStr) return null;
  const d = new Date(dateStr);
  return d.toLocaleDateString('bn-BD', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

{events.length > 0 && (
  <div class="section-card">
    <h3><i class="fas fa-calendar-days"></i> ইভেন্ট / আয়োজন</h3>

    <div class="event-tabs">
      <button class="event-tab active" data-tab="upcoming">আপকামিং ({upcoming.length})</button>
      <button class="event-tab" data-tab="past">সম্পন্ন ({past.length})</button>
    </div>

    <div class="event-panel" data-panel="upcoming">
      {upcoming.length === 0 ? (
        <p class="empty-note">কোনো আপকামিং ইভেন্ট নেই</p>
      ) : (
        upcoming.map((e) => (
          <div class="event-item">
            {e.image ? <img src={e.image} alt={e.title} class="event-img" /> : <div class="event-img-placeholder"><i class="fas fa-calendar"></i></div>}
            <div class="event-body">
              <p class="event-title">{e.title}</p>
              {e.event_date && <p class="event-date"><i class="fas fa-clock"></i> {formatDate(e.event_date)}</p>}
              {e.description && <p class="event-desc">{e.description}</p>}
            </div>
          </div>
        ))
      )}
    </div>

    <div class="event-panel" data-panel="past" style="display:none;">
      {past.length === 0 ? (
        <p class="empty-note">এখনো কোনো সম্পন্ন ইভেন্ট নেই</p>
      ) : (
        past.map((e) => (
          <div class="event-item">
            {e.image ? <img src={e.image} alt={e.title} class="event-img" /> : <div class="event-img-placeholder"><i class="fas fa-calendar"></i></div>}
            <div class="event-body">
              <p class="event-title">{e.title}</p>
              {e.event_date && <p class="event-date"><i class="fas fa-clock"></i> {formatDate(e.event_date)}</p>}
              {e.description && <p class="event-desc">{e.description}</p>}
            </div>
          </div>
        ))
      )}
    </div>
  </div>
)}

<style>
  .section-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .event-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }

  .event-tab {
    background: #F4F7FC;
    border: none;
    padding: 8px 16px;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 700;
    color: #5A6E85;
    cursor: pointer;
  }

  .event-tab.active {
    background: #FF6B35;
    color: #fff;
  }

  .event-item {
    display: flex;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid #F0F3F8;
  }

  .event-item:last-child {
    border-bottom: none;
  }

  .event-img {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    object-fit: contain;
    background: #F4F7FC;
    flex-shrink: 0;
  }

  .event-img-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .event-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1B2A4A;
  }

  .event-date {
    font-size: 0.75rem;
    color: #FF6B35;
    font-weight: 600;
    margin-top: 2px;
  }

  .event-desc {
    font-size: 0.82rem;
    color: #5A6E85;
    margin-top: 4px;
    line-height: 1.6;
  }

  .empty-note {
    font-size: 0.85rem;
    color: #B0BCCB;
    text-align: center;
    padding: 20px 0;
  }
</style>

<script>
  document.querySelectorAll('.event-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const section = tab.closest('.section-card');
      section.querySelectorAll('.event-tab').forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      const target = tab.dataset.tab;
      section.querySelectorAll('.event-panel').forEach((p) => {
        p.style.display = p.dataset.panel === target ? 'block' : 'none';
      });
    });
  });
</script>