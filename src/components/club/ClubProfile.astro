---
// ============================================================
// কম্পোনেন্ট: ক্লাব প্রোফাইলের মূল লেআউট শেল
// কভার+লোগো হেডার, কুইক-ইনফো, ম্যাপ পিন — এবং বাকি সব সেকশন
// কম্পোনেন্ট এখান থেকেই ইমপোর্ট/রেন্ডার হয়
// ============================================================

import AnnouncementTicker from './AnnouncementTicker.astro';
import CommitteeSection from './CommitteeSection.astro';
import MemberGrid from './MemberGrid.astro';
import AchievementTimeline from './AchievementTimeline.astro';
import EventSection from './EventSection.astro';
import GallerySection from './GallerySection.astro';
import JoinRequestForm from './JoinRequestForm.astro';

const { club, members, posts } = Astro.props;

const UPAZILA_LABELS = {
  'feni-sadar': 'ফেনী সদর',
  'chhagalnaiya': 'ছাগলনাইয়া',
  'daganbhuiyan': 'দাগনভূঞা',
  'parshuram': 'পরশুরাম',
  'fulgazi': 'ফুলগাজী',
  'sonagazi': 'সোনাগাজী',
};

const upazilaLabel = club.upajila ? UPAZILA_LABELS[club.upajila] || club.upajila : '';

const committee = members.filter((m) => m.is_committee);
const regularMembers = members.filter((m) => !m.is_committee);
const announcements = posts.filter((p) => p.type === 'announcement');
const achievements = posts.filter((p) => p.type === 'achievement');
const events = posts.filter((p) => p.type === 'event');
const gallery = posts.filter((p) => p.type === 'gallery');

const hasMapPin = club.latitude && club.longitude;
---

<div class="club-page">
  <!-- ===== কভার + লোগো ===== -->
  <div class="club-cover-wrap">
    {club.cover_image ? (
      <img src={club.cover_image} alt={club.name} class="club-cover-img" />
    ) : (
      <div class="club-cover-placeholder"></div>
    )}
  </div>

  <div class="container">
    <div class="club-header">
      {club.logo_image ? (
        <img src={club.logo_image} alt={club.name} class="club-logo" />
      ) : (
        <div class="club-logo-placeholder"><i class="fas fa-people-group"></i></div>
      )}

      <div class="club-header-info">
        <h1>
          {club.name}
          {club.is_verified && <i class="fas fa-circle-check verified-icon"></i>}
        </h1>
        {club.tagline && <p class="club-tagline">{club.tagline}</p>}
        <div class="club-meta-row">
          {upazilaLabel && (
            <span class="meta-chip"><i class="fas fa-location-dot"></i> {upazilaLabel}</span>
          )}
          {club.established_year && (
            <span class="meta-chip"><i class="fas fa-flag"></i> প্রতিষ্ঠা: {club.established_year}</span>
          )}
        </div>
      </div>
    </div>
  </div>

  {announcements.length > 0 && <AnnouncementTicker announcements={announcements} />}

  <div class="container">
    {club.description && (
      <div class="club-description-card">
        <p>{club.description}</p>
      </div>
    )}

    <!-- ===== যোগাযোগ ===== -->
    <div class="contact-card">
      <h3><i class="fas fa-address-card"></i> যোগাযোগ</h3>
      <div class="contact-grid">
        {club.phone && (
          <a href={`tel:${club.phone}`} class="contact-item">
            <i class="fas fa-phone"></i> {club.phone}
          </a>
        )}
        {club.facebook_link && (
          <a href={club.facebook_link} target="_blank" rel="noopener" class="contact-item">
            <i class="fab fa-facebook"></i> ফেসবুক পেজ
          </a>
        )}
        {club.address && (
          <p class="contact-item">
            <i class="fas fa-map-pin"></i> {club.address}
          </p>
        )}
      </div>

      {hasMapPin && (
        <div class="map-embed">
          <iframe
            src={`https://www.google.com/maps?q=${club.latitude},${club.longitude}&z=15&output=embed`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      )}
    </div>

    <CommitteeSection committee={committee} />
    <MemberGrid members={regularMembers} />
    <AchievementTimeline achievements={achievements} />
    <EventSection events={events} />
    <GallerySection gallery={gallery} />
    <JoinRequestForm clubId={club.id} clubName={club.name} />
  </div>
</div>

<style>
  .club-page {
    padding-bottom: 60px;
    background: #F8FAFC;
  }

  .club-cover-wrap {
    width: 100%;
    aspect-ratio: 16/6;
    background: #F4F7FC;
    overflow: hidden;
  }

  .club-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .club-cover-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #FFF0EA, #F4F7FC);
  }

  .club-header {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    margin-top: -40px;
    margin-bottom: 20px;
    position: relative;
  }

  .club-logo {
    width: 90px;
    height: 90px;
    border-radius: 20px;
    object-fit: contain;
    background: #fff;
    border: 4px solid #fff;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.1);
    flex-shrink: 0;
  }

  .club-logo-placeholder {
    width: 90px;
    height: 90px;
    border-radius: 20px;
    background: #FFF0EA;
    color: #FF6B35;
    border: 4px solid #fff;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    flex-shrink: 0;
  }

  .club-header-info {
    padding-bottom: 6px;
  }

  .club-header-info h1 {
    font-size: 1.4rem;
    font-weight: 700;
    color: #1B2A4A;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .verified-icon {
    color: #FF6B35;
    font-size: 1rem;
  }

  .club-tagline {
    font-size: 0.88rem;
    color: #5A6E85;
    margin-top: 2px;
  }

  .club-meta-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .meta-chip {
    background: #fff;
    border: 1px solid #E5EAF0;
    padding: 5px 12px;
    border-radius: 40px;
    font-size: 0.76rem;
    font-weight: 600;
    color: #5A6E85;
  }

  .club-description-card,
  .contact-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .club-description-card p {
    font-size: 0.92rem;
    color: #3A4A60;
    line-height: 1.7;
  }

  .contact-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .contact-card h3 i {
    color: #FF6B35;
  }

  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: #3A4A60;
    text-decoration: none;
    font-weight: 600;
  }

  .contact-item i {
    color: #FF6B35;
    width: 18px;
  }

  .map-embed {
    margin-top: 16px;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .map-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>