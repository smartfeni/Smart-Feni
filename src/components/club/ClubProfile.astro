---
import AnnouncementTicker from './AnnouncementTicker.astro';
import CommitteeSection from './CommitteeSection.astro';
import MemberGrid from './MemberGrid.astro';
import AchievementTimeline from './AchievementTimeline.astro';
import EventSection from './EventSection.astro';
import GallerySection from './GallerySection.astro';
import JoinRequestForm from './JoinRequestForm.astro';

const { club, members, posts } = Astro.props;

const UPAZILA_LABELS = {
  'feni-sadar': 'ফেনী সদর',
  'chhagalnaiya': 'ছাগলনাইয়া',
  'daganbhuiyan': 'দাগনভূঞা',
  'parshuram': 'পরশুরাম',
  'fulgazi': 'ফুলগাজী',
  'sonagazi': 'সোনাগাজী',
};

const upazilaLabel = club.upajila ? UPAZILA_LABELS[club.upajila] || club.upajila : '';

const committee = members.filter((m) => m.is_committee);
const regularMembers = members.filter((m) => !m.is_committee);
const announcements = posts.filter((p) => p.type === 'announcement');
const achievements = posts.filter((p) => p.type === 'achievement');
const events = posts.filter((p) => p.type === 'event');
const gallery = posts.filter((p) => p.type === 'gallery');

const hasMapPin = club.latitude && club.longitude;
const mapUrl = hasMapPin ? `https://www.google.com/maps?q=${club.latitude},${club.longitude}` : null;
---

<div class="club-page">
  <!-- ===== কভার ===== -->
  <div class="club-cover-wrap">
    {club.cover_image ? (
      <img src={club.cover_image} alt={club.name} class="club-cover-img" />
    ) : (
      <div class="club-cover-placeholder"></div>
    )}
  </div>

  <!-- ===== লোগো (কভারের উপর ওভারল্যাপ) ===== -->
  <div class="container">
    <div class="club-logo-row">
      {club.logo_image ? (
        <img src={club.logo_image} alt={club.name} class="club-logo" />
      ) : (
        <div class="club-logo-placeholder"><i class="fas fa-users"></i></div>
      )}
    </div>
  </div>

  <!-- ===== এনাউন্সমেন্ট টিকার ===== -->
  {announcements.length > 0 && <AnnouncementTicker announcements={announcements} />}

  <div class="container">
    <!-- ===== নাম কার্ড (কভার থেকে আলাদা, single-line) ===== -->
    <div class="club-name-card">
      <h1 class="club-name-text" title={club.name}>
        <span class="name-truncate">{club.name}</span>
        {club.is_verified && <i class="fas fa-circle-check verified-icon"></i>}
      </h1>
      {club.tagline && <p class="club-tagline">{club.tagline}</p>}
      <div class="club-meta-row">
        {upazilaLabel && (
          <span class="meta-chip"><i class="fas fa-location-dot"></i> {upazilaLabel}</span>
        )}
        {club.established_year && (
          <span class="meta-chip"><i class="fas fa-flag"></i> প্রতিষ্ঠা: {club.established_year}</span>
        )}
      </div>
    </div>

    {club.description && (
      <div class="club-description-card">
        <p>{club.description}</p>
      </div>
    )}

    <!-- ===== যোগাযোগ ===== -->
    <div class="contact-card">
      <h3><i class="fas fa-address-card"></i> যোগাযোগ</h3>
      <div class="contact-grid">
        {club.phone && (
          <a href={`tel:${club.phone}`} class="contact-item">
            <i class="fas fa-phone"></i> {club.phone}
          </a>
        )}
        {club.facebook_link && (
          <a href={club.facebook_link} target="_blank" rel="noopener" class="contact-item">
            <i class="fab fa-facebook"></i> ফেসবুক পেজ
          </a>
        )}
        {club.address && (
          <p class="contact-item">
            <i class="fas fa-map-pin"></i> {club.address}
          </p>
        )}
        {hasMapPin && (
          <a href={mapUrl} target="_blank" rel="noopener" class="map-link-btn">
            <i class="fas fa-map-location-dot"></i> ম্যাপে দেখুন
          </a>
        )}
      </div>
    </div>

    <CommitteeSection committee={committee} />
    <MemberGrid members={regularMembers} />
    <AchievementTimeline achievements={achievements} />
    <EventSection events={events} />
    <GallerySection gallery={gallery} />
    <JoinRequestForm clubId={club.id} clubName={club.name} />
  </div>
</div>

<style>
  .club-page {
    padding-bottom: 60px;
    background: #F8FAFC;
  }

  .club-cover-wrap {
    width: 100%;
    aspect-ratio: 16/6;
    background: #F4F7FC;
    overflow: hidden;
  }

  .club-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .club-cover-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #FFF0EA, #F4F7FC);
  }

  /* ===== লোগো — শুধু এটাই কভারের উপর ওভারল্যাপ করে ===== */
  .club-logo-row {
    margin-top: -36px;
    margin-bottom: 12px;
  }

  .club-logo {
    width: 76px;
    height: 76px;
    border-radius: 18px;
    object-fit: contain;
    background: #fff;
    border: 4px solid #fff;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.12);
  }

  .club-logo-placeholder {
    width: 76px;
    height: 76px;
    border-radius: 18px;
    background: #FFF0EA;
    color: #FF6B35;
    border: 4px solid #fff;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
  }

  /* ===== নাম কার্ড — কভার থেকে সম্পূর্ণ আলাদা, single-line নাম ===== */
  .club-name-card {
    margin-bottom: 16px;
  }

  .club-name-text {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1B2A4A;
    max-width: 100%;
  }

  .name-truncate {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .verified-icon {
    color: #FF6B35;
    font-size: 0.95rem;
    flex-shrink: 0;
  }

  .club-tagline {
    font-size: 0.86rem;
    color: #5A6E85;
    margin-top: 3px;
  }

  .club-meta-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .meta-chip {
    background: #fff;
    border: 1px solid #E5EAF0;
    padding: 5px 12px;
    border-radius: 40px;
    font-size: 0.76rem;
    font-weight: 600;
    color: #5A6E85;
    white-space: nowrap;
  }

  .club-description-card,
  .contact-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .club-description-card p {
    font-size: 0.92rem;
    color: #3A4A60;
    line-height: 1.7;
  }

  .contact-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .contact-card h3 i {
    color: #FF6B35;
  }

  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-start;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: #3A4A60;
    text-decoration: none;
    font-weight: 600;
  }

  .contact-item i {
    color: #FF6B35;
    width: 18px;
  }

  /* ===== ম্যাপ — ছোট বাটন, বড় iframe না ===== */
  .map-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFF0EA;
    color: #FF6B35;
    text-decoration: none;
    padding: 9px 16px;
    border-radius: 40px;
    font-size: 0.82rem;
    font-weight: 700;
    margin-top: 2px;
  }

  .map-link-btn i {
    font-size: 0.85rem;
  }
</style>