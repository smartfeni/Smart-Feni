---
import AnnouncementTicker from './AnnouncementTicker.astro';
import CommitteeSection from './CommitteeSection.astro';
import MemberGrid from './MemberGrid.astro';
import AchievementTimeline from './AchievementTimeline.astro';
import EventSection from './EventSection.astro';
import GallerySection from './GallerySection.astro';
import JoinRequestForm from './JoinRequestForm.astro';

const { club, members, posts } = Astro.props;

const UPAZILA_LABELS = {
  'feni-sadar': 'ফেনী সদর',
  'chhagalnaiya': 'ছাগলনাইয়া',
  'daganbhuiyan': 'দাগনভূঞা',
  'parshuram': 'পরশুরাম',
  'fulgazi': 'ফুলগাজী',
  'sonagazi': 'সোনাগাজী',
};

const upazilaLabel = club.upajila ? UPAZILA_LABELS[club.upajila] || club.upajila : '';

const committee = members.filter((m) => m.is_committee).sort((a, b) => a.position_order - b.position_order);
const regularMembers = members.filter((m) => !m.is_committee);
const announcements = posts.filter((p) => p.type === 'announcement');
const achievements = posts.filter((p) => p.type === 'achievement');
const events = posts.filter((p) => p.type === 'event');
const gallery = posts.filter((p) => p.type === 'gallery');

const hasMapPin = club.latitude && club.longitude;
const mapUrl = hasMapPin ? `https://www.google.com/maps?q=${club.latitude},${club.longitude}` : null;
---

<div class="club-page">
  <!-- ===== কভার (নিচে গোল কোণ) ===== -->
  <div class="club-cover-wrap">
    {club.cover_image ? (
      <img src={club.cover_image} alt={club.name} class="club-cover-img" />
    ) : (
      <div class="club-cover-placeholder"></div>
    )}
  </div>

  <!-- ===== লোগো (কভারের উপর সেন্টার-ওভারল্যাপ) ===== -->
  <div class="club-logo-center">
    {club.logo_image ? (
      <img src={club.logo_image} alt={club.name} class="club-logo" />
    ) : (
      <div class="club-logo-placeholder"><i class="fas fa-users"></i></div>
    )}
  </div>

  <div class="container">
    <!-- ===== নাম, ট্যাগলাইন, মেটা — সব সেন্টার্ড ===== -->
    <div class="club-identity">
      <h1 class="club-name-text">
        <span class="name-truncate" title={club.name}>{club.name}</span>
        {club.is_verified && <i class="fas fa-circle-check verified-icon" title="ভেরিফায়েড ক্লাব"></i>}
      </h1>
      {club.tagline && <p class="club-tagline">{club.tagline}</p>}
      <div class="club-meta-row">
        {upazilaLabel && (
          <span class="meta-chip"><i class="fas fa-location-dot"></i> {upazilaLabel}</span>
        )}
        {club.established_year && (
          <span class="meta-chip"><i class="fas fa-flag"></i> প্রতিষ্ঠা: {club.established_year}</span>
        )}
      </div>
    </div>

    <!-- ===== এনাউন্সমেন্ট টিকার ===== -->
    {announcements.length > 0 && <AnnouncementTicker announcements={announcements} />}

    {club.description && (
      <div class="club-description-card">
        <span class="desc-icon"><i class="fas fa-users"></i></span>
        <p>{club.description}</p>
      </div>
    )}

    <!-- ===== যোগাযোগ ===== -->
    <div class="contact-card">
      <h3><i class="fas fa-address-card"></i> যোগাযোগ</h3>
      <div class="contact-grid">
        {club.phone && (
          <a href={`tel:${club.phone}`} class="contact-item">
            <span class="contact-icon"><i class="fas fa-phone"></i></span> {club.phone}
          </a>
        )}
        {club.facebook_link && (
          <a href={club.facebook_link} target="_blank" rel="noopener" class="contact-item">
            <span class="contact-icon fb"><i class="fab fa-facebook-f"></i></span> ফেসবুক পেজ
          </a>
        )}
        {club.address && (
          <p class="contact-item">
            <span class="contact-icon"><i class="fas fa-map-pin"></i></span> {club.address}
          </p>
        )}
        {hasMapPin && (
          <a href={mapUrl} target="_blank" rel="noopener" class="map-link-btn">
            <i class="fas fa-map-location-dot"></i> ম্যাপে দেখুন
          </a>
        )}
      </div>
    </div>

    <CommitteeSection committee={committee} />
    <MemberGrid members={regularMembers} />
    <AchievementTimeline achievements={achievements} />
    <EventSection events={events} />
    <GallerySection gallery={gallery} />
    <JoinRequestForm clubId={club.id} clubName={club.name} />
  </div>
</div>

<style>
  .club-page {
    padding-bottom: 60px;
    background: #F8FAFC;
  }

  .club-cover-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    background: #F4F7FC;
    overflow: hidden;
    border-radius: 0 0 36px 36px;
  }

  .club-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .club-cover-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #FFF0EA, #F4F7FC);
  }

  /* ===== লোগো — কভারের উপর সেন্টার-ওভারল্যাপ ===== */
  .club-logo-center {
    display: flex;
    justify-content: center;
    margin-top: -48px;
    margin-bottom: 14px;
    position: relative;
    z-index: 2;
  }

  .club-logo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    background: #fff;
    border: 5px solid #fff;
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.16);
  }

  .club-logo-placeholder {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    border: 5px solid #fff;
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.16);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.9rem;
  }

  /* ===== নাম/ট্যাগলাইন/মেটা — সেন্টার্ড ===== */
  .club-identity {
    text-align: center;
    margin-bottom: 18px;
  }

  .club-name-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 1.3rem;
    font-weight: 700;
    color: #1B2A4A;
  }

  .name-truncate {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 82vw;
  }

  .verified-icon {
    color: #2563EB;
    font-size: 1.05rem;
    flex-shrink: 0;
  }

  .club-tagline {
    font-size: 0.88rem;
    color: #5A6E85;
    margin-top: 4px;
  }

  .club-meta-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 12px;
  }

  .meta-chip {
    background: #fff;
    border: 1px solid #E5EAF0;
    padding: 6px 14px;
    border-radius: 40px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #5A6E85;
    white-space: nowrap;
  }

  /* ===== বিবরণ বক্স — আইকন সহ ===== */
  .club-description-card {
    background: #EAF2FF;
    border-radius: 18px;
    padding: 16px 18px;
    margin-bottom: 20px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .desc-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #2563EB;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    flex-shrink: 0;
  }

  .club-description-card p {
    font-size: 0.9rem;
    color: #1B3A6B;
    line-height: 1.7;
    padding-top: 6px;
  }

  .contact-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .contact-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .contact-card h3 i {
    color: #FF6B35;
  }

  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.88rem;
    color: #3A4A60;
    text-decoration: none;
    font-weight: 600;
  }

  .contact-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #2563EB;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .contact-icon.fb {
    background: #1877F2;
  }

  .map-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFF0EA;
    color: #FF6B35;
    text-decoration: none;
    padding: 9px 16px;
    border-radius: 40px;
    font-size: 0.82rem;
    font-weight: 700;
    margin-top: 2px;
  }

  .map-link-btn i {
    font-size: 0.85rem;
  }
</style>