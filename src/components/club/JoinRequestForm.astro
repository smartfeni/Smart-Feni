---
// ============================================================
// কম্পোনেন্ট: /my-club ড্যাশবোর্ড — জয়েন-রিকোয়েস্ট ইনবক্স
// আপডেট: "গ্রহণ করুন" চাপলে এখন আবেদনকারীর নাম/ছবি/জন্মতারিখ
// দিয়ে সরাসরি club_members টেবিলে (সাধারণ সদস্য হিসেবে) যোগ
// হয়ে যায় — আলাদা করে আবার সদস্য ফর্ম পূরণ করা লাগবে না
// ============================================================
---

<div class="dash-card">
  <h3><i class="fas fa-user-plus"></i> মেম্বারশিপ আবেদন</h3>
  <div id="joinList"></div>
  <p class="empty-note" id="joinEmpty" style="display:none;">এখনো কোনো আবেদন আসেনি</p>
</div>

<script>
  import { supabase } from '../../lib/supabase.js';

  let clubId = null;

  async function loadRequests() {
    const { data } = await supabase
      .from('club_join_requests')
      .select('*')
      .eq('club_id', clubId)
      .order('created_at', { ascending: false });

    const requests = data || [];
    const container = document.getElementById('joinList');
    const emptyEl = document.getElementById('joinEmpty');
    const pendingCount = requests.filter((r) => r.status === 'pending').length;

    const badge = document.getElementById('joinBadge');
    if (badge) {
      badge.style.display = pendingCount > 0 ? 'inline-block' : 'none';
      badge.textContent = pendingCount;
    }

    container.innerHTML = '';
    if (requests.length === 0) {
      emptyEl.style.display = 'block';
      return;
    }
    emptyEl.style.display = 'none';

    requests.forEach((r) => {
      const card = document.createElement('div');
      card.className = 'item-card';
      card.innerHTML = `
        ${r.photo ? `<img class="item-photo" src="${r.photo}" alt="${r.applicant_name}" style="border-radius:50%;" />` : `<div class="item-photo-placeholder" style="border-radius:50%;"><i class="fas fa-user"></i></div>`}
        <div class="item-body">
          <p class="item-title">${r.applicant_name} — ${r.phone}</p>
          <p class="item-sub">${r.message || ''} ${r.status !== 'pending' ? '· ' + (r.status === 'accepted' ? 'গৃহীত ও সদস্য তালিকায় যোগ হয়েছে' : 'বাতিল') : ''}</p>
        </div>
        <div class="item-actions">
          ${r.status === 'pending' ? `
            <button class="icon-btn edit accept-btn"><i class="fas fa-check"></i></button>
            <button class="icon-btn delete reject-btn"><i class="fas fa-xmark"></i></button>
          ` : ''}
        </div>
      `;
      card.querySelector('.accept-btn')?.addEventListener('click', (e) => acceptRequest(r, e.target.closest('button')));
      card.querySelector('.reject-btn')?.addEventListener('click', () => updateStatus(r.id, 'rejected'));
      container.appendChild(card);
    });
  }

  async function acceptRequest(request, btnEl) {
    btnEl.disabled = true;
    btnEl.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

    // ধাপ ১: সাধারণ সদস্য হিসেবে club_members এ যোগ
    const { error: memberError } = await supabase.from('club_members').insert({
      club_id: clubId,
      name: request.applicant_name,
      photo: request.photo || null,
      dob: request.dob || null,
      is_committee: false,
      position: null,
      position_order: 0,
    });

    if (memberError) {
      alert('সদস্য হিসেবে যোগ করা ব্যর্থ: ' + memberError.message);
      btnEl.disabled = false;
      btnEl.innerHTML = '<i class="fas fa-check"></i>';
      return;
    }

    // ধাপ ২: রিকোয়েস্ট স্ট্যাটাস আপডেট
    const { error: statusError } = await supabase
      .from('club_join_requests')
      .update({ status: 'accepted' })
      .eq('id', request.id);

    if (statusError) {
      alert('আপডেট ব্যর্থ: ' + statusError.message);
    }

    loadRequests();
  }

  async function updateStatus(id, status) {
    const { error } = await supabase.from('club_join_requests').update({ status }).eq('id', id);
    if (error) {
      alert('আপডেট ব্যর্থ: ' + error.message);
      return;
    }
    loadRequests();
  }

  window.addEventListener('smartfeni:club-ready', (e) => {
    clubId = e.detail.clubId;
    loadRequests();
  });
</script>