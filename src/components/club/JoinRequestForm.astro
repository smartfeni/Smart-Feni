---
const { clubId, clubName } = Astro.props;
---

<button class="join-cta-btn" id="showJoinFormBtn" type="button" data-club-name={clubName}>
  <span class="join-cta-text"><i class="fas fa-user-plus"></i> {clubName} এ যোগ দিতে চান? আবেদন করুন</span>
  <i class="fas fa-chevron-down join-cta-chevron" id="joinCtaChevron"></i>
</button>

<div class="section-card join-form-panel" id="joinFormBox">
  <h3><i class="fas fa-user-plus"></i> {clubName} এ যোগ দিতে চান?</h3>
  <p class="join-subtitle">নিচের ফর্মটি পূরণ করুন, ক্লাব কর্তৃপক্ষ আপনার সাথে যোগাযোগ করবে</p>

  <p class="form-message" id="joinFormMessage"></p>

  <input type="hidden" id="joinClubId" value={clubId} />

  <div class="photo-upload-circle" id="joinPhotoCircle">
    <img id="joinPhotoPreview" src="" alt="ছবি" />
    <i class="fas fa-camera"></i>
  </div>
  <input type="file" id="joinPhotoInput" accept="image/*" style="display:none;" />
  <p class="photo-hint">ছবি (ঐচ্ছিক) — গৃহীত হলে সদস্য তালিকায় ব্যবহার হবে</p>

  <label class="form-label">আপনার নাম</label>
  <input type="text" class="form-input" id="joinApplicantName" placeholder="পূর্ণ নাম লিখুন" />

  <label class="form-label">ফোন নম্বর</label>
  <input type="text" class="form-input" id="joinApplicantPhone" placeholder="01xxxxxxxxx" />

  <label class="form-label">জন্ম তারিখ (ঐচ্ছিক)</label>
  <input type="date" class="form-input" id="joinApplicantDob" />

  <label class="form-label">বার্তা (ঐচ্ছিক)</label>
  <textarea class="form-input" id="joinApplicantMessage" rows="3" placeholder="কেন যোগ দিতে চান..."></textarea>

  <button class="join-btn" id="joinSubmitBtn" type="button">
    <i class="fas fa-paper-plane"></i> <span id="joinBtnText">আবেদন পাঠান</span>
  </button>
</div>

<style>
  .join-cta-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    background: #FFF0EA;
    color: #FF6B35;
    border: 1.5px dashed #FFD3BC;
    padding: 15px 18px;
    border-radius: 16px;
    font-weight: 700;
    font-size: 0.88rem;
    cursor: pointer;
    margin-bottom: 0;
    text-align: left;
  }

  .join-cta-text {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .join-cta-chevron {
    font-size: 0.78rem;
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .join-cta-btn.open {
    border-radius: 16px 16px 0 0;
    margin-bottom: 0;
  }

  .join-cta-btn.open .join-cta-chevron {
    transform: rotate(180deg);
  }

  .join-cta-btn:hover {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  /* ===== ফর্ম প্যানেল — dropdown/accordion স্টাইলে খোলে-বন্ধ হয় ===== */
  .join-form-panel {
    background: #fff;
    border-radius: 0 0 20px 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
    overflow: hidden;
    max-height: 0;
    padding: 0 20px;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.25s ease, padding 0.35s ease;
  }

  .join-form-panel.open {
    max-height: 1400px;
    padding: 20px;
    opacity: 1;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .join-subtitle {
    font-size: 0.82rem;
    color: #8FA0BC;
    margin-bottom: 16px;
  }

  .form-message {
    display: none;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 10px 14px;
    border-radius: 12px;
    margin-bottom: 12px;
    text-align: center;
  }

  .form-message.show-error {
    display: block;
    background: #FFF0EA;
    color: #D14343;
  }

  .form-message.show-success {
    display: block;
    background: #EAFBF0;
    color: #1B7A3C;
  }

  .photo-upload-circle {
    position: relative;
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: #FFF0EA;
    border: 2px dashed #FFD3BC;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    overflow: hidden;
    margin: 0 auto 6px;
  }

  .photo-upload-circle img {
    display: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-upload-circle.has-photo img {
    display: block;
  }

  .photo-upload-circle.has-photo i {
    display: none;
  }

  .photo-upload-circle i {
    color: #FF6B35;
    font-size: 1.2rem;
  }

  .photo-hint {
    text-align: center;
    font-size: 0.72rem;
    color: #9AA8BC;
    margin-bottom: 16px;
  }

  .form-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: #1B2A4A;
    margin-bottom: 6px;
    margin-top: 14px;
  }

  .form-input {
    width: 100%;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1.5px solid #E5EAF0;
    font-size: 0.9rem;
    font-family: inherit;
    color: #1B2A4A;
    background: #FBFCFE;
    resize: vertical;
  }

  .form-input:focus {
    outline: none;
    border-color: #FF6B35;
    background: #fff;
  }

  .join-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    border: none;
    padding: 14px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 0.92rem;
    cursor: pointer;
    margin-top: 18px;
  }

  .join-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  let selectedPhotoFile = null;

  const toggleBtn = document.getElementById('showJoinFormBtn');
  const formPanel = document.getElementById('joinFormBox');
  const ctaText = document.querySelector('.join-cta-text');

  function setPanelOpen(isOpen) {
    if (!formPanel || !toggleBtn || !ctaText) return;
    formPanel.classList.toggle('open', isOpen);
    toggleBtn.classList.toggle('open', isOpen);
    const name = toggleBtn.dataset.clubName || '';
    ctaText.innerHTML = isOpen
      ? '<i class="fas fa-xmark"></i> ফর্ম বন্ধ করুন'
      : `<i class="fas fa-user-plus"></i> ${name} এ যোগ দিতে চান? আবেদন করুন`;
  }

  if (toggleBtn && formPanel) {
    toggleBtn.addEventListener('click', () => {
      const isOpen = formPanel.classList.contains('open');
      setPanelOpen(!isOpen);
    });
  }

  const btn = document.getElementById('joinSubmitBtn');
  const btnText = document.getElementById('joinBtnText');
  const msgEl = document.getElementById('joinFormMessage');

  function showMsg(text, type = 'error') {
    msgEl.textContent = text;
    msgEl.className = `form-message ${type === 'error' ? 'show-error' : 'show-success'}`;
  }

  document.getElementById('joinPhotoCircle')?.addEventListener('click', () => {
    document.getElementById('joinPhotoInput').click();
  });

  document.getElementById('joinPhotoInput')?.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    selectedPhotoFile = file;
    const reader = new FileReader();
    reader.onload = () => {
      document.getElementById('joinPhotoPreview').src = reader.result;
      document.getElementById('joinPhotoCircle').classList.add('has-photo');
    };
    reader.readAsDataURL(file);
  });

  async function uploadPhoto(file, clubId) {
    const ext = file.name.split('.').pop();
    const path = `club-join-requests/${clubId}-${Date.now()}.${ext}`;
    const { error } = await supabase.storage.from('listing-images').upload(path, file, { upsert: true });
    if (error) return null;
    const { data } = supabase.storage.from('listing-images').getPublicUrl(path);
    return data?.publicUrl || null;
  }

  btn?.addEventListener('click', async () => {
    const clubId = document.getElementById('joinClubId').value;
    const applicant_name = document.getElementById('joinApplicantName').value.trim();
    const phone = document.getElementById('joinApplicantPhone').value.trim();
    const dob = document.getElementById('joinApplicantDob').value;
    const message = document.getElementById('joinApplicantMessage').value.trim();

    if (!applicant_name || !phone) {
      showMsg('নাম ও ফোন নম্বর দিন');
      return;
    }

    btn.disabled = true;
    btnText.textContent = 'পাঠানো হচ্ছে...';

    let photoUrl = null;
    if (selectedPhotoFile) {
      photoUrl = await uploadPhoto(selectedPhotoFile, clubId);
    }

    const { error } = await supabase.from('club_join_requests').insert({
      club_id: clubId,
      applicant_name,
      phone,
      dob: dob || null,
      photo: photoUrl,
      message: message || null,
    });

    if (error) {
      showMsg('আবেদন পাঠানো ব্যর্থ: ' + error.message);
    } else {
      showMsg('আবেদন সফলভাবে পাঠানো হয়েছে ✓', 'success');
      document.getElementById('joinApplicantName').value = '';
      document.getElementById('joinApplicantPhone').value = '';
      document.getElementById('joinApplicantDob').value = '';
      document.getElementById('joinApplicantMessage').value = '';
      document.getElementById('joinPhotoCircle').classList.remove('has-photo');
      selectedPhotoFile = null;

      setTimeout(() => setPanelOpen(false), 2000);
    }

    btn.disabled = false;
    btnText.textContent = 'আবেদন পাঠান';
  });
</script>