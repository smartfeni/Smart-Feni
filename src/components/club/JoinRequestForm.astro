---
// ============================================================
// কম্পোনেন্ট: সদস্য হওয়ার আবেদন ফর্ম
// লগইন বাধ্যতামূলক — প্রোফাইল থেকে নাম/ফোন/ছবি অটো-ফিল, accordion
// টগল স্টাইল। পেজ লোডেই চেক করে ইউজার আগে আবেদন করেছে/সদস্য
// হয়েছে কিনা — সেই অনুযায়ী CTA-এর বদলে status ব্যানার দেখায়।
// ============================================================

const { clubId, clubName } = Astro.props;
---

<div id="joinStatusWrap">
  <button class="join-cta-btn" id="showJoinFormBtn" type="button" data-club-name={clubName}>
    <span class="join-cta-text"><i class="fas fa-user-plus"></i> {clubName} এ যোগ দিতে চান? আবেদন করুন</span>
    <i class="fas fa-chevron-down join-cta-chevron" id="joinCtaChevron"></i>
  </button>

  <div class="status-banner accepted" id="alreadyMemberBanner" style="display:none;">
    <i class="fas fa-circle-check"></i> আপনি ইতিমধ্যে এই ক্লাবের সদস্য
  </div>

  <div class="status-banner pending" id="pendingBanner" style="display:none;">
    <i class="fas fa-hourglass-half"></i> আপনার আবেদনটি পর্যালোচনাধীন
  </div>
</div>

<div class="section-card join-form-panel" id="joinFormBox">
  <h3><i class="fas fa-user-plus"></i> {clubName} এ যোগ দিতে চান?</h3>
  <p class="join-subtitle">আপনার প্রোফাইলের তথ্য থেকে আবেদন যাবে, ক্লাব কর্তৃপক্ষ যোগাযোগ করবে</p>

  <p class="form-message" id="joinFormMessage"></p>

  <input type="hidden" id="joinClubId" value={clubId} />

  <!-- ===== লগইন করা না থাকলে এটা দেখাবে ===== -->
  <div id="joinLoginPrompt" style="display:none;">
    <p class="login-prompt-text">আবেদন করতে হলে আগে লগইন করুন</p>
    <button class="join-btn" id="joinLoginBtn" type="button">
      <i class="fas fa-right-to-bracket"></i> লগইন করুন
    </button>
  </div>

  <!-- ===== লগইন থাকলে এটা দেখাবে ===== -->
  <div id="joinAuthedFields" style="display:none;">
    <div class="applicant-preview">
      <img id="joinProfilePhoto" src="" alt="" style="display:none;" />
      <div id="joinProfilePhotoPlaceholder" class="applicant-photo-placeholder"><i class="fas fa-user"></i></div>
      <div>
        <p class="applicant-name" id="joinProfileName"></p>
        <p class="applicant-phone" id="joinProfilePhone"></p>
      </div>
    </div>

    <label class="form-label">বার্তা (ঐচ্ছিক)</label>
    <textarea class="form-input" id="joinApplicantMessage" rows="3" placeholder="কেন যোগ দিতে চান..."></textarea>

    <button class="join-btn" id="joinSubmitBtn" type="button">
      <i class="fas fa-paper-plane"></i> <span id="joinBtnText">আবেদন পাঠান</span>
    </button>
  </div>
</div>

<style>
  .join-cta-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    background: #FFF0EA;
    color: #FF6B35;
    border: 1.5px dashed #FFD3BC;
    padding: 15px 18px;
    border-radius: 16px;
    font-weight: 700;
    font-size: 0.88rem;
    cursor: pointer;
    text-align: left;
    margin-bottom: 20px;
  }

  .join-cta-text {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .join-cta-chevron {
    font-size: 0.78rem;
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .join-cta-btn.open {
    border-radius: 16px 16px 0 0;
    margin-bottom: 0;
  }

  .join-cta-btn.open .join-cta-chevron {
    transform: rotate(180deg);
  }

  .join-cta-btn:hover {
    background: #FF6B35;
    color: #fff;
    border-color: #FF6B35;
  }

  .status-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 15px;
    border-radius: 16px;
    font-weight: 700;
    font-size: 0.88rem;
    margin-bottom: 20px;
  }

  .status-banner.accepted {
    background: #EAFBF0;
    color: #1B7A3C;
  }

  .status-banner.pending {
    background: #FFF3E0;
    color: #B36B00;
  }

  .join-form-panel {
    background: #fff;
    border-radius: 0 0 20px 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
    overflow: hidden;
    max-height: 0;
    padding: 0 20px;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.25s ease, padding 0.35s ease;
  }

  .join-form-panel.open {
    max-height: 700px;
    padding: 20px;
    opacity: 1;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .join-subtitle {
    font-size: 0.82rem;
    color: #8FA0BC;
    margin-bottom: 16px;
  }

  .form-message {
    display: none;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 10px 14px;
    border-radius: 12px;
    margin-bottom: 12px;
    text-align: center;
  }

  .form-message.show-error {
    display: block;
    background: #FFF0EA;
    color: #D14343;
  }

  .form-message.show-success {
    display: block;
    background: #EAFBF0;
    color: #1B7A3C;
  }

  .login-prompt-text {
    text-align: center;
    font-size: 0.85rem;
    color: #5A6E85;
    margin-bottom: 14px;
  }

  .applicant-preview {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #F8FAFC;
    border-radius: 14px;
    padding: 12px 14px;
    margin-bottom: 6px;
  }

  .applicant-preview img,
  .applicant-photo-placeholder {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: #FFF0EA;
  }

  .applicant-photo-placeholder {
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
  }

  .applicant-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1B2A4A;
  }

  .applicant-phone {
    font-size: 0.78rem;
    color: #8FA0BC;
    margin-top: 2px;
  }

  .form-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: #1B2A4A;
    margin-bottom: 6px;
    margin-top: 14px;
  }

  .form-input {
    width: 100%;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1.5px solid #E5EAF0;
    font-size: 0.9rem;
    font-family: inherit;
    color: #1B2A4A;
    background: #FBFCFE;
    resize: vertical;
  }

  .form-input:focus {
    outline: none;
    border-color: #FF6B35;
    background: #fff;
  }

  .join-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    border: none;
    padding: 14px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 0.92rem;
    cursor: pointer;
    margin-top: 16px;
  }

  .join-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  const wrap = document.getElementById('joinStatusWrap');
  const toggleBtn = document.getElementById('showJoinFormBtn');
  const formPanel = document.getElementById('joinFormBox');
  const ctaText = document.querySelector('.join-cta-text');
  const loginPrompt = document.getElementById('joinLoginPrompt');
  const authedFields = document.getElementById('joinAuthedFields');
  const acceptedBanner = document.getElementById('alreadyMemberBanner');
  const pendingBanner = document.getElementById('pendingBanner');

  let currentUserId = null;
  let profileLoaded = false;

  function setPanelOpen(isOpen) {
    if (!formPanel || !toggleBtn || !ctaText) return;
    formPanel.classList.toggle('open', isOpen);
    toggleBtn.classList.toggle('open', isOpen);
    const name = toggleBtn.dataset.clubName || '';
    ctaText.innerHTML = isOpen
      ? '<i class="fas fa-xmark"></i> ফর্ম বন্ধ করুন'
      : `<i class="fas fa-user-plus"></i> ${name} এ যোগ দিতে চান? আবেদন করুন`;
  }

  // ===== পেজ লোড হওয়ার সাথে সাথে — লগইন থাকলে চেক করা হয় এই ইউজার
  // আগে এই ক্লাবে আবেদন করেছে/সদস্য হয়েছে কিনা =====
  async function checkExistingStatus(clubId, userId) {
    const { data } = await supabase
      .from('club_join_requests')
      .select('status')
      .eq('club_id', clubId)
      .eq('user_id', userId)
      .order('created_at', { ascending: false })
      .limit(1)
      .maybeSingle();

    if (!data) return false; // কখনো আবেদন করেনি — CTA দেখাবে

    if (data.status === 'accepted') {
      toggleBtn.style.display = 'none';
      acceptedBanner.style.display = 'flex';
      return true;
    }
    if (data.status === 'pending') {
      toggleBtn.style.display = 'none';
      pendingBanner.style.display = 'flex';
      return true;
    }
    return false; // rejected হলে আবার আবেদন করতে পারবে
  }

  async function loadProfileIfNeeded() {
    if (profileLoaded) return;

    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      loginPrompt.style.display = 'block';
      authedFields.style.display = 'none';
      return;
    }

    currentUserId = session.user.id;

    const { data: profile } = await supabase
      .from('profiles')
      .select('full_name, phone, avatar_url')
      .eq('id', currentUserId)
      .single();

    document.getElementById('joinProfileName').textContent = profile?.full_name || 'নামহীন';
    document.getElementById('joinProfilePhone').textContent = profile?.phone || '';

    const photoImg = document.getElementById('joinProfilePhoto');
    const photoPlaceholder = document.getElementById('joinProfilePhotoPlaceholder');
    if (profile?.avatar_url) {
      photoImg.src = profile.avatar_url;
      photoImg.style.display = 'block';
      photoPlaceholder.style.display = 'none';
    } else {
      photoImg.style.display = 'none';
      photoPlaceholder.style.display = 'flex';
    }

    loginPrompt.style.display = 'none';
    authedFields.style.display = 'block';
    profileLoaded = true;
  }

  toggleBtn?.addEventListener('click', async () => {
    const isOpen = formPanel.classList.contains('open');
    if (!isOpen) await loadProfileIfNeeded();
    setPanelOpen(!isOpen);
  });

  document.getElementById('joinLoginBtn')?.addEventListener('click', () => {
    window.openAuthModal?.('login');
  });

  const btn = document.getElementById('joinSubmitBtn');
  const btnText = document.getElementById('joinBtnText');
  const msgEl = document.getElementById('joinFormMessage');

  function showMsg(text, type = 'error') {
    msgEl.textContent = text;
    msgEl.className = `form-message ${type === 'error' ? 'show-error' : 'show-success'}`;
  }

  btn?.addEventListener('click', async () => {
    const clubId = document.getElementById('joinClubId').value;
    const message = document.getElementById('joinApplicantMessage').value.trim();

    const applicant_name = document.getElementById('joinProfileName').textContent;
    const phone = document.getElementById('joinProfilePhone').textContent;
    const photoImg = document.getElementById('joinProfilePhoto');
    const photo = photoImg.style.display !== 'none' ? photoImg.src : null;

    btn.disabled = true;
    btnText.textContent = 'পাঠানো হচ্ছে...';

    const { error } = await supabase.from('club_join_requests').insert({
      club_id: clubId,
      user_id: currentUserId,
      applicant_name,
      phone,
      photo,
      message: message || null,
    });

    if (error) {
      showMsg('আবেদন পাঠানো ব্যর্থ: ' + error.message);
      btn.disabled = false;
      btnText.textContent = 'আবেদন পাঠান';
    } else {
      showMsg('আবেদন সফলভাবে পাঠানো হয়েছে ✓', 'success');
      setTimeout(() => {
        setPanelOpen(false);
        toggleBtn.style.display = 'none';
        pendingBanner.style.display = 'flex';
      }, 1500);
    }
  });

  // ===== ইনিশিয়াল চেক: লগইন থাকলে আগের আবেদনের status দেখে
  // সঠিক UI (CTA বনাম status ব্যানার) ঠিক করা হয় =====
  (async () => {
    const clubId = document.getElementById('joinClubId').value;
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return; // লগইন না থাকলে ডিফল্ট CTA-ই থাকবে

    currentUserId = session.user.id;
    await checkExistingStatus(clubId, currentUserId);
  })();
</script>