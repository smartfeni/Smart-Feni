---
const { clubId, clubName } = Astro.props;
---

<div class="section-card">
  <h3><i class="fas fa-user-plus"></i> {clubName} এ যোগ দিতে চান?</h3>
  <p class="join-subtitle">নিচের ফর্মটি পূরণ করুন, ক্লাব কর্তৃপক্ষ আপনার সাথে যোগাযোগ করবে</p>

  <p class="form-message" id="joinFormMessage"></p>

  <input type="hidden" id="joinClubId" value={clubId} />

  <label class="form-label">আপনার নাম</label>
  <input type="text" class="form-input" id="joinApplicantName" placeholder="পূর্ণ নাম লিখুন" />

  <label class="form-label">ফোন নম্বর</label>
  <input type="text" class="form-input" id="joinApplicantPhone" placeholder="01xxxxxxxxx" />

  <label class="form-label">বার্তা (ঐচ্ছিক)</label>
  <textarea class="form-input" id="joinApplicantMessage" rows="3" placeholder="কেন যোগ দিতে চান..."></textarea>

  <button class="join-btn" id="joinSubmitBtn" type="button">
    <i class="fas fa-paper-plane"></i> <span id="joinBtnText">আবেদন পাঠান</span>
  </button>
</div>

<style>
  .section-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .join-subtitle {
    font-size: 0.82rem;
    color: #8FA0BC;
    margin-bottom: 16px;
  }

  .form-message {
    display: none;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 10px 14px;
    border-radius: 12px;
    margin-bottom: 12px;
    text-align: center;
  }

  .form-message.show-error {
    display: block;
    background: #FFF0EA;
    color: #D14343;
  }

  .form-message.show-success {
    display: block;
    background: #EAFBF0;
    color: #1B7A3C;
  }

  .form-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: #1B2A4A;
    margin-bottom: 6px;
    margin-top: 14px;
  }

  .form-label:first-of-type {
    margin-top: 0;
  }

  .form-input {
    width: 100%;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1.5px solid #E5EAF0;
    font-size: 0.9rem;
    font-family: inherit;
    color: #1B2A4A;
    background: #FBFCFE;
    resize: vertical;
  }

  .form-input:focus {
    outline: none;
    border-color: #FF6B35;
    background: #fff;
  }

  .join-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff;
    border: none;
    padding: 14px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 0.92rem;
    cursor: pointer;
    margin-top: 18px;
  }

  .join-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  const btn = document.getElementById('joinSubmitBtn');
  const btnText = document.getElementById('joinBtnText');
  const msgEl = document.getElementById('joinFormMessage');

  function showMsg(text, type = 'error') {
    msgEl.textContent = text;
    msgEl.className = `form-message ${type === 'error' ? 'show-error' : 'show-success'}`;
  }

  btn?.addEventListener('click', async () => {
    const clubId = document.getElementById('joinClubId').value;
    const applicant_name = document.getElementById('joinApplicantName').value.trim();
    const phone = document.getElementById('joinApplicantPhone').value.trim();
    const message = document.getElementById('joinApplicantMessage').value.trim();

    if (!applicant_name || !phone) {
      showMsg('নাম ও ফোন নম্বর দিন');
      return;
    }

    btn.disabled = true;
    btnText.textContent = 'পাঠানো হচ্ছে...';

    const { error } = await supabase.from('club_join_requests').insert({
      club_id: clubId,
      applicant_name,
      phone,
      message: message || null,
    });

    if (error) {
      showMsg('আবেদন পাঠানো ব্যর্থ: ' + error.message);
    } else {
      showMsg('আবেদন সফলভাবে পাঠানো হয়েছে ✓', 'success');
      document.getElementById('joinApplicantName').value = '';
      document.getElementById('joinApplicantPhone').value = '';
      document.getElementById('joinApplicantMessage').value = '';
    }

    btn.disabled = false;
    btnText.textContent = 'আবেদন পাঠান';
  });
</script>