---
// ============================================================
// কম্পোনেন্ট: টিভি-স্টাইল স্ক্রলিং এনাউন্সমেন্ট টিকার
// ক্লিক করলে সব এনাউন্সমেন্টের ফুল-ডিটেইল মোডাল খোলে
// ============================================================

const { announcements } = Astro.props;

const tickerText = announcements.map((a) => a.title).join('   •   ');
---

<div class="ticker-bar" id="announcementTicker">
  <span class="ticker-label"><i class="fas fa-bullhorn"></i> ঘোষণা</span>
  <div class="ticker-track-wrap">
    <div class="ticker-track">
      <span>{tickerText}</span>
      <span aria-hidden="true">{tickerText}</span>
    </div>
  </div>
</div>

<div class="announcement-modal" id="announcementModal">
  <div class="announcement-modal-backdrop" id="announcementModalBackdrop"></div>
  <div class="announcement-modal-body">
    <button class="announcement-modal-close" id="announcementModalClose">
      <i class="fas fa-xmark"></i>
    </button>
    <h3><i class="fas fa-bullhorn"></i> সব ঘোষণা</h3>
    <div class="announcement-list">
      {announcements.map((a) => (
        <div class="announcement-item">
          <p class="announcement-title">{a.title}</p>
          {a.description && <p class="announcement-desc">{a.description}</p>}
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .ticker-bar {
    display: flex;
    align-items: center;
    background: #1B2A4A;
    cursor: pointer;
    overflow: hidden;
  }

  .ticker-label {
    flex-shrink: 0;
    background: #FF6B35;
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
    padding: 9px 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  .ticker-track-wrap {
    flex: 1;
    overflow: hidden;
  }

  .ticker-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: scroll-left 22s linear infinite;
    width: max-content;
  }

  .ticker-track span {
    padding: 0 24px;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .ticker-bar:hover .ticker-track {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .announcement-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    align-items: flex-end;
    justify-content: center;
  }

  .announcement-modal.open {
    display: flex;
  }

  .announcement-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
  }

  .announcement-modal-body {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 560px;
    max-height: 75vh;
    overflow-y: auto;
    border-radius: 24px 24px 0 0;
    padding: 24px 20px 32px;
  }

  .announcement-modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: #F4F7FC;
    border: none;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #5A6E85;
    cursor: pointer;
  }

  .announcement-modal-body h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .announcement-modal-body h3 i {
    color: #FF6B35;
  }

  .announcement-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .announcement-item {
    background: #F8FAFC;
    border-radius: 14px;
    padding: 14px 16px;
  }

  .announcement-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: #1B2A4A;
  }

  .announcement-desc {
    font-size: 0.85rem;
    color: #5A6E85;
    margin-top: 6px;
    line-height: 1.6;
  }
</style>

<script>
  const ticker = document.getElementById('announcementTicker');
  const modal = document.getElementById('announcementModal');
  const backdrop = document.getElementById('announcementModalBackdrop');
  const closeBtn = document.getElementById('announcementModalClose');

  ticker?.addEventListener('click', () => modal?.classList.add('open'));
  backdrop?.addEventListener('click', () => modal?.classList.remove('open'));
  closeBtn?.addEventListener('click', () => modal?.classList.remove('open'));
</script>