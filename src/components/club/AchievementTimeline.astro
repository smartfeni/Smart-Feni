---
const { achievements } = Astro.props;

function formatDate(dateStr) {
  if (!dateStr) return null;
  const d = new Date(dateStr);
  return d.toLocaleDateString('bn-BD', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

{achievements.length > 0 && (
  <div class="section-card">
    <h3><i class="fas fa-trophy"></i> অর্জন</h3>
    <div class="timeline">
      {achievements.map((a) => (
        <div class="timeline-item">
          {a.image ? (
            <img src={a.image} alt={a.title} class="timeline-img" />
          ) : (
            <div class="timeline-img-placeholder"><i class="fas fa-trophy"></i></div>
          )}
          <div class="timeline-body">
            <p class="timeline-title">{a.title}</p>
            {a.event_date && <p class="timeline-date">{formatDate(a.event_date)}</p>}
            {a.description && <p class="timeline-desc">{a.description}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
)}

<style>
  .section-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .timeline-item {
    display: flex;
    gap: 12px;
    padding-bottom: 16px;
    border-bottom: 1px solid #F0F3F8;
  }

  .timeline-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .timeline-img {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    object-fit: contain;
    background: #F4F7FC;
    flex-shrink: 0;
  }

  .timeline-img-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .timeline-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1B2A4A;
  }

  .timeline-date {
    font-size: 0.75rem;
    color: #FF6B35;
    font-weight: 600;
    margin-top: 2px;
  }

  .timeline-desc {
    font-size: 0.82rem;
    color: #5A6E85;
    margin-top: 4px;
    line-height: 1.6;
  }
</style>