---
const { gallery } = Astro.props;
---

{gallery.length > 0 && (
  <div class="section-card">
    <h3><i class="fas fa-images"></i> গ্যালারি</h3>
    <div class="gallery-grid">
      {gallery.map((g, i) => (
        <img src={g.image} alt={g.title || 'গ্যালারি ছবি'} class="gallery-img" data-index={i} loading="lazy" />
      ))}
    </div>
  </div>
)}

<style>
  .section-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    border-radius: 12px;
    cursor: zoom-in;
    background: #F4F7FC;
  }
</style>

<script>
  // ============================================================
  // আপডেট: নিজস্ব বেসিক লাইটবক্স (জুম/সেভ ছাড়া) সরিয়ে গ্লোবাল
  // ImageLightbox (window.openImageLightbox) ব্যবহার করা হচ্ছে —
  // এতে জুম-টু-ট্যাপ ও ডাউনলোড বাটন দুটোই পাওয়া যাবে
  // ============================================================
  document.querySelectorAll('.gallery-img').forEach((img) => {
    img.addEventListener('click', () => {
      window.openImageLightbox?.(img.src);
    });
  });
</script>