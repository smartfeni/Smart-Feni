---
const { committee } = Astro.props;
---

{committee.length > 0 && (
  <div class="section-card">
    <h3><i class="fas fa-users-gear"></i> কমিটি</h3>
    <div class="committee-grid">
      {committee.map((m) => (
        <div class="committee-item">
          {m.photo ? (
            <img src={m.photo} alt={m.name} class="committee-photo" />
          ) : (
            <div class="committee-photo-placeholder"><i class="fas fa-user"></i></div>
          )}
          <p class="committee-name">{m.name}</p>
          {m.position && <p class="committee-position">{m.position}</p>}
        </div>
      ))}
    </div>
  </div>
)}

<style>
  .section-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .committee-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .committee-item {
    text-align: center;
  }

  .committee-photo {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 16px;
    object-fit: contain;
    background: #F4F7FC;
  }

  .committee-photo-placeholder {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 16px;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
  }

  .committee-name {
    font-size: 0.8rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-top: 8px;
  }

  .committee-position {
    font-size: 0.72rem;
    color: #FF6B35;
    font-weight: 600;
  }

  @media (max-width: 400px) {
    .committee-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>