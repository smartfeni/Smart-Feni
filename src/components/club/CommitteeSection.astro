---
const { committee } = Astro.props;

const preview = committee.slice(0, 3);
const president = committee[0];
const secondThird = committee.slice(1, 3);
const restCommittee = committee.slice(3);
---

{committee.length > 0 && (
  <div class="section-card">
    <div class="section-head">
      <h3><i class="fas fa-users-gear"></i> কমিটি</h3>
      {committee.length > 3 && (
        <button class="see-more-btn" id="committeeSeeMoreBtn">সব দেখুন <i class="fas fa-arrow-right"></i></button>
      )}
    </div>

    <div class="committee-grid">
      {preview.map((m) => (
        <div class="committee-item">
          {m.photo ? (
            <img src={m.photo} alt={m.name} class="committee-photo" />
          ) : (
            <div class="committee-photo-placeholder"><i class="fas fa-user"></i></div>
          )}
          <p class="committee-name">{m.name}</p>
          {m.position && <p class="committee-position">{m.position}</p>}
        </div>
      ))}
    </div>
  </div>
)}

{committee.length > 3 && (
  <div class="committee-modal" id="committeeModal">
    <div class="committee-modal-backdrop" id="committeeModalBackdrop"></div>
    <div class="committee-modal-body">
      <button class="committee-modal-close" id="committeeModalClose"><i class="fas fa-xmark"></i></button>
      <h3><i class="fas fa-users-gear"></i> পূর্ণাঙ্গ কমিটি</h3>

      <!-- ===== পোডিয়াম: সভাপতি সবচেয়ে বড়, উপরে ===== -->
      {president && (
        <div class="podium-president">
          {president.photo ? (
            <img src={president.photo} alt={president.name} class="podium-photo-lg" />
          ) : (
            <div class="podium-photo-lg-placeholder"><i class="fas fa-user"></i></div>
          )}
          <p class="podium-name-lg">{president.name}</p>
          {president.position && <p class="podium-position-lg">{president.position}</p>}
        </div>
      )}

      <!-- ===== ২য়-৩য় সারি: মাঝারি সাইজ, পাশাপাশি ===== -->
      {secondThird.length > 0 && (
        <div class="podium-row">
          {secondThird.map((m) => (
            <div class="podium-item-md">
              {m.photo ? (
                <img src={m.photo} alt={m.name} class="podium-photo-md" />
              ) : (
                <div class="podium-photo-md-placeholder"><i class="fas fa-user"></i></div>
              )}
              <p class="podium-name-md">{m.name}</p>
              {m.position && <p class="podium-position-md">{m.position}</p>}
            </div>
          ))}
        </div>
      )}

      <!-- ===== বাকি সবাই: নরমাল লিস্ট ===== -->
      {restCommittee.length > 0 && (
        <div class="podium-rest-list">
          {restCommittee.map((m) => (
            <div class="podium-rest-item">
              {m.photo ? (
                <img src={m.photo} alt={m.name} class="podium-rest-photo" />
              ) : (
                <div class="podium-rest-photo-placeholder"><i class="fas fa-user"></i></div>
              )}
              <div>
                <p class="podium-rest-name">{m.name}</p>
                {m.position && <p class="podium-rest-position">{m.position}</p>}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
)}

<style>
  .section-card {
    background: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    margin-bottom: 20px;
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .section-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1B2A4A;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-card h3 i {
    color: #FF6B35;
  }

  .see-more-btn {
    background: #FFF0EA;
    color: #FF6B35;
    border: none;
    padding: 7px 14px;
    border-radius: 40px;
    font-size: 0.76rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
  }

  .committee-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .committee-item {
    text-align: center;
  }

  .committee-photo {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 16px;
    object-fit: cover;
    background: #F4F7FC;
  }

  .committee-photo-placeholder {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 16px;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
  }

  .committee-name {
    font-size: 0.8rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-top: 8px;
  }

  .committee-position {
    font-size: 0.72rem;
    color: #FF6B35;
    font-weight: 600;
  }

  /* ===== মোডাল ===== */
  .committee-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 300;
    align-items: flex-end;
    justify-content: center;
  }

  .committee-modal.open {
    display: flex;
  }

  .committee-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
  }

  .committee-modal-body {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 560px;
    max-height: 86vh;
    overflow-y: auto;
    border-radius: 24px 24px 0 0;
    padding: 26px 20px 34px;
  }

  .committee-modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: #F4F7FC;
    border: none;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #5A6E85;
    cursor: pointer;
    z-index: 2;
  }

  .committee-modal-body h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .committee-modal-body h3 i {
    color: #FF6B35;
  }

  /* ===== পোডিয়াম — সভাপতি ===== */
  .podium-president {
    text-align: center;
    margin-bottom: 20px;
  }

  .podium-photo-lg {
    width: 108px;
    height: 108px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid #FFF0EA;
    box-shadow: 0 6px 18px rgba(255, 107, 53, 0.18);
  }

  .podium-photo-lg-placeholder {
    width: 108px;
    height: 108px;
    border-radius: 50%;
    background: #FFF0EA;
    color: #FF6B35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.2rem;
    margin: 0 auto;
    border: 4px solid #FFF0EA;
  }

  .podium-name-lg {
    font-size: 1.02rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-top: 10px;
  }

  .podium-position-lg {
    font-size: 0.82rem;
    color: #FF6B35;
    font-weight: 700;
    margin-top: 2px;
  }

  /* ===== পোডিয়াম — ২য়/৩য় ===== */
  .podium-row {
    display: flex;
    justify-content: center;
    gap: 28px;
    margin-bottom: 24px;
  }

  .podium-item-md {
    text-align: center;
  }

  .podium-photo-md {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #F4F7FC;
  }

  .podium-photo-md-placeholder {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: #F4F7FC;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin: 0 auto;
  }

  .podium-name-md {
    font-size: 0.86rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-top: 8px;
  }

  .podium-position-md {
    font-size: 0.74rem;
    color: #FF6B35;
    font-weight: 600;
  }

  /* ===== বাকি সদস্য — নরমাল লিস্ট ===== */
  .podium-rest-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 1px solid #F0F3F8;
    padding-top: 18px;
  }

  .podium-rest-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .podium-rest-photo {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    background: #F4F7FC;
    flex-shrink: 0;
  }

  .podium-rest-photo-placeholder {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #F4F7FC;
    color: #8FA0BC;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .podium-rest-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: #1B2A4A;
  }

  .podium-rest-position {
    font-size: 0.74rem;
    color: #FF6B35;
    font-weight: 600;
  }

  @media (max-width: 400px) {
    .committee-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
  }
</style>

<script>
  const btn = document.getElementById('committeeSeeMoreBtn');
  const modal = document.getElementById('committeeModal');
  const backdrop = document.getElementById('committeeModalBackdrop');
  const closeBtn = document.getElementById('committeeModalClose');

  btn?.addEventListener('click', () => modal?.classList.add('open'));
  backdrop?.addEventListener('click', () => modal?.classList.remove('open'));
  closeBtn?.addEventListener('click', () => modal?.classList.remove('open'));
</script>