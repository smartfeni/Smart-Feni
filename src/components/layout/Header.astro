---
// ============================================================
// কম্পোনেন্ট: হেডার (ন্যাভবার)
// ব্র্যান্ড: স্মার্ট ফেনী
// লেআউট: লোকেশন (বাম) — লোগো+ট্যাগলাইন (মাঝে) — নেভ/মেনু (ডান)
// ============================================================

import LocationSelector from '../ui/LocationSelector.astro';
---

<nav class="navbar">
  <div class="container navbar-inner">
    <div class="navbar-left">
      <LocationSelector />
    </div>

    <a href="/" class="logo-center">
      <img src="/logo.png" alt="স্মার্ট ফেনী লোগো" class="logo-img" />
      <span class="logo-text">স্মার্ট <span>ফেনী</span></span>
      <span class="logo-tagline">Global Standards. Local Service.</span>
    </a>

    <div class="navbar-right">
      <div class="nav-links">
        <a href="/services">সেবাসমূহ</a>
        <a href="/about">আমাদের সম্পর্কে</a>
        <a href="/contact">যোগাযোগ</a>
        <a href="/login" class="nav-cta">
          <i class="fas fa-user-plus"></i> লগইন
        </a>
      </div>

      <button class="menu-toggle" id="menuToggle" aria-label="মেনু খুলুন">
        <i class="fas fa-bars"></i>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    <a href="/services">সেবাসমূহ</a>
    <a href="/about">আমাদের সম্পর্কে</a>
    <a href="/contact">যোগাযোগ</a>
    <a href="/login" class="mobile-cta">লগইন</a>
  </div>
</nav>

<style>
  .navbar {
    padding: 10px 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 999;
    border-bottom: 1px solid rgba(27, 42, 74, 0.06);
  }

  .navbar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    position: relative;
  }

  .navbar-left {
    flex: 1;
    display: flex;
    justify-content: flex-start;
  }

  .navbar-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .logo-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: #1B2A4A;
    flex-shrink: 0;
    line-height: 1.1;
  }

  .logo-img {
    height: 44px;
    width: auto;
    display: block;
    margin-bottom: 2px;
  }

  .logo-text {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .logo-text span {
    color: #FF6B35;
  }

  .logo-tagline {
    font-size: 0.68rem;
    font-weight: 500;
    color: #7A8EA5;
    letter-spacing: 0.3px;
    margin-top: 2px;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .nav-links a {
    text-decoration: none;
    color: #1B2A4A;
    font-weight: 500;
    font-size: 0.92rem;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: #FF6B35;
  }

  .nav-cta {
    background: #1B2A4A;
    color: #fff !important;
    padding: 9px 22px;
    border-radius: 40px;
    font-weight: 600 !important;
  }

  .nav-cta:hover {
    background: #FF6B35 !important;
    color: #fff !important;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.4rem;
    color: #1B2A4A;
    cursor: pointer;
    padding: 6px;
    margin-left: 8px;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 20px 24px;
    background: #fff;
    border-top: 1px solid #EEF3F9;
    gap: 16px;
  }

  .mobile-menu a {
    text-decoration: none;
    color: #1B2A4A;
    font-weight: 500;
    font-size: 1rem;
    padding: 8px 0;
  }

  .mobile-cta {
    background: #FF6B35;
    color: #fff !important;
    text-align: center;
    padding: 12px !important;
    border-radius: 40px;
    font-weight: 600 !important;
  }

  @media (max-width: 768px) {
    .logo-img {
      height: 32px;
    }

    .logo-text {
      font-size: 1.1rem;
    }

    .logo-tagline {
      font-size: 0.58rem;
    }

    .nav-links {
      display: none;
    }