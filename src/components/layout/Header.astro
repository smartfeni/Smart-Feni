---
// ============================================================
// কম্পোনেন্ট: হেডার (ন্যাভবার) — মিনিমাল
// ব্র্যান্ড: স্মার্ট ফেনী
// লেআউট: লোকেশন (বাম) — লোগো+ট্যাগলাইন (মাঝে) — প্রোফাইল (ডান)
// আপডেট: Supabase Auth সেশন কানেক্ট করা হয়েছে — পেজ লোড হলে
//         আগে থেকে লগইন থাকলে প্রোফাইল দেখাবে, লগইন করা থাকলে
//         প্রোফাইল বাটনে ক্লিক করলে লগআউট কনফার্ম করবে।
// ============================================================

import LocationSelector from '../ui/LocationSelector.astro';
import AuthModal from '../ui/AuthModal.astro';
---

<nav class="navbar">
  <div class="container navbar-inner">
    <div class="navbar-left">
      <LocationSelector />
    </div>

    <a href="/" class="logo-center">
      <img src="/logo.png" alt="স্মার্ট ফেনী লোগো" class="logo-img" />
      <span class="logo-tagline">Global Standards. Local Service.</span>
    </a>

    <div class="navbar-right">
      <button class="profile-btn" id="profileBtn" aria-label="প্রোফাইল">
        <span class="profile-avatar" id="profileAvatar">
          <img id="profileAvatarImg" src="" alt="প্রোফাইল ছবি" />
          <i class="fas fa-circle-user" id="profileDefaultIcon"></i>
        </span>
        <span class="profile-label" id="profileLabel">প্রোফাইল</span>
      </button>
    </div>
  </div>
</nav>

<AuthModal />

<style>
  .navbar {
    padding: 10px 0;
    background: rgba(255, 255, 255, 0.98);
    position: sticky;
    top: 0;
    z-index: 999;
    border-bottom: 1px solid rgba(27, 42, 74, 0.06);
  }

  .navbar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    position: relative;
  }

  .navbar-left {
    flex: 1;
    display: flex;
    justify-content: flex-start;
    min-width: 0;
  }

  .navbar-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .logo-center {
    --logo-h: 84px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    line-height: 1.15;
    padding: 2px 8px;
  }

  .logo-img {
    height: var(--logo-h);
    width: auto;
    display: block;
    margin-bottom: 3px;
  }

  .logo-tagline {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 0.7rem;
    font-weight: 600;
    font-style: italic;
    color: #1B2A4A;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  /* ===== প্রোফাইল আইকন (গোলাকার) ===== */
  .profile-btn {
    display: flex;
    align-items: center;
    gap: 9px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px 10px 4px 4px;
    border-radius: 40px;
    transition: background 0.2s ease;
  }

  .profile-btn:hover {
    background: #F4F7FC;
  }

  .profile-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #FFF0EA;
    border: 2px solid #FFE3D4;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    transition: border-color 0.2s ease;
  }

  .profile-btn:hover .profile-avatar {
    border-color: #FF6B35;
  }

  .profile-avatar #profileDefaultIcon {
    color: #FF6B35;
    font-size: 1.5rem;
    line-height: 1;
  }

  .profile-avatar img {
    display: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-avatar.has-photo #profileDefaultIcon {
    display: none;
  }

  .profile-avatar.has-photo img {
    display: block;
  }

  .profile-label {
    color: #1B2A4A;
    font-weight: 600;
    font-size: 0.88rem;
  }

  @media (max-width: 768px) {
    .logo-center {
      --logo-h: 60px;
    }

    .logo-tagline {
      font-size: 0.6rem;
    }

    .profile-btn {
      flex-direction: column;
      gap: 2px;
      padding: 4px 6px;
    }

    .profile-label {
      font-size: 0.62rem;
      font-weight: 600;
    }

    .profile-avatar {
      width: 34px;
      height: 34px;
    }

    .profile-avatar #profileDefaultIcon {
      font-size: 1.3rem;
    }
  }

  @media (max-width: 480px) {
    .logo-center {
      --logo-h: 50px;
    }

    .logo-tagline {
      font-size: 0.52rem;
    }

    .profile-avatar {
      width: 30px;
      height: 30px;
    }

    .profile-avatar #profileDefaultIcon {
      font-size: 1.15rem;
    }

    .profile-label {
      font-size: 0.56rem;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';

  const profileBtn = document.getElementById('profileBtn');
  const avatarWrap = document.getElementById('profileAvatar');
  const avatarImg = document.getElementById('profileAvatarImg');
  const label = document.getElementById('profileLabel');

  let isLoggedIn = false;

  function showLoggedInState(name, avatarUrl) {
    isLoggedIn = true;
    if (avatarUrl) {
      avatarImg.src = avatarUrl;
      avatarWrap?.classList.add('has-photo');
    }
    if (label) {
      label.textContent = name || 'প্রোফাইল';
    }
  }

  function showLoggedOutState() {
    isLoggedIn = false;
    avatarImg.src = '';
    avatarWrap?.classList.remove('has-photo');
    if (label) {
      label.textContent = 'প্রোফাইল';
    }
  }

  // পেজ লোড হলে আগে থেকে সেশন আছে কিনা চেক করা (রিফ্রেশেও লগইন থাকবে)
  async function restoreSession() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;

    const { data: profile } = await supabase
      .from('profiles')
      .select('full_name, avatar_url')
      .eq('id', session.user.id)
      .single();

    showLoggedInState(profile?.full_name, profile?.avatar_url);
  }

  restoreSession();

  // প্রোফাইল বাটন — লগইন করা না থাকলে মোডাল খুলবে, থাকলে লগআউট জিজ্ঞেস করবে
  profileBtn?.addEventListener('click', async () => {
    if (isLoggedIn) {
      const confirmLogout = confirm('আপনি কি লগআউট করতে চান?');
      if (confirmLogout) {
        await supabase.auth.signOut();
        showLoggedOutState();
      }
    } else {
      window.openAuthModal?.('login');
    }
  });

  // AuthModal থেকে সাইনআপ/লগইন সফল হলে এই ইভেন্ট আসবে
  window.addEventListener('smartfeni:auth-changed', (e) => {
    const { name, avatarUrl } = e.detail || {};
    showLoggedInState(name, avatarUrl);
  });
</script>