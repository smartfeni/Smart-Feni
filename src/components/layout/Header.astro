---
// আপনার আগের সব ইমপোর্ট এবং লজিক একদম অপরিবর্তিত থাকবে
// শুধু নিচের HTML ও CSS অংশ পরিবর্তন হবে
---

<header class="header">
  <div class="header-inner">
    <!-- ====== লোকেশন সিলেক্টর (আগের মতো অটো) ====== -->
    <div class="location-wrapper">
      <select id="locationSelect" class="location-select">
        <option value="ফেনী সদর">ফেনী সদর</option>
        <option value="ছাগলনাইয়া">ছাগলনাইয়া</option>
        <option value="পরশুরাম">পরশুরাম</option>
        <option value="ফুলগাজী">ফুলগাজী</option>
        <option value="দাগনভূইয়া">দাগনভূইয়া</option>
        <option value="সোনাগাজী">সোনাগাজী</option>
      </select>
    </div>

    <!-- ====== মাঝে: লোগো (শুধু সাইজ বড় করা) ====== -->
    <div class="logo-wrapper">
      <a href="/" class="logo-link">
        <img src="/images/logo.png" alt="স্মার্ট ফেনী" class="logo-img" />
      </a>
    </div>

    <!-- ====== ডান পাশ: আগের মতো থাকবে ====== -->
    <div class="header-right">
      <!-- আপনার আগের ন্যাভিগেশন/কন্টেন্ট -->
    </div>
  </div>
</header>

<style>
  /* ====== হেডার ====== */
  .header {
    background: #ffffff;
    padding: 12px 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  /* ====== লোকেশন (অফ-হোয়াইট বক্স বাদ) ====== */
  .location-wrapper {
    flex: 0 0 auto;
    min-width: 140px;
  }

  .location-select {
    padding: 8px 12px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: transparent; /* অফ-হোয়াইট বাদ */
    font-size: 0.95rem;
    color: #1f2937;
    cursor: pointer;
    outline: none;
    transition: all 0.2s;
    width: 100%;
  }

  .location-select:hover {
    border-color: #1e3a8a;
  }

  .location-select:focus {
    border-color: #1e3a8a;
    box-shadow: 0 0 0 3px rgba(30,58,138,0.1);
  }

  /* ====== লোগো (সাইজ বড়) ====== */
  .logo-wrapper {
    flex: 0 0 auto;
    display: flex;
    justify-content: center;
  }

  .logo-link {
    display: block;
    text-decoration: none;
  }

  .logo-img {
    height: 72px;          /* আগের চেয়ে বড় */
    width: auto;
    object-fit: contain;
    display: block;
  }

  /* ====== ডান পাশ ====== */
  .header-right {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* ====== মোবাইল রেস্পন্সিভ ====== */
  @media (max-width: 640px) {
    .header {
      padding: 10px 16px;
    }
    .header-inner {
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
    }
    .location-wrapper {
      min-width: 120px;
      order: 1;
      flex: 1 1 100%;
      text-align: center;
    }
    .logo-wrapper {
      order: 0;
      flex: 0 0 auto;
    }
    .logo-img {
      height: 52px;
    }
    .header-right {
      order: 2;
    }
    .location-select {
      font-size: 0.85rem;
      padding: 6px 10px;
    }
  }

  @media (max-width: 480px) {
    .logo-img {
      height: 40px;
    }
    .location-select {
      font-size: 0.8rem;
    }
  }
</style>