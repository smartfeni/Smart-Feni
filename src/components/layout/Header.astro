---
// ============================================================
// কম্পোনেন্ট: হেডার (ন্যাভবার)
// ব্র্যান্ড: স্মার্ট ফেনী
// লোগো: /logo.png
// ============================================================

import LocationSelector from '../ui/LocationSelector.astro';
---

<nav class="navbar">
  <div class="container">
    <a href="/" class="logo">
      <img src="/logo.png" alt="স্মার্ট ফেনী লোগো" class="logo-img" />
      <span class="logo-text">স্মার্ট <span>ফেনী</span></span>
    </a>

    <LocationSelector />

    <div class="nav-links">
      <a href="/services">সেবাসমূহ</a>
      <a href="/about">আমাদের সম্পর্কে</a>
      <a href="/contact">যোগাযোগ</a>
      <a href="/login" class="nav-cta">
        <i class="fas fa-user-plus"></i> লগইন
      </a>
    </div>

    <button class="menu-toggle" id="menuToggle" aria-label="মেনু খুলুন">
      <i class="fas fa-bars"></i>
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    <a href="/services">সেবাসমূহ</a>
    <a href="/about">আমাদের সম্পর্কে</a>
    <a href="/contact">যোগাযোগ</a>
    <a href="/login" class="mobile-cta">লগইন</a>
  </div>
</nav>

<style>
  .navbar {
    padding: 12px 0;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 999;
    border-bottom: 1px solid rgba(27, 42, 74, 0.06);
  }

  .navbar .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: #1B2A4A;
    flex-shrink: 0;
  }

  .logo-img {
    height: 40px;
    width: auto;
    display: block;
  }

  .logo-text {
    font-size: 1.4rem;
    font-weight: 700;
  }

  .logo-text span {
    color: #FF6B35;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    align-items: center;
    margin-left: auto;
  }

  .nav-links a {
    text-decoration: none;
    color: #1B2A4A;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: #FF6B35;
  }

  .nav-cta {
    background: #1B2A4A;
    color: #fff !important;
    padding: 10px 24px;
    border-radius: 40px;
    font-weight: 600 !important;
  }

  .nav-cta:hover {
    background: #FF6B35 !important;
    color: #fff !important;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.5rem;
    color: #1B2A4A;
    cursor: pointer;
    padding: 8px;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 20px 24px;
    background: #fff;
    border-top: 1px solid #EEF3F9;
    gap: 16px;
  }

  .mobile-menu a {
    text-decoration: none;
    color: #1B2A4A;
    font-weight: 500;
    font-size: 1rem;
    padding: 8px 0;
  }

  .mobile-cta {
    background: #FF6B35;
    color: #fff !important;
    text-align: center;
    padding: 12px !important;
    border-radius: 40px;
    font-weight: 600 !important;
  }

  @media (max-width: 768px) {
    .logo-img {
      height: 32px;
    }

    .logo-text {
      font-size: 1.1rem;
    }

    .nav-links {
      display: none;
    }

    .menu-toggle {
      display: block;
    }

    .mobile-menu.open {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .logo-text {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');

  toggle.addEventListener('click', () => {
    menu.classList.toggle('open');
  });
</script>