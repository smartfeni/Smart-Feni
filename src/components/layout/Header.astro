---
// আপনার ইমপোর্ট (যদি থাকে)
---

<header class="header">
  <div class="header-inner">
    <!-- ====== বাম পাশে: লোকেশন আইকন ====== -->
    <div class="header-left">
      <button class="location-trigger" id="locationTrigger">
        <span class="location-icon">📍</span>
        <span class="location-name" id="selectedLocation">ফেনী সদর</span>
        <span class="dropdown-arrow">▾</span>
      </button>
    </div>

    <!-- ====== মাঝে: বড় লোগো ====== -->
    <div class="header-center">
      <a href="/" class="logo-link">
        <img src="/images/logo.png" alt="স্মার্ট ফেনী" class="logo-img" />
      </a>
    </div>

    <!-- ====== ডান পাশে ফাঁকা (ন্যাভিগেশনের জন্য রাখলাম) ====== -->
    <div class="header-right">
      <!-- এখানে ন্যাভিগেশন মেনু আসবে (যদি থাকে) -->
    </div>
  </div>
</header>

<!-- ====== প্রফেশনাল লোকেশন পপআপ ====== -->
<div class="location-overlay" id="locationOverlay">
  <div class="location-popup">
    <button class="popup-close" id="closePopup">✕</button>
    <h3 class="popup-title">📍 আপনার অবস্থান নির্বাচন করুন</h3>
    <p class="popup-subtitle">আপনার এলাকার জন্য সেবা পেতে উপজেলা নির্বাচন করুন</p>
    
    <div class="popup-search">
      <input type="text" id="locationSearch" placeholder="উপজেলা খুঁজুন..." />
    </div>

    <div class="popup-list" id="locationList">
      <button class="location-option" data-location="ফেনী সদর">ফেনী সদর</button>
      <button class="location-option" data-location="ছাগলনাইয়া">ছাগলনাইয়া</button>
      <button class="location-option" data-location="পরশুরাম">পরশুরাম</button>
      <button class="location-option" data-location="ফুলগাজী">ফুলগাজী</button>
      <button class="location-option" data-location="দাগনভূইয়া">দাগনভূইয়া</button>
      <button class="location-option" data-location="সোনাগাজী">সোনাগাজী</button>
    </div>

    <button class="popup-confirm" id="confirmLocation">নির্বাচন করুন</button>
  </div>
</div>

<style>
  /* ====== হেডার স্টাইল ====== */
  .header {
    background: #ffffff;
    padding: 12px 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid #f3f4f6;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  /* ====== বাম: লোকেশন বাটন (কোনো বক্স নেই) ====== */
  .header-left {
    display: flex;
    justify-content: flex-start;
  }

  .location-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 6px 12px;
    font-size: 0.95rem;
    color: #1f2937;
    transition: all 0.2s;
  }

  .location-trigger:hover {
    color: #1e3a8a;
  }

  .location-icon {
    font-size: 1.2rem;
  }

  .location-name {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .dropdown-arrow {
    font-size: 0.7rem;
    color: #9ca3af;
    margin-left: 2px;
  }

  /* ====== মাঝে: বড় লোগো ====== */
  .header-center {
    display: flex;
    justify-content: center;
  }

  .logo-link {
    display: block;
    text-decoration: none;
  }

  .logo-img {
    height: 80px;          /* বড় সাইজ */
    width: auto;
    object-fit: contain;
    display: block;
  }

  /* ====== ডান পাশ ====== */
  .header-right {
    display: flex;
    justify-content: flex-end;
    gap: 16px;
  }

  /* ====== প্রফেশনাল পপআপ (স্ক্রিনের মাঝে) ====== */
  .location-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(6px);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    animation: fadeIn 0.3s ease;
  }

  .location-overlay.active {
    display: flex;
  }

  .location-popup {
    background: #ffffff;
    border-radius: 20px;
    padding: 32px 36px;
    max-width: 460px;
    width: 90%;
    box-shadow: 0 24px 80px rgba(0,0,0,0.25);
    position: relative;
    animation: slideUp 0.3s ease;
    max-height: 80vh;
    overflow-y: auto;
  }

  .popup-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: #f3f4f6;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-size: 1rem;
    cursor: pointer;
    color: #6b7280;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .popup-close:hover {
    background: #e5e7eb;
    color: #1f2937;
  }

  .popup-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 4px 0;
  }

  .popup-subtitle {
    font-size: 0.9rem;
    color: #6b7280;
    margin: 0 0 20px 0;
  }

  .popup-search input {
    width: 100%;
    padding: 10px 14px;
    border: 2px solid #e5e7eb;
    border-radius: 10px;
    font-size: 0.95rem;
    transition: border 0.2s;
    outline: none;
    margin-bottom: 16px;
  }

  .popup-search input:focus {
    border-color: #1e3a8a;
  }

  .popup-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 200px;
    overflow-y: auto;
    margin-bottom: 20px;
  }

  .location-option {
    padding: 10px 14px;
    background: #f9fafb;
    border: 1px solid #f3f4f6;
    border-radius: 8px;
    cursor: pointer;
    text-align: left;
    font-size: 0.95rem;
    color: #1f2937;
    transition: all 0.15s;
  }

  .location-option:hover {
    background: #eff6ff;
    border-color: #93c5fd;
    color: #1e3a8a;
  }

  .location-option.selected {
    background: #1e3a8a;
    color: white;
    border-color: #1e3a8a;
  }

  .popup-confirm {
    width: 100%;
    padding: 12px;
    background: #1e3a8a;
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .popup-confirm:hover {
    background: #1e40af;
  }

  /* ====== অ্যানিমেশন ====== */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(30px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ====== মোবাইল রেস্পন্সিভ ====== */
  @media (max-width: 640px) {
    .header {
      padding: 10px 16px;
    }
    .header-inner {
      grid-template-columns: auto 1fr auto;
      gap: 12px;
    }
    .logo-img {
      height: 56px;
    }
    .location-trigger {
      font-size: 0.8rem;
      padding: 4px 8px;
    }
    .location-name {
      font-size: 0.8rem;
    }
    .location-popup {
      padding: 24px 20px;
      max-width: 95%;
    }
  }

  @media (max-width: 480px) {
    .logo-img {
      height: 44px;
    }
    .location-icon {
      font-size: 1rem;
    }
    .location-name {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  // ====== জাভাস্ক্রিপ্ট - পপআপ কন্ট্রোল ======
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.getElementById('locationTrigger');
    const overlay = document.getElementById('locationOverlay');
    const closeBtn = document.getElementById('closePopup');
    const confirmBtn = document.getElementById('confirmLocation');
    const locationOptions = document.querySelectorAll('.location-option');
    const locationNameDisplay = document.getElementById('selectedLocation');
    const searchInput = document.getElementById('locationSearch');

    let selectedLocation = 'ফেনী সদর'; // ডিফল্ট

    // ====== পপআপ খোলা ======
    trigger.addEventListener('click', () => {
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      searchInput.value = '';
      filterLocations('');
    });

    // ====== পপআপ বন্ধ ======
    function closePopup() {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    closeBtn.addEventListener('click', closePopup);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closePopup();
    });

    // ====== লোকেশন সিলেক্ট ======
    locationOptions.forEach(option => {
      option.addEventListener('click', () => {
        locationOptions.forEach(opt => opt.classList.remove('selected'));
        option.classList.add('selected');
        selectedLocation = option.dataset.location;
        locationNameDisplay.textContent = selectedLocation;
      });
    });

    // ====== কনফার্ম বাটন ======
    confirmBtn.addEventListener('click', () => {
      const selected = document.querySelector('.location-option.selected');
      if (selected) {
        selectedLocation = selected.dataset.location;
        locationNameDisplay.textContent = selectedLocation;
        closePopup();
      } else {
        alert('দয়া করে একটি উপজেলা নির্বাচন করুন।');
      }
    });

    // ====== সার্চ ফিল্টার ======
    searchInput.addEventListener('input', (e) => {
      filterLocations(e.target.value);
    });

    function filterLocations(query) {
      const lowerQuery = query.toLowerCase();
      locationOptions.forEach(opt => {
        const text = opt.textContent.toLowerCase();
        opt.style.display = text.includes(lowerQuery) ? 'block' : 'none';
      });
    }

    // ====== এন্টার কী ======
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        const visible = document.querySelector('.location-option[style*="display: block"]');
        if (visible) {
          visible.click();
          confirmBtn.click();
        }
      }
    });
  });
</script>