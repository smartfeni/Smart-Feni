---
// ============================================================
// কম্পোনেন্ট: হেডার (ন্যাভবার)
// ব্র্যান্ড: স্মার্ট ফেনী
// লেআউট: লোকেশন (বাম) — লোগো+ট্যাগলাইন (মাঝে) — নেভ/মেনু (ডান)
// ফিক্স: backdrop-filter ancestor-এ থাকার কারণে LocationSelector-এর
//        fixed dropdown viewport-এর বদলে navbar-এর ভেতরে আটকে
//        hero সেকশনে ঢুকে যাচ্ছিল — backdrop-filter সরিয়ে সমাধান
// ============================================================

import LocationSelector from '../ui/LocationSelector.astro';
---

<nav class="navbar">
  <div class="container navbar-inner">
    <div class="navbar-left">
      <LocationSelector />
    </div>

    <a href="/" class="logo-center">
      <img src="/logo.png" alt="স্মার্ট ফেনী লোগো" class="logo-img" />
      <span class="logo-tagline">Global Standards. Local Service.</span>
    </a>

    <div class="navbar-right">
      <div class="nav-links">
        <a href="/services">সেবাসমূহ</a>
        <a href="/about">আমাদের সম্পর্কে</a>
        <a href="/contact">যোগাযোগ</a>
        <a href="/login" class="nav-cta">
          <i class="fas fa-user-plus"></i> লগইন
        </a>
      </div>

      <button class="menu-toggle" id="menuToggle" aria-label="মেনু খুলুন">
        <i class="fas fa-bars"></i>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    <a href="/services">সেবাসমূহ</a>
    <a href="/about">আমাদের সম্পর্কে</a>
    <a href="/contact">যোগাযোগ</a>
    <a href="/login" class="mobile-cta">লগইন</a>
  </div>
</nav>

<style>
  .navbar {
    padding: 10px 0;
    background: rgba(255, 255, 255, 0.98);
    position: sticky;
    top: 0;
    z-index: 999;
    border-bottom: 1px solid rgba(27, 42, 74, 0.06);
    /* backdrop-filter: blur(12px); এই লাইনটা সরিয়ে দেওয়া হয়েছে —
       এটাই LocationSelector-এর fixed dropdown ভাঙার কারণ ছিল।
       background প্রায় opaque (0.98) থাকায় visual difference নেই। */
  }

  .navbar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    position: relative;
  }

  .navbar-left {
    flex: 1;
    display: flex;
    justify-content: flex-start;
    min-width: 0;
  }

  .navbar-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  /* ===== লোগো — বড়, prominent, নিচে ট্যাগলাইন ===== */
  .logo-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    line-height: 1.15;
    padding: 2px 8px;
  }

  .logo-img {
    height: 62px;
    width: auto;
    display: block;
    margin-bottom: 3px;
  }

  .logo-tagline {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 0.7rem;
    font-weight: 600;
    font-style: italic;
    color: #1B2A4A;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .nav-links a {
    text-decoration: none;
    color: #1B2A4A;
    font-weight: 500;
    font-size: 0.92rem;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: #FF6B35;
  }

  .nav-cta {
    background: #1B2A4A;
    color: #fff !important;
    padding: 9px 22px;
    border-radius: 40px;
    font-weight: 600 !important;
  }

  .nav-cta:hover {
    background: #FF6B35 !important;
    color: #fff !important;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.4rem;
    color: #1B2A4A;
    cursor: pointer;
    padding: 6px;
    margin-left: 8px;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 20px 24px;
    background: #fff;
    border-top: 1px solid #EEF3F9;
    gap: 16px;
  }

  .mobile-menu a {
    text-decoration: none;
    color: #1B2A4A;
    font-weight: 500;
    font-size: 1rem;
    padding: 8px 0;
  }

  .mobile-cta {
    background: #FF6B35;
    color: #fff !important;
    text-align: center;
    padding: 12px !important;
    border-radius: 40px;
    font-weight: 600 !important;
  }

  @media (max-width: 768px) {
    .logo-img {
      height: 44px;
    }

    .logo-tagline {
      font-size: 0.6rem;
    }

    .nav-links {
      display: none;
    }

    .menu-toggle {
      display: block;
    }

    .mobile-menu.open {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .logo-img {
      height: 38px;
    }

    .logo-tagline {
      font-size: 0.52rem;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');

  toggle.addEventListener('click', () => {
    menu.classList.toggle('open');
  });
</script>