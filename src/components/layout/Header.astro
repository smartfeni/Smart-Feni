---
// ============================================================
// কম্পোনেন্ট: হেডার (ন্যাভবার)
// ব্র্যান্ড: স্মার্ট ফেনী
// লেআউট: লোকেশন (বাম) — লোগো+ট্যাগলাইন (মাঝে) — নেভ/প্রোফাইল/মেনু (ডান)
// ফিক্স: backdrop-filter সরানো (LocationSelector fixed dropdown ভাঙছিল)
//        লোগো সাইজ বড় করা হলো, --logo-h ভ্যারিয়েবল দিয়ে সহজে adjust করা যায়
// নতুন: ডান পাশে গোলাকার প্রোফাইল আইকন — ক্লিক করলে লগইন/সাইনআপ মোডাল
//       খোলে (AuthModal.astro)। এখনো শুধু UI, ব্যাকএন্ড যুক্ত হয়নি।
// ============================================================

import LocationSelector from '../ui/LocationSelector.astro';
import AuthModal from '../ui/AuthModal.astro';
---

<nav class="navbar">
  <div class="container navbar-inner">
    <div class="navbar-left">
      <LocationSelector />
    </div>

    <a href="/" class="logo-center">
      <img src="/logo.png" alt="স্মার্ট ফেনী লোগো" class="logo-img" />
      <span class="logo-tagline">Global Standards. Local Service.</span>
    </a>

    <div class="navbar-right">
      <div class="nav-links">
        <a href="/services">সেবাসমূহ</a>
        <a href="/about">আমাদের সম্পর্কে</a>
        <a href="/contact">যোগাযোগ</a>
      </div>

      <button class="profile-btn" id="profileBtn" aria-label="প্রোফাইল">
        <span class="profile-avatar" id="profileAvatar">
          <img id="profileAvatarImg" src="" alt="প্রোফাইল ছবি" />
          <i class="fas fa-user" id="profileDefaultIcon"></i>
        </span>
        <span class="profile-label">প্রোফাইল</span>
      </button>

      <button class="menu-toggle" id="menuToggle" aria-label="মেনু খুলুন">
        <i class="fas fa-bars"></i>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    <a href="/services">সেবাসমূহ</a>
    <a href="/about">আমাদের সম্পর্কে</a>
    <a href="/contact">যোগাযোগ</a>
    <button class="mobile-cta" id="mobileProfileBtn" type="button">
      <i class="fas fa-user"></i> প্রোফাইল / লগইন
    </button>
  </div>
</nav>

<AuthModal />

<style>
  .navbar {
    padding: 10px 0;
    background: rgba(255, 255, 255, 0.98);
    position: sticky;
    top: 0;
    z-index: 999;
    border-bottom: 1px solid rgba(27, 42, 74, 0.06);
  }

  .navbar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    position: relative;
  }

  .navbar-left {
    flex: 1;
    display: flex;
    justify-content: flex-start;
    min-width: 0;
  }

  .navbar-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 6px;
  }

  .logo-center {
    --logo-h: 84px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    line-height: 1.15;
    padding: 2px 8px;
  }

  .logo-img {
    height: var(--logo-h);
    width: auto;
    display: block;
    margin-bottom: 3px;
  }

  .logo-tagline {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 0.7rem;
    font-weight: 600;
    font-style: italic;
    color: #1B2A4A;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
    margin-right: 8px;
  }

  .nav-links a {
    text-decoration: none;
    color: #1B2A4A;
    font-weight: 500;
    font-size: 0.92rem;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: #FF6B35;
  }

  /* ===== প্রোফাইল আইকন (গোলাকার) ===== */
  .profile-btn {
    display: flex;
    align-items: center;
    gap: 9px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px 10px 4px 4px;
    border-radius: 40px;
    transition: background 0.2s ease;
  }

  .profile-btn:hover {
    background: #F4F7FC;
  }

  .profile-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #EFF3F9;
    border: 2px solid #E5EAF0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    transition: border-color 0.2s ease;
  }

  .profile-btn:hover .profile-avatar {
    border-color: #FF6B35;
  }

  .profile-avatar #profileDefaultIcon {
    color: #8FA0BC;
    font-size: 1rem;
  }

  .profile-avatar img {
    display: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-avatar.has-photo #profileDefaultIcon {
    display: none;
  }

  .profile-avatar.has-photo img {
    display: block;
  }

  .profile-label {
    color: #1B2A4A;
    font-weight: 600;
    font-size: 0.88rem;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.4rem;
    color: #1B2A4A;
    cursor: pointer;
    padding: 6px;
    margin-left: 8px;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 20px 24px;
    background: #fff;
    border-top: 1px solid #EEF3F9;
    gap: 16px;
  }

  .mobile-menu a {
    text-decoration: none;
    color: #1B2A4A;
    font-weight: 500;
    font-size: 1rem;
    padding: 8px 0;
  }

  .mobile-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #FF6B35;
    color: #fff !important;
    text-align: center;
    padding: 12px !important;
    border-radius: 40px;
    border: none;
    font-weight: 600 !important;
    font-size: 1rem;
    cursor: pointer;
    width: 100%;
  }

  @media (max-width: 768px) {
    .logo-center {
      --logo-h: 60px;
    }

    .logo-tagline {
      font-size: 0.6rem;
    }

    .nav-links {
      display: none;
    }

    .profile-label {
      display: none;
    }

    .profile-btn {
      padding: 4px;
    }

    .menu-toggle {
      display: block;
    }

    .mobile-menu.open {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .logo-center {
      --logo-h: 50px;
    }

    .logo-tagline {
      font-size: 0.52rem;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('open');
  });

  // প্রোফাইল আইকনে ক্লিক করলে অথ মোডাল খোলা (AuthModal.astro-তে window.openAuthModal ডিফাইন করা আছে)
  const profileBtn = document.getElementById('profileBtn');
  const mobileProfileBtn = document.getElementById('mobileProfileBtn');

  profileBtn?.addEventListener('click', () => {
    window.openAuthModal?.('login');
  });

  mobileProfileBtn?.addEventListener('click', () => {
    menu?.classList.remove('open');
    window.openAuthModal?.('login');
  });

  // ডেমো লগইন/সাইনআপ ইভেন্ট শুনে হেডারের প্রোফাইল সার্কেল আপডেট করা (UI only)
  const desktopAvatarWrap = document.getElementById('profileAvatar');
  const desktopAvatarImg = document.getElementById('profileAvatarImg');
  const desktopLabel = document.querySelector('.profile-label');

  window.addEventListener('smartfeni:auth-demo-login', (e) => {
    const { name, photo } = e.detail || {};
    if (photo) {
      desktopAvatarImg.src = photo;
      desktopAvatarWrap?.classList.add('has-photo');
    }
    if (desktopLabel && name) {
      desktopLabel.textContent = name;
    }
  });
</script>