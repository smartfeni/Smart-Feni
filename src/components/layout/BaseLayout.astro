---
// src/components/ChatWidget.astro
// Rule-based FAQ chat widget for Smart Feni
---

<div id="sf-chat-root">
  <button id="sf-chat-toggle" aria-label="সাহায্য চ্যাট খুলুন">
    <svg id="sf-icon-chat" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <svg id="sf-icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <div id="sf-chat-panel" hidden>
    <header id="sf-chat-header">
      <span>স্মার্ট ফেনী সহায়ক</span>
    </header>

    <div id="sf-chat-messages"></div>

    <div id="sf-chat-quick"></div>

    <form id="sf-chat-form">
      <input
        id="sf-chat-input"
        type="text"
        placeholder="প্রশ্ন লিখুন..."
        autocomplete="off"
      />
      <button type="submit" aria-label="পাঠান">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<style>
  #sf-chat-root {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
    font-family: 'Inter', system-ui, -apple-system, "Noto Sans Bengali", sans-serif;
  }

  #sf-chat-toggle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FF6B35;
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.35);
  }
  #sf-chat-toggle svg { width: 26px; height: 26px; }
  #sf-chat-toggle:active { transform: scale(0.95); }

  #sf-chat-panel {
    position: fixed;
    bottom: 88px;
    right: 20px;
    width: min(340px, calc(100vw - 32px));
    height: min(480px, calc(100vh - 140px));
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.25);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  #sf-chat-header {
    background: #1B2A4A;
    color: #fff;
    padding: 14px 16px;
    font-weight: 600;
    font-size: 15px;
  }

  #sf-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: #F8FAFC;
  }

  .sf-msg {
    max-width: 82%;
    padding: 9px 12px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.45;
    white-space: pre-line;
  }
  .sf-msg-bot {
    background: #fff;
    border: 1px solid #e5e5e0;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .sf-msg-user {
    background: #FF6B35;
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  .sf-msg-user a { color: #fff; }
  .sf-msg-bot a { color: #FF6B35; font-weight: 600; }

  #sf-chat-quick {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 8px 12px;
    border-top: 1px solid #eee;
  }
  .sf-quick-btn {
    font-size: 12.5px;
    background: #FFF0EA;
    color: #FF6B35;
    border: 1px solid #FFD9C4;
    border-radius: 999px;
    padding: 6px 11px;
    cursor: pointer;
  }
  .sf-quick-btn:active { background: #FFE0CC; }

  #sf-chat-form {
    display: flex;
    gap: 8px;
    padding: 10px;
    border-top: 1px solid #eee;
  }
  #sf-chat-input {
    flex: 1;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 14px;
    outline: none;
  }
  #sf-chat-input:focus { border-color: #FF6B35; }
  #sf-chat-form button[type="submit"] {
    width: 40px;
    background: #FF6B35;
    color: #fff;
    border: none;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  #sf-chat-form button[type="submit"] svg { width: 18px; height: 18px; }

  @media (max-width: 400px) {
    #sf-chat-panel { right: 16px; bottom: 84px; }
    #sf-chat-root { right: 16px; bottom: 16px; }
  }
</style>

<script>
  type Rule = { keywords: string[]; reply: string };

  const RULES: Rule[] = [
    {
      keywords: ["ফার্মেসি", "ওষুধ", "medicine", "pharmacy"],
      reply: "ফার্মেসি ডেলিভারির জন্য ওষুধের নাম/ছবি হোয়াটসঅ্যাপ বা ইমো তে পাঠান। আমরা ফেনী সদরের যেকোনো ফার্মেসি থেকে সংগ্রহ করে পৌঁছে দিই।",
    },
    {
      keywords: ["গ্রোসারি", "বাজার", "grocery", "মুদি"],
      reply: "দৈনন্দিন বাজার/মুদি সামগ্রীর তালিকা পাঠালে আমরা কালেক্ট করে বাসায় পৌঁছে দিই। হোয়াটসঅ্যাপে লিস্ট পাঠাতে পারেন।",
    },
    {
      keywords: ["রক্ত", "blood", "ব্লাড"],
      reply: "রক্তদাতা খুঁজতে বা রক্তদানে আগ্রহী হলে আমাদের ব্লাড ডোনেশন সেকশনে গিয়ে গ্রুপ ও এলাকা উল্লেখ করুন।",
    },
    {
      keywords: ["বাসা ভাড়া", "house rent", "ভাড়া", "flat"],
      reply: "বাসা/ফ্ল্যাট ভাড়ার বিজ্ঞাপন দেখতে বা দিতে House Rent সেকশন ব্যবহার করুন।",
    },
    {
      keywords: ["চাকরি", "job", "jobs"],
      reply: "স্থানীয় চাকরির খবর পেতে বা পোস্ট করতে Jobs সেকশনে যান।",
    },
    {
      keywords: ["হোম সার্ভিস", "মিস্ত্রি", "ইলেকট্রিশিয়ান", "প্লাম্বার", "home service"],
      reply: "ইলেকট্রিশিয়ান, প্লাম্বার, মিস্ত্রি ইত্যাদি হোম সার্ভিসের জন্য Home Services সেকশনে অনুরোধ পাঠান।",
    },
    {
      keywords: ["ইভেন্ট", "event", "অনুষ্ঠান"],
      reply: "ফেনীর স্থানীয় ইভেন্ট দেখতে বা নিজের ইভেন্ট পোস্ট করতে Events সেকশনে যান।",
    },
    {
      keywords: ["মার্কেটপ্লেস", "কেনাবেচা", "marketplace", "বিক্রি"],
      reply: "কেনাবেচার জন্য Marketplace সেকশনে পণ্যের ছবি ও দাম দিয়ে পোস্ট করতে পারেন।",
    },
    {
      keywords: ["ডেলিভারি চার্জ", "চার্জ কত", "delivery charge", "খরচ"],
      reply: "ডেলিভারি চার্জ এলাকা ও দূরত্বের উপর নির্ভর করে। সঠিক চার্জ জানতে আপনার এলাকার নাম উল্লেখ করে হোয়াটসঅ্যাপে জিজ্ঞাসা করুন।",
    },
    {
      keywords: ["এলাকা", "কভার", "সার্ভিস এরিয়া", "service area", "কোথায়"],
      reply: "আমরা বর্তমানে ফেনী সদর এলাকায় সেবা দিচ্ছি। ধীরে ধীরে অন্যান্য এলাকায় সম্প্রসারিত হবে।",
    },
    {
      keywords: ["অর্ডার", "কিভাবে", "কীভাবে", "order", "কল"],
      reply: "অর্ডার করতে হোয়াটসঅ্যাপ বা ইমো তে মেসেজ পাঠান — কী লাগবে লিখুন, আমরা কনফার্ম করে ডেলিভারি দেব।",
    },
    {
      keywords: ["যোগাযোগ", "নাম্বার", "ফোন", "contact", "number"],
      reply: "যোগাযোগের জন্য ওয়েবসাইটের Contact সেকশন দেখুন অথবা হোয়াটসঅ্যাপ বাটনে ক্লিক করুন।",
    },
  ];

  const FALLBACK =
    "দুঃখিত, এই প্রশ্নের সঠিক উত্তর আমার কাছে নেই। অনুগ্রহ করে হোয়াটসঅ্যাপে সরাসরি জিজ্ঞাসা করুন, আমাদের টিম সাহায্য করবে।";

  const QUICK_REPLIES = [
    "ফার্মেসি অর্ডার কিভাবে করব?",
    "ডেলিভারি চার্জ কত?",
    "কোন এলাকায় সার্ভিস আছে?",
    "যোগাযোগ নাম্বার কী?",
  ];

  function findReply(text: string): string {
    const lower = text.toLowerCase().trim();
    for (const rule of RULES) {
      if (rule.keywords.some((k) => lower.includes(k.toLowerCase()))) {
        return rule.reply;
      }
    }
    return FALLBACK;
  }

  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.getElementById("sf-chat-toggle")!;
    const panel = document.getElementById("sf-chat-panel")!;
    const iconChat = document.getElementById("sf-icon-chat")!;
    const iconClose = document.getElementById("sf-icon-close")!;
    const messages = document.getElementById("sf-chat-messages")!;
    const form = document.getElementById("sf-chat-form") as HTMLFormElement;
    const input = document.getElementById("sf-chat-input") as HTMLInputElement;
    const quickWrap = document.getElementById("sf-chat-quick")!;

    let opened = false;

    function addMessage(text: string, sender: "bot" | "user") {
      const div = document.createElement("div");
      div.className = `sf-msg sf-msg-${sender}`;
      div.textContent = text;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function handleUserText(text: string) {
      if (!text.trim()) return;
      addMessage(text, "user");
      const reply = findReply(text);
      setTimeout(() => addMessage(reply, "bot"), 300);
    }

    QUICK_REPLIES.forEach((q) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "sf-quick-btn";
      btn.textContent = q;
      btn.addEventListener("click", () => handleUserText(q));
      quickWrap.appendChild(btn);
    });

    toggle.addEventListener("click", () => {
      opened = !opened;
      panel.hidden = !opened;
      iconChat.style.display = opened ? "none" : "block";
      iconClose.style.display = opened ? "block" : "none";
      if (opened && messages.children.length === 0) {
        addMessage(
          "আসসালামু আলাইকুম! আমি স্মার্ট ফেনী সহায়ক। নিচের বাটন থেকে বেছে নিন অথবা প্রশ্ন লিখুন।",
          "bot"
        );
      }
    });

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const text = input.value;
      input.value = "";
      handleUserText(text);
    });
  });
</script>