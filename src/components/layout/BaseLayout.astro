---
// ============================================================
// কম্পোনেন্ট: বেস লেআউট
// ফাংশন: সব পেজের মাস্টার টেমপ্লেট
// আপডেট: PWA manifest, theme-color, iOS আইকন যোগ করা হয়েছে
//         + beforeinstallprompt ইভেন্ট গ্লোবালি ক্যাচ করে রাখা হয়েছে
//         যাতে Footer.astro-র ইনস্টল বাটন থেকে ব্যবহার করা যায়
//         + Google Analytics (GA4) বেস ট্র্যাকিং স্ক্রিপ্ট যোগ করা হয়েছে
//         + গ্লোবাল কল বাটন (tel:) ক্লিক ট্র্যাকিং যোগ করা হয়েছে —
//           সব পেজে অটোমেটিক কাজ করে, প্রতি পেজে আলাদা কোড লাগে না
//         + বাগফিক্স: analytics.js ইমপোর্ট পাথ ঠিক করা হয়েছে
//           (আগে '/src/lib/analytics.js' ছিল যেটা প্রোডাকশনে কাজ
//           করত না, এখন রিলেটিভ পাথ '../../lib/analytics.js')
//         + Rule-based FAQ চ্যাট উইজেট (ChatWidget.astro) যোগ করা হয়েছে
//         + বাগফিক্স: ChatWidget import পাথ ঠিক করা হয়েছে
//           (আগে '../components/ChatWidget.astro' ছিল যেটা ভুল ছিল,
//           কারণ এই ফাইলটা নিজেই components/layout/ ফোল্ডারে আছে —
//           এখন সঠিক পাথ '../ChatWidget.astro')
//         + SEO আপডেট: keywords, ogImage, canonicalPath props যোগ করা
//           হয়েছে + Open Graph + Twitter Card + JSON-LD LocalBusiness
//           schema যোগ করা হয়েছে। description-এ "সার্ভিস ডিরেক্টরি"
//           শব্দ রাখা হয়েছে যাতে Google আমাদের e-commerce শপ (Smart
//           Feni BD নামে আলাদা সাইট আছে) থেকে আলাদা বুঝতে পারে।
// বাগফিক্স: ফাইলটা </main> এর আগে কাটা/অসম্পূর্ণ হয়ে গিয়েছিল (আগের
//           একটা এক্সপোর্ট/সেভে) — Footer, ChatWidget, closing tags,
//           beforeinstallprompt ও কল-ট্র্যাকিং script অনুপস্থিত ছিল,
//           যার কারণে পুরো সাইট বিল্ড ফেইল করছিল। এখন পুরনো working
//           ভার্সনের <body> অংশের সাথে নতুন SEO <head> মার্জ করে
//           সম্পূর্ণ করা হলো।
// আপডেট: Font Awesome CDN ভার্সন 6.0.0-beta3 → 6.5.2 (স্টেবল)।
//         বিটা ভার্সনে অনেক নতুন আইকন (যেমন fa-people-group) ছিল না,
//         ক্লাব মডিউলের কিছু আইকন তাই দেখা যাচ্ছিল না।
// ============================================================

import Header from './Header.astro';
import Footer from './Footer.astro';
import ChatWidget from '../ChatWidget.astro';

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonicalPath?: string;
}

const {
  title,
  description = 'স্মার্ট ফেনী - ফেনী জেলার প্রথম ডিজিটাল কমিউনিটি সার্ভিস ডিরেক্টরি। বাসা ভাড়া, টিউশন, রক্তদাতা, হোম ফুড, রিপেয়ার সহ ১৮+ ধরনের লোকাল সেবা এক জায়গায়।',
  keywords = 'স্মার্ট ফেনী, Smart Feni, ফেনী সার্ভিস ডিরেক্টরি, ফেনী কমিউনিটি প্ল্যাটফর্ম, ফেনী লোকাল সেবা',
  ogImage = '/logo.png',
  canonicalPath,
} = Astro.props;

const GA_MEASUREMENT_ID = 'G-RWTRLNTCD6';

// সাইট বেস URL (astro.config.mjs এর site থেকে আসে)
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://smartfeni.com';
const canonicalUrl = canonicalPath
  ? `${siteUrl}${canonicalPath.startsWith('/') ? canonicalPath : `/${canonicalPath}`}`
  : `${siteUrl}${Astro.url.pathname}`;
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// JSON-LD LocalBusiness schema — ফেনী জেলা কনটেক্সট সহ
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'স্মার্ট ফেনী (Smart Feni)',
  alternateName: 'Smart Feni Service Directory',
  description: 'ফেনী জেলার মাল্টি-ক্যাটাগরি হাইপারলোকাল কমিউনিটি সার্ভিস প্ল্যাটফর্ম',
  url: siteUrl,
  logo: `${siteUrl}/logo.png`,
  image: absoluteOgImage,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'ফেনী',
    addressRegion: 'চট্টগ্রাম বিভাগ',
    addressCountry: 'BD',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'ফেনী জেলা',
  },
};
---

<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- ===== Open Graph (Facebook/WhatsApp শেয়ার প্রিভিউ) ===== -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absoluteOgImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="স্মার্ট ফেনী" />
  <meta property="og:locale" content="bn_BD" />

  <!-- ===== Twitter Card ===== -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absoluteOgImage} />

  <!-- ===== JSON-LD স্ট্রাকচার্ড ডেটা ===== -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- ===== Google Analytics (GA4) ===== -->
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
  <script define:vars={{ GA_MEASUREMENT_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', GA_MEASUREMENT_ID);
    window.gtag = gtag;
  </script>

  <!-- ===== PWA ===== -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#FF6B35" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="SmartFeni" />

  <!-- ফন্ট ও আইকন -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  
  <style is:global>
    /* ===== গ্লোবাল স্টাইল ===== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #F8FAFC;
      color: #1B2A4A;
      line-height: 1.6;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ===== কামন বাটন ===== */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #FF6B35;
      color: #fff;
      padding: 14px 32px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.25s ease;
      box-shadow: 0 8px 24px rgba(255, 107, 53, 0.25);
    }

    .btn-primary:hover {
      background: #e85a2a;
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(255, 107, 53, 0.35);
    }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: transparent;
      color: #1B2A4A;
      padding: 14px 32px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      border: 2px solid #1B2A4A;
      transition: all 0.25s ease;
      cursor: pointer;
    }

    .btn-outline:hover {
      background: #1B2A4A;
      color: #fff;
    }

    /* ===== সেকশন হেডার ===== */
    .section-header {
      text-align: center;
      margin-bottom: 48px;
    }

    .section-tag {
      display: inline-block;
      font-size: 0.85rem;
      font-weight: 600;
      color: #FF6B35;
      background: #FFF0EA;
      padding: 4px 16px;
      border-radius: 40px;
      margin-bottom: 12px;
    }

    .section-header h2 {
      font-size: 2.4rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .section-header h2 .accent {
      color: #FF6B35;
    }

    .section-header p {
      color: #5A6E85;
      font-size: 1.1rem;
      margin-top: 8px;
    }

    /* ===== রেসপন্সিভ ===== */
    @media (max-width: 768px) {
      .section-header h2 {
        font-size: 1.8rem;
      }
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <slot /> <!-- পেজের কন্টেন্ট এখানে বসবে -->
  </main>
  <Footer />
  <ChatWidget />

  <script>
    // ============================================================
    // beforeinstallprompt ইভেন্ট গ্লোবালি ক্যাচ করে window-এ রাখা হচ্ছে,
    // যাতে পেজের যেকোনো জায়গা (Footer-এর ইনস্টল বাটন) থেকে এটা
    // ট্রিগার করা যায়। এই ইভেন্ট শুধু Android/Chrome-এ আসে।
    // ============================================================
    window.deferredInstallPrompt = null;

    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      window.deferredInstallPrompt = e;
      window.dispatchEvent(new CustomEvent('smartfeni:install-available'));
    });

    window.addEventListener('appinstalled', () => {
      window.deferredInstallPrompt = null;
      window.dispatchEvent(new CustomEvent('smartfeni:install-done'));
    });
  </script>

  <script>
    // ============================================================
    // গ্লোবাল কল বাটন (tel:) ক্লিক ট্র্যাকিং
    // সাইটের যেকোনো পেজের যেকোনো <a href="tel:..."> লিংকে ক্লিক হলেই
    // অটোমেটিক ধরা পড়ে, প্রতিটা পেজে আলাদা কোড বসানোর দরকার নেই।
    // ক্যাটাগরি বের করা হয় URL path থেকে (/services/home-food → home-food)।
    // item-লেভেল ডিটেইল (যেমন কোন শপ) দরকার হলে বাটনে data-shop-name
    // অ্যাট্রিবিউট বসালে সেটাও অটোমেটিক পাঠানো হবে।
    // ============================================================
    import { trackEvent } from '../../lib/analytics.js';

    document.addEventListener('click', (e) => {
      const link = e.target.closest('a[href^="tel:"]');
      if (!link) return;

      // URL থেকে ক্যাটাগরি বের করা: /services/home-food → home-food
      const pathParts = window.location.pathname.split('/').filter(Boolean);
      const category = pathParts[pathParts.length - 1] || 'home';

      const shopName = link.getAttribute('data-shop-name') || null;
      const upazila = localStorage.getItem('smartfeni_upazila');

      trackEvent('call_button_click', {
        category,
        upazila: upazila || null,
        ...(shopName ? { shop_name: shopName } : {}),
      });
    });
  </script>
</body>
</html>