---
// ============================================================
// কম্পোনেন্ট: বেস লেআউট
// ফাংশন: সব পেজের মাস্টার টেমপ্লেট
// আপডেট: PWA manifest, theme-color, iOS আইকন যোগ করা হয়েছে
//         + beforeinstallprompt ইভেন্ট গ্লোবালি ক্যাচ করে রাখা হয়েছে
//         যাতে Footer.astro-র ইনস্টল বাটন থেকে ব্যবহার করা যায়
// ============================================================

import Header from './Header.astro';
import Footer from './Footer.astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'স্মার্ট ফেনী - ফেনী জেলার প্রথম ডিজিটাল কমিউনিটি প্ল্যাটফর্ম' } = Astro.props;
---

<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- ===== PWA ===== -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#FF6B35" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="SmartFeni" />

  <!-- ফন্ট ও আইকন -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  
  <style is:global>
    /* ===== গ্লোবাল স্টাইল ===== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #F8FAFC;
      color: #1B2A4A;
      line-height: 1.6;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ===== কামন বাটন ===== */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #FF6B35;
      color: #fff;
      padding: 14px 32px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.25s ease;
      box-shadow: 0 8px 24px rgba(255, 107, 53, 0.25);
    }

    .btn-primary:hover {
      background: #e85a2a;
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(255, 107, 53, 0.35);
    }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: transparent;
      color: #1B2A4A;
      padding: 14px 32px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      border: 2px solid #1B2A4A;
      transition: all 0.25s ease;
      cursor: pointer;
    }

    .btn-outline:hover {
      background: #1B2A4A;
      color: #fff;
    }

    /* ===== সেকশন হেডার ===== */
    .section-header {
      text-align: center;
      margin-bottom: 48px;
    }

    .section-tag {
      display: inline-block;
      font-size: 0.85rem;
      font-weight: 600;
      color: #FF6B35;
      background: #FFF0EA;
      padding: 4px 16px;
      border-radius: 40px;
      margin-bottom: 12px;
    }

    .section-header h2 {
      font-size: 2.4rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .section-header h2 .accent {
      color: #FF6B35;
    }

    .section-header p {
      color: #5A6E85;
      font-size: 1.1rem;
      margin-top: 8px;
    }

    /* ===== রেসপন্সিভ ===== */
    @media (max-width: 768px) {
      .section-header h2 {
        font-size: 1.8rem;
      }
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <slot /> <!-- পেজের কন্টেন্ট এখানে বসবে -->
  </main>
  <Footer />

  <script>
    // ============================================================
    // beforeinstallprompt ইভেন্ট গ্লোবালি ক্যাচ করে window-এ রাখা হচ্ছে,
    // যাতে পেজের যেকোনো জায়গা (Footer-এর ইনস্টল বাটন) থেকে এটা
    // ট্রিগার করা যায়। এই ইভেন্ট শুধু Android/Chrome-এ আসে।
    // ============================================================
    window.deferredInstallPrompt = null;

    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      window.deferredInstallPrompt = e;
      window.dispatchEvent(new CustomEvent('smartfeni:install-available'));
    });

    window.addEventListener('appinstalled', () => {
      window.deferredInstallPrompt = null;
      window.dispatchEvent(new CustomEvent('smartfeni:install-done'));
    });
  </script>
</body>
</html>