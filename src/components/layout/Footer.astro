---
// ============================================================
// কম্পোনেন্ট: ফুটার
// ব্র্যান্ড: স্মার্ট ফেনী
// রিডিজাইন: প্রফেশনাল ৪-কলাম লেআউট (লোগো বক্স সরানো, ওয়ার্ডমার্ক টাইপোগ্রাফি)
// + "অ্যাপ ইনস্টল করুন" বাটন (Android/Chrome নেটিভ প্রম্পট, iPhone ম্যানুয়াল)
// ============================================================

// পরে রিয়েল ইনফো বসাবে — আপাতত প্লেসহোল্ডার
const contact = {
  email: 'info@smartfeni.com',
  phone: '+8801816355833',
};
---

<footer>
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="wordmark">স্মার্ট ফেনী</a>
        <p class="footer-tagline">"প্রয়োজন আপনার, দায়িত্ব আমাদের"</p>
        <p class="footer-desc">ফেনী জেলার প্রথম হাইপারলোকাল কমিউনিটি সার্ভিস প্ল্যাটফর্ম।</p>
        <div class="social-links">
          <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
        </div>
      </div>

      <div class="footer-col">
        <h4>জনপ্রিয় সেবা</h4>
        <a href="/services/repair">রিপেয়ার সার্ভিস</a>
        <a href="/services/housing">বাসা ভাড়া</a>
        <a href="/services/car-rental">গাড়ি ভাড়া</a>
        <a href="/services/home-food">হোম মেস ফুড</a>
      </div>

      <div class="footer-col">
        <h4>কোম্পানি</h4>
        <a href="/about">আমাদের সম্পর্কে</a>
        <a href="/privacy-policy">প্রাইভেসি পলিসি</a>
      </div>

      <div class="footer-col">
        <h4>যোগাযোগ</h4>
        <a href={`mailto:${contact.email}`}>
          <i class="fas fa-envelope"></i> {contact.email}
        </a>
        <a href={`tel:${contact.phone}`}>
          <i class="fas fa-phone"></i> {contact.phone}
        </a>

        <button class="install-btn" id="installBtn" type="button">
          <i class="fas fa-mobile-screen-button"></i> অ্যাপ ইনস্টল করুন
        </button>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© ২০২৬ স্মার্ট ফেনী। সর্বস্বত্ব সংরক্ষিত।</p>
      <p>Global Standards. Local Service.</p>
    </div>
  </div>
</footer>

<!-- iPhone-এর জন্য ম্যানুয়াল ইনস্টল ইনস্ট্রাকশন (Apple beforeinstallprompt সাপোর্ট করে না) -->
<div class="ios-tip-overlay" id="iosTipOverlay">
  <div class="ios-tip-box">
    <button class="ios-tip-close" id="iosTipClose" aria-label="বন্ধ করুন"><i class="fas fa-xmark"></i></button>
    <i class="fas fa-mobile-screen-button ios-tip-icon"></i>
    <h4>আইফোনে অ্যাপ ইনস্টল করুন</h4>
    <ol>
      <li>নিচে <i class="fas fa-arrow-up-from-bracket"></i> শেয়ার বাটনে ট্যাপ করুন</li>
      <li>"Add to Home Screen" সিলেক্ট করুন</li>
      <li>উপরে ডানে "Add" ট্যাপ করুন</li>
    </ol>
  </div>
</div>

<style>
  footer {
    background: #0F1A2E;
    color: #A0B3C9;
    padding: 48px 0 24px;
    border-radius: 32px 32px 0 0;
    margin-top: 40px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 0.8fr 1fr;
    gap: 32px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .wordmark {
    display: inline-block;
    font-size: 1.6rem;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }

  .wordmark::after {
    content: '';
    display: block;
    width: 36px;
    height: 3px;
    background: #FF6B35;
    border-radius: 2px;
    margin-top: 8px;
  }

  .footer-tagline {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: 0.85rem;
    color: #FFB088;
    margin-bottom: 10px;
  }

  .footer-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    opacity: 0.75;
    max-width: 280px;
    margin-bottom: 16px;
  }

  .social-links {
    display: flex;
    gap: 10px;
  }

  .social-links a {
    width: 34px;
    height: 34px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #A0B3C9;
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }

  .social-links a:hover {
    background: #FF6B35;
    border-color: #FF6B35;
    color: #fff;
  }

  .footer-col h4 {
    color: #fff;
    font-size: 0.92rem;
    margin-bottom: 14px;
    font-weight: 700;
  }

  .footer-col a {
    display: block;
    color: #A0B3C9;
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 11px;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .footer-col a:hover {
    opacity: 1;
    color: #FFB088;
  }

  .footer-col a i {
    width: 16px;
    color: #FF6B35;
    margin-left: 2px;
    margin-right: 6px;
  }

  /* ===== ইনস্টল বাটন (পার্মানেন্ট) ===== */
  .install-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 107, 53, 0.12);
    border: 1px solid rgba(255, 107, 53, 0.35);
    color: #FF9A6E;
    padding: 10px 16px;
    border-radius: 30px;
    font-weight: 600;
    font-size: 0.82rem;
    cursor: pointer;
    margin-top: 14px;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .install-btn:hover {
    background: #FF6B35;
    color: #fff;
  }

  .install-btn.hidden {
    display: none;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20px;
    font-size: 0.78rem;
    opacity: 0.55;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ===== iOS ইনস্টল টিপ মোডাল ===== */
  .ios-tip-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.6);
    z-index: 2100;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
  }

  .ios-tip-overlay.open {
    display: flex;
  }

  .ios-tip-box {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 420px;
    border-radius: 24px 24px 0 0;
    padding: 32px 28px 36px;
    text-align: center;
    animation: iosTipUp 0.25s ease;
  }

  @keyframes iosTipUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  .ios-tip-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: #F4F7FC;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: #5A6E85;
    cursor: pointer;
  }

  .ios-tip-icon {
    font-size: 2rem;
    color: #FF6B35;
    margin-bottom: 12px;
  }

  .ios-tip-box h4 {
    color: #1B2A4A;
    font-size: 1.1rem;
    margin-bottom: 18px;
  }

  .ios-tip-box ol {
    text-align: right;
    padding-right: 26px;
    color: #5A6E85;
    font-size: 0.88rem;
    line-height: 2;
  }

  .ios-tip-box ol i {
    color: #FF6B35;
    margin: 0 4px;
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 26px;
    }
  }
</style>

<script>
  const installBtn = document.getElementById('installBtn');
  const iosOverlay = document.getElementById('iosTipOverlay');
  const iosClose = document.getElementById('iosTipClose');

  const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isStandalone = window.matchMedia('(display-mode: standalone)').matches
    || window.navigator.standalone === true;

  // ইতিমধ্যে অ্যাপ হিসেবে ইনস্টল করা থাকলে বাটন লুকানো
  if (isStandalone) {
    installBtn?.classList.add('hidden');
  }

  installBtn?.addEventListener('click', async () => {
    if (isIOS) {
      iosOverlay?.classList.add('open');
      return;
    }

    const promptEvent = window.deferredInstallPrompt;
    if (!promptEvent) {
      // ইতিমধ্যে ইনস্টল করা বা ব্রাউজার সাপোর্ট না করলে
      alert('আপনার ব্রাউজারে ইতিমধ্যে ইনস্টল করা আছে অথবা এই মুহূর্তে ইনস্টল অপশন উপলব্ধ নেই।');
      return;
    }

    promptEvent.prompt();
    await promptEvent.userChoice;
    window.deferredInstallPrompt = null;
  });

  iosClose?.addEventListener('click', () => iosOverlay?.classList.remove('open'));
  iosOverlay?.addEventListener('click', (e) => {
    if (e.target === iosOverlay) iosOverlay.classList.remove('open');
  });

  window.addEventListener('smartfeni:install-done', () => {
    installBtn?.classList.add('hidden');
  });
</script>