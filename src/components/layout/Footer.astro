---
// ============================================================
// কম্পোনেন্ট: ফুটার — স্টাইল ৩ (কমলা অ্যাকসেন্ট, ব্র্যান্ড-ফরওয়ার্ড)
// + ডেকোরেটিভ ব্যাকগ্রাউন্ড লেয়ার (ব্লার ব্লব + ড্যাশড-লাইনে কানেক্টেড
//   আইকন মেডেলিয়ন — রেফারেন্স ইলাস্ট্রেশনের ভাইব, কোনো ইমেজ ফাইল ছাড়াই
//   কোড দিয়ে বানানো, পুরো ফুটার-প্রস্থ জুড়ে)
// কন্টেন্ট অপরিবর্তিত: লোগো+ট্যাগলাইন+সোশ্যাল / কুইক লিংক / যোগাযোগ / কপিরাইট
// ============================================================

// পরে রিয়েল ইনফো বসাবে — আপাতত প্লেসহোল্ডার
const contact = {
  email: 'info@smartfeni.com',
  phone: '+880 1XXX-XXXXXX',
};
---

<footer>
  <!-- ডেকোরেটিভ ব্যাকগ্রাউন্ড লেয়ার: ব্লার ব্লব + ড্যাশড লাইনে কানেক্টেড আইকন মেডেলিয়ন -->
  <div class="footer-decor" aria-hidden="true">
    <div class="blob blob-orange"></div>
    <div class="blob blob-light"></div>

    <svg class="connector-svg" viewBox="0 0 1100 140" preserveAspectRatio="none">
      <path d="M 90 90 Q 260 20, 400 70 T 700 60 T 1010 90" fill="none" stroke="#FF6B35" stroke-width="1.5" stroke-dasharray="5 6" opacity="0.4" />
    </svg>

    <div class="medallion" style="left:6%; top:18px;"><i class="fas fa-house"></i></div>
    <div class="medallion" style="left:34%; top:52px;"><i class="fas fa-motorcycle"></i></div>
    <div class="medallion" style="left:64%; top:46px;"><i class="fas fa-user-doctor"></i></div>
    <div class="medallion" style="left:91%; top:20px;"><i class="fas fa-graduation-cap"></i></div>
  </div>

  <div class="container footer-grid">
    <!-- কলাম ১: ব্র্যান্ড -->
    <div class="footer-col footer-brand">
      <a href="/" class="logo">
        <img src="/logo.png" alt="স্মার্ট ফেনী" class="footer-logo" />
      </a>
      <p>ফেনী জেলার প্রথম ডিজিটাল কমিউনিটি প্ল্যাটফর্ম</p>
      <div class="social-links">
        <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      </div>
    </div>

    <!-- কলাম ২: কুইক লিংক -->
    <div class="footer-col">
      <h4>কুইক লিংক</h4>
      <a href="/services">সেবাসমূহ</a>
      <a href="/about">আমাদের সম্পর্কে</a>
      <a href="/contact">যোগাযোগ</a>
    </div>

    <!-- কলাম ৩: যোগাযোগ -->
    <div class="footer-col">
      <h4>যোগাযোগ করুন</h4>
      <a href={`mailto:${contact.email}`}>
        <i class="fas fa-envelope"></i> {contact.email}
      </a>
      <a href={`tel:${contact.phone}`}>
        <i class="fas fa-phone"></i> {contact.phone}
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© ২০২৬ স্মার্ট ফেনী. সর্বস্বত্ব সংরক্ষিত।</p>
  </div>
</footer>

<style>
  footer {
    position: relative;
    background: #1B2A4A;
    color: #C9D4E3;
    padding: 0;
    border-top: 5px solid #FF6B35;
    margin-top: 40px;
    overflow: hidden; /* ব্লব ও মেডেলিয়ন যেন ফুটারের বাইরে না ছড়ায় */
  }

  /* ===== ডেকোরেটিভ ব্যাকগ্রাউন্ড লেয়ার ===== */
  .footer-decor {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
  }

  .blob-orange {
    width: 280px;
    height: 280px;
    top: -120px;
    left: 8%;
    background: #FF6B35;
    opacity: 0.16;
  }

  .blob-light {
    width: 320px;
    height: 320px;
    top: -160px;
    right: 6%;
    background: #7C93B8;
    opacity: 0.14;
  }

  .connector-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 140px;
  }

  .medallion {
    position: absolute;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FF6B35;
    font-size: 1rem;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  /* ===== মূল কন্টেন্ট ডেকোরেশনের ওপরে থাকবে ===== */
  .footer-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: 32px;
    padding: 96px 0 28px;
  }

  .footer-col h4 {
    color: #FF6B35;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-bottom: 16px;
  }

  .footer-col a {
    display: block;
    color: #C9D4E3;
    text-decoration: none;
    font-size: 0.92rem;
    margin-bottom: 12px;
    transition: color 0.2s ease;
    width: fit-content;
  }

  .footer-col a:hover {
    color: #FF6B35;
  }

  .footer-col a i {
    width: 16px;
    margin-right: 6px;
    color: #7C8FAE;
  }

  /* ===== ব্র্যান্ড কলাম ===== */
  .footer-brand .logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    margin-bottom: 16px;
    background: #fff;
    padding: 12px 24px;
    border-radius: 14px;
  }

  .footer-logo {
    height: 52px;
    width: auto;
    display: block;
  }

  .footer-brand p {
    font-size: 0.9rem;
    color: #C9D4E3;
    opacity: 0.85;
    margin-bottom: 18px;
    max-width: 280px;
  }

  .social-links {
    display: flex;
    gap: 10px;
  }

  .social-links a {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(255, 107, 53, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: #FF6B35;
    margin-bottom: 0;
  }

  .social-links a:hover {
    background: #FF6B35;
    color: #fff;
  }

  /* ===== বটম বার ===== */
  .footer-bottom {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 16px 0;
    background: rgba(0, 0, 0, 0.15);
  }

  .footer-bottom p {
    font-size: 0.82rem;
    color: #8FA0BC;
    margin: 0;
  }

  @media (max-width: 768px) {
    /* মোবাইলে মেডেলিয়ন/কানেক্টর লাইন সরিয়ে শুধু হালকা ব্লব রাখা হলো —
       ছোট স্ক্রিনে এতগুলো ভাসমান আইকন কন্টেন্টের সাথে ওভারল্যাপ করে
       এলোমেলো লাগতো, তাই সিম্পল রাখা হলো */
    .medallion,
    .connector-svg {
      display: none;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 28px;
      padding-top: 44px;
      text-align: center;
    }

    .footer-brand p {
      max-width: none;
      margin-left: auto;
      margin-right: auto;
    }

    .social-links {
      justify-content: center;
    }

    .footer-col a {
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>