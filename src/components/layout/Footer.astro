---
// ============================================================
// কম্পোনেন্ট: ফুটার (কম্প্যাক্ট ভার্সন)
// ব্র্যান্ড: স্মার্ট ফেনী
// ফিচার: ২-কলাম লেআউট, ছোট সাইজ, মিনিমালিস্ট
// ============================================================

const contact = {
  email: 'info@smartfeni.com',
  phone: '+8801816355833',
};
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <!-- বাম পাশ: ব্র্যান্ড + সোশ্যাল -->
      <div class="footer-left">
        <a href="/" class="wordmark">স্মার্ট ফেনী</a>
        <p class="tagline">"প্রয়োজন আপনার, দায়িত্ব আমাদের"</p>
        <div class="social-links">
          <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
        </div>
      </div>

      <!-- ডান পাশ: লিংকসমূহ (২ কলামে) -->
      <div class="footer-right">
        <div class="links-group">
          <h4>জনপ্রিয় সেবা</h4>
          <a href="/services/repair">রিপেয়ার সার্ভিস</a>
          <a href="/services/housing">বাসা ভাড়া</a>
          <a href="/services/car-rental">গাড়ি ভাড়া</a>
          <a href="/services/home-food">হোম মেস ফুড</a>
        </div>

        <div class="links-group">
          <h4>কোম্পানি</h4>
          <a href="/about">আমাদের সম্পর্কে</a>
          <a href="/privacy-policy">প্রাইভেসি পলিসি</a>
        </div>

        <div class="links-group contact-group">
          <h4>যোগাযোগ</h4>
          <a href={`mailto:${contact.email}`}>
            <i class="fas fa-envelope"></i> {contact.email}
          </a>
          <a href={`tel:${contact.phone}`}>
            <i class="fas fa-phone"></i> {contact.phone}
          </a>
          <button class="install-btn" id="installBtn" type="button">
            <i class="fas fa-mobile-screen-button"></i> অ্যাপ ইনস্টল
          </button>
        </div>
      </div>
    </div>

    <!-- কপিরাইট (এক লাইনে) -->
    <div class="footer-bottom">
      <p>© ২০২৬ স্মার্ট ফেনী · সর্বস্বত্ব সংরক্ষিত</p>
      <p>Global Standards. Local Service.</p>
    </div>
  </div>
</footer>

<!-- iOS ইনস্টল টিপ (আগের মতো) -->
<div class="ios-tip-overlay" id="iosTipOverlay">
  <div class="ios-tip-box">
    <button class="ios-tip-close" id="iosTipClose" aria-label="বন্ধ করুন"><i class="fas fa-xmark"></i></button>
    <i class="fas fa-mobile-screen-button ios-tip-icon"></i>
    <h4>আইফোনে অ্যাপ ইনস্টল করুন</h4>
    <ol>
      <li>নিচে <i class="fas fa-arrow-up-from-bracket"></i> শেয়ার বাটনে ট্যাপ করুন</li>
      <li>"Add to Home Screen" সিলেক্ট করুন</li>
      <li>উপরে ডানে "Add" ট্যাপ করুন</li>
    </ol>
  </div>
</div>

<style>
  footer {
    background: #0F1A2E;
    color: #A0B3C9;
    padding: 32px 0 16px;
    border-radius: 24px 24px 0 0;
    margin-top: 32px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ===== বাম পাশ ===== */
  .footer-left .wordmark {
    display: inline-block;
    font-size: 1.3rem;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }

  .wordmark::after {
    content: '';
    display: block;
    width: 28px;
    height: 2px;
    background: #FF6B35;
    border-radius: 2px;
    margin-top: 4px;
  }

  .tagline {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: 0.75rem;
    color: #FFB088;
    margin: 6px 0 10px;
  }

  .social-links {
    display: flex;
    gap: 8px;
  }

  .social-links a {
    width: 30px;
    height: 30px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #A0B3C9;
    text-decoration: none;
    font-size: 0.75rem;
    transition: all 0.2s ease;
  }

  .social-links a:hover {
    background: #FF6B35;
    border-color: #FF6B35;
    color: #fff;
  }

  /* ===== ডান পাশ (২ কলাম) ===== */
  .footer-right {
    display: grid;
    grid-template-columns: 1fr 1fr 1.2fr;
    gap: 24px;
  }

  .links-group h4 {
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .links-group a {
    display: block;
    color: #A0B3C9;
    text-decoration: none;
    font-size: 0.8rem;
    margin-bottom: 6px;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .links-group a:hover {
    opacity: 1;
    color: #FFB088;
  }

  .links-group a i {
    width: 14px;
    color: #FF6B35;
    margin-right: 6px;
    font-size: 0.75rem;
  }

  /* ===== ইনস্টল বাটন ===== */
  .install-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 107, 53, 0.12);
    border: 1px solid rgba(255, 107, 53, 0.3);
    color: #FF9A6E;
    padding: 6px 14px;
    border-radius: 30px;
    font-weight: 600;
    font-size: 0.72rem;
    cursor: pointer;
    margin-top: 6px;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .install-btn:hover {
    background: #FF6B35;
    color: #fff;
  }

  .install-btn.hidden {
    display: none;
  }

  /* ===== কপিরাইট ===== */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 14px;
    font-size: 0.7rem;
    opacity: 0.4;
    flex-wrap: wrap;
    gap: 4px;
  }

  /* ===== iOS টিপ (আগের মতো) ===== */
  .ios-tip-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.6);
    z-index: 2100;
    align-items: flex-end;
    justify-content: center;
  }

  .ios-tip-overlay.open {
    display: flex;
  }

  .ios-tip-box {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 420px;
    border-radius: 24px 24px 0 0;
    padding: 28px 24px 32px;
    text-align: center;
    animation: iosTipUp 0.25s ease;
  }

  @keyframes iosTipUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  .ios-tip-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #F4F7FC;
    border: none;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    color: #5A6E85;
    cursor: pointer;
    font-size: 0.9rem;
  }

  .ios-tip-icon {
    font-size: 1.6rem;
    color: #FF6B35;
    margin-bottom: 8px;
  }

  .ios-tip-box h4 {
    color: #1B2A4A;
    font-size: 1rem;
    margin-bottom: 14px;
  }

  .ios-tip-box ol {
    text-align: right;
    padding-right: 20px;
    color: #5A6E85;
    font-size: 0.82rem;
    line-height: 2;
  }

  .ios-tip-box ol i {
    color: #FF6B35;
    margin: 0 4px;
  }

  /* ===== রেসপন্সিভ ===== */
  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .footer-right {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 576px) {
    footer {
      padding: 24px 0 12px;
      border-radius: 16px 16px 0 0;
    }

    .footer-right {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 2px;
    }

    .links-group a {
      font-size: 0.75rem;
      margin-bottom: 4px;
    }
  }
</style>

<script>
  const installBtn = document.getElementById('installBtn');
  const iosOverlay = document.getElementById('iosTipOverlay');
  const iosClose = document.getElementById('iosTipClose');

  const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isStandalone = window.matchMedia('(display-mode: standalone)').matches
    || window.navigator.standalone === true;

  if (isStandalone) {
    installBtn?.classList.add('hidden');
  }

  installBtn?.addEventListener('click', async () => {
    if (isIOS) {
      iosOverlay?.classList.add('open');
      return;
    }

    const promptEvent = window.deferredInstallPrompt;
    if (!promptEvent) {
      alert('আপনার ব্রাউজারে ইতিমধ্যে ইনস্টল করা আছে অথবা এই মুহূর্তে ইনস্টল অপশন উপলব্ধ নেই।');
      return;
    }

    promptEvent.prompt();
    await promptEvent.userChoice;
    window.deferredInstallPrompt = null;
  });

  iosClose?.addEventListener('click', () => iosOverlay?.classList.remove('open'));
  iosOverlay?.addEventListener('click', (e) => {
    if (e.target === iosOverlay) iosOverlay.classList.remove('open');
  });

  window.addEventListener('smartfeni:install-done', () => {
    installBtn?.classList.add('hidden');
  });
</script>