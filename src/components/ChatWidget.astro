---
// src/components/ChatWidget.astro
// Smart Feni AI চ্যাট উইজেট
// আপডেট: rule-based keyword matching সরিয়ে সরাসরি /api/chat
//         এন্ডপয়েন্টে (Gemini) কল করা হচ্ছে — প্রতিটা মেসেজে AI উত্তর দেয়
//         + "টাইপ করছে..." লোডিং ইন্ডিকেটর যোগ করা হয়েছে
---

<div id="sf-chat-root">
  <button id="sf-chat-toggle" aria-label="সাহায্য চ্যাট খুলুন">
    <svg id="sf-icon-chat" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <svg id="sf-icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <div id="sf-chat-panel">
    <header id="sf-chat-header">
      <span>স্মার্ট ফেনী সহায়ক</span>
      <button id="sf-chat-panel-close" type="button" aria-label="বন্ধ করুন">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </header>

    <div id="sf-chat-messages"></div>

    <div id="sf-chat-quick"></div>

    <form id="sf-chat-form">
      <input
        id="sf-chat-input"
        type="text"
        placeholder="প্রশ্ন লিখুন..."
        autocomplete="off"
      />
      <button type="submit" aria-label="পাঠান">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<style>
  #sf-chat-root {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
    font-family: 'Inter', system-ui, -apple-system, "Noto Sans Bengali", sans-serif;
  }

  #sf-chat-toggle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #FF6B35;
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.35);
  }
  #sf-chat-toggle svg { width: 26px; height: 26px; }
  #sf-chat-toggle:active { transform: scale(0.95); }

  #sf-chat-panel {
    position: fixed;
    bottom: 88px;
    right: 20px;
    width: min(340px, calc(100vw - 32px));
    height: min(480px, calc(100vh - 140px));
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.25);
    display: none;
    flex-direction: column;
    overflow: hidden;
  }

  #sf-chat-panel.sf-open {
    display: flex;
  }

  #sf-chat-header {
    background: #1B2A4A;
    color: #fff;
    padding: 14px 16px;
    font-weight: 600;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  #sf-chat-panel-close {
    background: transparent;
    border: none;
    color: #fff;
    opacity: 0.85;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
  }
  #sf-chat-panel-close svg { width: 18px; height: 18px; }

  #sf-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: #F8FAFC;
  }

  .sf-msg {
    max-width: 82%;
    padding: 9px 12px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.45;
    white-space: pre-line;
  }
  .sf-msg-bot {
    background: #fff;
    border: 1px solid #e5e5e0;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .sf-msg-user {
    background: #FF6B35;
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  .sf-msg-user a { color: #fff; }
  .sf-msg-bot a { color: #FF6B35; font-weight: 600; }

  .sf-msg-typing {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 11px 14px;
  }
  .sf-msg-typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #b8bcc4;
    animation: sfBlink 1.2s infinite ease-in-out;
  }
  .sf-msg-typing span:nth-child(2) { animation-delay: 0.2s; }
  .sf-msg-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes sfBlink {
    0%, 80%, 100% { opacity: 0.3; }
    40% { opacity: 1; }
  }

  #sf-chat-quick {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 8px 12px;
    border-top: 1px solid #eee;
  }
  .sf-quick-btn {
    font-size: 12.5px;
    background: #FFF0EA;
    color: #FF6B35;
    border: 1px solid #FFD9C4;
    border-radius: 999px;
    padding: 6px 11px;
    cursor: pointer;
  }
  .sf-quick-btn:active { background: #FFE0CC; }
  .sf-quick-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  #sf-chat-form {
    display: flex;
    gap: 8px;
    padding: 10px;
    border-top: 1px solid #eee;
  }
  #sf-chat-input {
    flex: 1;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 14px;
    outline: none;
  }
  #sf-chat-input:focus { border-color: #FF6B35; }
  #sf-chat-input:disabled { background: #f5f5f5; }
  #sf-chat-form button[type="submit"] {
    width: 40px;
    background: #FF6B35;
    color: #fff;
    border: none;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  #sf-chat-form button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }
  #sf-chat-form button[type="submit"] svg { width: 18px; height: 18px; }

  @media (max-width: 400px) {
    #sf-chat-panel { right: 16px; bottom: 84px; }
    #sf-chat-root { right: 16px; bottom: 16px; }
  }
</style>

<script>
  const QUICK_REPLIES = [
    "ফার্মেসি অর্ডার কিভাবে করব?",
    "ডেলিভারি চার্জ কত?",
    "কোন এলাকায় সার্ভিস আছে?",
    "যোগাযোগ নাম্বার কী?",
  ];

  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.getElementById("sf-chat-toggle")!;
    const panel = document.getElementById("sf-chat-panel")!;
    const panelClose = document.getElementById("sf-chat-panel-close")!;
    const iconChat = document.getElementById("sf-icon-chat")!;
    const iconClose = document.getElementById("sf-icon-close")!;
    const messages = document.getElementById("sf-chat-messages")!;
    const form = document.getElementById("sf-chat-form") as HTMLFormElement;
    const input = document.getElementById("sf-chat-input") as HTMLInputElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const quickWrap = document.getElementById("sf-chat-quick")!;

    let opened = false;
    let isSending = false;

    function setOpen(next: boolean) {
      opened = next;
      panel.classList.toggle("sf-open", opened);
      iconChat.style.display = opened ? "none" : "block";
      iconClose.style.display = opened ? "block" : "none";
      if (opened && messages.children.length === 0) {
        addMessage(
          "আসসালামু আলাইকুম! আমি স্মার্ট ফেনী সহায়ক। কিছু জিজ্ঞাসা করুন অথবা নিচের বাটন থেকে বেছে নিন।",
          "bot"
        );
      }
    }

    function addMessage(text: string, sender: "bot" | "user") {
      const div = document.createElement("div");
      div.className = `sf-msg sf-msg-${sender}`;
      div.textContent = text;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
      return div;
    }

    function showTyping() {
      const div = document.createElement("div");
      div.className = "sf-msg sf-msg-bot sf-msg-typing";
      div.id = "sf-typing-indicator";
      div.innerHTML = "<span></span><span></span><span></span>";
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function hideTyping() {
      document.getElementById("sf-typing-indicator")?.remove();
    }

    function setSending(next: boolean) {
      isSending = next;
      input.disabled = next;
      submitBtn.disabled = next;
      quickWrap.querySelectorAll("button").forEach((b) => {
        (b as HTMLButtonElement).disabled = next;
      });
    }

    async function handleUserText(text: string) {
      if (!text.trim() || isSending) return;
      addMessage(text, "user");
      setSending(true);
      showTyping();

      try {
        const res = await fetch("/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ message: text }),
        });
        const data = await res.json();
        hideTyping();
        addMessage(
          data?.reply || "দুঃখিত, উত্তর দিতে সমস্যা হয়েছে। আবার চেষ্টা করুন।",
          "bot"
        );
      } catch (err) {
        hideTyping();
        addMessage(
          "দুঃখিত, ইন্টারনেট সংযোগে সমস্যা হচ্ছে। একটু পরে আবার চেষ্টা করুন।",
          "bot"
        );
      } finally {
        setSending(false);
        input.focus();
      }
    }

    QUICK_REPLIES.forEach((q) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "sf-quick-btn";
      btn.textContent = q;
      btn.addEventListener("click", () => handleUserText(q));
      quickWrap.appendChild(btn);
    });

    toggle.addEventListener("click", () => setOpen(!opened));
    panelClose.addEventListener("click", () => setOpen(false));

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const text = input.value;
      input.value = "";
      handleUserText(text);
    });
  });
</script>