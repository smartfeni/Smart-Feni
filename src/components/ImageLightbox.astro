---
// ============================================================
// কম্পোনেন্ট: রিইউজেবল ফুলস্ক্রিন ইমেজ লাইটবক্স
// যেকোনো জায়গা থেকে window.openImageLightbox(url) কল করলেই খুলবে।
// ফিচার: ট্যাপ করে জুম ইন/আউট, ডাউনলোড/সেভ বাটন, ব্যাকড্রপ/X/Esc
// দিয়ে বন্ধ করা যায়। একটা পেজে একবার <ImageLightbox /> বসালেই হবে।
// ============================================================
---

<div class="lightbox-overlay" id="imageLightboxOverlay">
  <div class="lightbox-backdrop" id="lightboxBackdrop"></div>

  <div class="lightbox-toolbar">
    <button class="lightbox-icon-btn" id="lightboxDownloadBtn" aria-label="ডাউনলোড">
      <i class="fas fa-download"></i>
    </button>
    <button class="lightbox-icon-btn" id="lightboxCloseBtn" aria-label="বন্ধ করুন">
      <i class="fas fa-xmark"></i>
    </button>
  </div>

  <div class="lightbox-image-wrap" id="lightboxImageWrap">
    <img id="lightboxImage" src="" alt="ছবি" />
  </div>

  <p class="lightbox-hint">ছবিতে ট্যাপ করে জুম করুন</p>
</div>

<style is:global>
  .lightbox-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 5000;
    align-items: center;
    justify-content: center;
  }

  .lightbox-overlay.open {
    display: flex;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 14, 24, 0.92);
  }

  .lightbox-toolbar {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 2;
    display: flex;
    gap: 10px;
  }

  .lightbox-icon-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border: none;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-icon-btn:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  .lightbox-image-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 20px;
  }

  .lightbox-image-wrap img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    cursor: zoom-in;
    transition: transform 0.25s ease;
    transform: scale(1);
    touch-action: pinch-zoom;
  }

  .lightbox-image-wrap img.zoomed {
    transform: scale(2.2);
    cursor: zoom-out;
  }

  .lightbox-hint {
    position: absolute;
    bottom: 20px;
    left: 0;
    right: 0;
    text-align: center;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.78rem;
    z-index: 1;
  }
</style>

<script>
  const overlay = document.getElementById('imageLightboxOverlay');
  const backdrop = document.getElementById('lightboxBackdrop');
  const img = document.getElementById('lightboxImage');
  const closeBtn = document.getElementById('lightboxCloseBtn');
  const downloadBtn = document.getElementById('lightboxDownloadBtn');

  let currentUrl = null;

  function openLightbox(url) {
    if (!url) return;
    currentUrl = url;
    img.src = url;
    img.classList.remove('zoomed');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
    img.classList.remove('zoomed');
  }

  img?.addEventListener('click', () => {
    img.classList.toggle('zoomed');
  });

  closeBtn?.addEventListener('click', closeLightbox);
  backdrop?.addEventListener('click', closeLightbox);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('open')) closeLightbox();
  });

  downloadBtn?.addEventListener('click', async () => {
    if (!currentUrl) return;
    try {
      const res = await fetch(currentUrl);
      const blob = await res.blob();
      const blobUrl = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = blobUrl;
      a.download = `smartfeni-${Date.now()}.jpg`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(blobUrl);
    } catch (err) {
      // CORS বা নেটওয়ার্ক সমস্যায় fallback — নতুন ট্যাবে খুলে দাও,
      // ইউজার সেখান থেকে "ছবি সেভ করুন" করতে পারবে
      window.open(currentUrl, '_blank');
    }
  });

  window.openImageLightbox = openLightbox;
</script>