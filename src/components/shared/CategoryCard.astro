---
// ============================================================
// কম্পোনেন্ট: ক্যাটাগরি কার্ড (রিইউজেবল)
// ============================================================

export interface Props {
  cat: {
    id: string;
    name: string;
    icon: string;
    desc: string;
    slug: string;
  };
}

const { cat } = Astro.props;
---

<a href={`/services/${cat.slug}`} class="category-card">
  <div class="card-icon">
    <i class={`fas ${cat.icon}`}></i>
  </div>
  <h4>{cat.name}</h4>
  <p>{cat.desc}</p>
</a>

<style>
  .category-card {
    background: #fff;
    padding: 24px 16px;
    border-radius: 24px;
    text-align: center;
    text-decoration: none;
    color: #1B2A4A;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
    display: block;
  }

  .category-card:hover {
    transform: translateY(-6px);
    border-color: #FF6B35;
    box-shadow: 0 12px 32px rgba(255, 107, 53, 0.06);
  }

  .card-icon {
    font-size: 2rem;
    color: #FF6B35;
    margin-bottom: 12px;
  }

  .category-card h4 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .category-card p {
    font-size: 0.75rem;
    color: #7A8EA5;
    margin: 0;
  }
</style>