---
export interface Props {
  cat: {
    id: string;
    name: string;
    icon: string;
    desc: string;
    slug: string;
    color?: string;
  };
  imageUrl?: string;
}

const { cat, imageUrl } = Astro.props;

const palette = [
  '#FF6B35',
  '#6C5CE7',
  '#00B894',
  '#0984E3',
  '#E84393',
  '#FDCB6E',
  '#00CEC9',
  '#D63031',
];

function hashColor(str: string) {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = str.charCodeAt(i) + ((hash << 5) - hash);
  }
  const index = Math.abs(hash) % palette.length;
  return palette[index];
}

const themeColor = cat.color || hashColor(cat.id || cat.name);

function hexToRgba(hex: string, alpha: number) {
  const parsed = hex.replace('#', '');
  const r = parseInt(parsed.substring(0, 2), 16);
  const g = parseInt(parsed.substring(2, 4), 16);
  const b = parseInt(parsed.substring(4, 6), 16);
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}

const iconBg = hexToRgba(themeColor, 0.12);
---

<a
  href={`/services/${cat.slug}`}
  class={`category-card ${imageUrl ? 'has-image' : ''}`}
  style={`--theme-color: ${themeColor}; --icon-bg: ${iconBg};`}
  data-category-id={cat.id}
  data-category-name={cat.name}
>
  {imageUrl ? (
    <>
      <img class="card-bg-image" src={imageUrl} alt={cat.name} loading="lazy" />
      <div class="card-image-overlay">
        <h4>{cat.name}</h4>
      </div>
    </>
  ) : (
    <>
      <div class="card-icon">
        <i class={`fas ${cat.icon}`}></i>
      </div>
      <h4>{cat.name}</h4>
      <p>{cat.desc}</p>
    </>
  )}
</a>

<style>
  .category-card {
    background: #fff;
    padding: 28px 16px 24px;
    border-radius: 20px;
    text-align: center;
    text-decoration: none;
    color: #1B2A4A;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .category-card:hover {
    transform: translateY(-4px);
    border-color: var(--theme-color);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .card-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--icon-bg);
    color: var(--theme-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    margin-bottom: 14px;
    transition: transform 0.25s ease;
  }

  .category-card:hover .card-icon {
    transform: scale(1.08);
  }

  .category-card h4 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .category-card p {
    font-size: 0.75rem;
    color: #7A8EA5;
    margin: 0;
    line-height: 1.4;
  }

  /* ===== ইমেজ ভ্যারিয়েন্ট (UC স্টাইল: ছবি + নিচে সাদা টাইটেল বার) ===== */
  .category-card.has-image {
    position: relative;
    padding: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid #EEF3F9;
    background: #fff;
  }

  .card-bg-image {
    width: 100%;
    height: 78%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .category-card.has-image:hover .card-bg-image {
    transform: scale(1.06);
  }

  .card-image-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 22%;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 0 12px;
    background: #fff;
  }

  .card-image-overlay h4 {
    color: #1B2A4A;
    font-size: 0.82rem;
    font-weight: 700;
    margin: 0;
    text-align: left;
    line-height: 1.3;
  }
</style>

<script>
  import { trackEvent } from '../../lib/analytics.js';

  document.querySelectorAll('.category-card').forEach(card => {
    card.addEventListener('click', function(e) {
      const id = this.dataset.categoryId;
      const name = this.dataset.categoryName;
      if (!id) return;

      const counts = JSON.parse(localStorage.getItem('service_counts') || '{}');
      counts[id] = (counts[id] || 0) + 1;
      localStorage.setItem('service_counts', JSON.stringify(counts));
      console.log(`${name} (${id}) এর ক্লিক: ${counts[id]}`);

      const savedUpazila = localStorage.getItem('smartfeni_upazila');
      trackEvent('category_click', { category: id, upazila: savedUpazila || null });
    });
  });
</script>