---
// ============================================================
// কম্পোনেন্ট: ক্যাটাগরি কার্ড (রিইউজেবল) — Urban Company স্টাইল
// ============================================================

export interface Props {
  cat: {
    id: string;
    name: string;
    icon: string;
    desc: string;
    slug: string;
    color?: string; // ঐচ্ছিক: এই ক্যাটাগরির থিম কালার (hex), না দিলে auto assign হবে
  };
}

const { cat } = Astro.props;

const palette = [
  '#FF6B35', // কমলা
  '#6C5CE7', // বেগুনি
  '#00B894', // সবুজ
  '#0984E3', // নীল
  '#E84393', // গোলাপি
  '#FDCB6E', // হলুদ
  '#00CEC9', // টিল
  '#D63031', // লাল
];

function hashColor(str: string) {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = str.charCodeAt(i) + ((hash << 5) - hash);
  }
  const index = Math.abs(hash) % palette.length;
  return palette[index];
}

const themeColor = cat.color || hashColor(cat.id || cat.name);

function hexToRgba(hex: string, alpha: number) {
  const parsed = hex.replace('#', '');
  const r = parseInt(parsed.substring(0, 2), 16);
  const g = parseInt(parsed.substring(2, 4), 16);
  const b = parseInt(parsed.substring(4, 6), 16);
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}

const iconBg = hexToRgba(themeColor, 0.12);
---

<a
  href={`/services/${cat.slug}`}
  class="category-card"
  style={`--theme-color: ${themeColor}; --icon-bg: ${iconBg};`}
>
  <div class="card-icon">
    <i class={`fas ${cat.icon}`}></i>
  </div>
  <h4>{cat.name}</h4>
  <p>{cat.desc}</p>
</a>

<style>
  .category-card {
    background: #fff;
    padding: 28px 16px 24px;
    border-radius: 20px;
    text-align: center;
    text-decoration: none;
    color: #1B2A4A;
    border: 1px solid #EEF3F9;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .category-card:hover {
    transform: translateY(-4px);
    border-color: var(--theme-color);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .card-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--icon-bg);
    color: var(--theme-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    margin-bottom: 14px;
    transition: transform 0.25s ease;
  }

  .category-card:hover .card-icon {
    transform: scale(1.08);
  }

  .category-card h4 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .category-card p {
    font-size: 0.75rem;
    color: #7A8EA5;
    margin: 0;
    line-height: 1.4;
  }
</style>