---
export interface Props {
  cat: {
    id: string;
    name: string;
    icon: string;
    desc: string;
    slug: string;
  };
}
const { cat } = Astro.props;
---
<a href={`/services/${cat.slug}`} class="category-card">
  <div class="category-icon"><i class={`fas ${cat.icon}`}></i></div>
  <h4>{cat.name}</h4>
  <p>{cat.desc}</p>
</a>

<style>
  .category-card {
    background: #fff;
    padding: 28px 16px 24px;
    border-radius: 28px;
    text-align: center;
    box-shadow: 0 8px 24px rgba(27,42,74,0.04);
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border: 1px solid rgba(255,255,255,0.8);
    text-decoration: none;
    color: inherit;
    display: block;
    cursor: pointer;
  }
  .category-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 48px rgba(255,107,53,0.10);
    border-color: #FF6B35;
  }
  .category-icon {
    width: 72px;
    height: 72px;
    background: #F4F7FC;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 18px;
    font-size: 2.2rem;
    color: #FF6B35;
    transition: 0.3s;
  }
  .category-card:hover .category-icon {
    background: #FF6B35;
    color: #fff;
  }
  .category-card h4 { font-size: 0.95rem; font-weight: 600; margin-bottom: 4px; }
  .category-card p { font-size: 0.75rem; color: #7A8EA5; margin: 0; }
</style>