---
// ============================================================
// কম্পোনেন্ট: জনপ্রিয় ক্যাটাগরি কার্ড (CategoryCard.astro থেকে ভ্যারিয়েন্ট)
// ফিচার: টপে ফায়ার ব্যাজ, কাস্টম SVG ইলাস্ট্রেশন আইকন (FontAwesome এর বদলে),
//         আলাদা localStorage কাউন্ট কী, ইউনিক বর্ডার/শ্যাডো
// ============================================================

export interface Props {
  cat: {
    id: string;
    name: string;
    icon: string;
    desc: string;
    slug: string;
    color?: string;
  };
}

const { cat } = Astro.props;

const palette = [
  '#FF6B35',
  '#6C5CE7',
  '#00B894',
  '#0984E3',
  '#E84393',
  '#FDCB6E',
  '#00CEC9',
  '#D63031',
];

function hashColor(str: string) {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = str.charCodeAt(i) + ((hash << 5) - hash);
  }
  const index = Math.abs(hash) % palette.length;
  return palette[index];
}

const themeColor = cat.color || hashColor(cat.id || cat.name);

function hexToRgba(hex: string, alpha: number) {
  const parsed = hex.replace('#', '');
  const r = parseInt(parsed.substring(0, 2), 16);
  const g = parseInt(parsed.substring(2, 4), 16);
  const b = parseInt(parsed.substring(4, 6), 16);
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}

const iconBg = hexToRgba(themeColor, 0.12);

// ===== কাস্টম SVG ইলাস্ট্রেশন আইকন (slug অনুযায়ী) =====
const customIcons: Record<string, string> = {
  'car-rental': `
    <svg viewBox="0 0 80 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- CNG অটোরিকশা সিলুয়েট -->
      <path d="M14 44 L14 38 Q14 30 22 28 L26 20 Q28 16 34 16 L42 16 Q46 16 46 20 L46 38 Q46 44 40 44 Z" fill="currentColor"/>
      <rect x="27" y="20" width="9" height="8" rx="1.5" fill="white" opacity="0.5"/>
      <circle cx="21" cy="46" r="6" fill="currentColor"/>
      <circle cx="40" cy="46" r="6" fill="currentColor"/>
      <circle cx="21" cy="46" r="2.3" fill="white" opacity="0.6"/>
      <circle cx="40" cy="46" r="2.3" fill="white" opacity="0.6"/>
      <!-- পাশে দাঁড়ানো ড্রাইভার -->
      <circle cx="58" cy="19" r="5" fill="currentColor"/>
      <path d="M50 27 Q50 24 53 24 L63 24 Q66 24 66 27 L65 43 Q65 45 63 45 L55 45 Q53 45 53 43 Z" fill="currentColor"/>
      <path d="M55 45 L54 54 M61 45 L62 54" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
    </svg>
  `,
  'courier': `
    <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- ডেলিভারি বক্স -->
      <rect x="6" y="28" width="14" height="13" rx="2" fill="currentColor"/>
      <path d="M9 33 L17 33 M13 30 L13 39" stroke="white" stroke-width="1.4" opacity="0.6"/>
      <!-- মোটরসাইকেল বডি -->
      <path d="M18 48 Q18 38 26 36 L32 36 Q35 29 41 29 L45 29 Q48 29 48 33 L48 41 Q48 45 44 45 L41 48 Z" fill="currentColor"/>
      <circle cx="16" cy="48" r="8" fill="currentColor"/>
      <circle cx="46" cy="48" r="8" fill="currentColor"/>
      <circle cx="16" cy="48" r="3.2" fill="white" opacity="0.6"/>
      <circle cx="46" cy="48" r="3.2" fill="white" opacity="0.6"/>
      <!-- হেলমেট পরা রাইডার -->
      <circle cx="35" cy="21" r="6.5" fill="currentColor"/>
      <path d="M29.5 21 L40.5 21" stroke="white" stroke-width="1.6" opacity="0.6" stroke-linecap="round"/>
      <path d="M35 27 Q30 30 30 36 L40 36 Q40 30 35 27 Z" fill="currentColor"/>
      <path d="M40 30 L46 32" stroke="currentColor" stroke-width="3.4" stroke-linecap="round"/>
    </svg>
  `,
  'online-shop': `
    <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- শপিং ব্যাগ -->
      <path d="M17 24 Q17 12 32 12 Q47 12 47 24" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
      <path d="M14 24 L50 24 L46 55 Q45.7 58 42.5 58 L21.5 58 Q18.3 58 18 55 Z" fill="currentColor"/>
      <circle cx="32" cy="38" r="4.5" fill="white" opacity="0.55"/>
      <path d="M32 34.5 L32 41.5 M28.5 38 L35.5 38" stroke="currentColor" stroke-width="1.6" opacity="0.9"/>
    </svg>
  `,
};
---

<a
  href={`/services/${cat.slug}`}
  class="category-card-popular"
  style={`--theme-color: ${themeColor}; --icon-bg: ${iconBg};`}
  data-category-id={cat.id}
  data-category-name={cat.name}
>
  <span class="popular-badge">🔥 জনপ্রিয়</span>
  <div class="card-icon">
    {customIcons[cat.slug] ? (
      <Fragment set:html={customIcons[cat.slug]} />
    ) : (
      <i class={`fas ${cat.icon}`}></i>
    )}
  </div>
  <h4>{cat.name}</h4>
  <p>{cat.desc}</p>
</a>

<style>
  .category-card-popular {
    position: relative;
    background: #fff;
    padding: 32px 16px 24px;
    border-radius: 20px;
    text-align: center;
    text-decoration: none;
    color: #1B2A4A;
    border: 1.5px solid #FFD9C7;
    box-shadow: 0 6px 18px rgba(255, 107, 53, 0.1);
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .category-card-popular:hover {
    transform: translateY(-4px);
    border-color: var(--theme-color);
    box-shadow: 0 14px 30px rgba(255, 107, 53, 0.18);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #FF6B35, #FF8C5A);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: 0 4px 10px rgba(255, 107, 53, 0.35);
  }

  .card-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--icon-bg);
    color: var(--theme-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    margin-bottom: 14px;
    transition: transform 0.25s ease;
    overflow: hidden;
  }

  .card-icon :global(svg) {
    width: 40px;
    height: 40px;
  }

  .category-card-popular:hover .card-icon {
    transform: scale(1.08);
  }

  .category-card-popular h4 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .category-card-popular p {
    font-size: 0.75rem;
    color: #7A8EA5;
    margin: 0;
    line-height: 1.4;
  }
</style>

<script>
  import { trackEvent } from '../../lib/analytics.js';

  document.querySelectorAll('.category-card-popular').forEach(card => {
    card.addEventListener('click', function(e) {
      const id = this.dataset.categoryId;
      const name = this.dataset.categoryName;
      if (!id) return;

      const counts = JSON.parse(localStorage.getItem('service_counts_popular') || '{}');
      counts[id] = (counts[id] || 0) + 1;
      localStorage.setItem('service_counts_popular', JSON.stringify(counts));
      console.log(`[জনপ্রিয়] ${name} (${id}) এর ক্লিক: ${counts[id]}`);

      const savedUpazila = localStorage.getItem('smartfeni_upazila');
      trackEvent('category_click', { category: id, upazila: savedUpazila || null, is_popular: true });
    });
  });
</script>